//* ── §12 Mobile lang toggle ── */
@media screen and (max-width: 749px) {

  header-actions shopify-account,
  header-actions .account-button { display: none !important; }
   .header__columns.spacing-style {
    grid-template-columns: 44px 44px 1fr 1fr 44px !important;
  }

  /* วาง toggle ใน grid slot rightA (ช่องที่ account เคยอยู่) */
  .oc-lang-toggle--in-actions {
    grid-area: rightA !important;
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    background: rgba(0, 0, 0, 0.08) !important;
    border-radius: 999px !important;
    padding: 2px !important;
    position: relative !important;
    gap: 0 !important;
    border: none !important;
    box-shadow: none !important;
    margin-right: 8px; /* ขยับซ้ายออกจาก cart */
  }

  .oc-lang-toggle--in-actions .oc-lang-toggle__track {
    position: absolute !important;
    top: 2px !important; left: 2px !important;
    height: calc(100% - 4px) !important;
    width: 36px !important;
    background: linear-gradient(90deg, #14c9df, #17a9bb) !important;
    border-radius: 999px !important;
    box-shadow: 0 2px 8px rgba(20, 201, 223, 0.35) !important;
    transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1),
                width 0.25s cubic-bezier(0.34, 1.56, 0.64, 1) !important;
    pointer-events: none !important;
  }

  .oc-lang-toggle--in-actions .oc-lang-toggle__btn {
    all: unset !important;
    position: relative !important;
    z-index: 1 !important;
    display: inline-block !important;
    padding: 4px 10px !important;
    border-radius: 999px !important;
    color: var(--color-foreground) !important;
    opacity: 0.55 !important;
    cursor: pointer !important;
    font-family: 'Google Sans', 'Noto Sans Thai', sans-serif !important;
    font-size: 12px !important;
    font-weight: 700 !important;
    letter-spacing: 0.04em !important;
    line-height: 1 !important;
    white-space: nowrap !important;
  }

  .oc-lang-toggle--in-actions .oc-lang-toggle__btn.active {
    color: #fff !important;
    opacity: 1 !important;
    cursor: default !important;
    pointer-events: none !important;
  }

  /* form tags ที่อยู่ใน toggle ต้องไม่กินพื้นที่ */
  .oc-lang-toggle--in-actions form {
    display: contents !important;
  }
}