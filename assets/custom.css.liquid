  background-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" width="42.871" height="44.697" viewBox="0 0 42.871 44.697"><defs><style>.a{fill:url(%23a);}.b{fill:%2317a9bb;opacity:0.3;}</style><linearGradient id="a" x1="0.5" x2="0.5" y2="1" gradientUnits="objectBoundingBox"><stop offset="0" stop-color="%232bc1d1"/><stop offset="1" stop-color="%23ac57a0"/></linearGradient></defs><circle class="b" cx="15" cy="15" r="15" transform="translate(12.871)"/></svg>');
}

/* ── §10e Icon blocks (article icons) ── */
.how-to-icon,
.new-active-icon,
.pin-active-icon,
.cart-icon,
.news-active-icon,
.write-icon,
.idea-icon {
  background-color: #EAEDF2;
  background-size: 35px;
  background-repeat: no-repeat;
  background-position: center;
  display: block !important;
  padding: 8px;
  width: 55px!important;
  height: 55px;
}


/* ── §10f Footer Payment List ── */
.list-payment {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  margin: -0.5rem 0;
  padding-top: 1rem;
  padding-left: 0;
}
@media screen and (min-width: 750px) {
  .list-payment {
    justify-content: flex-end;
    margin: -0.5rem;
    padding-top: 0;
  }
}
.list-payment__item {
  align-items: center;
  display: flex;
  padding: 0.5rem;
}
@media screen and (max-width: 767px) {
  .footer__copyright { margin-bottom: 6rem; }
}
.img1 { width: 40px; }


/* ── §10g Octo Black Ribbon (fixed logo) ── */
.octo-black-ribbon {
  position: fixed;
  left: calc(env(safe-area-inset-left, 0));
  bottom: calc(env(safe-area-inset-bottom, 0));
  z-index: 99999;
  width: 90px;
  display: block;
  pointer-events: auto;
}
.octo-black-ribbon img {
  width: 100%;
  height: auto;
  display: block;
  pointer-events: none;
}
@media (max-width: 480px) {
  .octo-black-ribbon {
    width: 64px;
    left: calc(env(safe-area-inset-left, 0));
    bottom: 0 !important;
  }
}


/* ============================================================
   §11 HORIZON NATIVE OVERRIDES
   ============================================================ */

/* ── Header Glassmorphism ── */
.shopify-section-group-header-group .header {
  backdrop-filter: var(--oc-blur);
  -webkit-backdrop-filter: var(--oc-blur);
  background: var(--oc-glass) !important;
  border-bottom: 1px solid var(--oc-glass-border-subtle);
  box-shadow: 0 2px 20px rgba(100, 120, 200, 0.08),
              inset 0 1px 0 rgba(255, 255, 255, 0.6);
}

/* ── Inputs ── */
.field__input,
.select__select {
  border-radius: var(--oc-radius-sm) !important;
  border-color: var(--oc-ink-15) !important;
  font-family: 'Google Sans', 'Noto Sans Thai', sans-serif;
}
.field__input:focus {
  border-color: var(--oc-cyan) !important;
  box-shadow: 0 0 0 3px rgba(20, 201, 223, 0.14) !important;
}

/* ── Facets ── */
.facets__heading { font-family: 'Google Sans', 'Noto Sans Thai', sans-serif; }

/* ── Hide desktop header icons (GrandMenu handles nav) ── */
@media screen and (min-width: 990px) {
  .header__icon { display: none; }
}

/* ── z-index fix for animate-arrow links ── */
.link.animate-arrow { z-index: 9999; }

/* ── Predictive search (off by default, GrandMenu handles) ── */
.predictive-search.predictive-search--header { display: none !important; }

/* ── Container mobile spacing ── */
@media screen and (max-width: 1015px) {
  .c-container { margin: 5px; }
}

/* ── Horizon AI FAQ chip buttons ── */
[class*="ai-faq-chip-"] {
  font-family: 'Google Sans', 'Noto Sans Thai', sans-serif;
  padding: 6px 14px;
  border-radius: 6px;
  background: rgba(23,169,187,0.09);
  border: none;
  color: #17a9bb;
  font-size: {{ block.settings.chip_font_size }}px;
  font-weight: 500;
  cursor: pointer;
  white-space: nowrap;
  letter-spacing: 0.03em;
  transition: background 0.2s;
}

[class*="ai-faq-chip-"]:hover {
  background: rgba(23,169,187,0.18);
}

[class*="ai-faq-chip-"].active {
  background: linear-gradient(135deg, #14c9df, #17a9bb);
  color: #fff;
  box-shadow: 0 2px 8px rgba(20,201,223,0.28);
}

/* ============================================================
   §12 PAGE-SPECIFIC
   ============================================================ */

/* ── Product Page ── */
@media screen and (max-width: 767px) {
  .product .breadcrumb { display: none; }
  .product .product__title { margin-top: 0; }
  .collection .collection-hero__title { margin-bottom: 0; }
  .collection .layout_block { margin: 0 6px; }
}


/* ============================================================
   §13 TABLES
   ============================================================ */

/* ── Standard Table ── */
.divtable {
  overflow-x: auto;
  width: 100%;
  display: block;
}

table {
  border-collapse: collapse;
  width: 100%;
  white-space: nowrap;
  table-layout: auto;
  min-width: 120px;
  box-shadow: unset;
}
@media (max-width: 768px) {
  table { min-width: 550px; }
}

thead tr > th {
  background: #bef3f3;
  color: black;
  font-weight: 600;
  position: sticky;
  padding: 0.75rem;
  z-index: 1;
  top: 0;
}

thead tr > :first-child,
tbody tr > :first-child {
  position: sticky;
  left: 0;
  z-index: 2;
  min-width: 45px;
  background-color: white;
}
thead tr > :first-child { background: #bef3f3; }

tbody tr:nth-child(even) > td:first-child,
tbody tr:nth-child(even) > th:first-child { background-color: #eff2f3; }
tbody tr:nth-child(even) { background-color: #eff2f3; }
tbody tr:nth-child(odd)  { background-color: #ffffff; }

td, th {
  text-align: center;
  padding: 0.5rem 0.25rem;
  white-space: nowrap;
  overflow: hidden;
  min-width: 40px;
}
table:not([class]) td,
table:not([class]) th { padding: 0.3em; border: 0; }

.p-table { margin: 0.1em 0 0 0; font-weight: 600; }


/* ── Spec Table ── */
.divtable-spec {
  overflow-x: auto;
  width: 100%;
  display: block;
}

.spec-table {
  border-collapse: separate;
  border-spacing: 0;
  width: 100%;
  table-layout: auto;
  background: #fff;
}

.spec-table th,
.spec-table td {
  white-space: nowrap;
  text-align: left;
  padding: 0.6rem 0.5rem;
  border-bottom: 1px solid #e5e7eb;
}

.spec-table thead th {
  position: sticky;
  top: 0;
  z-index: 3;
  background: #bef3f3 !important;
  text-align: center;
  font-weight: 600;
}
.spec-table thead th:first-child { background: #bef3f3 !important; }

.spec-table th:first-child,
.spec-table td:first-child {
  position: sticky;
  left: 0;
  z-index: 2;
  background: #fff !important;
  min-width: 120px;
}

.spec-table .subhead th {
  padding: 0.6rem;
  background-color: #f5f5f5 !important;
  font-weight: 600;
  letter-spacing: 0.02em;
  border-bottom: 1px solid #e5e7eb;
}

.spec-table tbody tr { background: #fff !important; }

@media (max-width: 768px) {
  .spec-table { min-width: 560px; }
}


/* ============================================================
   §14 SCROLLBAR
   ============================================================ */

::-webkit-scrollbar          { width: 12px; height: 8px; }
::-webkit-scrollbar-track    { background: rgba(241,241,241,1); }
::-webkit-scrollbar-thumb    { background: #bbb; border-radius: 10px; }
::-webkit-scrollbar-thumb:hover { background: #aaa; }


/* ============================================================
   §15 MEDIA / IMAGE FIXES
   ============================================================ */

/* Fix Dawn's height:100% bug — images must never stretch */
img {
  max-width: 100%;
  height: auto;         /* ← แก้ bug สำคัญจาก Dawn legacy */
  overflow: hidden;
}

video {
  max-width: 100%;
  height: auto;
  overflow: hidden;
}

canvas {
  max-width: 100%;
  height: auto;
  overflow: hidden;
}


/* ============================================================
   §16  INTERACTIONS & MICRO-ANIMATIONS
   
   ข้อมูลจาก settings_schema.json:
   - card_hover_effect: none | lift | scale | subtle-zoom (default: lift)
   - color_scheme CSS vars: --color-primary, --color-primary-hover,
     --color-primary-button-background, --color-primary-button-hover-background
   - Horizon class hooks: .card-wrapper, .card, .button, .badge,
     .variant-input, .swatch, .quick-add, .media
   
   เราเพิ่ม layer animations ของเราทับบน Horizon's default เพื่อให้
   สอดคล้องกับ CI Cyan Duo System
   ============================================================ */


/* ── §16a Card Hover System ──────────────────────────────── */
/*
   Horizon native card_hover_effect ทำ transform เบื้องต้น
   เราเพิ่ม: border shimmer, box-shadow glow, image zoom
   transition ทำงานร่วมกันไม่ conflict กัน
*/

/* Base transition — ทุก card ได้ transition นี้ */
.card-wrapper .card,
.card--product {
  transition:
    transform    var(--oc-dur-slow) var(--oc-ease-expo),
    box-shadow   var(--oc-dur-slow) var(--oc-ease-expo),
    border-color var(--oc-dur-base) ease,
    outline-color var(--oc-dur-base) ease;
  will-change: transform, box-shadow;
}

/* Lift (Horizon default) — enhance with cyan glow */
.card-wrapper:hover .card,
.card-wrapper:focus-within .card {
  transform: translateY(-8px) !important;
  box-shadow:
    0 12px 40px rgba(20, 201, 223, 0.18),
    0 4px 16px rgba(100, 100, 160, 0.12) !important;
  border-color: rgba(20, 201, 223, 0.35) !important;
}

/* Active / press state */
.card-wrapper:active .card {
  transform: translateY(-3px) scale(0.99) !important;
  box-shadow:
    0 4px 16px rgba(20, 201, 223, 0.14),
    0 2px 6px rgba(100, 100, 160, 0.10) !important;
  transition-duration: 0.08s !important;
}

/* Product image zoom on card hover */
.card-wrapper:hover .card__media .media img,
.card-wrapper:hover .card__media .media video {
  transform: scale(1.06);
  transition: transform 0.65s var(--oc-ease-expo);
}
.card-wrapper .card__media .media img,
.card-wrapper .card__media .media video {
  transition: transform 0.45s var(--oc-ease-smooth);
}

/* Quick-add button — slide up on card hover */
.card-wrapper .quick-add {
  opacity: 0;
  transform: translateY(8px);
  transition:
    opacity  var(--oc-dur-base) var(--oc-ease-expo),
    transform var(--oc-dur-base) var(--oc-ease-expo);
}
.card-wrapper:hover .quick-add,
.card-wrapper:focus-within .quick-add {
  opacity: 1;
  transform: translateY(0);
}

/* Card badge micro-pulse on hover */
.card-wrapper:hover .badge {
  animation: oc-badge-pulse 0.5s var(--oc-ease-back) forwards;
}
@keyframes oc-badge-pulse {
  0%   { transform: scale(1); }
  55%  { transform: scale(1.15); }
  100% { transform: scale(1.06); }
}


/* ── §16b Button Animations ──────────────────────────────── */
/*
   Horizon native .button ใช้ --color-primary-button-background
   เราเพิ่ม animated gradient + lift + ripple effect
*/

/* Base — ทุก button */
.button {
  position: relative;
  overflow: hidden;
  transition:
    transform     var(--oc-dur-fast)   var(--oc-ease-back),
    box-shadow    var(--oc-dur-base)   ease,
    filter        var(--oc-dur-base)   ease,
    background-position var(--oc-dur-base) ease !important;
}

/* Ripple layer */
.button::after {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at var(--ripple-x, 50%) var(--ripple-y, 50%), rgba(255,255,255,0.25) 0%, transparent 60%);
  opacity: 0;
  transition: opacity var(--oc-dur-base) ease;
  pointer-events: none;
}
.button:hover::after { opacity: 1; }
.button:active::after { opacity: 0.6; }

/* Hover — lift + glow */
.button:hover {
  transform: translateY(-2px) !important;
  box-shadow: var(--oc-shadow-glow-cyan) !important;
}

/* Primary hover — gradient slide */
.button--primary:hover,
button.shopify-payment-button__button--unbranded:hover {
  background-position: 100% 0 !important;
  filter: brightness(1.05) !important;
}

/* Active / press — push down */
.button:active {
  transform: translateY(0) scale(0.97) !important;
  box-shadow: none !important;
  transition-duration: 0.06s !important;
}

/* Secondary hover — purple glow */
.button--secondary:hover,
.button-secondary:hover {
  box-shadow: var(--oc-shadow-glow-purple) !important;
  transform: translateY(-2px) !important;
}

/* ── Animated rainbow border on focus (accessibility) ── */
.button:focus-visible {
  outline: 3px solid transparent;
  outline-offset: 3px;
  box-shadow:
    0 0 0 3px var(--oc-cyan-vv),
    var(--oc-shadow-glow-cyan) !important;
}


/* ── §16c Link & Nav Animations ──────────────────────────── */

/* Underline slide — ใช้ได้กับ nav links, text links */
.oc-link-slide {
  position: relative;
  display: inline-block;
  text-decoration: none;
}
.oc-link-slide::after {
  content: '';
  position: absolute;
  left: 0; bottom: -2px;
  width: 0; height: 2px;
  background: var(--oc-grad-btn);
  border-radius: 2px;
  transition: width var(--oc-dur-base) var(--oc-ease-expo);
}
.oc-link-slide:hover::after { width: 100%; }

/* Nav items in header */
.header__menu-item,
.menu__link {
  position: relative;
  transition: color var(--oc-dur-fast) ease;
}
.header__menu-item::after,
.menu__link::after {
  content: '';
  position: absolute;
  left: 50%; bottom: -2px;
  width: 0; height: 2px;
  background: var(--oc-cyan-vv);
  border-radius: 2px;
  transform: translateX(-50%);
  transition: width var(--oc-dur-base) var(--oc-ease-expo);
}
.header__menu-item:hover::after,
.header__menu-item[aria-current="page"]::after,
.menu__link:hover::after {
  width: 80%;
}
.header__menu-item:hover,
.menu__link:hover {
  color: var(--oc-cyan-d) !important;
}


/* ── §16d Input & Form Animations ───────────────────────── */

/* Input focus expand glow */
.field__input,
.select__select,
.customer input,
.customer select {
  transition:
    border-color  var(--oc-dur-base) ease,
    box-shadow    var(--oc-dur-base) ease,
    transform     var(--oc-dur-fast) ease !important;
}
.field__input:focus,
.select__select:focus,
.customer input:focus {
  border-color: var(--oc-cyan) !important;
  box-shadow: 0 0 0 4px rgba(20, 201, 223, 0.14) !important;
  transform: translateY(-1px);
  outline: none;
}
.field__input:hover:not(:focus),
.select__select:hover:not(:focus) {
  border-color: rgba(20, 201, 223, 0.5) !important;
}

/* Floating label animate */
.field__label {
  transition:
    top      var(--oc-dur-fast) var(--oc-ease-smooth),
    font-size var(--oc-dur-fast) var(--oc-ease-smooth),
    color     var(--oc-dur-fast) ease;
}
.field__input:focus ~ .field__label,
.field__input:not(:placeholder-shown) ~ .field__label {
  color: var(--oc-cyan-d) !important;
}


/* ── §16e Variant Swatches & Buttons ─────────────────────── */

/* Color swatches */
.swatch-input__input + .swatch-input__label,
[class*="variant-input"],
.color-swatch {
  transition:
    transform     var(--oc-dur-fast) var(--oc-ease-back),
    box-shadow    var(--oc-dur-base) ease,
    border-color  var(--oc-dur-fast) ease;
  cursor: pointer;
}
.swatch-input__input + .swatch-input__label:hover,
[class*="variant-input"]:hover {
  transform: scale(1.12);
  box-shadow: 0 0 0 3px rgba(20, 201, 223, 0.35);
}
.swatch-input__input:checked + .swatch-input__label,
[class*="variant-input--selected"] {
  box-shadow:
    0 0 0 2px #fff,
    0 0 0 4px var(--oc-cyan-d) !important;
  transform: scale(1.08);
}

/* Variant text/size buttons */
.variant-input-wrapper .variant-input {
  transition:
    background-color var(--oc-dur-fast) ease,
    border-color     var(--oc-dur-fast) ease,
    color            var(--oc-dur-fast) ease,
    transform        var(--oc-dur-fast) var(--oc-ease-back);
}
.variant-input-wrapper .variant-input:hover {
  border-color: var(--oc-cyan) !important;
  color: var(--oc-cyan-d) !important;
  transform: translateY(-1px);
}
.variant-input-wrapper .variant-input--selected,
.variant-input-wrapper input:checked + .variant-input {
  border-color: var(--oc-cyan-d) !important;
  background: var(--oc-cyan-l) !important;
  color: var(--oc-cyan-d) !important;
}


/* ── §16f Badges ─────────────────────────────────────────── */

.badge {
  transition:
    transform  var(--oc-dur-fast) var(--oc-ease-back),
    box-shadow var(--oc-dur-base) ease;
}
.badge:hover { transform: scale(1.1); }

/* Sale badge — extra glow */
.badge--sale:hover {
  box-shadow: 0 2px 12px rgba(239, 68, 68, 0.4);
}

/* New / custom badges */
.oc-badge-cyan:hover {
  box-shadow: var(--oc-shadow-glow-cyan);
  transform: scale(1.06);
}
.oc-badge-purple:hover {
  box-shadow: var(--oc-shadow-glow-purple);
  transform: scale(1.06);
}


/* ── §16g Social Icon Bounce ──────────────────────────────── */

.social-icon,
.oc-sticky-btn {
  transition:
    transform  var(--oc-dur-fast)  var(--oc-ease-back),
    filter     var(--oc-dur-base)  ease;
}
.social-icon:hover,
.oc-sticky-btn:hover {
  transform: translateY(-3px) scale(1.12);
  filter: drop-shadow(0 4px 8px rgba(20, 201, 223, 0.4));
}
.social-icon:active,
.oc-sticky-btn:active {
  transform: scale(0.93);
  transition-duration: 0.06s;
}


/* ── §16h Blog Tab Icon Interaction ──────────────────────── */

.blog-tab-icon,
.how-to-icon, .new-active-icon, .pin-active-icon,
.cart-icon, .news-active-icon, .write-icon, .idea-icon {
  transition:
    transform  var(--oc-dur-base)  var(--oc-ease-back),
    filter     var(--oc-dur-base)  ease,
    background-color var(--oc-dur-fast) ease;
}
.blog-tab-icon:hover,
.how-to-icon:hover, .new-active-icon:hover,
.cart-icon:hover, .idea-icon:hover, .write-icon:hover {
  transform: scale(1.08);
  filter: drop-shadow(0 3px 6px rgba(23, 169, 187, 0.35));
  background-color: rgba(23, 169, 187, 0.12) !important;
}
.blog-tab-icon:active,
.how-to-icon:active {
  transform: scale(0.94);
}


/* ── §16i Announce Bar Shimmer ───────────────────────────── */

@keyframes oc-shimmer-sweep {
  0%   { transform: translateX(-100%) skewX(-15deg); }
  100% { transform: translateX(300%) skewX(-15deg); }
}

.shopify-section-group-header-group .announcement-bar,
.oc-announce-bar {
  position: relative;
  overflow: hidden;
}
.shopify-section-group-header-group .announcement-bar::after,
.oc-announce-bar::after {
  content: '';
  position: absolute;
  top: 0; bottom: 0;
  width: 40%;
  background: linear-gradient(
    90deg,
    transparent 0%,
    rgba(255,255,255,0.3) 50%,
    transparent 100%
  );
  animation: oc-shimmer-sweep 4s ease-in-out infinite;
  pointer-events: none;
}


/* ── §16j Page Transition ─────────────────────────────────── */
/*
   Horizon has page_transition_enabled (default: true)
   เราเพิ่ม fade-up สำหรับ main content area
*/

.shopify-section:not(.shopify-section-group-header-group):not(.shopify-section-group-footer-group) {
  animation: oc-fade-up 0.5s var(--oc-ease-expo) both;
}

/* Stagger sections */
.shopify-section:nth-child(2) { animation-delay: 0.05s; }
.shopify-section:nth-child(3) { animation-delay: 0.10s; }
.shopify-section:nth-child(4) { animation-delay: 0.15s; }
.shopify-section:nth-child(5) { animation-delay: 0.20s; }


/* ── §16k Cart Drawer / Popover ──────────────────────────── */

/* Cart line item quantity buttons */
.cart-item__quantity-wrapper .quantity__button {
  transition:
    background-color var(--oc-dur-fast) ease,
    color            var(--oc-dur-fast) ease,
    transform        var(--oc-dur-fast) var(--oc-ease-back);
}
.cart-item__quantity-wrapper .quantity__button:hover {
  color: var(--oc-cyan-d) !important;
  transform: scale(1.15);
}
.cart-item__quantity-wrapper .quantity__button:active {
  transform: scale(0.9);
}

/* Cart image hover */
.cart-item__image {
  transition: transform var(--oc-dur-base) var(--oc-ease-smooth);
}
.cart-item:hover .cart-item__image {
  transform: scale(1.04);
}


/* ── §16l Utility Animation Classes ─────────────────────── */
/*
   ใช้ใน Liquid templates ได้เลย:
   <div class="oc-animate-fade-up">...</div>
   <div class="oc-animate-scale-in oc-delay-2">...</div>
*/

.oc-animate-fade-up    { animation: oc-fade-up    0.5s var(--oc-ease-expo) both; }
.oc-animate-fade-in    { animation: oc-fade-in    0.4s ease both; }
.oc-animate-scale-in   { animation: oc-scale-in   0.4s var(--oc-ease-back) both; }
.oc-animate-float-in   { animation: oc-float-in   0.5s var(--oc-ease-expo) both; }

.oc-delay-1 { animation-delay: 0.05s; }
.oc-delay-2 { animation-delay: 0.10s; }
.oc-delay-3 { animation-delay: 0.15s; }
.oc-delay-4 { animation-delay: 0.20s; }
.oc-delay-5 { animation-delay: 0.30s; }
.oc-delay-6 { animation-delay: 0.40s; }

/* Hover-triggered reveal (no JS needed) */
.oc-reveal-on-hover {
  opacity: 0;
  transform: translateY(6px);
  transition:
    opacity   var(--oc-dur-base) var(--oc-ease-expo),
    transform var(--oc-dur-base) var(--oc-ease-expo);
}
*:hover > .oc-reveal-on-hover,
*:focus-within > .oc-reveal-on-hover {
  opacity: 1;
  transform: translateY(0);
}

/*--------------------------------- PEAR ICONs - GLOBAL-------------------------------------------*/


.rainbowBG {
  padding: 0px;
  padding-left: 5px;
  padding-right: 5px;
  background: linear-gradient(108deg,rgba(223,213,254,.7) 0%,rgba(215,252,240,.7) 100%);
}

.grayBG {
  color: #262b30;
  background: #EAEDF2;
  margin: 10px 0;
  padding: 15px;
}

.grayBG p {
  margin: 8px 0;
}

.lightvioletBG {
  background =#eeeaf4;
}

.whiteBG {
  background: #fff;
  margin: 0px 10px 10px 10px;
  padding: 0px 15px 15px 15px;
}

/* blog icon */

.blog-tab-icon {
  background-size: contain;
  background-repeat: no-repeat;
  padding: 0px 10px;
  margin-right: 5px;
}

.blog-tab-icon.active {
  padding: 4px 13px;
}

