  );
}.oc-section-vivid    { background: linear-gradient(177deg, #c3f9ff 0%, #c78ff2 100%); }.oc-section-dark     { background: var(--oc-surface-dark); }.oc-section-dark-teal { background: var(--oc-surface-dark-teal); }.oc-section-rainbow  {
