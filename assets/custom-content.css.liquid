/* ── §STAT-NORMALIZE — .oc-stat-* aliases + namespace fallback (2026-05-03) ──
   Solves spelling chaos:
   • .oc-stat-lbl / .oc-stat-l   = aliases of .oc-stat-label (11+3 broken)
   • .oc-stat-n                  = alias of .oc-stat-num (3 broken)
   • .oc-stat-desc / .oc-stat-unit = new descriptor / unit utilities
   • [class$="-stat-num"] etc.   = namespace fallback for .xx-stat-num, .xx-kpi-n etc.

   Per-product <style> rules win via source order on equal specificity.
   Container .xx-stat / .xx-kpi NOT in fallback — too divergent (grid/flex/card). ── */

/* === Aliases of canonical .oc-stat-label === */
.oc-stat-label,
.oc-stat-lbl,
.oc-stat-l {
  display: block;
  font-size: var(--fs-2xs);
  font-weight: 600;
  opacity: .85;
  margin-top: 4px;
  line-height: 1.3;
}

/* === Alias of canonical .oc-stat-num === */
.oc-stat-num,
.oc-stat-n {
  display: block;
  font-size: var(--fs-lg);
  font-weight: 800;
  line-height: 1.1;
  color: var(--oc-cyan);
}

/* === New: descriptor (paragraph below stat) === */
.oc-stat-desc {
  display: block;
  font-size: var(--fs-xs);
  color: var(--oc-ink-70);
  line-height: 1.5;
  margin-top: 2px;
}

/* === New: unit (small suffix beside number) === */
.oc-stat-unit {
  font-size: 0.6em;
  font-weight: 600;
  color: var(--oc-ink-70);
  margin-left: 2px;
}

/* === Namespace fallback — number === */
:where(.text-block, .desc_container) [class$="-stat-num"],
:where(.text-block, .desc_container) [class$="-stat-n"],
:where(.text-block, .desc_container) [class$="-kpi-num"],
:where(.text-block, .desc_container) [class$="-kpi-n"] {
  display: block;
  font-size: var(--fs-lg);
  font-weight: 800;
  line-height: 1.1;
  color: var(--oc-cyan);
}

/* === Namespace fallback — label === */
:where(.text-block, .desc_container) [class$="-stat-label"],
:where(.text-block, .desc_container) [class$="-stat-lbl"],
:where(.text-block, .desc_container) [class$="-stat-l"],
:where(.text-block, .desc_container) [class$="-kpi-label"],
:where(.text-block, .desc_container) [class$="-kpi-lbl"] {
  display: block;
  font-size: var(--fs-2xs);
  font-weight: 600;
  opacity: .85;
  margin-top: 4px;
  line-height: 1.3;
}

/* === Namespace fallback — kicker (eyebrow above section title) === */
:where(.text-block, .desc_container) [class$="-kicker"] {
  font-size: var(--fs-sm);
  color: var(--oc-cyan);
  font-weight: 700;
  letter-spacing: .05em;
  text-transform: uppercase;
  margin-bottom: 2px;
  display: inline-block;
}


/* ── §STAT-TILE — canonical tile inside .oc-stat container (2026-05-03) ──
   Solves naming chaos for the metric tile (1 number + label):
   • .oc-stat-tile               = canonical
   • [class$="-kpi"]             = namespace fallback (.of-kpi, .wg-kpi, .sr-kpi …)
   • [class$="-ki"]              = namespace fallback (.ci-ki …)
   • [class$="-tile"]            = namespace fallback (.xx-tile)

   Children of .oc-stat get hairline gaps (gap:1px on parent) so the cyan
   parent shows through as a thin divider line. ── */

.oc-stat-tile,
:where(.oc-stat) [class$="-kpi"],
:where(.oc-stat) [class$="-ki"],
:where(.oc-stat) [class$="-tile"] {
  flex: 1;
  min-width: 100px;
  padding: 16px 12px;
  background: #fff;
  text-align: center;
}

/* ── §FEAT-CARD — white content card (was .au-box, .zh-box, .oc-box, etc.) ──
   White card with border + padding + soft shadow. Generic content container.
   Distinct from .oc-feat-strip (compact horizontal strip with small icons).
   Fallback covers all .xx-box namespace variants found across products
   (.au-box, .zh-box, .oc-box, .tr-qc-box, .nb-spec-box …).
   Scoped to .text-block / .desc_container to avoid touching theme classes
   like .lightbox. Per-product <style> overrides win via source order. ── */

.oc-feat-card,
:where(.text-block, .desc_container) [class$="-box"] {
  background: #fff;
  border: 1px solid var(--oc-ink-15);
  border-radius: var(--oc-radius);
  padding: 14px;
  box-shadow: var(--oc-shadow-sm);
  margin-bottom: 12px;
}

/* Last-child reset — no trailing space below the last card */
.oc-feat-card:last-child,
:where(.text-block, .desc_container) [class$="-box"]:last-child {
  margin-bottom: 0;
}

/* Inside flex/grid containers (parent uses gap), suppress margin
   so it doesn't compound with parent's gap. Detected via :has() — covers
   .oc-grid2, .oc-grid3, .oc-feat-grid, .oc-feas-grid, and product-specific
   grids with namespace -grid, -row, -hero suffixes. */
:where([class$="-grid"], [class$="-row"], [class$="-hero"], [class$="-hero-main"], [class*="oc-grid"]) > .oc-feat-card,
:where([class$="-grid"], [class$="-row"], [class$="-hero"], [class$="-hero-main"], [class*="oc-grid"]) > [class$="-box"] {
  margin-bottom: 0;
}

.oc-feat-card-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 34px;
  height: 34px;
  border-radius: var(--oc-radius-sm, 8px);
  background: var(--oc-cyan-l, #e3f8fb);
  margin-bottom: 10px;
}

/* ── §H2-NORMALIZE — single source of truth for product desc h2 (2026-05-03) ──
   Apply 1.25em uniformly across all 564 product descriptions. Wins over any
   inline non-!important font-size. Inline !important must be stripped (see
   batch script). Blog articles (.text-block .oc-article h2) keep 22px via
   higher-specificity rule above. ── */
.text-block h2,
.desc_container h2 {
  font-size: 1.25em !important;
}

/* ── Suppress Horizon margin-block on h2 inside DNA namespace containers ──
   Horizon's .text-block h2 adds margin-block which conflicts with inline styles.
   Product description h2 controls its own margin — let it. ── */
.text-block .desc_container h2,
.rte .desc_container h2 {
  margin-block: 0;
}.oc-bar {
  width: 3px; min-height: 32px; border-radius: 99px;
  background: var(--oc-grad-ci); flex-shrink: 0; align-self: stretch;
}/* ── Moved from global ── */
.desc_container span[style*="underline"] {
  display: inline-block;
  padding: 0px;
  padding-left: 5px;
  padding-right: 5px;
  background: linear-gradient(108deg,rgba(223,213,254,.7) 0%,rgba(215,252,240,.7) 100%);
  text-decoration: none !important;
}.text-block > style + * { margin-block-start: 1rem; }.oc-faq-question {
  font-weight: 700;
  color: var(--oc-ink);
  padding: 16px 0;
  cursor: pointer;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

/* ── Restored oc-* component rules ── */
