/* ============================================================
   §16  PRODUCT-DESC TYPOGRAPHY HELPERS
   ============================================================ */
.tiny    { font-size: 0.8rem; line-height: 1.6rem; font-weight: 700; }
.prod_h2 { font-size: 1.4rem; line-height: 1.8rem; }
.prod_h4 { font-size: 1.2rem; line-height: 1.6rem; }

/* ── §DNA-SPACING  Component spacing — Option C fix (2026-05-03) ──────────
   Glyph A: safe container suffixes (verified 95-100% container usage)
   Glyph B: adjacent-sibling after section headings
   ─────────────────────────────────────────────────────────────────────── */

/* A — container bottom margin */
/* B — adjacent sibling after section headings gets top breathing room */
.oc-bar-wrap {
  display: flex; align-items: stretch; gap: 12px;
  margin-top: 22px;
  margin-bottom: 14px;
}.oc-bar-wrap + *,
[class$="-kicker"] + * {
  margin-top: 14px;
}/* img inside product desc — never let it collapse to zero margin */

/* ── CTA button rows — force center regardless of namespace ── */
.oc-cta [class$="-btns"],
.oc-cta [class$="-btn-row"],
.oc-cta [class*="-btns"],
.oc-cta-btns {
  justify-content: center;
}/* ── DNA Spacing — suffix-based, no parent qualifier needed ── */
/* covers ALL namespace variants (psc-, flr-, dir-, sp-, etc.)  */

/* ── §LIST-NORMALIZE — .oc-list/-item/-dot utility + namespace fallback (2026-05-03) ──
   Solves: 198 products use .oc-list (undefined) + 197 namespace prefixes
   (.au-list, .psn-list, .brp-list, ...) define same pattern inconsistently.

   Card-style design adopted from /products/composite-inkjet-uv (.ci-item):
   white bg + border + radius + soft shadow + typography normalization.

   • .oc-list / .oc-item / .oc-dot                = primary utility classes (always-on)
   • [class$="-list/-item/-dot"] in :where()      = zero-spec namespace fallback
     :where() makes scope contribute 0 specificity → product <style> rules
     (.xx-list = 0,1,0) win via source order
   • Rules split so :has()/:where() unsupported in old browser drops only fallback ── */

/* === Primary utility classes — always loaded === */
.oc-list {
  margin: 0 0 18px;
  padding: 0;
  list-style: none;
}
.oc-item {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  padding: 10px 14px;
  margin-bottom: 7px;
  border-radius: var(--oc-radius);
  background: #fff;
  border: 1px solid var(--oc-ink-15);
  box-shadow: var(--oc-shadow-sm);
  font-size: 0.96em;
  color: var(--oc-ink-70);
  line-height: 1.65;
}
.oc-dot {
  display: block;
  flex-shrink: 0;
  width: 10px;
  height: 10px;
  min-width: 10px;
  border-radius: 50%;
  background: var(--oc-grad-ci);
  margin-top: 5px;
}

/* === Namespace fallback (modern browsers only — :where + :has) === */
:where(.text-block, .desc_container) [class$="-list"] {
  margin: 0 0 18px;
  padding: 0;
  list-style: none;
}
:where(.text-block, .desc_container) [class$="-item"]:has(> [class$="-dot"]) {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  padding: 10px 14px;
  margin-bottom: 7px;
  border-radius: var(--oc-radius);
  background: #fff;
  border: 1px solid var(--oc-ink-15);
  box-shadow: var(--oc-shadow-sm);
  font-size: 0.96em;
  color: var(--oc-ink-70);
  line-height: 1.65;
}
:where(.text-block, .desc_container) [class$="-dot"] {
  display: block;
  flex-shrink: 0;
  width: 10px;
  height: 10px;
  min-width: 10px;
  border-radius: 50%;
  background: var(--oc-grad-ci);
  margin-top: 5px;
}

/* ── §DNA-MOVED-FROM-GLOBAL — relocated to content for proper scoping (2026-05-03) ──
   These DNA component rules previously lived in custom-global.css.liquid but
   are only used inside product/article descriptions. Moved here to reduce
   CSS bloat on non-content pages (home, collection, cart, etc.). ── */

.oc-faq-answer {
