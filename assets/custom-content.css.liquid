/* ── §DNA-SPACING  Component spacing — Option C fix (2026-05-03) ──────────
   Glyph A: safe container suffixes (verified 95-100% container usage)
   Glyph B: adjacent-sibling after section headings
   ─────────────────────────────────────────────────────────────────────── */

/* A — container bottom margin */
.desc_container [class$="-chip"],
.desc_container [class$="-chips"] {
  margin-bottom: 16px;
}
.desc_container [class$="-feat"],
.desc_container [class$="-step"],
.desc_container [class$="-grid"],
.desc_container [class$="-grid3"],
.desc_container [class$="-feat-row"],
.desc_container [class$="-step-row"] {
  margin-bottom: 22px;
}
.desc_container [class$="-bq"],
.desc_container [class$="-qt"],
.desc_container [class$="-table"],
.desc_container [class$="-spec"],
.desc_container [class$="-badge-row"] {
  margin-bottom: 18px;
}

/* B — adjacent sibling after section headings gets top breathing room */
.desc_container [class$="-sh"] + *,
.desc_container .oc-bar-wrap + *,
.desc_container [class$="-kicker"] + * {
  margin-top: 14px;
}

/* img inside product desc — never let it collapse to zero margin */
.desc_container img:not([class*="oc-icon"]) {
  display: block;
  margin-bottom: 14px;
}

