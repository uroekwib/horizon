}

.oc-bar-wrap {
  display: flex; align-items: stretch; gap: 12px;
  margin-top: 22px;
  margin-bottom: 14px;
}

.oc-bar-wrap + *,
[class$="-kicker"] + * {
  margin-top: 14px;
}

.oc-cta [class$="-btns"],
.oc-cta [class$="-btn-row"],
.oc-cta [class*="-btns"],
.oc-cta-btns {
  justify-content: center;
}

.oc-bar {
  width: 3px; min-height: 32px; border-radius: 99px;
  background: var(--oc-grad-ci); flex-shrink: 0; align-self: stretch;
}

.oc-faq-question {
  font-weight: 700;
  color: var(--oc-ink);
  padding: 16px 0;
  cursor: pointer;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
