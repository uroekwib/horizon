/* ============================================================
   §11 HORIZON NATIVE OVERRIDES
   ============================================================ */

/* ── Inputs ── */
.field__input,
.select__select {
  border-radius: var(--oc-radius-sm) !important;
  border-color: var(--oc-ink-15) !important;
  font-family: var(--font-body--family);
}

/* ── Facets ── */
.facets__heading { font-family: var(--font-body--family); }

/* ── z-index fix ── */
