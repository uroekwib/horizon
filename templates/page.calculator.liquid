    if (l) { l.value = shape.l; l.addEventListener('input', function () { shape.l = l.value; renderShapeResults(); }); }
    if (h) { h.value = shape.h; h.addEventListener('input', function () { shape.h = h.value; renderShapeResults(); }); }
    if (u) { u.addEventListener('change', function () { shape.unit = u.value; renderShapeResults(); }); }
    var tabs = document.querySelectorAll('#oc-sh-tabs button');
    for (var i = 0; i < tabs.length; i++) {
      (function (b) {
