    if (!r) {
      resEl.innerHTML = '<div class="shape-result"><span class="shape-result-label">' + t('shapeEnterDims') + '</span><span class="shape-result-value">—</span></div>';
      if (sendBtn) sendBtn.disabled = true;
      return;
    }
    if (sendBtn) sendBtn.disabled = false;
    var html = '';
    if (shape.kind === 'rect') {
      html += '<div class="shape-result"><span class="shape-result-label">' + t('shapeArea') + '</span><span class="shape-result-value">' + fmtConv(r.area_native) + '<span class="unit">' + u2 + '</span><span class="alt">' + fmtConv(r.area_m2) + ' m²</span></span></div>';
      html += '<div class="shape-result"><span class="shape-result-label">' + t('shapePerimeter') + '</span><span class="shape-result-value">' + fmtConv(r.perim_native) + '<span class="unit">' + u + '</span></span></div>';
    } else {
      html += '<div class="shape-result"><span class="shape-result-label">' + t('shapeSurface') + '</span><span class="shape-result-value">' + fmtConv(r.surface_native) + '<span class="unit">' + u2 + '</span><span class="alt">' + fmtConv(r.surface_m2) + ' m²</span></span></div>';
      html += '<div class="shape-result"><span class="shape-result-label">' + t('shapeVolume') + '</span><span class="shape-result-value">' + fmtConv(r.volume_native) + '<span class="unit">' + u3 + '</span><span class="alt">' + fmtConv(r.volume_m3) + ' m³</span></span></div>';
    }
    resEl.innerHTML = html;
  }
  function bindShape() {
