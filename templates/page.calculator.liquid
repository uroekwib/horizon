      '<button class="shape-send" id="oc-sh-send" type="button"><span data-i18n="shapeSendToCalc">Use this value →</span></button>';
  }

  // ===== Calc core =====
  function fmt(n) {
    if (!isFinite(n)) return 'Error';
    if (state.dp !== 'auto') return n.toFixed(parseInt(state.dp, 10));
    if (Math.abs(n) > 1e15 || (n !== 0 && Math.abs(n) < 1e-9)) return n.toExponential(6);
    return parseFloat(n.toPrecision(12)).toString();
  }
  function fact(n) {
    n = Math.round(n);
    if (n < 0 || n > 170) return NaN;
    var r = 1;
    for (var i = 2; i <= n; i++) r *= i;
    return r;
  }
  function compute(s) {
    var j = s
      .replace(/×/g, '*').replace(/÷/g, '/').replace(/−/g, '-')
      .replace(/π/g, '(' + Math.PI + ')')
      .replace(/(?<![a-zA-Z])e(?![a-zA-Z0-9])/g, '(' + Math.E + ')');
    j = j.replace(/sin\(/g, 'Math.sin(').replace(/cos\(/g, 'Math.cos(').replace(/tan\(/g, 'Math.tan(')
         .replace(/log\(/g, 'Math.log10(').replace(/ln\(/g, 'Math.log(').replace(/√\(/g, 'Math.sqrt(');
    j = j.replace(/(\d+(?:\.\d+)?)!/g, function (_, n) { return fact(parseFloat(n)); }).replace(/\^/g, '**');
    try {
      var r = Function('"use strict"; return (' + j + ')')();
      return fmt(r);
    } catch (e) { return 'Error'; }
  }
  function renderCalc() {
    var H = document.getElementById('oc-hist');
    var C = document.getElementById('oc-cur');
    if (H) H.textContent = state.hist || '\u00a0';
    if (C) C.textContent = state.expr || state.result;
  }
  function append(ch) {
    if (state.evald) {
      if (/[0-9.(]/.test(ch)) state.expr = ch;
      else state.expr = (state.result === 'Error' ? '0' : state.result) + ch;
      state.evald = false;
      state.hist = '';
    } else {
      state.expr += ch;
    }
  }
  var KMAP = { lp: '(', rp: ')', pi: 'π', ec: 'e' };
  function press(k) {
    if (k === 'clear') { state.expr = ''; state.result = '0'; state.hist = ''; state.evald = false; }
    else if (k === 'back') { state.expr = state.expr.slice(0, -1); }
    else if (k === 'eq') {
      if (state.expr) {
        var r = compute(state.expr);
        state.hist = state.expr + ' =';
        state.result = r;
        state.expr = '';
        state.evald = true;
      }
    }
    else if (k === 'neg') {
      var b = state.expr || (state.result !== '0' && state.result !== 'Error' ? state.result : '');
      if (b) { state.expr = '-(' + b + ')'; state.evald = false; }
    }
    else if (k === 'pct') {
      var b2 = state.expr || (state.result !== '0' && state.result !== 'Error' ? state.result : '');
      if (b2) { state.expr = '(' + b2 + ')/100'; state.evald = false; }
    }
    else if (k === 'sq') {
      var b3 = state.expr || (state.result !== '0' && state.result !== 'Error' ? state.result : '');
      if (b3) { state.expr = '(' + b3 + ')^2'; state.evald = false; }
    }
    else if (k === 'inv') {
      var b4 = state.expr || (state.result !== '0' && state.result !== 'Error' ? state.result : '');
      if (b4) { state.expr = '1/(' + b4 + ')'; state.evald = false; }
    }
    else if (k === 'sqrt') append('√(');
    else if (k === 'sin' || k === 'cos' || k === 'tan' || k === 'log' || k === 'ln') append(k + '(');
    else if (k === 'pow') append('^');
    else if (k === 'fact') append('!');
    else if (KMAP[k]) append(KMAP[k]);
    else if (k === '/') append('÷');
    else if (k === '*') append('×');
    else if (k === '-') append('−');
    else append(k);
    renderCalc();
  }
  function bindCalcButtons() {
    var btns = document.querySelectorAll('#oc-grid button');
    for (var i = 0; i < btns.length; i++) {
      (function (b) {
        b.addEventListener('click', function () { press(b.getAttribute('data-k')); });
      })(btns[i]);
    }
    bindCopy();
  }
  function bindCopy() {
    var disp = document.querySelector('#oc-body .display');
    if (!disp) return;
    disp.setAttribute('role', 'button');
    disp.setAttribute('tabindex', '0');
    disp.setAttribute('aria-label', t('hintTapCopy'));
    var handler = function () {
      var text = (state.expr || state.result || '').trim();
      if (!text || text === '0') return;
      copyText(text).then(function () { flashCopied(disp); });
    };
    disp.addEventListener('click', handler);
    disp.addEventListener('keydown', function (e) {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); handler(); }
    });
  }
  function copyText(text) {
    if (navigator.clipboard && navigator.clipboard.writeText) {
      return navigator.clipboard.writeText(text);
    }
    return new Promise(function (resolve) {
      var ta = document.createElement('textarea');
      ta.value = text;
      ta.style.position = 'fixed';
      ta.style.opacity = '0';
      document.body.appendChild(ta);
      ta.select();
      try { document.execCommand('copy'); } catch (e) {}
      document.body.removeChild(ta);
      resolve();
    });
  }
  function flashCopied(el) {
    var hist = document.getElementById('oc-hist');
    if (!hist) return;
    var prev = hist.textContent;
    hist.textContent = t('copied');
    hist.style.color = 'var(--accent)';
    el.classList.add('is-copied');
    clearTimeout(flashCopied._t);
    flashCopied._t = setTimeout(function () {
      hist.textContent = prev;
      hist.style.color = '';
      el.classList.remove('is-copied');
    }, 1200);
  }

  // ===== Converter =====
  function buildOpts(cat, sel) {
    var us = UNITS[cat].u, h = '';
    for (var i = 0; i < us.length; i++) {
      // For money: only show currencies we have rates for (or the base)
      if (cat === 'money' && moneyRates && us[i][0] !== moneyRates.base && !moneyRates.rates[us[i][0]]) continue;
      h += '<option value="' + us[i][0] + '"' + (us[i][0] === sel ? ' selected' : '') + '>' + labelFor(us[i]) + '</option>';
    }
    return h;
  }
  function renderConv() {
    var ia = document.getElementById('oc-cv-a');
    var ib = document.getElementById('oc-cv-b');
    var sa = document.getElementById('oc-cv-au');
    var sb = document.getElementById('oc-cv-bu');
    if (!ia) return;
    sa.innerHTML = buildOpts(cv.cat, cv.ua);
    sb.innerHTML = buildOpts(cv.cat, cv.ub);
    var v = parseFloat(cv.va);
    ia.value = cv.va;
    if (isNaN(v)) { ib.value = ''; updateConvHint(); return; }
    if (cv.cat === 'money' && !moneyRates) { ib.value = ''; updateConvHint(); return; }
    var result = convert(cv.cat, v, cv.ua, cv.ub);
    ib.value = isNaN(result) ? '' : fmtConv(result);
    updateConvHint();
  }
  function updateConvHint() {
    var hint = document.getElementById('oc-hint');
    if (!hint) return;
    if (state.mode !== 'conv') return;
    if (cv.cat === 'money') {
      hint.removeAttribute('data-i18n');
      if (ratesLoading && !moneyRates) {
        hint.textContent = t('ratesLoading');
      } else if (moneyRates) {
        // Validate date format YYYY-MM-DD before injecting
        var safeDate = /^\d{4}-\d{2}-\d{2}$/.test(moneyRates.date) ? moneyRates.date : '';
        hint.innerHTML = t('ratesAsOf') + ' ' + safeDate +
          ' · <a href="https://www.exchangerate-api.com" target="_blank" rel="noopener" style="color:inherit;text-decoration:underline;opacity:0.85">ExchangeRate-API</a>';
      } else {
        hint.textContent = t('ratesError');
      }
    } else {
      hint.setAttribute('data-i18n', 'hintConv');
      hint.textContent = t('hintConv');
    }
  }
  function bindConv() {
    var ia = document.getElementById('oc-cv-a');
    var ib = document.getElementById('oc-cv-b');
    var sa = document.getElementById('oc-cv-au');
    var sb = document.getElementById('oc-cv-bu');
    ia.addEventListener('input', function () {
      cv.va = ia.value;
      var v = parseFloat(ia.value);
      if (isNaN(v)) { ib.value = ''; return; }
      var r = convert(cv.cat, v, cv.ua, cv.ub);
      ib.value = isNaN(r) ? '' : fmtConv(r);
    });
    ib.addEventListener('input', function () {
      var v = parseFloat(ib.value);
      if (isNaN(v)) { ia.value = ''; cv.va = ''; return; }
      var a = convert(cv.cat, v, cv.ub, cv.ua);
      ia.value = isNaN(a) ? '' : fmtConv(a);
      cv.va = ia.value;
    });
    sa.addEventListener('change', function () { cv.ua = sa.value; renderConv(); });
    sb.addEventListener('change', function () { cv.ub = sb.value; renderConv(); });
    document.getElementById('oc-cv-swap').addEventListener('click', function () {
      var tmp = cv.ua; cv.ua = cv.ub; cv.ub = tmp;
      var av = ia.value; ia.value = ib.value; ib.value = av;
      cv.va = ia.value;
      renderConv();
    });
    var cats = document.querySelectorAll('#oc-cats button');
    for (var i = 0; i < cats.length; i++) {
      (function (b) {
        b.addEventListener('click', function () {
          var c = b.getAttribute('data-c');
          cv.cat = c;
          cv.ua = UNITS[c].a;
          cv.ub = UNITS[c].b;
          cv.va = '1';
          for (var j = 0; j < cats.length; j++) cats[j].classList.toggle('is-active', cats[j] === b);
          if (c === 'money') {
            renderConv();
            ensureRates().then(function () { renderConv(); }, function () { updateConvHint(); });
          } else {
            renderConv();
          }
        });
      })(cats[i]);
    }
  }

  // ===== Ratio / Rule of three =====
  var rState = { W1: '', H1: '', W2: '', H2: '', set: [], computed: null };

  function gcd(a, b) {
    a = Math.abs(Math.round(a));
    b = Math.abs(Math.round(b));
    while (b) { var t = b; b = a % b; a = t; }
    return a;
  }
  function ratioLabel(w, h) {
    if (!isFinite(w) || !isFinite(h) || w <= 0 || h <= 0) return '—';
    var wi = Math.round(w), hi = Math.round(h);
    if (Math.abs(w - wi) < 0.001 && Math.abs(h - hi) < 0.001 && wi > 0 && hi > 0) {
      var g = gcd(wi, hi);
      if (g > 0) {
        var a = wi / g, b = hi / g;
        if (a <= 99 && b <= 99) return a + ' : ' + b;
      }
    }
    return (w / h).toFixed(3) + ' : 1';
  }

  function buildRatioHTML() {
    return '' +
      '<div class="ratio-block">' +
        '<div class="ratio-block-label" data-i18n="ratioOriginal">Original</div>' +
        '<div class="ratio-row">' +
          '<input type="text" inputmode="decimal" id="oc-r-W1" placeholder="W" data-i18n-placeholder="placeWidth" autocomplete="off">' +
          '<span class="ratio-times">×</span>' +
          '<input type="text" inputmode="decimal" id="oc-r-H1" placeholder="H" data-i18n-placeholder="placeHeight" autocomplete="off">' +
        '</div>' +
      '</div>' +
      '<div class="ratio-info">' +
        '<span class="ratio-chip is-empty" id="oc-r-ratio">—</span>' +
        '<span class="ratio-chip is-empty" id="oc-r-scale">—</span>' +
      '</div>' +
      '<div class="ratio-block">' +
        '<div class="ratio-block-label" data-i18n="ratioTarget">Target</div>' +
        '<div class="ratio-row">' +
          '<input type="text" inputmode="decimal" id="oc-r-W2" placeholder="W" data-i18n-placeholder="placeWidth" autocomplete="off">' +
          '<span class="ratio-times">×</span>' +
          '<input type="text" inputmode="decimal" id="oc-r-H2" placeholder="H" data-i18n-placeholder="placeHeight" autocomplete="off">' +
        '</div>' +
      '</div>' +
      '<div class="ratio-presets">' +
        '<button type="button" data-r="16:9">16:9</button>' +
        '<button type="button" data-r="4:3">4:3</button>' +
        '<button type="button" data-r="1:1">1:1</button>' +
        '<button type="button" data-r="3:2">3:2</button>' +
        '<button type="button" data-r="9:16">9:16</button>' +
      '</div>' +
      '<div class="ratio-clear">' +
        '<button type="button" id="oc-r-clear" data-i18n="ratioClear">Clear all</button>' +
      '</div>';
  }

  function rGetVal(k) { return parseFloat(rState[k]); }

  function rRecompute() {
    var keys = ['W1', 'H1', 'W2', 'H2'];
    keys.forEach(function (k) {
      var el = document.getElementById('oc-r-' + k);
      if (el) el.classList.remove('is-computed');
    });
    rState.computed = null;

    if (rState.set.length === 3) {
      var unset = keys.filter(function (k) { return rState.set.indexOf(k) < 0; });
      if (unset.length === 1) {
        var target = unset[0];
        var W1 = rGetVal('W1'), H1 = rGetVal('H1'), W2 = rGetVal('W2'), H2 = rGetVal('H2');
        var result;
        // Cross multiply: W1/H1 = W2/H2  →  W1·H2 = H1·W2
        if (target === 'W1') result = (H1 * W2) / H2;
        else if (target === 'H1') result = (W1 * H2) / W2;
        else if (target === 'W2') result = (W1 * H2) / H1;
        else if (target === 'H2') result = (H1 * W2) / W1;

        if (isFinite(result) && !isNaN(result)) {
          var formatted = fmtConv(result);
          rState[target] = formatted;
          var el = document.getElementById('oc-r-' + target);
          if (el) {
            el.value = formatted;
            el.classList.add('is-computed');
          }
          rState.computed = target;
        }
      }
    }
    rUpdateChips();
  }

  function rUpdateChips() {
    var ratioChip = document.getElementById('oc-r-ratio');
    var scaleChip = document.getElementById('oc-r-scale');
    if (!ratioChip || !scaleChip) return;
    var W1 = rGetVal('W1'), H1 = rGetVal('H1'), W2 = rGetVal('W2'), H2 = rGetVal('H2');

    // Ratio chip — prefer original pair if both present, else target
    var rW = NaN, rH = NaN;
    if (isFinite(W1) && isFinite(H1) && W1 > 0 && H1 > 0) { rW = W1; rH = H1; }
    else if (isFinite(W2) && isFinite(H2) && W2 > 0 && H2 > 0) { rW = W2; rH = H2; }
    if (isFinite(rW) && isFinite(rH)) {
      ratioChip.textContent = ratioLabel(rW, rH);
      ratioChip.classList.remove('is-empty');
    } else {
      ratioChip.textContent = '—';
      ratioChip.classList.add('is-empty');
    }

    // Scale chip — W2 / W1 (or H2 / H1 if W1 unset)
    var s = NaN;
    if (isFinite(W1) && isFinite(W2) && W1 > 0) s = W2 / W1;
    else if (isFinite(H1) && isFinite(H2) && H1 > 0) s = H2 / H1;
    if (isFinite(s) && s > 0) {
      var pct = Math.round(s * 100);
      scaleChip.textContent = '×' + s.toFixed(2) + ' · ' + pct + '%';
      scaleChip.classList.remove('is-empty');
    } else {
      scaleChip.textContent = '—';
      scaleChip.classList.add('is-empty');
    }
  }

  function rEdit(key, val) {
    rState[key] = val;
    if (val === '' || val === '-' || val === '.') {
      // empty / partial — remove from set
      var idx = rState.set.indexOf(key);
      if (idx !== -1) rState.set.splice(idx, 1);
    } else {
      var i = rState.set.indexOf(key);
      if (i !== -1) rState.set.splice(i, 1);
      rState.set.push(key);
      while (rState.set.length > 3) rState.set.shift();
    }
    rRecompute();
  }

  function rApplyPreset(ratioStr) {
    var parts = ratioStr.split(':');
    if (parts.length !== 2) return;
    var w = parts[0], h = parts[1];
    rState.W1 = w; rState.H1 = h;
    var inW1 = document.getElementById('oc-r-W1');
    var inH1 = document.getElementById('oc-r-H1');
    if (inW1) inW1.value = w;
    if (inH1) inH1.value = h;
    // Mark W1, H1 as user-set (most recent)
    ['W1', 'H1'].forEach(function (k) {
      var idx = rState.set.indexOf(k);
      if (idx !== -1) rState.set.splice(idx, 1);
    });
    rState.set.push('W1');
    rState.set.push('H1');
    while (rState.set.length > 3) rState.set.shift();
    rRecompute();
  }

  function rClearAll() {
    rState.W1 = ''; rState.H1 = ''; rState.W2 = ''; rState.H2 = '';
    rState.set = []; rState.computed = null;
    ['W1', 'H1', 'W2', 'H2'].forEach(function (k) {
      var el = document.getElementById('oc-r-' + k);
      if (el) { el.value = ''; el.classList.remove('is-computed'); }
    });
    rUpdateChips();
  }

  function bindRatio() {
    ['W1', 'H1', 'W2', 'H2'].forEach(function (k) {
      var el = document.getElementById('oc-r-' + k);
      if (!el) return;
      el.value = rState[k] || '';
      el.addEventListener('input', function () { rEdit(k, el.value); });
    });
    var presets = document.querySelectorAll('.ratio-presets button');
    for (var i = 0; i < presets.length; i++) {
      (function (b) {
        b.addEventListener('click', function () { rApplyPreset(b.getAttribute('data-r')); });
      })(presets[i]);
    }
    var clr = document.getElementById('oc-r-clear');
    if (clr) clr.addEventListener('click', rClearAll);
  }

  function renderRatio() {
    // Re-format any computed value with current dp, then update chips
    if (rState.computed) {
      var n = parseFloat(rState[rState.computed]);
      if (!isNaN(n)) {
        rState[rState.computed] = fmtConv(n);
        var el = document.getElementById('oc-r-' + rState.computed);
        if (el) el.value = rState[rState.computed];
      }
    }
    rUpdateChips();
  }

  // ===== Mode switching =====
  function setMode(m) {
    state.mode = m;
    var modes = document.querySelectorAll('.octopus-calc__modes .mode-btn');
    for (var i = 0; i < modes.length; i++) {
      modes[i].classList.toggle('is-active', modes[i].getAttribute('data-mode') === m);
    }
    var body = document.getElementById('oc-body');
    var hint = document.getElementById('oc-hint');
    if (m === 'conv') {
      body.innerHTML =
        '<div class="cats" id="oc-cats">' +
          '<button class="' + (cv.cat === 'length' ? 'is-active' : '') + '" data-c="length"><span data-i18n="catLength">Length</span></button>' +
          '<button class="' + (cv.cat === 'area' ? 'is-active' : '') + '" data-c="area"><span data-i18n="catArea">Area</span></button>' +
          '<button class="' + (cv.cat === 'weight' ? 'is-active' : '') + '" data-c="weight"><span data-i18n="catWeight">Weight</span></button>' +
          '<button class="' + (cv.cat === 'volume' ? 'is-active' : '') + '" data-c="volume"><span data-i18n="catVolume">Volume</span></button>' +
          '<button class="' + (cv.cat === 'temp' ? 'is-active' : '') + '" data-c="temp"><span data-i18n="catTemp">Temp</span></button>' +
          '<button class="' + (cv.cat === 'money' ? 'is-active' : '') + '" data-c="money"><span data-i18n="catMoney">Money</span></button>' +
        '</div>' +
        '<div class="conv-row"><input type="text" inputmode="decimal" id="oc-cv-a" value="1" data-i18n-aria="fromValue"><select id="oc-cv-au" data-i18n-aria="fromUnit"></select></div>' +
        '<div class="conv-swap"><button id="oc-cv-swap" type="button" data-i18n-aria="swapUnits">⇅</button></div>' +
        '<div class="conv-row"><input type="text" inputmode="decimal" id="oc-cv-b" data-i18n-aria="toValue"><select id="oc-cv-bu" data-i18n-aria="toUnit"></select></div>';
      hint.setAttribute('data-i18n', 'hintConv');
      applyI18n(body);
      applyI18n(hint);
      bindConv();
      if (cv.cat === 'money') {
        renderConv();
        ensureRates().then(function () { renderConv(); }, function () { updateConvHint(); });
      } else {
        renderConv();
      }
    } else if (m === 'shape') {
      body.innerHTML = buildShapeHTML();
      hint.setAttribute('data-i18n', 'hintShape');
      applyI18n(body);
      applyI18n(hint);
      bindShape();
      renderShapeResults();
    } else if (m === 'ratio') {
      body.innerHTML = buildRatioHTML();
      hint.setAttribute('data-i18n', 'ratioHint');
      applyI18n(body);
      applyI18n(hint);
      bindRatio();
      renderRatio();
    } else {
      body.innerHTML =
        '<div class="display"><div class="display__history" id="oc-hist">&nbsp;</div><div class="display__current" id="oc-cur">0</div></div>' +
        '<div class="grid ' + (m === 'simple' ? 'grid--simple' : 'grid--adv') + '" id="oc-grid">' + (m === 'simple' ? SIMPLE_HTML : ADV_HTML) + '</div>';
      hint.setAttribute('data-i18n', 'hintCalc');
      applyI18n(hint);
      bindCalcButtons();
      renderCalc();
    }
  }

  // ===== Theme =====
  function applyTheme(theme) {
    state.theme = theme;
    document.getElementById('oc-root').setAttribute('data-theme', theme);
    var btn = document.getElementById('oc-theme');
    btn.innerHTML = theme === 'dark' ? ICON_SUN : ICON_MOON;
    try { localStorage.setItem('oc-theme', theme); } catch (e) {}
  }
  function toggleTheme() {
    applyTheme(state.theme === 'dark' ? 'light' : 'dark');
  }

  // ===== Language =====
  function applyLang(lang) {
    state.lang = lang;
    document.documentElement.setAttribute('lang', lang);
    document.getElementById('oc-lang').textContent = lang === 'en' ? 'TH' : 'EN';
    applyI18n(document.getElementById('oc-root'));
    if (state.mode === 'conv') renderConv();
    // refresh dp button label (uses i18n string for AUTO)
    var dpBtn = document.getElementById('oc-dp');
    if (dpBtn) {
      dpBtn.innerHTML = '<span class="dp-pre">' + t('dpLabel') + '</span>' + dpLabelText(state.dp);
      var desc = (state.dp === 'auto' ? t('dpAuto') : state.dp + ' ' + t('dpDecimals'));
      dpBtn.setAttribute('title', t('dpSwitch') + ' — ' + desc);
      dpBtn.setAttribute('aria-label', t('dpSwitch') + ': ' + desc);
    }
    try { localStorage.setItem('oc-lang', lang); } catch (e) {}
  }
  function toggleLang() {
    applyLang(state.lang === 'en' ? 'th' : 'en');
  }

  // ===== Decimal places =====
  function applyDp(dp) {
    state.dp = dp;
    var btn = document.getElementById('oc-dp');
    btn.innerHTML = '<span class="dp-pre">' + t('dpLabel') + '</span>' + dpLabelText(dp);
    var desc = (dp === 'auto' ? t('dpAuto') : dp + ' ' + t('dpDecimals'));
    btn.setAttribute('title', t('dpSwitch') + ' — ' + desc);
    btn.setAttribute('aria-label', t('dpSwitch') + ': ' + desc);
    try { localStorage.setItem('oc-dp', dp); } catch (e) {}
    // Re-format current display
    if (state.mode === 'conv') {
      renderConv();
    } else if (state.mode === 'shape') {
      renderShapeResults();
    } else if (state.mode === 'ratio') {
      renderRatio();
    } else {
      if (state.result !== '0' && state.result !== 'Error') {
        var n = parseFloat(state.result);
        if (!isNaN(n)) state.result = fmt(n);
      }
      renderCalc();
    }
  }
  function dpLabelText(dp) {
    if (dp === 'auto') return 'auto';
    if (dp === '0') return '0';
    return '0.' + new Array(parseInt(dp, 10) + 1).join('0');
  }
  function cycleDp() {
    var idx = DP_STATES.indexOf(state.dp);
    var next = DP_STATES[(idx + 1) % DP_STATES.length];
    applyDp(next);
  }

  // ===== Init =====
  function init() {
    // theme
    var savedTheme = null;
    try { savedTheme = localStorage.getItem('oc-theme'); } catch (e) {}
    var initTheme = savedTheme || (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
    applyTheme(initTheme);

    // language
    var savedLang = null;
    try { savedLang = localStorage.getItem('oc-lang'); } catch (e) {}
    var initLang = savedLang || ((navigator.language || 'en').toLowerCase().indexOf('th') === 0 ? 'th' : 'en');
    applyLang(initLang);

    // decimal places
    var savedDp = null;
    try { savedDp = localStorage.getItem('oc-dp'); } catch (e) {}
    var initDp = (savedDp && DP_STATES.indexOf(savedDp) !== -1) ? savedDp : 'auto';
    applyDp(initDp);

    // hydrate cached FX rates if any (don't fetch yet — wait for Money tab)
    moneyRates = loadCachedRates();

    // initial mode = simple
    document.getElementById('oc-grid').innerHTML = SIMPLE_HTML;
    bindCalcButtons();

    // mode buttons
    var modeBtns = document.querySelectorAll('.octopus-calc__modes .mode-btn');
    for (var i = 0; i < modeBtns.length; i++) {
      (function (b) {
        b.addEventListener('click', function () { setMode(b.getAttribute('data-mode')); });
      })(modeBtns[i]);
    }

    // toolbar
    document.getElementById('oc-theme').addEventListener('click', toggleTheme);
    document.getElementById('oc-lang').addEventListener('click', toggleLang);
    document.getElementById('oc-dp').addEventListener('click', cycleDp);

    // keyboard
    document.addEventListener('keydown', function (e) {
      if (state.mode === 'conv' || state.mode === 'shape') return;
      var ae = document.activeElement;
      if (ae && (ae.tagName === 'INPUT' || ae.tagName === 'SELECT' || ae.tagName === 'TEXTAREA')) return;
      var k = e.key;
      if (/^[0-9.]$/.test(k))                      { press(k); e.preventDefault(); }
      else if (k === '+' || k === '-' || k === '*' || k === '/') { press(k); e.preventDefault(); }
      else if (k === '(' || k === ')')             { press(k === '(' ? 'lp' : 'rp'); e.preventDefault(); }
      else if (k === '^')                          { press('pow'); e.preventDefault(); }
      else if (k === '!')                          { press('fact'); e.preventDefault(); }
      else if (k === 'Enter' || k === '=')         { press('eq'); e.preventDefault(); }
      else if (k === 'Backspace')                  { press('back'); e.preventDefault(); }
      else if (k === 'Escape')                     { press('clear'); e.preventDefault(); }
    });
  }

  init();
})();
</script>
