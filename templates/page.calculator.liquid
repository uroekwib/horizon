  }
  function buildShapeHTML() {
    var hRow = (shape.kind === 'box')
      ? '<div class="shape-row"><label data-i18n="abbrH">H</label><input id="oc-sh-h" type="text" inputmode="decimal" placeholder="0" aria-label="' + t('shapeHeight') + '"><span class="shape-unit-spacer"></span></div>'
      : '';
    return '<div class="shape-tabs" id="oc-sh-tabs">' +
        '<button class="' + (shape.kind === 'rect' ? 'is-active' : '') + '" data-shape="rect"><span data-i18n="shapeRect">Rectangle</span></button>' +
        '<button class="' + (shape.kind === 'box' ? 'is-active' : '') + '" data-shape="box"><span data-i18n="shapeBox">Box</span></button>' +
      '</div>' +
      '<div class="shape-inputs">' +
        '<div class="shape-row"><label data-i18n="abbrW">W</label><input id="oc-sh-w" type="text" inputmode="decimal" placeholder="0" aria-label="' + t('shapeWidth') + '"><select class="shape-unit" id="oc-sh-u">' + buildShapeUnitOpts() + '</select></div>' +
        '<div class="shape-row"><label data-i18n="abbrL">L</label><input id="oc-sh-l" type="text" inputmode="decimal" placeholder="0" aria-label="' + t('shapeLength') + '"><span class="shape-unit-spacer"></span></div>' +
        hRow +
      '</div>' +
