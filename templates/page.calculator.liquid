      h += '<option value="' + SHAPE_UNITS[i][0] + '"' + (SHAPE_UNITS[i][0] === shape.unit ? ' selected' : '') + '>' + SHAPE_UNITS[i][1] + '</option>';
    }
    return h;
  }
  function computeShape() {
    var w = parseFloat(shape.w), l = parseFloat(shape.l), h = parseFloat(shape.h);
    if (isNaN(w) || isNaN(l) || w <= 0 || l <= 0) return null;
    var s = shapeUnitScale(shape.unit);
    var wm = w * s, lm = l * s;
    if (shape.kind === 'rect') {
      return {
        area_native: w * l, area_m2: wm * lm,
        perim_native: 2 * (w + l)
      };
    }
    // box
    if (isNaN(h) || h <= 0) return null;
    var hm = h * s;
    return {
      surface_native: 2 * (w * l + w * h + l * h),
      surface_m2:     2 * (wm * lm + wm * hm + lm * hm),
      volume_native:  w * l * h,
      volume_m3:      wm * lm * hm
    };
  }
  function renderShapeResults() {
    var resEl = document.getElementById('oc-sh-results');
    var sendBtn = document.getElementById('oc-sh-send');
