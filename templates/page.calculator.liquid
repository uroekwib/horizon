    if (shape.kind === 'rect') {
      value = r.area_m2;
      label = t('shapeArea') + ' ' + fmtConv(r.area_native) + ' ' + shape.unit + '² (' + fmtConv(value) + ' m²)';
    } else {
      value = r.surface_m2;
      label = t('shapeSurface') + ' ' + fmtConv(r.surface_native) + ' ' + shape.unit + '² (' + fmtConv(value) + ' m²)';
    }
    state.result = fmt(value);
    state.expr = '';
