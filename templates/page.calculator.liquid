{% comment %}
  Octopus Calculator — Free online calculator for signage and printing.
  URL: /pages/calculator
  Page handle: calculator · template_suffix: calculator
{% endcomment %}

<style>
.oc-calc-page {
  background: #f3f7fa;
  padding: 32px 16px 64px;
  min-height: 60vh;
}
.oc-calc-page-inner {
  max-width: 880px;
  margin: 0 auto;
}
.oc-calc-page h1 {
  font-size: clamp(24px, 4vw, 34px);
  font-weight: 700;
  text-align: center;
  margin: 0 0 8px;
  color: #0f172a;
  line-height: 1.25;
}
.oc-calc-page .lead {
  text-align: center;
  color: #475569;
  font-size: 15px;
  max-width: 620px;
  margin: 0 auto 28px;
  line-height: 1.6;
}

/* Hide intro lead on mobile to save scroll-space */
@media (max-width: 768px) {
  .oc-calc-page .lead { display: none !important; }
}

.oc-calc-page .calc-mount {
  display: flex;
  justify-content: center;
  margin-bottom: 40px;
}
.oc-calc-page h2 {
  font-size: 22px;
  font-weight: 700;
  margin: 36px 0 14px;
  color: #0f172a;
}
.oc-calc-page h3 {
  font-size: 16px;
  font-weight: 600;
  margin: 18px 0 10px;
  color: #17a9bb;
}
.oc-calc-page p {
  color: #334155;
  line-height: 1.7;
  margin: 0 0 12px;
  font-size: 15px;
}
.oc-calc-page .uses {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 14px;
  margin: 16px 0 8px;
}
.oc-calc-page .uses .item {
  background: #ffffff;
  border: 1px solid #e2e8f0;
  border-radius: 12px;
  padding: 14px 16px;
}
.oc-calc-page .uses .item-title {
  font-weight: 600;
  color: #0f172a;
  margin-bottom: 4px;
  font-size: 14px;
}
.oc-calc-page .uses .item-desc {
  color: #64748b;
  font-size: 13px;
  line-height: 1.55;
}
.oc-calc-page .examples {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 16px;
  margin: 14px 0 8px;
}
.oc-calc-page .examples .ex {
  background: #ffffff;
  border: 1px solid #e2e8f0;
  border-radius: 12px;
  padding: 16px 18px;
}
.oc-calc-page .examples .ex h3 {
  margin-top: 0;
}
.oc-calc-page .ex-table {
  width: 100%;
  font-size: 13px;
  border-collapse: collapse;
  margin: 8px 0 4px;
}
.oc-calc-page .ex-table th,
.oc-calc-page .ex-table td {
  text-align: left;
  padding: 6px 8px;
  border-bottom: 1px solid #f1f5f9;
}
.oc-calc-page .ex-table th {
  color: #64748b;
  font-weight: 500;
  font-size: 12px;
}
.oc-calc-page .ex-table td {
  color: #0f172a;
  font-family: ui-monospace, "SF Mono", "JetBrains Mono", "Menlo", monospace;
}
.oc-calc-page details {
  background: #ffffff;
  border: 1px solid #e2e8f0;
  border-radius: 10px;
  padding: 0;
  margin-bottom: 8px;
}
.oc-calc-page details summary {
  list-style: none;
  cursor: pointer;
  padding: 12px 16px;
  font-weight: 600;
  color: #0f172a;
  font-size: 15px;
}
.oc-calc-page details summary::-webkit-details-marker { display: none; }
.oc-calc-page details summary::before {
  content: "+";
  display: inline-block;
  margin-right: 10px;
  color: #17a9bb;
  font-weight: 700;
  width: 14px;
}
.oc-calc-page details[open] summary::before { content: "−"; }
.oc-calc-page details[open] {
  border-color: #17a9bb;
}
.oc-calc-page details > div {
  padding: 0 16px 14px;
  color: #475569;
  font-size: 14px;
  line-height: 1.7;
}
.oc-calc-page .related-links {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  gap: 10px;
  margin: 12px 0 0;
}
.oc-calc-page .related-links a {
  display: block;
  background: #ffffff;
  border: 1px solid #e2e8f0;
  border-radius: 10px;
  padding: 12px 14px;
  text-decoration: none;
  color: #0f172a;
  font-weight: 500;
  font-size: 14px;
  transition: all 0.18s ease;
}
.oc-calc-page .related-links a:hover {
  border-color: #17a9bb;
  background: #eaf7fa;
  color: #17a9bb;
  transform: translateY(-2px);
}
.oc-calc-page .related-links a::after {
  content: " →";
  color: #94a3b8;
}
.oc-calc-page .related-links a:hover::after {
  color: #17a9bb;
}
.oc-calc-page .credit {
  text-align: center;
  font-size: 12px;
  color: #94a3b8;
  margin-top: 32px;
  padding-top: 20px;
  border-top: 1px solid #e2e8f0;
}
@media (max-width: 640px) {
  .oc-calc-page { padding: 24px 12px 48px; }
  .oc-calc-page .uses,
  .oc-calc-page .examples { gap: 10px; }
}
</style>

<style>
/* ===========================================================
   Octopus Calculator — scoped component
   Theme: data-theme="light" | "dark"
   Customize accent: override --accent / --accent-2
   =========================================================== */
.octopus-calc {
  --bg: #ffffff;
  --surface: #f4f4f5;
  --surface-2: #ffffff;
  --text-1: #18181b;
  --text-2: #71717a;
  --text-3: #a1a1aa;
  --accent: #17a9bb;
  --accent-2: #14c9df;
  --accent-bg: #eaf7fa;
  --accent-bg-strong: #d5eef3;
  --danger: #d43f5c;
  --danger-bg: #ffe4ea;
  --border: rgba(0, 0, 0, 0.08);
  --border-2: rgba(0, 0, 0, 0.16);
  --radius-sm: 8px;
  --radius-md: 12px;
  --radius-lg: 16px;
  --shadow: 0 1px 2px rgba(0,0,0,0.04), 0 8px 24px rgba(0,0,0,0.06);
  --font-sans: -apple-system, BlinkMacSystemFont, "Inter", "Segoe UI", "Noto Sans Thai", Roboto, "Helvetica Neue", Arial, sans-serif;
  --font-mono: ui-monospace, "SF Mono", "JetBrains Mono", "Menlo", "Consolas", "Roboto Mono", monospace;

  font-family: var(--font-sans);
  color: var(--text-1);
  background: var(--bg);
  border-radius: var(--radius-lg);
  padding: 20px;
  width: 100%;
  max-width: 380px;
  box-sizing: border-box;
  box-shadow: var(--shadow);
  border: 1px solid var(--border);
}

.octopus-calc[data-theme="dark"] {
  --bg: #18181b;
  --surface: #27272a;
  --surface-2: #1f1f22;
  --text-1: #fafafa;
  --text-2: #a1a1aa;
  --text-3: #52525b;
  --accent: #14c9df;
  --accent-2: #17a9bb;
  --accent-bg: rgba(20, 201, 223, 0.12);
  --accent-bg-strong: rgba(20, 201, 223, 0.22);
  --danger: #f87171;
  --danger-bg: rgba(212, 63, 92, 0.16);
  --border: rgba(255, 255, 255, 0.08);
  --border-2: rgba(255, 255, 255, 0.16);
  --shadow: 0 1px 2px rgba(0,0,0,0.3), 0 8px 24px rgba(0,0,0,0.4);
}

.octopus-calc *,
.octopus-calc *::before,
.octopus-calc *::after { box-sizing: border-box; }

/* Override host theme button defaults that bleed into .octopus-calc */
.octopus-calc button,
.octopus-calc .grid button,
.octopus-calc .grid > button {
  margin: 0 !important;
  width: auto !important;
  flex: none !important;
  display: inline-flex !important;
  align-items: center !important;
  justify-content: center !important;
  appearance: none !important;
  -webkit-appearance: none !important;
  text-transform: none !important;
  letter-spacing: normal !important;
  min-height: 0 !important;
  font-family: var(--font-mono) !important;
}
.octopus-calc input,
.octopus-calc select {
  margin: 0;
  font-family: inherit;
  appearance: none;
  -webkit-appearance: none;
  box-shadow: none;
}


/* Toolbar (theme + lang) */
.octopus-calc__toolbar {
  display: flex !important;
  justify-content: flex-end;
  gap: 6px;
  margin-bottom: 8px;
  flex-wrap: wrap;
}
.octopus-calc .tool-btn {
  font-family: inherit;
  font-size: 11px;
  font-weight: 500;
  height: 28px;
  padding: 0 10px;
  border: 1px solid var(--border-2);
  background: transparent;
  color: var(--text-2);
  border-radius: var(--radius-sm);
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 4px;
  transition: all 0.12s ease;
  -webkit-tap-highlight-color: transparent;
}
.octopus-calc .tool-btn:hover {
  background: var(--surface);
  color: var(--text-1);
  border-color: var(--text-3);
}
.octopus-calc .tool-btn--icon {
  width: 28px;
  padding: 0;
}
.octopus-calc #oc-dp {
  font-family: var(--font-mono);
  min-width: 64px;
}
.octopus-calc #oc-dp .dp-pre {
  font-family: var(--font-sans);
  font-weight: 400;
  opacity: 0.7;
  margin-right: 5px;
}
.octopus-calc .tool-btn svg { display: block; }

/* Mode toggle */
.octopus-calc__modes {
  display: flex;
  gap: 6px;
  justify-content: flex-end;
  flex-wrap: wrap;
  margin-bottom: 12px;
}
.octopus-calc__modes .mode-btn {
  font-family: inherit;
  font-size: 12px;
  font-weight: 500;
  padding: 6px 10px;
  border: 1px solid var(--border-2);
  border-radius: var(--radius-sm);
  background: transparent;
  color: var(--text-2);
  cursor: pointer;
  transition: all 0.12s ease;
  -webkit-tap-highlight-color: transparent;
}
.octopus-calc__modes .mode-btn:hover {
  background: var(--surface);
  color: var(--text-1);
}
.octopus-calc__modes .mode-btn.is-active {
  background: var(--accent-bg);
  color: var(--accent);
  border-color: var(--accent);
}

/* Display */
.octopus-calc .display {
  background: var(--surface);
  border-radius: var(--radius-md);
  padding: 18px 16px 14px;
  margin-bottom: 12px;
  min-height: 92px;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  cursor: pointer;
  -webkit-tap-highlight-color: transparent;
  transition: background 0.12s ease;
  position: relative;
}
.octopus-calc .display:hover { background: var(--accent-bg); }
.octopus-calc .display:active { transform: scale(0.995); }
.octopus-calc .display.is-copied { background: var(--accent-bg-strong); }
.octopus-calc .display__history {
  font-size: 13px;
  color: var(--text-3);
  font-family: var(--font-mono);
  min-height: 16px;
  text-align: right;
  word-break: break-all;
  line-height: 1.4;
}
.octopus-calc .display__current {
  font-size: 32px;
  font-weight: 500;
  font-family: var(--font-mono);
  text-align: right;
  word-break: break-all;
  line-height: 1.2;
  margin-top: 4px;
  color: var(--text-1);
}

/* Button grid */
.octopus-calc .grid {
  display: grid !important;
  gap: 8px;
  width: 100%;
  grid-template-areas: none;
}
.octopus-calc .grid--simple { grid-template-columns: repeat(4, 1fr) !important; }
.octopus-calc .grid--adv { grid-template-columns: repeat(5, 1fr) !important; }
.octopus-calc .grid button,
.octopus-calc .grid > button {
  height: 48px !important;
  width: auto !important;
  font-family: var(--font-mono) !important;
  font-size: 16px;
  font-weight: 500;
  padding: 0 !important;
  line-height: 1;
  background: var(--surface-2);
  color: var(--text-1);
  border: 1px solid var(--border-2);
  border-radius: var(--radius-sm);
  cursor: pointer;
  transition: transform 0.06s ease, background 0.12s ease, border-color 0.12s ease;
  -webkit-tap-highlight-color: transparent;
  display: inline-flex !important;
  align-items: center !important;
  justify-content: center !important;
  flex: none !important;
}
.octopus-calc .grid button:hover {
  background: var(--surface);
  border-color: var(--text-3);
}
.octopus-calc .grid button:active { transform: scale(0.96); }
.octopus-calc .grid .op {
  color: var(--accent);
  border-color: var(--accent);
  background: var(--accent-bg);
}
.octopus-calc .grid .op:hover { background: var(--accent-bg-strong); }
.octopus-calc .grid .eq {
  background: linear-gradient(135deg, var(--accent-2), var(--accent));
  color: #ffffff;
  border-color: transparent;
}
.octopus-calc .grid .eq:hover { filter: brightness(1.05); }
.octopus-calc .grid .fn {
  color: var(--text-2);
  font-size: 13px;
}
.octopus-calc .grid .clr {
  color: var(--danger);
  background: var(--danger-bg);
  border-color: var(--danger);
}
.octopus-calc .grid .span2 { grid-column: span 2 !important; }

/* Hint */
.octopus-calc__hint {
  font-size: 11px;
  color: var(--text-3);
  text-align: center;
  margin-top: 12px;
  font-family: var(--font-mono);
  min-height: 14px;
  line-height: 1.4;
}

/* Convert mode */
.octopus-calc .cats {
  display: flex;
  gap: 6px;
  margin-bottom: 14px;
  flex-wrap: wrap;
}
.octopus-calc .cats button {
  font-family: inherit;
  font-size: 12px;
  font-weight: 500;
  padding: 7px 6px;
  flex: 1;
  min-width: 56px;
  border: 1px solid var(--border-2);
  border-radius: var(--radius-sm);
  background: transparent;
  color: var(--text-2);
  cursor: pointer;
  transition: all 0.12s ease;
  -webkit-tap-highlight-color: transparent;
}
.octopus-calc .cats button:hover {
  background: var(--surface);
  color: var(--text-1);
}
.octopus-calc .cats button.is-active {
  background: var(--accent-bg);
  color: var(--accent);
  border-color: var(--accent);
}

.octopus-calc .conv-row {
  background: var(--surface);
  border-radius: var(--radius-md);
  padding: 14px 16px;
  display: flex;
  gap: 10px;
  align-items: center;
}
.octopus-calc .conv-row input {
  flex: 1;
  border: none;
  background: transparent;
  font-family: var(--font-mono);
  font-size: 26px;
  font-weight: 500;
  color: var(--text-1);
  text-align: right;
  padding: 0;
  outline: none;
  min-width: 0;
  width: 100%;
}
.octopus-calc .conv-row input::-webkit-outer-spin-button,
.octopus-calc .conv-row input::-webkit-inner-spin-button {
  -webkit-appearance: none;
  margin: 0;
}
.octopus-calc .conv-row select {
  font-family: var(--font-sans);
  font-size: 13px;
  font-weight: 500;
  padding: 6px 8px;
  border: 1px solid var(--border-2);
  border-radius: var(--radius-sm);
  background: var(--bg);
  color: var(--text-1);
  min-width: 110px;
  flex-shrink: 0;
  cursor: pointer;
}
.octopus-calc .conv-swap {
  display: flex;
  justify-content: center;
  margin: 8px 0;
}
.octopus-calc .conv-swap button {
  height: 36px;
  width: 36px;
  font-size: 16px;
  padding: 0;
  line-height: 1;
  border-radius: 50%;
  background: var(--surface-2);
  color: var(--accent);
  border: 1px solid var(--accent);
  cursor: pointer;
  transition: transform 0.18s ease, background 0.12s ease;
  -webkit-tap-highlight-color: transparent;
}
.octopus-calc .conv-swap button:hover {
  background: var(--accent-bg);
  transform: rotate(180deg);
}

.octopus-calc__sr-only {
  position: absolute;
  width: 1px;
  height: 1px;
  overflow: hidden;
  clip: rect(0 0 0 0);
}

/* Area / Shape mode */
.octopus-calc .shape-tabs {
  display: flex;
  gap: 6px;
  margin-bottom: 14px;
}
.octopus-calc .shape-tabs button {
  font-family: inherit;
  font-size: 12px;
  font-weight: 500;
  padding: 7px 12px;
  flex: 1;
  border: 1px solid var(--border-2);
  border-radius: var(--radius-sm);
  background: transparent;
  color: var(--text-2);
  cursor: pointer;
  transition: all 0.12s ease;
  -webkit-tap-highlight-color: transparent;
}
.octopus-calc .shape-tabs button:hover {
  background: var(--surface);
  color: var(--text-1);
}
.octopus-calc .shape-tabs button.is-active {
  background: var(--accent-bg);
  color: var(--accent);
  border-color: var(--accent);
}
.octopus-calc .shape-inputs {
  background: var(--surface);
  border-radius: var(--radius-md);
  padding: 12px 16px;
  margin-bottom: 12px;
}
.octopus-calc .shape-row {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 6px 0;
}
.octopus-calc .shape-row + .shape-row {
  border-top: 1px solid var(--border);
}
.octopus-calc .shape-row label {
  font-family: var(--font-sans);
  font-size: 13px;
  font-weight: 600;
  color: var(--text-2);
  width: 28px;
  flex-shrink: 0;
  text-transform: uppercase;
}
.octopus-calc .shape-row input {
  flex: 1;
  border: none;
  background: transparent;
  font-family: var(--font-mono);
  font-size: 22px;
  font-weight: 500;
  color: var(--text-1);
  text-align: right;
  padding: 0;
  outline: none;
  min-width: 0;
}
.octopus-calc .shape-row select.shape-unit {
  font-family: var(--font-sans);
  font-size: 12px;
  font-weight: 500;
  padding: 4px 6px;
  border: 1px solid var(--border-2);
  border-radius: var(--radius-sm);
  background: var(--bg);
  color: var(--text-1);
  width: 64px;
  flex-shrink: 0;
  cursor: pointer;
}
.octopus-calc .shape-unit-spacer { width: 64px; flex-shrink: 0; }
.octopus-calc .shape-results {
  background: var(--surface);
  border-radius: var(--radius-md);
  padding: 4px 16px;
  margin-bottom: 12px;
  min-height: 56px;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.octopus-calc .shape-result {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  padding: 8px 0;
}
.octopus-calc .shape-result + .shape-result {
  border-top: 1px solid var(--border);
}
.octopus-calc .shape-result-label {
  font-size: 12px;
  font-weight: 500;
  color: var(--text-2);
  text-transform: uppercase;
  letter-spacing: 0.04em;
}
.octopus-calc .shape-result-value {
  font-family: var(--font-mono);
  font-size: 16px;
  font-weight: 500;
  color: var(--text-1);
  text-align: right;
}
.octopus-calc .shape-result-value .unit {
  color: var(--text-3);
  font-size: 13px;
  margin-left: 4px;
}
.octopus-calc .shape-result-value .alt {
  display: block;
  font-size: 12px;
  color: var(--text-3);
  margin-top: 2px;
}
.octopus-calc .shape-send {
  width: 100%;
  padding: 12px;
  background: linear-gradient(135deg, var(--accent-2), var(--accent));
  color: #ffffff;
  border: none;
  border-radius: var(--radius-md);
  font-family: inherit;
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  transition: filter 0.12s ease;
  -webkit-tap-highlight-color: transparent;
}
.octopus-calc .shape-send:hover { filter: brightness(1.05); }
.octopus-calc .shape-send:disabled {
  background: var(--surface);
  color: var(--text-3);
  cursor: not-allowed;
  filter: none;
}

/* Ratio / Rule-of-three mode */
.octopus-calc .ratio-block {
  background: var(--surface);
  border-radius: var(--radius-md);
  padding: 12px 16px 14px;
  margin-bottom: 8px;
}
.octopus-calc .ratio-block-label {
  font-size: 10px;
  color: var(--text-2);
  font-weight: 600;
  margin-bottom: 6px;
  text-transform: uppercase;
  letter-spacing: 0.06em;
}
.octopus-calc .ratio-row {
  display: flex;
  align-items: center;
  gap: 10px;
}
.octopus-calc .ratio-row input {
  flex: 1;
  border: none;
  background: transparent;
  font-family: var(--font-mono);
  font-size: 22px;
  font-weight: 500;
  color: var(--text-1);
  text-align: right;
  outline: none;
  min-width: 0;
  width: 100%;
  padding: 0;
}
.octopus-calc .ratio-row input.is-computed {
  color: var(--accent);
}
.octopus-calc .ratio-row input::placeholder {
  color: var(--text-3);
  font-family: var(--font-sans);
  font-weight: 400;
}
.octopus-calc .ratio-times {
  font-family: var(--font-mono);
  color: var(--text-3);
  font-size: 18px;
  flex-shrink: 0;
}
.octopus-calc .ratio-info {
  display: flex;
  gap: 8px;
  justify-content: center;
  flex-wrap: wrap;
  margin: 4px 0 8px;
}
.octopus-calc .ratio-chip {
  background: var(--accent-bg);
  color: var(--accent);
  padding: 4px 12px;
  border-radius: 999px;
  border: 1px solid transparent;
  font-family: var(--font-mono);
  font-size: 12px;
  font-weight: 500;
}
.octopus-calc .ratio-chip.is-empty {
  background: transparent;
  color: var(--text-3);
  border-color: var(--border);
}
.octopus-calc .ratio-presets {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
