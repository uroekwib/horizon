<script>
(function(){
  'use strict';

  // ===== Helpers =====
  function $(id){return document.getElementById(id);}
  function escapeVCard(s){return (s||'').replace(/\\/g,'\\\\').replace(/,/g,'\\,').replace(/;/g,'\\;').replace(/\n/g,'\\n');}

  // ===== Build encoded data string from form by type =====
  function encodeByType(type, fields) {
    switch(type) {
      case 'url':   return fields.url || 'https://www.octopus.co.th';
      case 'text':  return fields.text || '';
      case 'tel':   return 'tel:' + (fields.tel || '');
      case 'sms':   return 'SMSTO:' + (fields.smsNum || '') + ':' + (fields.smsMsg || '');
      case 'email': return 'mailto:' + (fields.emailTo || '') + '?subject=' + encodeURIComponent(fields.emailSubj||'') + '&body=' + encodeURIComponent(fields.emailBody||'');
      case 'wifi':  return 'WIFI:T:' + (fields.wifiEnc || 'WPA') + ';S:' + (fields.wifiSsid || '') + ';P:' + (fields.wifiPwd || '') + ';;';
      case 'vcard':
        return 'BEGIN:VCARD\nVERSION:3.0\n' +
          'N:' + escapeVCard(fields.vcLname) + ';' + escapeVCard(fields.vcFname) + '\n' +
          'FN:' + escapeVCard((fields.vcFname||'') + ' ' + (fields.vcLname||'')) + '\n' +
          (fields.vcOrg ? 'ORG:' + escapeVCard(fields.vcOrg) + '\n' : '') +
          (fields.vcTitle ? 'TITLE:' + escapeVCard(fields.vcTitle) + '\n' : '') +
          (fields.vcTel ? 'TEL:' + escapeVCard(fields.vcTel) + '\n' : '') +
          (fields.vcEmail ? 'EMAIL:' + escapeVCard(fields.vcEmail) + '\n' : '') +
          (fields.vcUrl ? 'URL:' + escapeVCard(fields.vcUrl) + '\n' : '') +
          'END:VCARD';
      case 'line':
        var line = fields.line || '';
        if (/^https?:\/\//.test(line)) return line;
        if (line.charAt(0) === '@') return 'https://line.me/R/ti/p/' + encodeURIComponent(line);
        return 'https://line.me/R/ti/p/~' + encodeURIComponent(line);
      case 'promptpay':
        // EMV QR for PromptPay (Thai) — simplified payload
        // Production needs CRC16 calc — for MVP we encode the ID as text
        return generatePromptPay(fields.ppId || '', fields.ppAmt || '');
      default: return fields.text || '';
    }
  }

  // ===== PromptPay EMV QR (proper, with CRC) =====
  function generatePromptPay(id, amount) {
    if (!id) return '';
    // Normalize ID: strip non-digits
    var d = id.replace(/[^0-9]/g, '');
    var target;
    if (d.length === 13) {
      // Thai national ID
      target = '02' + (13 < 10 ? '0' : '') + '13' + d;
    } else if (d.length === 10 && d.charAt(0) === '0') {
      // Mobile — convert to 0066 format
      target = '01' + '13' + '0066' + d.substring(1);
    } else if (d.length === 15) {
      // e-Wallet
      target = '03' + '15' + d;
    } else {
      // fallback as text
      return id;
    }
    var merchant = '0016A000000677010111' + target;
    var f00 = '000201';
    var f01 = '010212'; // dynamic if amount, else 010211
    var f29 = '29' + (merchant.length < 10 ? '0' + merchant.length : merchant.length) + merchant;
    var f53 = '5303764'; // currency THB
    var amtStr = '';
    if (amount && parseFloat(amount) > 0) {
      var a = parseFloat(amount).toFixed(2);
      amtStr = '54' + (a.length < 10 ? '0' + a.length : a.length) + a;
      f01 = '010212';
    } else {
      f01 = '010211';
    }
    var f58 = '5802TH';
    var pre = f00 + f01 + f29 + f53 + amtStr + f58 + '6304';
    var crc = crc16(pre).toString(16).toUpperCase();
    while (crc.length < 4) crc = '0' + crc;
    return pre + crc;
  }
  function crc16(str) {
    var crc = 0xFFFF;
    for (var i = 0; i < str.length; i++) {
      crc ^= str.charCodeAt(i) << 8;
      for (var j = 0; j < 8; j++) {
        crc = (crc & 0x8000) ? ((crc << 1) ^ 0x1021) : (crc << 1);
        crc &= 0xFFFF;
      }
    }
    return crc;
  }

  // ===== Single QR state =====
  var st = {
    type: 'url',
    moduleStyle: 'square',
    fgColor: '#000000',
    bgColor: '#ffffff',
    logo: null,  // dataURL string
    qr: null,    // QRCodeStyling instance
  };

  function getFormFields() {
    return {
      url: $('oqr-url').value,
      text: $('oqr-text').value,
      tel: $('oqr-tel').value,
      smsNum: $('oqr-sms-num').value,
      smsMsg: $('oqr-sms-msg').value,
      emailTo: $('oqr-email-to').value,
      emailSubj: $('oqr-email-subj').value,
      emailBody: $('oqr-email-body').value,
      wifiSsid: $('oqr-wifi-ssid').value,
      wifiEnc: $('oqr-wifi-enc').value,
      wifiPwd: $('oqr-wifi-pwd').value,
      vcFname: $('oqr-vc-fname').value,
      vcLname: $('oqr-vc-lname').value,
      vcOrg: $('oqr-vc-org').value,
      vcTitle: $('oqr-vc-title').value,
      vcTel: $('oqr-vc-tel').value,
      vcEmail: $('oqr-vc-email').value,
      vcUrl: $('oqr-vc-url').value,
      line: $('oqr-line').value,
      ppId: $('oqr-pp-id').value,
      ppAmt: $('oqr-pp-amt').value,
    };
  }

  function buildQR(targetEl, opts) {
    var data = opts.data || ' ';
    var qr = new QRCodeStyling({
      width: opts.size || 300,
      height: opts.size || 300,
      type: 'svg',
      data: data,
      margin: 8,
      qrOptions: { errorCorrectionLevel: opts.logo ? 'H' : 'M' },
      dotsOptions: { type: opts.style || 'square', color: opts.fg || '#000000' },
      backgroundOptions: { color: opts.bg || '#ffffff' },
      cornersSquareOptions: { type: opts.style === 'dots' ? 'dot' : (opts.style === 'rounded' ? 'extra-rounded' : 'square'), color: opts.fg || '#000000' },
      image: opts.logo || undefined,
      imageOptions: { crossOrigin: 'anonymous', margin: 4, imageSize: 0.22 }
    });
    if (targetEl) {
      targetEl.innerHTML = '';
      qr.append(targetEl);
    }
    return qr;
  }

  function renderPreview() {
    if (typeof QRCodeStyling === 'undefined') {
      $('oqr-preview').innerHTML = '<div style="padding:20px;color:#999;font-size:13px;text-align:center">กำลังโหลด QR library...</div>';
      setTimeout(renderPreview, 300);
      return;
    }
    var data = encodeByType(st.type, getFormFields());
    if (!data) data = ' ';
    st.qr = buildQR($('oqr-preview'), {
      data: data, size: 300,
      style: st.moduleStyle, fg: st.fgColor, bg: st.bgColor, logo: st.logo
    });
  }

  function bindSingle() {
    // Type switcher
    $('oqr-type').addEventListener('change', function () {
      st.type = this.value;
      var fieldsets = document.querySelectorAll('.oqr-type-fields');
      for (var i = 0; i < fieldsets.length; i++) {
        fieldsets[i].classList.toggle('is-active', fieldsets[i].getAttribute('data-type') === st.type);
      }
      renderPreview();
    });

    // All input changes → re-render
    var inputs = document.querySelectorAll('#oqr-single-input input, #oqr-single-input textarea, #oqr-single-input select');
    for (var i = 0; i < inputs.length; i++) {
      inputs[i].addEventListener('input', renderPreview);
      inputs[i].addEventListener('change', renderPreview);
    }

    // Style buttons
    var styleBtns = document.querySelectorAll('#oqr-style-modules button');
    for (var j = 0; j < styleBtns.length; j++) {
      styleBtns[j].addEventListener('click', (function (b) { return function () {
        for (var k = 0; k < styleBtns.length; k++) styleBtns[k].classList.remove('is-active');
        b.classList.add('is-active');
        st.moduleStyle = b.getAttribute('data-style');
        renderPreview();
      }; })(styleBtns[j]));
    }

    // Color inputs
    $('oqr-color-fg').addEventListener('input', function () {
      st.fgColor = this.value; $('oqr-color-fg-hex').textContent = this.value; renderPreview();
    });
    $('oqr-color-bg').addEventListener('input', function () {
      st.bgColor = this.value; $('oqr-color-bg-hex').textContent = this.value; renderPreview();
    });

    // Logo
    $('oqr-logo-input').addEventListener('change', function (e) {
      var f = e.target.files[0];
      if (!f) return;
      var reader = new FileReader();
      reader.onload = function (ev) {
        st.logo = ev.target.result;
        $('oqr-logo-status').textContent = '✓ ' + f.name + ' (กดเพื่อเปลี่ยน)';
        $('oqr-logo-drop').classList.add('has-file');
        renderPreview();
      };
      reader.readAsDataURL(f);
    });

    // Download buttons
    $('oqr-dl-svg').addEventListener('click', function () {
      if (!st.qr) return;
      st.qr.download({ name: 'qr-' + filenameSafe(getCurrentLabel()), extension: 'svg' });
    });
    $('oqr-dl-png').addEventListener('click', function () {
      var size = parseInt($('oqr-png-size').value, 10);
      var data = encodeByType(st.type, getFormFields()) || ' ';
      var qrPng = new QRCodeStyling({
        width: size, height: size, type: 'canvas',
        data: data, margin: Math.round(size / 40),
        qrOptions: { errorCorrectionLevel: st.logo ? 'H' : 'M' },
        dotsOptions: { type: st.moduleStyle, color: st.fgColor },
        backgroundOptions: { color: st.bgColor },
        cornersSquareOptions: { type: st.moduleStyle === 'dots' ? 'dot' : 'extra-rounded', color: st.fgColor },
        image: st.logo || undefined,
        imageOptions: { crossOrigin: 'anonymous', margin: 4, imageSize: 0.22 }
      });
      qrPng.download({ name: 'qr-' + filenameSafe(getCurrentLabel()), extension: 'png' });
    });
  }
  function getCurrentLabel() {
    var f = getFormFields();
    return f.url || f.text || f.line || f.tel || f.emailTo || 'qr';
  }
  function filenameSafe(s) {
    return (s || 'qr').replace(/[^a-zA-Z0-9ก-๙_-]/g, '-').substring(0, 50);
  }

  // ===== Tabs =====
  function bindTabs() {
    var tabs = document.querySelectorAll('#oqr-tabs button');
    for (var i = 0; i < tabs.length; i++) {
      tabs[i].addEventListener('click', (function (b) { return function () {
        for (var j = 0; j < tabs.length; j++) tabs[j].classList.remove('is-active');
        b.classList.add('is-active');
        var mode = b.getAttribute('data-mode');
        $('oqr-single-input').style.display = mode === 'single' ? 'block' : 'none';
        $('oqr-preview-panel').style.display = mode === 'single' ? 'flex' : 'none';
        $('oqr-batch-panel').style.display = mode === 'batch' ? 'block' : 'none';
      }; })(tabs[i]));
    }
  }

  // ===== Batch mode =====
  var batchRows = [];
  function bindBatch() {
    var drop = $('oqr-batch-drop');
    var input = $('oqr-batch-input');
    drop.addEventListener('dragover', function (e) { e.preventDefault(); drop.classList.add('is-dragover'); });
    drop.addEventListener('dragleave', function () { drop.classList.remove('is-dragover'); });
    drop.addEventListener('drop', function (e) {
      e.preventDefault(); drop.classList.remove('is-dragover');
      if (e.dataTransfer.files[0]) handleBatchFile(e.dataTransfer.files[0]);
    });
    input.addEventListener('change', function (e) {
      if (e.target.files[0]) handleBatchFile(e.target.files[0]);
    });

    $('oqr-tpl-csv').addEventListener('click', function (e) {
      e.preventDefault();
      var csv = 'label,data,type\nWebsite,https://www.octopus.co.th,url\nLINE OA,@octopusdesign,line\nสำนักงาน,02-123-4567,tel\n';
      var blob = new Blob(['\uFEFF' + csv], { type: 'text/csv;charset=utf-8' });
      saveAs(blob, 'qr-batch-template.csv');
    });
    $('oqr-tpl-xlsx').addEventListener('click', function (e) {
      e.preventDefault();
      var ws = XLSX.utils.aoa_to_sheet([
        ['label', 'data', 'type'],
        ['Website', 'https://www.octopus.co.th', 'url'],
        ['LINE OA', '@octopusdesign', 'line'],
        ['Office', '02-123-4567', 'tel']
      ]);
      var wb = XLSX.utils.book_new();
      XLSX.utils.book_append_sheet(wb, ws, 'QR Batch');
      XLSX.writeFile(wb, 'qr-batch-template.xlsx');
    });

    $('oqr-batch-zip-svg').addEventListener('click', function () { downloadBatchZip('svg'); });
    $('oqr-batch-zip-png').addEventListener('click', function () { downloadBatchZip('png'); });
    $('oqr-batch-clear').addEventListener('click', function () {
      batchRows = [];
      $('oqr-batch-results').innerHTML = '';
      $('oqr-batch-results').style.display = 'none';
      $('oqr-batch-bar').style.display = 'none';
    });
  }

  function handleBatchFile(file) {
    var name = file.name.toLowerCase();
    if (name.endsWith('.csv') || name.endsWith('.tsv') || file.type === 'text/csv') {
      Papa.parse(file, {
        header: true, skipEmptyLines: true,
        complete: function (res) { processBatchRows(res.data); }
      });
    } else if (name.endsWith('.xlsx') || name.endsWith('.xls')) {
      var reader = new FileReader();
      reader.onload = function (e) {
        var wb = XLSX.read(e.target.result, { type: 'array' });
        var ws = wb.Sheets[wb.SheetNames[0]];
        var rows = XLSX.utils.sheet_to_json(ws, { defval: '' });
        processBatchRows(rows);
      };
      reader.readAsArrayBuffer(file);
    } else {
      alert('รองรับไฟล์ CSV และ Excel เท่านั้น');
    }
  }

  function processBatchRows(rows) {
    batchRows = [];
    var resultsEl = $('oqr-batch-results');
    resultsEl.innerHTML = '';
    resultsEl.style.display = 'block';
    $('oqr-batch-bar').style.display = 'flex';
    for (var i = 0; i < rows.length; i++) {
      var r = rows[i];
      var data = r.data || r.Data || r.URL || r.url || r.value || '';
      var label = r.label || r.Label || r.name || r.Name || ('qr-' + (i + 1));
      var type = (r.type || r.Type || 'url').toLowerCase();
      if (!data) continue;
      // Encode based on type
      var encoded = encodeByType(type, {
        url: data, text: data, tel: data, line: data,
        emailTo: data, ppId: data
      });
      var row = { label: label, data: data, type: type, encoded: encoded };
      batchRows.push(row);
      // Render row with thumbnail
      var rowEl = document.createElement('div');
      rowEl.className = 'oqr-batch-row';
      rowEl.innerHTML = '<div class="qr-thumb" id="thumb-' + i + '"></div>' +
        '<div class="qr-info"><div class="qr-label">' + escapeHtml(label) + '</div>' +
        '<div class="qr-data">' + escapeHtml(data) + '</div></div>' +
        '<div class="qr-action"><button onclick="window.__oqrDl(' + i + ',\'svg\')">SVG</button></div>';
      resultsEl.appendChild(rowEl);
      // Build preview qr in row
      buildQR($('thumb-' + i), {
        data: encoded || ' ', size: 60,
        style: st.moduleStyle, fg: st.fgColor, bg: st.bgColor
      });
    }
  }

  function escapeHtml(s){return (s||'').toString().replace(/[<>&"]/g,function(c){return{'<':'&lt;','>':'&gt;','&':'&amp;','"':'&quot;'}[c];});}

  // Single-row download (called from inline onclick)
  window.__oqrDl = function (idx, ext) {
    var r = batchRows[idx];
    if (!r) return;
    var size = ext === 'svg' ? 300 : 1024;
    var qr = new QRCodeStyling({
      width: size, height: size, type: ext === 'svg' ? 'svg' : 'canvas',
      data: r.encoded || ' ', margin: Math.round(size / 40),
      qrOptions: { errorCorrectionLevel: 'M' },
      dotsOptions: { type: st.moduleStyle, color: st.fgColor },
      backgroundOptions: { color: st.bgColor }
    });
    qr.download({ name: filenameSafe(r.label), extension: ext });
  };

  // Bulk ZIP download
  function downloadBatchZip(ext) {
    if (!batchRows.length) return;
    var zip = new JSZip();
    var size = ext === 'svg' ? 300 : 1024;
    var pending = batchRows.length;

    batchRows.forEach(function (r, idx) {
      var qr = new QRCodeStyling({
        width: size, height: size, type: ext === 'svg' ? 'svg' : 'canvas',
        data: r.encoded || ' ', margin: Math.round(size / 40),
        qrOptions: { errorCorrectionLevel: 'M' },
        dotsOptions: { type: st.moduleStyle, color: st.fgColor },
        backgroundOptions: { color: st.bgColor }
      });
      qr.getRawData(ext).then(function (blob) {
        zip.file(filenameSafe(r.label) + '.' + ext, blob);
        pending--;
        if (pending === 0) {
          zip.generateAsync({ type: 'blob' }).then(function (content) {
            saveAs(content, 'qr-batch-' + ext + '-' + Date.now() + '.zip');
          });
        }
      });
    });
  }

  // ===== Init =====
  bindSingle();
  bindTabs();
  bindBatch();
  renderPreview();
})();
</script>
