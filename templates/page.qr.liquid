{% comment %}
  Octopus QR Code Generator — /pages/qr-code
  Single page · 6 styles · SVG/PNG export · CSV/XLSX batch upload · ZIP download
{% endcomment %}

{%- assign canonical_url = shop.url | append: '/pages/qr-code' -%}
{%- capture og_title -%}สร้าง QR Code ออนไลน์ฟรี + Batch CSV/Excel | Octopus{%- endcapture -%}
{%- capture og_desc -%}สร้าง QR Code คุณภาพพิมพ์ ดาวน์โหลด SVG/PNG ขนาดใหญ่ · 6 สไตล์ · ใส่ logo · สีกำหนดเอง · Batch import จาก CSV/Excel สร้าง QR หลายอันพร้อมกัน · ฟรี ไม่มีโฆษณา{%- endcapture -%}

<link rel="canonical" href="{{ canonical_url }}">
<meta property="og:type" content="website">
<meta property="og:locale" content="th_TH">
<meta property="og:url" content="{{ canonical_url }}">
<meta property="og:title" content="{{ og_title }}">
<meta property="og:description" content="{{ og_desc }}">
<meta property="og:site_name" content="Octopus Media Solutions">
{%- if shop.brand.logo %}
<meta property="og:image" content="{{ shop.brand.logo | image_url: width: 1200 }}">
{%- endif %}
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ og_title }}">
<meta name="twitter:description" content="{{ og_desc }}">
<meta name="keywords" content="QR Code, สร้าง QR Code, สร้าง QR Code ออนไลน์, QR generator, QR Code SVG, QR Code PNG, batch QR, สร้าง QR หลายอัน, QR จาก Excel, QR จาก CSV, QR Code logo, QR Code สี">

<style>
.oc-qr-page {
  max-width: 1100px;
  margin: 0 auto;
  padding: 32px 20px 60px;
  font-family: -apple-system, BlinkMacSystemFont, "Inter", "Noto Sans Thai", sans-serif;
  color: #1a202c;
}
.oc-qr-page h1 {
  font-size: clamp(1.6em, 4vw, 2.2em);
  font-weight: 700;
  text-align: center;
  margin: 0 0 12px;
  letter-spacing: -0.01em;
}
.oc-qr-page h1 .grad {
  background: linear-gradient(135deg, #14c9df, #17a9bb);
  -webkit-background-clip: text; background-clip: text; color: transparent;
}
.oc-qr-page .lead {
  text-align: center;
  color: #475569;
  font-size: 15px;
  max-width: 680px;
  margin: 0 auto 32px;
  line-height: 1.6;
}
@media (max-width: 768px) { .oc-qr-page .lead { display: none !important; } }

/* ===== QR app container — same design tokens as calculator ===== */
.octopus-qr {
  --bg: #ffffff;
  --surface: #f4f4f5;
  --surface-2: #ffffff;
  --text-1: #18181b;
  --text-2: #71717a;
  --text-3: #a1a1aa;
  --accent: #17a9bb;
  --accent-2: #14c9df;
  --accent-bg: #eaf7fa;
  --accent-bg-strong: #d5eef3;
  --danger: #d43f5c;
  --danger-bg: #ffe4ea;
  --border: rgba(0, 0, 0, 0.08);
  --border-2: rgba(0, 0, 0, 0.16);
  --radius-sm: 8px;
  --radius-md: 12px;
  --radius-lg: 16px;
  --shadow: 0 1px 2px rgba(0,0,0,0.04), 0 8px 24px rgba(0,0,0,0.06);
  --font-sans: -apple-system, BlinkMacSystemFont, "Inter", "Noto Sans Thai", Roboto, sans-serif;
  --font-mono: ui-monospace, "SF Mono", "JetBrains Mono", "Menlo", "Consolas", monospace;
  font-family: var(--font-sans);
  background: var(--bg);
  border-radius: var(--radius-lg);
  padding: 24px;
  box-shadow: var(--shadow);
  border: 1px solid var(--border);
  display: grid;
  grid-template-columns: 1fr 360px;
  gap: 24px;
}
.octopus-qr[data-theme="dark"] {
  --bg: #18181b; --surface: #27272a; --surface-2: #1f1f22;
  --text-1: #fafafa; --text-2: #a1a1aa; --text-3: #52525b;
  --accent: #14c9df; --accent-2: #17a9bb;
  --accent-bg: rgba(20,201,223,.12); --accent-bg-strong: rgba(20,201,223,.22);
  --border: rgba(255,255,255,.08); --border-2: rgba(255,255,255,.16);
}
.octopus-qr * { box-sizing: border-box; }
.octopus-qr button { font-family: inherit; cursor: pointer; -webkit-tap-highlight-color: transparent; appearance: none; }

@media (max-width: 768px) {
  .octopus-qr { grid-template-columns: 1fr; padding: 16px; gap: 16px; }
}

/* ===== Mode tabs ===== */
.oqr-tabs {
  display: flex !important; gap: 6px; margin-bottom: 16px; flex-wrap: wrap;
  grid-column: 1 / -1;
}
.oqr-tabs button {
  font-size: 13px; font-weight: 500; padding: 8px 14px;
  border: 1px solid var(--border-2); border-radius: var(--radius-sm);
  background: transparent; color: var(--text-2);
  transition: all .12s ease;
}
.oqr-tabs button:hover { background: var(--surface); color: var(--text-1); }
.oqr-tabs button.is-active {
  background: var(--accent-bg); color: var(--accent); border-color: var(--accent);
}

/* ===== Left: input panel ===== */
.oqr-input-panel { min-width: 0; }
.oqr-form-row { margin-bottom: 14px; }
.oqr-form-row label {
  display: block; font-size: 12px; font-weight: 500; color: var(--text-2);
  margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.04em;
}
.oqr-form-row input[type="text"],
.oqr-form-row input[type="url"],
.oqr-form-row input[type="tel"],
.oqr-form-row input[type="email"],
.oqr-form-row input[type="number"],
.oqr-form-row textarea,
.oqr-form-row select {
  width: 100%;
  font-family: var(--font-sans);
  font-size: 14px;
  padding: 10px 12px;
  border: 1px solid var(--border-2);
  border-radius: var(--radius-sm);
  background: var(--bg);
  color: var(--text-1);
  outline: none;
  transition: border-color .12s;
}
.oqr-form-row textarea { min-height: 80px; resize: vertical; font-family: var(--font-mono); font-size: 13px; }
.oqr-form-row input:focus, .oqr-form-row textarea:focus, .oqr-form-row select:focus {
  border-color: var(--accent);
}
.oqr-form-grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }

/* Type-specific containers (hide all by default) */
.oqr-type-fields { display: none; }
.oqr-type-fields.is-active { display: block; }

/* Style controls */
.oqr-style-section {
  background: var(--surface);
  border-radius: var(--radius-md);
  padding: 14px 16px;
  margin-top: 16px;
}
.oqr-style-section h3 {
  font-size: 13px; font-weight: 600; margin: 0 0 10px;
  color: var(--text-1); text-transform: uppercase; letter-spacing: 0.04em;
}
.oqr-style-grid {
  display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px;
}
.oqr-style-btn {
  aspect-ratio: 1;
  border: 2px solid var(--border-2);
  border-radius: var(--radius-sm);
  background: #fff;
  padding: 8px;
  display: flex; align-items: center; justify-content: center;
  transition: border-color .12s;
}
.oqr-style-btn.is-active { border-color: var(--accent); }
.oqr-style-btn svg { width: 100%; height: 100%; }

.oqr-color-row {
  display: flex; align-items: center; gap: 10px;
  padding: 8px 0;
}
.oqr-color-row + .oqr-color-row { border-top: 1px solid var(--border); }
.oqr-color-row label { flex: 1; font-size: 12px; color: var(--text-2); margin: 0; }
.oqr-color-row input[type="color"] {
  width: 48px; height: 32px; padding: 2px;
  border: 1px solid var(--border-2); border-radius: var(--radius-sm);
  cursor: pointer; background: none;
}
.oqr-color-row .hex {
  font-family: var(--font-mono); font-size: 12px; color: var(--text-2);
  width: 80px;
}

.oqr-logo-drop {
  border: 2px dashed var(--border-2);
  border-radius: var(--radius-sm);
  padding: 16px;
  text-align: center;
  font-size: 12px; color: var(--text-2);
  cursor: pointer;
  transition: all .12s;
}
.oqr-logo-drop:hover { border-color: var(--accent); background: var(--accent-bg); }
.oqr-logo-drop.has-file { border-style: solid; border-color: var(--accent); color: var(--accent); }
.oqr-logo-drop input[type="file"] { display: none; }

/* ===== Right: preview panel ===== */
.oqr-preview-panel {
  background: var(--surface);
  border-radius: var(--radius-md);
  padding: 20px;
  display: flex; flex-direction: column;
  align-items: center;
  gap: 16px;
  position: sticky;
  top: 20px;
  align-self: start;
}
.oqr-preview-frame {
  width: 100%;
  aspect-ratio: 1;
  background: #fff;
  border-radius: var(--radius-sm);
  display: flex; align-items: center; justify-content: center;
  padding: 16px;
  border: 1px solid var(--border);
}
.oqr-preview-frame > * { max-width: 100%; max-height: 100%; }

.oqr-download-row {
  display: grid; grid-template-columns: 1fr 1fr; gap: 8px;
  width: 100%;
}
.oqr-download-row button {
  padding: 12px;
  border-radius: var(--radius-sm);
  font-size: 13px;
  font-weight: 600;
  border: none;
  background: linear-gradient(135deg, var(--accent-2), var(--accent));
  color: #fff;
  transition: filter .12s;
}
.oqr-download-row button:hover { filter: brightness(1.05); }
.oqr-download-row button.outline {
  background: transparent;
  color: var(--accent);
  border: 1px solid var(--accent);
}
.oqr-download-row button:disabled {
  background: var(--border-2); color: var(--text-3); cursor: not-allowed;
  filter: none;
}
.oqr-size-row {
  display: flex; gap: 8px; width: 100%;
  font-size: 12px; color: var(--text-2);
  align-items: center;
}
.oqr-size-row select {
  flex: 1; padding: 6px 8px;
  border: 1px solid var(--border-2); border-radius: var(--radius-sm);
  background: var(--bg); color: var(--text-1);
  font-size: 12px;
}

/* ===== Batch mode ===== */
.oqr-batch-panel { grid-column: 1 / -1; }
.oqr-batch-drop {
  border: 2px dashed var(--accent);
  border-radius: var(--radius-md);
  padding: 32px 20px;
  text-align: center;
  background: var(--accent-bg);
  cursor: pointer;
  transition: all .12s;
}
.oqr-batch-drop:hover, .oqr-batch-drop.is-dragover {
  background: var(--accent-bg-strong);
  border-color: var(--accent-2);
}
.oqr-batch-drop strong { display: block; font-size: 16px; color: var(--accent); margin-bottom: 6px; }
.oqr-batch-drop input[type="file"] { display: none; }
.oqr-batch-template {
  margin-top: 12px; font-size: 12px; color: var(--text-2);
}
.oqr-batch-template a { color: var(--accent); text-decoration: underline; }

.oqr-batch-results {
  margin-top: 16px;
  background: var(--surface);
  border-radius: var(--radius-md);
  padding: 16px;
  max-height: 360px;
  overflow-y: auto;
}
.oqr-batch-row {
  display: grid;
  grid-template-columns: 60px 1fr auto;
  gap: 12px; align-items: center;
  padding: 8px 0;
}
.oqr-batch-row + .oqr-batch-row { border-top: 1px solid var(--border); }
.oqr-batch-row .qr-thumb {
  width: 60px; height: 60px; background: #fff;
  border-radius: 4px; padding: 4px;
  border: 1px solid var(--border);
}
.oqr-batch-row .qr-thumb svg, .oqr-batch-row .qr-thumb canvas { width: 100%; height: 100%; }
.oqr-batch-row .qr-info { font-size: 13px; min-width: 0; }
.oqr-batch-row .qr-label { font-weight: 500; color: var(--text-1); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.oqr-batch-row .qr-data { font-family: var(--font-mono); font-size: 11px; color: var(--text-3); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-top: 2px; }
.oqr-batch-action button { font-size: 11px; padding: 5px 10px; border: 1px solid var(--accent); color: var(--accent); background: transparent; border-radius: 4px; }

.oqr-batch-bar {
  display: flex; gap: 8px; margin-top: 16px; flex-wrap: wrap;
}
.oqr-batch-bar button {
  flex: 1;
  padding: 12px;
  border-radius: var(--radius-sm);
  font-size: 13px; font-weight: 600;
  border: none;
  background: linear-gradient(135deg, var(--accent-2), var(--accent));
  color: #fff;
  min-width: 140px;
}
.oqr-batch-bar button:disabled { background: var(--border-2); color: var(--text-3); }

/* ===== Hint ===== */
/* Mobile overflow fixes */
.oc-qr-page { overflow-x: hidden; }
.octopus-qr { min-width: 0; max-width: 100%; }
.oqr-input-panel { min-width: 0; max-width: 100%; }
.oqr-preview-panel { min-width: 0; max-width: 100%; }
.oqr-batch-panel { min-width: 0; max-width: 100%; }
.octopus-qr select,
.octopus-qr input[type="text"],
.octopus-qr input[type="url"],
.octopus-qr input[type="tel"],
.octopus-qr input[type="email"],
.octopus-qr input[type="number"],
.octopus-qr textarea {
  max-width: 100%;
  min-width: 0;
}
@media (max-width: 768px) {
  .oc-qr-page { padding: 16px 12px 40px; }
  .oc-qr-page h1 { font-size: 1.4em; }
  .octopus-qr { padding: 14px; gap: 14px; }
  .oqr-tabs button { padding: 7px 10px; font-size: 12px; }
  .oqr-form-row label { font-size: 11px; }
  .oqr-form-row input, .oqr-form-row textarea, .oqr-form-row select {
    font-size: 16px !important; /* iOS zoom prevention */
    padding: 9px 10px;
  }
  .oqr-form-grid-2 { grid-template-columns: 1fr !important; gap: 8px !important; }
  .oqr-style-section { padding: 12px; }
  .oqr-style-section h3 { font-size: 12px; }
  .oqr-style-grid { grid-template-columns: repeat(3, 1fr); gap: 6px; }
  .oqr-style-btn { padding: 6px; }
  .oqr-color-row label { font-size: 11px; }
  .oqr-color-row .hex { font-size: 11px; width: auto; }
  .oqr-color-row input[type="color"] { width: 40px; height: 28px; }
  .oqr-preview-panel {
    position: static !important;
    padding: 14px;
  }
  .oqr-preview-frame { padding: 10px; }
  .oqr-download-row { grid-template-columns: 1fr 1fr; gap: 6px; }
  .oqr-download-row button { padding: 10px; font-size: 12px; }
  .oqr-batch-drop { padding: 24px 14px; }
  .oqr-batch-drop strong { font-size: 14px; }
  .oqr-batch-bar { flex-direction: column; gap: 6px; }
  .oqr-batch-bar button { font-size: 12px; padding: 10px; }
  .oqr-batch-row { grid-template-columns: 50px 1fr auto; gap: 8px; }
  .oqr-batch-row .qr-thumb { width: 50px; height: 50px; }
  .oqr-batch-row .qr-info { font-size: 12px; }
  .oqr-batch-row .qr-data { font-size: 10px; }
}
@media (max-width: 480px) {
  .oqr-style-grid { grid-template-columns: repeat(3, 1fr); }
  .oqr-batch-template { font-size: 11px; }
}

.oqr-hint {
  font-size: 11px; color: var(--text-3);
  text-align: center; margin-top: 16px;
  font-family: var(--font-mono);
}
</style>

<div class="oc-qr-page">

  <h1>สร้าง <span class="grad">QR Code</span> ออนไลน์ฟรี</h1>
  <p class="lead">
    QR Code คุณภาพพิมพ์ — ดาวน์โหลด SVG (vector) และ PNG ความละเอียดสูง · 
    6 สไตล์ พร้อมใส่ logo และเลือกสีได้ · 
    Batch upload จาก CSV/Excel สร้าง QR ทีละหลายอันพร้อม ZIP download
  </p>

  <div class="octopus-qr" id="oqr-root">
    <div class="oqr-tabs" id="oqr-tabs">
      <button class="is-active" data-mode="single">สร้างทีละอัน</button>
      <button data-mode="batch">Batch (CSV/Excel)</button>
    </div>

    <!-- ───── SINGLE MODE ───── -->
    <div class="oqr-input-panel" id="oqr-single-input">

      <div class="oqr-form-row">
        <label for="oqr-type">ประเภทข้อมูล</label>
        <select id="oqr-type">
          <option value="url">URL / ลิงก์เว็บ</option>
          <option value="text">ข้อความทั่วไป</option>
          <option value="tel">เบอร์โทร</option>
          <option value="sms">SMS</option>
          <option value="email">อีเมล</option>
          <option value="wifi">WiFi</option>
          <option value="vcard">นามบัตร (vCard)</option>
          <option value="line">LINE ID</option>
          <option value="promptpay">PromptPay</option>
        </select>
      </div>

      <!-- URL -->
      <div class="oqr-type-fields is-active" data-type="url">
        <div class="oqr-form-row">
          <label>URL</label>
          <input type="url" id="oqr-url" placeholder="https://www.octopus.co.th" value="https://www.octopus.co.th">
        </div>
      </div>

      <!-- Text -->
      <div class="oqr-type-fields" data-type="text">
        <div class="oqr-form-row">
          <label>ข้อความ</label>
          <textarea id="oqr-text" placeholder="พิมพ์ข้อความที่ต้องการ"></textarea>
        </div>
      </div>

      <!-- Tel -->
      <div class="oqr-type-fields" data-type="tel">
        <div class="oqr-form-row">
          <label>เบอร์โทร</label>
          <input type="tel" id="oqr-tel" placeholder="0812345678">
        </div>
      </div>

      <!-- SMS -->
      <div class="oqr-type-fields" data-type="sms">
        <div class="oqr-form-grid-2">
          <div class="oqr-form-row">
            <label>เบอร์โทร</label>
            <input type="tel" id="oqr-sms-num" placeholder="0812345678">
          </div>
          <div class="oqr-form-row">
            <label>ข้อความ</label>
            <input type="text" id="oqr-sms-msg" placeholder="ข้อความ">
          </div>
        </div>
      </div>

      <!-- Email -->
      <div class="oqr-type-fields" data-type="email">
        <div class="oqr-form-row">
          <label>อีเมล</label>
          <input type="email" id="oqr-email-to" placeholder="hello@octopus.co.th">
        </div>
        <div class="oqr-form-grid-2">
          <div class="oqr-form-row">
            <label>หัวข้อ</label>
            <input type="text" id="oqr-email-subj" placeholder="หัวข้อเมล">
          </div>
          <div class="oqr-form-row">
            <label>ข้อความ</label>
            <input type="text" id="oqr-email-body" placeholder="เนื้อหา">
          </div>
        </div>
      </div>

      <!-- WiFi -->
      <div class="oqr-type-fields" data-type="wifi">
        <div class="oqr-form-grid-2">
          <div class="oqr-form-row">
            <label>SSID</label>
            <input type="text" id="oqr-wifi-ssid" placeholder="ชื่อ WiFi">
          </div>
          <div class="oqr-form-row">
            <label>Encryption</label>
            <select id="oqr-wifi-enc"><option>WPA</option><option>WEP</option><option value="">nopass</option></select>
          </div>
        </div>
        <div class="oqr-form-row">
          <label>รหัสผ่าน</label>
          <input type="text" id="oqr-wifi-pwd" placeholder="password">
        </div>
      </div>

      <!-- vCard -->
      <div class="oqr-type-fields" data-type="vcard">
        <div class="oqr-form-grid-2">
          <div class="oqr-form-row"><label>ชื่อ</label><input type="text" id="oqr-vc-fname" placeholder="ชื่อ"></div>
          <div class="oqr-form-row"><label>นามสกุล</label><input type="text" id="oqr-vc-lname" placeholder="นามสกุล"></div>
        </div>
        <div class="oqr-form-grid-2">
          <div class="oqr-form-row"><label>บริษัท</label><input type="text" id="oqr-vc-org" placeholder="Octopus Media Solutions"></div>
          <div class="oqr-form-row"><label>ตำแหน่ง</label><input type="text" id="oqr-vc-title" placeholder="Position"></div>
        </div>
        <div class="oqr-form-grid-2">
          <div class="oqr-form-row"><label>เบอร์โทร</label><input type="tel" id="oqr-vc-tel" placeholder="0812345678"></div>
          <div class="oqr-form-row"><label>อีเมล</label><input type="email" id="oqr-vc-email" placeholder="email"></div>
        </div>
        <div class="oqr-form-row"><label>เว็บไซต์</label><input type="url" id="oqr-vc-url" placeholder="https://..."></div>
      </div>

      <!-- LINE -->
      <div class="oqr-type-fields" data-type="line">
        <div class="oqr-form-row">
          <label>LINE ID หรือ URL</label>
          <input type="text" id="oqr-line" placeholder="@octopusdesign หรือ https://lin.ee/...">
        </div>
      </div>

      <!-- PromptPay -->
      <div class="oqr-type-fields" data-type="promptpay">
        <div class="oqr-form-grid-2">
          <div class="oqr-form-row">
            <label>เบอร์ / เลขบัตร / e-Wallet ID</label>
            <input type="text" id="oqr-pp-id" placeholder="0812345678">
          </div>
          <div class="oqr-form-row">
            <label>จำนวนเงิน (บาท, ถ้ามี)</label>
            <input type="number" id="oqr-pp-amt" placeholder="0.00" step="0.01">
          </div>
        </div>
      </div>

      <!-- Style controls -->
      <div class="oqr-style-section">
        <h3>สไตล์ Module</h3>
        <div class="oqr-style-grid" id="oqr-style-modules">
