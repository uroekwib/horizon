          <button class="oqr-style-btn" data-style="extra-rounded" title="Extra rounded"><svg viewBox="0 0 30 30"><g fill="#17a9bb"><circle cx="5" cy="5" r="3.5"/><circle cx="14" cy="5" r="3.5"/><circle cx="23" cy="5" r="3.5"/><circle cx="5" cy="14" r="3.5"/><circle cx="23" cy="14" r="3.5"/><circle cx="5" cy="23" r="3.5"/><circle cx="14" cy="23" r="3.5"/><circle cx="23" cy="23" r="3.5"/></g></svg></button>
