                }
              },
              "block_order": [
                "text_abjKQL"
              ]
            },
            "accordion_row_CmXqHC": {
              "type": "_accordion-row",
              "name": "t:names.accordion_row",
              "settings": {
                "heading": "ป้ายไฟกับป้ายไม่มีไฟต่างกันอย่างไร?",
                "open_by_default": false,
                "icon": "none",
                "width": 20
              },
              "blocks": {
                "text_VmUk9k": {
                  "type": "text",
                  "name": "t:names.text",
                  "settings": {
                    "text": "<p>ป้ายไม่มีไฟ (Non-illuminated Sign) อาศัยแสงธรรมชาติหรือแสงภายนอกในการมองเห็น เหมาะกับสถานที่ที่มีแสงสว่างเพียงพอตลอดเวลาและไม่ต้องการความโดดเด่นในเวลากลางคืน ส่วน<strong>ป้ายไฟ LED</strong>มีระบบให้แสงสว่างจากภายใน ทำให้มองเห็นได้ทั้งกลางวันและกลางคืน เพิ่มความโดดเด่นได้อย่างมาก เหมาะกับร้านค้า โชว์รูม อาคารพาณิชย์ หรือสถานที่ที่เปิดให้บริการตอนกลางคืน โดยทั่วไปป้ายไฟมีค่าใช้จ่ายสูงกว่า 2–5 เท่า แต่คุ้มค่าในแง่ visibility</p>",
                    "width": "100%",
                    "max_width": "normal",
                    "alignment": "left",
                    "type_preset": "rte",
