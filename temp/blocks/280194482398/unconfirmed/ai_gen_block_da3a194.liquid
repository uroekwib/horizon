{% doc %}
  @prompt
    Create a Shopify section with two rows of pill navigation links. Row 1: parent collection pills. Row 2: child collection pills from custom.subcollections metafield of the active parent. Each pill is an <a> tag linking to that collection's URL. Active state: pill whose handle matches collection.handle. Style: active pill background: linear-gradient(135deg, #14c9df, #17a9bb) white text, inactive background: rgba(0,0,0,0.06). Schema blocks each have a collection picker. No JavaScript needed., Below the pill navigation, add a card grid showing subcollections. If current page is a parent collection, show cards from collection.metafields.custom.subcollections.value. If current page is a child collection, show its products or a back link. Card: featured image 4:3, title, links to collection URL. CSS Grid 2 col mobile, 3 col desktop. Border-radius 16px, box-shadow subtle.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-subcollection-grid-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-subcollection-grid__container-{{ ai_gen_id }} {
    padding: {{ block.settings.vertical_padding }}px {{ block.settings.horizontal_padding }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-subcollection-grid__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  @media screen and (min-width: 750px) {
    .ai-subcollection-grid__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .ai-subcollection-grid__card-{{ ai_gen_id }} {
    display: block;
    text-decoration: none;
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    background-color: {{ block.settings.card_background }};
    box-shadow: {{ block.settings.shadow_horizontal }}px {{ block.settings.shadow_vertical }}px {{ block.settings.shadow_blur }}px rgba(0, 0, 0, {{ block.settings.shadow_opacity }});
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-subcollection-grid__card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: {{ block.settings.shadow_horizontal }}px {{ block.settings.shadow_vertical | plus: 4 }}px {{ block.settings.shadow_blur | plus: 8 }}px rgba(0, 0, 0, {{ block.settings.shadow_opacity | times: 1.5 }});
  }

  .ai-subcollection-grid__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 75%;
    overflow: hidden;
    background-color: #f5f5f5;
  }

  .ai-subcollection-grid__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-subcollection-grid__placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f5f5f5;
  }

  .ai-subcollection-grid__placeholder-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
    opacity: 0.3;
  }

  .ai-subcollection-grid__content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
  }

  .ai-subcollection-grid__title-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.title_font_size }}px;
    font-weight: {{ block.settings.title_font_weight }};
    color: {{ block.settings.title_color }};
    line-height: 1.3;
  }

  .ai-subcollection-grid__back-link-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: {{ block.settings.pill_padding_vertical }}px {{ block.settings.pill_padding_horizontal }}px;
    background-color: rgba(0, 0, 0, 0.06);
    color: {{ block.settings.back_link_color }};
    text-decoration: none;
    border-radius: {{ block.settings.back_link_radius }}px;
    font-size: {{ block.settings.back_link_font_size }}px;
    font-weight: 500;
    transition: background-color 0.2s ease;
    margin-bottom: {{ block.settings.grid_gap }}px;
  }

  .ai-subcollection-grid__back-link-{{ ai_gen_id }}:hover {
    background-color: rgba(0, 0, 0, 0.1);
  }

  .ai-subcollection-grid__back-icon-{{ ai_gen_id }} {
    width: 16px;
    height: 16px;
  }

  @media screen and (max-width: 749px) {
    .ai-subcollection-grid__container-{{ ai_gen_id }} {
      padding: {{ block.settings.vertical_padding | times: 0.7 }}px {{ block.settings.horizontal_padding | times: 0.7 }}px;
    }

    .ai-subcollection-grid__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-subcollection-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-subcollection-grid__container-{{ ai_gen_id }}">
    {% assign is_parent = false %}
    {% assign parent_collection = null %}
    {% assign subcollections = collection.metafields.custom.subcollections.value %}

    {% if subcollections != blank and subcollections.size > 0 %}
      {% assign is_parent = true %}
    {% else %}
      {% for i in (1..10) %}
        {% assign collection_key = 'parent_collection_' | append: i %}
        {% assign parent_coll = block.settings[collection_key] %}
        
        {% if parent_coll != blank %}
          {% assign parent_subcollections = parent_coll.metafields.custom.subcollections.value %}
          {% if parent_subcollections != blank %}
            {% for subcoll in parent_subcollections %}
              {% if subcoll.handle == collection.handle %}
                {% assign parent_collection = parent_coll %}
                {% break %}
              {% endif %}
            {% endfor %}
          {% endif %}
        {% endif %}
        
        {% if parent_collection %}
          {% break %}
        {% endif %}
      {% endfor %}
    {% endif %}

    {% if is_parent %}
      <div class="ai-subcollection-grid__grid-{{ ai_gen_id }}">
        {% for subcollection in subcollections %}
          <a href="{{ subcollection.url }}" class="ai-subcollection-grid__card-{{ ai_gen_id }}">
            <div class="ai-subcollection-grid__image-wrapper-{{ ai_gen_id }}">
              {% if subcollection.featured_image %}
                <img
                  src="{{ subcollection.featured_image | image_url: width: 600 }}"
                  alt="{{ subcollection.featured_image.alt | escape }}"
                  class="ai-subcollection-grid__image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="600"
                  height="450"
                >
              {% else %}
                <div class="ai-subcollection-grid__placeholder-{{ ai_gen_id }}">
                  {{ 'collection-1' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>
            <div class="ai-subcollection-grid__content-{{ ai_gen_id }}">
              <h3 class="ai-subcollection-grid__title-{{ ai_gen_id }}">{{ subcollection.title }}</h3>
            </div>
          </a>
        {% endfor %}
      </div>
    {% elsif parent_collection %}
      {% if block.settings.show_back_link %}
        <a href="{{ parent_collection.url }}" class="ai-subcollection-grid__back-link-{{ ai_gen_id }}">
          <svg class="ai-subcollection-grid__back-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
          {{ block.settings.back_link_text }}
        </a>
      {% endif %}

      {% if block.settings.show_products %}
        <div class="ai-subcollection-grid__grid-{{ ai_gen_id }}">
          {% for product in collection.products limit: block.settings.products_limit %}
            <a href="{{ product.url }}" class="ai-subcollection-grid__card-{{ ai_gen_id }}">
              <div class="ai-subcollection-grid__image-wrapper-{{ ai_gen_id }}">
                {% if product.featured_image %}
                  <img
                    src="{{ product.featured_image | image_url: width: 600 }}"
                    alt="{{ product.featured_image.alt | escape }}"
                    class="ai-subcollection-grid__image-{{ ai_gen_id }}"
                    loading="lazy"
                    width="600"
                    height="450"
                  >
                {% else %}
                  <div class="ai-subcollection-grid__placeholder-{{ ai_gen_id }}">
                    {{ 'product-1' | placeholder_svg_tag }}
                  </div>
                {% endif %}
              </div>
              <div class="ai-subcollection-grid__content-{{ ai_gen_id }}">
                <h3 class="ai-subcollection-grid__title-{{ ai_gen_id }}">{{ product.title }}</h3>
              </div>
            </a>
          {% endfor %}
        </div>
      {% endif %}
    {% endif %}
  </div>
</div>

