{% doc %}
  @prompt
    อยากได้ section โชว์ product card ที่ filter มาจาก collection/subcollection
    
    เราจะโชว์ collection pill 8-10 อัน พอกดให้ active ก็จะโชว์ subcillection pils ออกมาเพิ่มเติม ให้กดเพื่อเลือก filter และแสดงแต่ product cards ที่อยู่ภายใต้หมวดนั้น ๆ ออกมา โดยเป็นการโหลดหน้า url ของ collection หรือ subcollection นั้น ๆ ออกมา, subcoll เตรียมไว้แล้ว เป็น list Metafields ชื่อ subcollections
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-collection-filter-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-collection-filter__container-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .ai-collection-filter__heading-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.text_color }};
  }

  .ai-collection-filter__pills-wrapper-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-collection-filter__pills-container-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .ai-collection-filter__pill-{{ ai_gen_id }} {
    padding: 10px 20px;
    background-color: {{ block.settings.pill_background }};
    color: {{ block.settings.pill_text_color }};
    border: {{ block.settings.pill_border_width }}px solid {{ block.settings.pill_border_color }};
    border-radius: {{ block.settings.pill_border_radius }}px;
    cursor: pointer;
    transition: all 0.3s ease;
    text-decoration: none;
    display: inline-block;
    font-size: {{ block.settings.pill_font_size }}px;
  }

  .ai-collection-filter__pill-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.pill_hover_background }};
    color: {{ block.settings.pill_hover_text_color }};
    border-color: {{ block.settings.pill_hover_border_color }};
  }

  .ai-collection-filter__pill-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.pill_active_background }};
    color: {{ block.settings.pill_active_text_color }};
    border-color: {{ block.settings.pill_active_border_color }};
  }

  .ai-collection-filter__subcollections-{{ ai_gen_id }} {
    display: none;
    padding-left: 16px;
  }

  .ai-collection-filter__subcollections-{{ ai_gen_id }}.visible {
    display: block;
  }

  .ai-collection-filter__products-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.products_per_row }}, 1fr);
    gap: {{ block.settings.product_gap }}px;
    margin-top: 24px;
  }

  @media screen and (max-width: 749px) {
    .ai-collection-filter__products-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.products_per_row_mobile }}, 1fr);
    }
  }

  .ai-collection-filter__product-card-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
    text-decoration: none;
    color: inherit;
  }

  .ai-collection-filter__product-image-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: {{ block.settings.product_image_radius }}px;
  }

  .ai-collection-filter__product-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_title_size }}px;
    margin: 0;
    color: {{ block.settings.text_color }};
  }

  .ai-collection-filter__product-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_price_size }}px;
    color: {{ block.settings.price_color }};
  }

  .ai-collection-filter__loading-{{ ai_gen_id }} {
    text-align: center;
    padding: 40px;
    color: {{ block.settings.text_color }};
  }

  .ai-collection-filter__empty-{{ ai_gen_id }} {
    text-align: center;
    padding: 40px;
    color: {{ block.settings.text_color }};
  }
{% endstyle %}

<collection-filter-{{ ai_gen_id }}
  class="ai-collection-filter-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-collection-filter__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-collection-filter__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    <div class="ai-collection-filter__pills-wrapper-{{ ai_gen_id }}">
      <div class="ai-collection-filter__pills-container-{{ ai_gen_id }}">
        {% for i in (1..10) %}
          {% liquid
            assign collection_key = 'collection_' | append: i
            assign collection = block.settings[collection_key]
          %}

          {% if collection != blank %}
            <a
              href="{{ collection.url }}"
              class="ai-collection-filter__pill-{{ ai_gen_id }}"
              data-collection-id="{{ collection.id }}"
              data-collection-handle="{{ collection.handle }}"
            >
              {{ collection.title }}
            </a>

            {% if collection.metafields.custom.subcollections.value != blank %}
              <div
                class="ai-collection-filter__subcollections-{{ ai_gen_id }}"
                data-parent-collection="{{ collection.id }}"
              >
                <div class="ai-collection-filter__pills-container-{{ ai_gen_id }}">
                  {% for subcollection in collection.metafields.custom.subcollections.value %}
                    <a
                      href="{{ subcollection.url }}"
                      class="ai-collection-filter__pill-{{ ai_gen_id }}"
                      data-collection-id="{{ subcollection.id }}"
                      data-collection-handle="{{ subcollection.handle }}"
                    >
                      {{ subcollection.title }}
                    </a>
                  {% endfor %}
                </div>
              </div>
            {% endif %}
          {% endif %}
        {% endfor %}
      </div>
    </div>

    <div
      class="ai-collection-filter__products-{{ ai_gen_id }}"
      id="ai-collection-products-{{ ai_gen_id }}"
    >
      <div class="ai-collection-filter__loading-{{ ai_gen_id }}">
        กรุณาเลือก collection เพื่อแสดงสินค้า
      </div>
    </div>
  </div>
</collection-filter-{{ ai_gen_id }}>

<script>
  (function() {
    class CollectionFilter{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.pills = this.querySelectorAll('.ai-collection-filter__pill-{{ ai_gen_id }}');
        this.productsContainer = this.querySelector('#ai-collection-products-{{ ai_gen_id }}');
        this.activeCollectionId = null;
      }

      connectedCallback() {
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.pills.forEach((pill) => {
          pill.addEventListener('click', (e) => {
            e.preventDefault();
            const collectionId = pill.getAttribute('data-collection-id');
            const collectionHandle = pill.getAttribute('data-collection-handle');
            const parentCollection = pill.closest('.ai-collection-filter__subcollections-{{ ai_gen_id }}');

            if (parentCollection) {
              this.loadCollection(collectionHandle);
            } else {
              const subcollections = this.querySelector(
                `.ai-collection-filter__subcollections-{{ ai_gen_id }}[data-parent-collection="${collectionId}"]`
              );

              this.querySelectorAll('.ai-collection-filter__subcollections-{{ ai_gen_id }}').forEach((sub) => {
                if (sub !== subcollections) {
                  sub.classList.remove('visible');
                }
              });

              this.pills.forEach((p) => {
                if (!p.closest('.ai-collection-filter__subcollections-{{ ai_gen_id }}')) {
                  p.classList.remove('active');
                }
              });

              pill.classList.add('active');

              if (subcollections) {
                subcollections.classList.toggle('visible');
              }

              this.loadCollection(collectionHandle);
            }
          });
        });
      }

      async loadCollection(handle) {
        this.productsContainer.innerHTML = '<div class="ai-collection-filter__loading-{{ ai_gen_id }}">กำลังโหลด...</div>';

        try {
          const response = await fetch(`/collections/${handle}?view=json`);
          
          if (!response.ok) {
            const fallbackResponse = await fetch(`/collections/${handle}`);
            const html = await fallbackResponse.text();
            const parser = new DOMParser();
            const doc = parser.parseFromString(html, 'text/html');
            const products = doc.querySelectorAll('.product-card, [data-product-id]');
            
            if (products.length === 0) {
              this.productsContainer.innerHTML = '<div class="ai-collection-filter__empty-{{ ai_gen_id }}">ไม่พบสินค้าใน collection นี้</div>';
              return;
            }

            this.renderProductsFromHTML(products);
            return;
          }

          const data = await response.json();
          this.renderProducts(data.products);
        } catch (error) {
          console.error('Error loading collection:', error);
          this.productsContainer.innerHTML = '<div class="ai-collection-filter__empty-{{ ai_gen_id }}">เกิดข้อผิดพลาดในการโหลดสินค้า</div>';
        }
      }

      renderProducts(products) {
        if (!products || products.length === 0) {
          this.productsContainer.innerHTML = '<div class="ai-collection-filter__empty-{{ ai_gen_id }}">ไม่พบสินค้าใน collection นี้</div>';
          return;
        }

        const productsHTML = products.map((product) => {
          const image = product.featured_image || product.images[0];
          const price = this.formatMoney(product.price);
          
          return `
            <a href="${product.url}" class="ai-collection-filter__product-card-{{ ai_gen_id }}">
              <img
                src="${image}"
                alt="${product.title}"
                class="ai-collection-filter__product-image-{{ ai_gen_id }}"
                loading="lazy"
              >
              <h3 class="ai-collection-filter__product-title-{{ ai_gen_id }}">${product.title}</h3>
              <div class="ai-collection-filter__product-price-{{ ai_gen_id }}">${price}</div>
            </a>
          `;
        }).join('');

        this.productsContainer.innerHTML = productsHTML;
      }

      renderProductsFromHTML(productElements) {
        const productsHTML = Array.from(productElements).slice(0, {{ block.settings.products_limit }}).map((el) => {
          const link = el.querySelector('a') || el;
          const img = el.querySelector('img');
          const title = el.querySelector('.product-card__title, .product-title, h3, h2');
          const price = el.querySelector('.price, .product-price');

          return `
            <a href="${link.href}" class="ai-collection-filter__product-card-{{ ai_gen_id }}">
              <img
                src="${img ? img.src : ''}"
                alt="${title ? title.textContent.trim() : ''}"
                class="ai-collection-filter__product-image-{{ ai_gen_id }}"
                loading="lazy"
              >
              <h3 class="ai-collection-filter__product-title-{{ ai_gen_id }}">${title ? title.textContent.trim() : ''}</h3>
              <div class="ai-collection-filter__product-price-{{ ai_gen_id }}">${price ? price.textContent.trim() : ''}</div>
            </a>
          `;
        }).join('');

        this.productsContainer.innerHTML = productsHTML;
      }

      formatMoney(cents) {
        const amount = cents / 100;
        return new Intl.NumberFormat('th-TH', {
          style: 'currency',
          currency: 'THB'
        }).format(amount);
      }
    }

    customElements.define('collection-filter-{{ ai_gen_id }}', CollectionFilter{{ ai_gen_id }});
  })();
</script>

