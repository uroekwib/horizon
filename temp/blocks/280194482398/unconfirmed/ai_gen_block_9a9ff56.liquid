{% doc %}
  @prompt
    อยากได้ section โชว์ product card ที่ filter มาจาก collection/subcollection
    
    เราจะโชว์ collection pill 8-10 อัน พอกดให้ active ก็จะโชว์ subcillection pils ออกมาเพิ่มเติม ให้กดเพื่อเลือก filter และแสดงแต่ product cards ที่อยู่ภายใต้หมวดนั้น ๆ ออกมา โดยเป็นการโหลดหน้า url ของ collection หรือ subcollection นั้น ๆ ออกมา, subcoll เตรียมไว้แล้ว เป็น list Metafields ชื่อ subcollections, พอเรากดเลือก  Collection ก็จะเปลี่ยน url เลย แล้วก็มี subcoll โชว์ และกดก็เปลี่ยน url ไปต่อ
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-collection-filter-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-collection-filter__container-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .ai-collection-filter__heading-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.text_color }};
  }

  .ai-collection-filter__pills-wrapper-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-collection-filter__pills-container-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .ai-collection-filter__pill-{{ ai_gen_id }} {
    padding: 10px 20px;
    background-color: {{ block.settings.pill_background }};
    color: {{ block.settings.pill_text_color }};
    border: {{ block.settings.pill_border_width }}px solid {{ block.settings.pill_border_color }};
    border-radius: {{ block.settings.pill_border_radius }}px;
    cursor: pointer;
    transition: all 0.3s ease;
    text-decoration: none;
    display: inline-block;
    font-size: {{ block.settings.pill_font_size }}px;
  }

  .ai-collection-filter__pill-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.pill_hover_background }};
    color: {{ block.settings.pill_hover_text_color }};
    border-color: {{ block.settings.pill_hover_border_color }};
  }

  .ai-collection-filter__pill-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.pill_active_background }};
    color: {{ block.settings.pill_active_text_color }};
    border-color: {{ block.settings.pill_active_border_color }};
  }

  .ai-collection-filter__subcollections-{{ ai_gen_id }} {
    display: none;
    padding-left: 16px;
  }

  .ai-collection-filter__subcollections-{{ ai_gen_id }}.visible {
    display: block;
  }
{% endstyle %}

<collection-filter-{{ ai_gen_id }}
  class="ai-collection-filter-{{ ai_gen_id }}"
  data-current-handle="{{ collection.handle }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-collection-filter__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-collection-filter__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    <div class="ai-collection-filter__pills-wrapper-{{ ai_gen_id }}">
      <div class="ai-collection-filter__pills-container-{{ ai_gen_id }}">
        {% for i in (1..10) %}
          {% liquid
            assign collection_key = 'collection_' | append: i
            assign selected_collection = block.settings[collection_key]
          %}

          {% if selected_collection != blank %}
            {% assign is_active = false %}
            {% if collection.handle == selected_collection.handle %}
              {% assign is_active = true %}
            {% endif %}

            {% assign has_active_subcollection = false %}
            {% if selected_collection.metafields.custom.subcollections.value != blank %}
              {% for subcollection in selected_collection.metafields.custom.subcollections.value %}
                {% if collection.handle == subcollection.handle %}
                  {% assign has_active_subcollection = true %}
                  {% assign is_active = true %}
                  {% break %}
                {% endif %}
              {% endfor %}
            {% endif %}

            <a
              href="{{ selected_collection.url }}"
              class="ai-collection-filter__pill-{{ ai_gen_id }} {% if is_active %}active{% endif %}"
              data-collection-id="{{ selected_collection.id }}"
              data-has-subcollections="{% if selected_collection.metafields.custom.subcollections.value != blank %}true{% else %}false{% endif %}"
            >
              {{ selected_collection.title }}
            </a>

            {% if selected_collection.metafields.custom.subcollections.value != blank %}
              <div
                class="ai-collection-filter__subcollections-{{ ai_gen_id }} {% if is_active %}visible{% endif %}"
                data-parent-collection="{{ selected_collection.id }}"
              >
                <div class="ai-collection-filter__pills-container-{{ ai_gen_id }}">
                  {% for subcollection in selected_collection.metafields.custom.subcollections.value %}
                    {% assign is_subcollection_active = false %}
                    {% if collection.handle == subcollection.handle %}
                      {% assign is_subcollection_active = true %}
                    {% endif %}

                    <a
                      href="{{ subcollection.url }}"
                      class="ai-collection-filter__pill-{{ ai_gen_id }} {% if is_subcollection_active %}active{% endif %}"
                      data-collection-id="{{ subcollection.id }}"
                    >
                      {{ subcollection.title }}
                    </a>
                  {% endfor %}
                </div>
              </div>
            {% endif %}
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</collection-filter-{{ ai_gen_id }}>

<script>
  (function() {
    class CollectionFilter{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.pills = this.querySelectorAll('.ai-collection-filter__pill-{{ ai_gen_id }}');
      }

      connectedCallback() {
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.pills.forEach((pill) => {
          pill.addEventListener('click', (e) => {
            const hasSubcollections = pill.getAttribute('data-has-subcollections') === 'true';
            const isParentPill = !pill.closest('.ai-collection-filter__subcollections-{{ ai_gen_id }}');

            if (hasSubcollections && isParentPill) {
              e.preventDefault();
              
              const collectionId = pill.getAttribute('data-collection-id');
              const subcollections = this.querySelector(
                `.ai-collection-filter__subcollections-{{ ai_gen_id }}[data-parent-collection="${collectionId}"]`
              );

              this.querySelectorAll('.ai-collection-filter__subcollections-{{ ai_gen_id }}').forEach((sub) => {
                if (sub !== subcollections) {
                  sub.classList.remove('visible');
                }
              });

              this.pills.forEach((p) => {
                if (!p.closest('.ai-collection-filter__subcollections-{{ ai_gen_id }}')) {
                  p.classList.remove('active');
                }
              });

              pill.classList.add('active');

              if (subcollections) {
                const isVisible = subcollections.classList.contains('visible');
                subcollections.classList.toggle('visible');
                
                if (!isVisible) {
                  return;
                }
              }

              window.location.href = pill.href;
            }
          });
        });
      }
    }

    customElements.define('collection-filter-{{ ai_gen_id }}', CollectionFilter{{ ai_gen_id }});
  })();
</script>

