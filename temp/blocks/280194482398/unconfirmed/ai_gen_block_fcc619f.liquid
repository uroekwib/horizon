{% doc %}
  @prompt
    Create a Shopify section with two rows of pill navigation links. Row 1: parent collection pills. Row 2: child collection pills from custom.subcollections metafield of the active parent. Each pill is an <a> tag linking to that collection's URL. Active state: pill whose handle matches collection.handle. Style: active pill background: linear-gradient(135deg, #14c9df, #17a9bb) white text, inactive background: rgba(0,0,0,0.06). Schema blocks each have a collection picker. No JavaScript needed.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-collection-nav-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-collection-nav__container-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.row_gap }}px;
    padding: {{ block.settings.vertical_padding }}px {{ block.settings.horizontal_padding }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-collection-nav__row-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: {{ block.settings.pill_gap }}px;
  }

  .ai-collection-nav__pill-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.pill_padding_vertical }}px {{ block.settings.pill_padding_horizontal }}px;
    border-radius: {{ block.settings.pill_border_radius }}px;
    text-decoration: none;
    font-size: {{ block.settings.font_size }}px;
    font-weight: {{ block.settings.font_weight }};
    transition: all 0.2s ease;
    white-space: nowrap;
  }

  .ai-collection-nav__pill-{{ ai_gen_id }}--inactive {
    background-color: rgba(0, 0, 0, 0.06);
    color: {{ block.settings.inactive_text_color }};
  }

  .ai-collection-nav__pill-{{ ai_gen_id }}--inactive:hover {
    background-color: rgba(0, 0, 0, 0.1);
  }

  .ai-collection-nav__pill-{{ ai_gen_id }}--active {
    background: linear-gradient(135deg, #14c9df, #17a9bb);
    color: #ffffff;
  }

  @media screen and (max-width: 749px) {
    .ai-collection-nav__container-{{ ai_gen_id }} {
      padding: {{ block.settings.vertical_padding | times: 0.7 }}px {{ block.settings.horizontal_padding | times: 0.7 }}px;
    }

    .ai-collection-nav__pill-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.9 }}px;
      padding: {{ block.settings.pill_padding_vertical | times: 0.8 }}px {{ block.settings.pill_padding_horizontal | times: 0.8 }}px;
    }
  }
{% endstyle %}

<div class="ai-collection-nav-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-collection-nav__container-{{ ai_gen_id }}">
    {% assign parent_collections = '' | split: ',' %}
    {% assign active_parent = null %}

    {% for i in (1..10) %}
      {% assign collection_key = 'parent_collection_' | append: i %}
      {% assign parent_coll = block.settings[collection_key] %}
      
      {% if parent_coll != blank %}
        {% assign parent_collections = parent_collections | push: parent_coll %}
        
        {% if collection.handle == parent_coll.handle %}
          {% assign active_parent = parent_coll %}
        {% else %}
          {% assign subcollections = parent_coll.metafields.custom.subcollections.value %}
          {% if subcollections != blank %}
            {% for subcollection in subcollections %}
              {% if collection.handle == subcollection.handle %}
                {% assign active_parent = parent_coll %}
                {% break %}
              {% endif %}
            {% endfor %}
          {% endif %}
        {% endif %}
      {% endif %}
    {% endfor %}

    {% if parent_collections.size > 0 %}
      <div class="ai-collection-nav__row-{{ ai_gen_id }}">
        {% for parent_coll in parent_collections %}
          {% assign is_active = false %}
          
          {% if active_parent and active_parent.handle == parent_coll.handle %}
            {% assign is_active = true %}
          {% endif %}

          <a
            href="{{ parent_coll.url }}"
            class="ai-collection-nav__pill-{{ ai_gen_id }} {% if is_active %}ai-collection-nav__pill-{{ ai_gen_id }}--active{% else %}ai-collection-nav__pill-{{ ai_gen_id }}--inactive{% endif %}"
          >
            {{ parent_coll.title }}
          </a>
        {% endfor %}
      </div>

      {% if active_parent %}
        {% assign subcollections = active_parent.metafields.custom.subcollections.value %}
        {% if subcollections != blank and subcollections.size > 0 %}
          <div class="ai-collection-nav__row-{{ ai_gen_id }}">
            {% for subcollection in subcollections %}
              <a
                href="{{ subcollection.url }}"
                class="ai-collection-nav__pill-{{ ai_gen_id }} {% if collection.handle == subcollection.handle %}ai-collection-nav__pill-{{ ai_gen_id }}--active{% else %}ai-collection-nav__pill-{{ ai_gen_id }}--inactive{% endif %}"
              >
                {{ subcollection.title }}
              </a>
            {% endfor %}
          </div>
        {% endif %}
      {% endif %}
    {% endif %}
  </div>
</div>

