{% doc %}
  @prompt
    Create a responsive HTML section for a website called “Professional Installation Process”.
    
    Requirements:
    - Return full HTML, CSS, and minimal JavaScript in one code block
    - Use plain HTML/CSS/JS only
    - No frameworks
    - Clean, modern, premium design
    - Style inspired by a professional signage / installation company
    - White or very light grey background
    - Dark heading text
    - Cyan accent color
    - Mobile-first responsive layout
    
    Section structure:
    1. Centered title
    2. Centered subtitle
    3. Process cards
    4. Pagination dots
    5. Bottom trust items
    
    Important layout rules:
    - Put everything inside a centered container
    - Max width around 1200px
    - Use margin: 0 auto
    - All content must align to the same center axis
    - The card group itself must be centered, not stretched full width
    - Do not use justify-content: space-between
    - Use justify-content: center
    
    Desktop:
    - Show 3 cards in one row
    - Equal gap between cards
    - Cards remain centered as a group
    
    Mobile:
    - Convert cards into horizontal scroll slider
    - Show about 1.2 cards per view
    - Use scroll snap
    - Equal left and right padding
    
    Pagination:
    - Remove scrollbar
    - Add centered dot navigation below cards
    - Active dot = cyan
    - Inactive dots = light grey
    
    Card style:
    - Image on top
    - Title below
    - Short description below
    - Soft border or soft shadow
    - Clean padding
    - No floating step numbers
    
    Bottom trust row:
    - Add divider line above
    - Center these items:
      - Custom Production
      - Nationwide Installation
      - Professional Team
      - Engineering Support
    
    Content:
    Title: Professional Installation Process
    Subtitle: From design consultation to final installation, our experienced team ensures precision and quality at every step.
    
    Cards:
    1. Site Survey & Consultation
       Technical assessment and measurement of installation location
    
    2. Design & Engineering
       Custom design development with structural engineering approval
    
    3. Production & Fabrication
       In-house manufacturing with quality control at every stage
    
    4. Delivery & Preparation
       Logistics planning and site preparation before installation
    
    5. Installation & Finishing
       Professional on-site installation with final inspection
    
    Final instruction:
    Make the layout truly centered, visually balanced, and optimized for desktop and mobile.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-installation-process-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding_top }}px 20px {{ block.settings.section_padding_bottom }}px;
  }

  .ai-installation-process-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_max_width }}px;
    margin: 0 auto;
  }

  .ai-installation-process-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-installation-process-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_margin_bottom }}px;
    font-weight: 600;
  }

  .ai-installation-process-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.6;
  }

  .ai-installation-process-cards-wrapper-{{ ai_gen_id }} {
    position: relative;
    margin-bottom: {{ block.settings.cards_margin_bottom }}px;
  }

  .ai-installation-process-cards-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.card_gap }}px;
    justify-content: center;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding: 0 0 20px;
  }

  .ai-installation-process-cards-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .ai-installation-process-card-{{ ai_gen_id }} {
    flex: 0 0 auto;
    width: calc((100% - {{ block.settings.card_gap | times: 2 }}px) / 3);
    min-width: 280px;
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    text-align: center;
    scroll-snap-align: center;
    {% if block.settings.card_style == 'shadow' %}
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    {% elsif block.settings.card_style == 'border' %}
      border: 1px solid {{ block.settings.card_border_color }};
    {% endif %}
  }

  .ai-installation-process-card-image-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.card_image_height }}px;
    object-fit: cover;
    border-radius: {{ block.settings.card_image_radius }}px;
    margin-bottom: {{ block.settings.card_image_margin }}px;
  }

  .ai-installation-process-card-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.card_image_height }}px;
    background-color: #f4f4f4;
    border-radius: {{ block.settings.card_image_radius }}px;
    margin-bottom: {{ block.settings.card_image_margin }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-installation-process-card-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-installation-process-card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_title_size }}px;
    color: {{ block.settings.card_title_color }};
    margin: 0 0 {{ block.settings.card_title_margin }}px;
    font-weight: 600;
  }

  .ai-installation-process-card-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_description_size }}px;
    color: {{ block.settings.card_description_color }};
    margin: 0;
    line-height: 1.5;
  }

  .ai-installation-process-pagination-{{ ai_gen_id }} {
    display: none;
    justify-content: center;
    gap: 8px;
    margin-bottom: {{ block.settings.pagination_margin_bottom }}px;
  }

  .ai-installation-process-dot-{{ ai_gen_id }} {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_inactive_color }};
    cursor: pointer;
    transition: background-color 0.3s ease;
  }

  .ai-installation-process-dot-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.dot_active_color }};
  }

  .ai-installation-process-trust-{{ ai_gen_id }} {
    border-top: 1px solid {{ block.settings.divider_color }};
    padding-top: {{ block.settings.trust_padding_top }}px;
  }

  .ai-installation-process-trust-items-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: {{ block.settings.trust_gap }}px;
    flex-wrap: wrap;
  }

  .ai-installation-process-trust-item-{{ ai_gen_id }} {
    font-size: {{ block.settings.trust_item_size }}px;
    color: {{ block.settings.trust_item_color }};
    font-weight: 500;
  }

  @media screen and (max-width: 989px) {
    .ai-installation-process-cards-{{ ai_gen_id }} {
      justify-content: flex-start;
      padding-left: 20px;
      padding-right: 20px;
    }

    .ai-installation-process-card-{{ ai_gen_id }} {
      width: calc(100% - 60px);
      min-width: calc(100% - 60px);
    }

    .ai-installation-process-pagination-{{ ai_gen_id }} {
      display: flex;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-installation-process-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.8);
    }

    .ai-installation-process-subtitle-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subtitle_size }}px * 0.9);
    }

    .ai-installation-process-trust-items-{{ ai_gen_id }} {
      gap: {{ block.settings.trust_gap | divided_by: 2 }}px;
    }

    .ai-installation-process-trust-item-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.trust_item_size }}px * 0.9);
    }
  }
{% endstyle %}

<installation-process-{{ ai_gen_id }}
  class="ai-installation-process-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-installation-process-container-{{ ai_gen_id }}">
    <div class="ai-installation-process-header-{{ ai_gen_id }}">
      {% if block.settings.title != blank %}
        <h2 class="ai-installation-process-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
      {% endif %}
      {% if block.settings.subtitle != blank %}
        <p class="ai-installation-process-subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
      {% endif %}
    </div>

    <div class="ai-installation-process-cards-wrapper-{{ ai_gen_id }}">
      <div class="ai-installation-process-cards-{{ ai_gen_id }}" data-cards-container>
        {% for i in (1..5) %}
          {% liquid
            assign card_title_key = 'card_' | append: i | append: '_title'
            assign card_description_key = 'card_' | append: i | append: '_description'
            assign card_image_key = 'card_' | append: i | append: '_image'
            
            assign card_title = block.settings[card_title_key]
            assign card_description = block.settings[card_description_key]
            assign card_image = block.settings[card_image_key]
          %}

          <div class="ai-installation-process-card-{{ ai_gen_id }}" data-card-index="{{ forloop.index0 }}">
            {% if card_image %}
              <img
                src="{{ card_image | image_url: width: 600 }}"
                alt="{{ card_image.alt | escape }}"
                loading="lazy"
                width="600"
                height="{{ block.settings.card_image_height }}"
                class="ai-installation-process-card-image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-installation-process-card-image-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}

            {% if card_title != blank %}
              <h3 class="ai-installation-process-card-title-{{ ai_gen_id }}">{{ card_title }}</h3>
            {% endif %}

            {% if card_description != blank %}
              <p class="ai-installation-process-card-description-{{ ai_gen_id }}">{{ card_description }}</p>
            {% endif %}
          </div>
        {% endfor %}
      </div>

      <div class="ai-installation-process-pagination-{{ ai_gen_id }}" data-pagination>
        {% for i in (1..5) %}
          <span class="ai-installation-process-dot-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}" data-dot-index="{{ forloop.index0 }}"></span>
        {% endfor %}
      </div>
    </div>

    <div class="ai-installation-process-trust-{{ ai_gen_id }}">
      <div class="ai-installation-process-trust-items-{{ ai_gen_id }}">
        {% if block.settings.trust_item_1 != blank %}
          <div class="ai-installation-process-trust-item-{{ ai_gen_id }}">{{ block.settings.trust_item_1 }}</div>
        {% endif %}
        {% if block.settings.trust_item_2 != blank %}
          <div class="ai-installation-process-trust-item-{{ ai_gen_id }}">{{ block.settings.trust_item_2 }}</div>
        {% endif %}
        {% if block.settings.trust_item_3 != blank %}
          <div class="ai-installation-process-trust-item-{{ ai_gen_id }}">{{ block.settings.trust_item_3 }}</div>
        {% endif %}
        {% if block.settings.trust_item_4 != blank %}
          <div class="ai-installation-process-trust-item-{{ ai_gen_id }}">{{ block.settings.trust_item_4 }}</div>
        {% endif %}
      </div>
    </div>
  </div>
</installation-process-{{ ai_gen_id }}>

<script>
  (function() {
    class InstallationProcess{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.cardsContainer = this.querySelector('[data-cards-container]');
        this.pagination = this.querySelector('[data-pagination]');
        this.dots = this.querySelectorAll('[data-dot-index]');
        
        if (!this.cardsContainer || !this.pagination) return;

        this.setupScrollListener();
        this.setupDotClickListeners();
      }

      setupScrollListener() {
        let scrollTimeout;
        this.cardsContainer.addEventListener('scroll', () => {
          clearTimeout(scrollTimeout);
          scrollTimeout = setTimeout(() => {
            this.updateActiveDot();
          }, 100);
        });
      }

      setupDotClickListeners() {
        this.dots.forEach((dot) => {
          dot.addEventListener('click', () => {
            const index = parseInt(dot.getAttribute('data-dot-index'));
            const cards = this.querySelectorAll('[data-card-index]');
            const targetCard = cards[index];
            
            if (targetCard) {
              targetCard.scrollIntoView({
                behavior: 'smooth',
                block: 'nearest',
                inline: 'center'
              });
            }
          });
        });
      }

      updateActiveDot() {
        const containerRect = this.cardsContainer.getBoundingClientRect();
        const containerCenter = containerRect.left + containerRect.width / 2;
        
        const cards = this.querySelectorAll('[data-card-index]');
        let closestIndex = 0;
        let closestDistance = Infinity;

        cards.forEach((card, index) => {
          const cardRect = card.getBoundingClientRect();
          const cardCenter = cardRect.left + cardRect.width / 2;
          const distance = Math.abs(containerCenter - cardCenter);

          if (distance < closestDistance) {
            closestDistance = distance;
            closestIndex = index;
          }
        });

        this.dots.forEach((dot, index) => {
          if (index === closestIndex) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      }
    }

    customElements.define('installation-process-{{ ai_gen_id }}', InstallationProcess{{ ai_gen_id }});
  })();
</script>

