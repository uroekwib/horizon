{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-inkjet-gallery-{{ ai_gen_id }} {
    display: block;
    max-width: 1160px;
    margin: 0 auto;
    padding: {{ block.settings.section_padding_top }}px 20px {{ block.settings.section_padding_bottom }}px;
    background: {{ block.settings.background_color }};
    width: {{ block.settings.desktop_width_percent }}%;
  }

  .ai-inkjet-header-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 16px;
    margin-bottom: 24px;
  }

  .ai-inkjet-pill-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 5px 13px;
    border-radius: 99px;
    white-space: nowrap;
    background: {{ block.settings.pill_background }};
    color: {{ block.settings.pill_text_color }};
    border: 1px solid {{ block.settings.pill_border_color }};
  }

  .ai-inkjet-dot-{{ ai_gen_id }} {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: {{ block.settings.pill_dot_color }};
  }

  .ai-inkjet-line-{{ ai_gen_id }} {
    height: 1px;
    background: {{ block.settings.divider_color }};
  }

  .ai-inkjet-title-{{ ai_gen_id }} {
    font-size: clamp(17px, 2.4vw, {{ block.settings.title_font_size }}px);
    font-weight: {{ block.settings.title_font_weight }};
    letter-spacing: -0.025em;
    white-space: nowrap;
    color: {{ block.settings.title_color }};
  }

  .ai-inkjet-title-{{ ai_gen_id }} em {
    font-style: normal;
    background: {{ block.settings.gradient_color_1 }};
    background: linear-gradient(90deg, {{ block.settings.gradient_color_1 }}, {{ block.settings.gradient_color_2 }});
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .ai-inkjet-top-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 8px;
    height: {{ block.settings.top_grid_height }}px;
    margin-bottom: 8px;
  }

  .ai-inkjet-bottom-{{ ai_gen_id }} {
    display: flex;
    gap: 8px;
    overflow-x: auto;
    padding-bottom: 6px;
    scrollbar-width: thin;
    scrollbar-color: {{ block.settings.scrollbar_color }} transparent;
  }

  .ai-inkjet-bottom-{{ ai_gen_id }}::-webkit-scrollbar {
    height: 3px;
  }

  .ai-inkjet-bottom-{{ ai_gen_id }}::-webkit-scrollbar-thumb {
    background: {{ block.settings.scrollbar_color }};
    border-radius: 99px;
  }

  .ai-inkjet-item-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.item_border_radius }}px;
    background: {{ block.settings.item_placeholder_bg }};
    cursor: pointer;
    flex-shrink: 0;
  }

  .ai-inkjet-item-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .ai-inkjet-item-{{ ai_gen_id }}:hover img {
    transform: scale(1.08);
  }

  .ai-inkjet-caption-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 32px 11px 10px;
    background: linear-gradient(to top, {{ block.settings.caption_overlay_color }} 0%, transparent 100%);
    color: {{ block.settings.caption_text_color }};
    font-size: 11px;
    font-weight: 700;
    line-height: 1.35;
    transform: translateY(6px);
    opacity: 0;
    transition: transform 0.22s, opacity 0.22s;
  }

  .ai-inkjet-item-{{ ai_gen_id }}:hover .ai-inkjet-caption-{{ ai_gen_id }} {
    transform: translateY(0);
    opacity: 1;
  }

  .ai-inkjet-item-{{ ai_gen_id }}.hero .ai-inkjet-caption-{{ ai_gen_id }} {
    opacity: 1;
    transform: none;
    font-size: 14px;
    padding: 48px 16px 14px;
  }

  .ai-inkjet-tag-{{ ai_gen_id }} {
    position: absolute;
    top: 9px;
    left: 9px;
    font-size: 9px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: 99px;
    background: {{ block.settings.tag_background }};
    color: {{ block.settings.tag_text_color }};
    border: 1px solid {{ block.settings.tag_border_color }};
  }

  .ai-inkjet-bottom-{{ ai_gen_id }} .ai-inkjet-item-{{ ai_gen_id }} {
    width: {{ block.settings.bottom_item_width }}px;
    height: {{ block.settings.bottom_item_height }}px;
    flex: 0 0 {{ block.settings.bottom_item_width }}px;
  }

  .ai-inkjet-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: {{ block.settings.item_placeholder_bg }};
  }

  .ai-inkjet-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  @media (max-width: 900px) {
    .ai-inkjet-top-{{ ai_gen_id }} {
      grid-template-columns: 1.5fr 1fr 1fr;
      height: 200px;
    }
    .ai-inkjet-top-{{ ai_gen_id }} .ai-inkjet-item-{{ ai_gen_id }}:nth-child(4) {
      display: none;
    }
  }

  @media (max-width: 580px) {
    .ai-inkjet-top-{{ ai_gen_id }} {
      grid-template-columns: 1fr 1fr;
      height: 160px;
    }
    .ai-inkjet-top-{{ ai_gen_id }} .ai-inkjet-item-{{ ai_gen_id }}:nth-child(3),
    .ai-inkjet-top-{{ ai_gen_id }} .ai-inkjet-item-{{ ai_gen_id }}:nth-child(4) {
      display: none;
    }
    .ai-inkjet-header-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 8px;
    }
    .ai-inkjet-line-{{ ai_gen_id }} {
      display: none;
    }
    .ai-inkjet-gallery-{{ ai_gen_id }} {
      padding: 32px 14px 40px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ai-inkjet-item-{{ ai_gen_id }} img,
    .ai-inkjet-caption-{{ ai_gen_id }} {
      transition: none;
    }
  }
{% endstyle %}

<inkjet-gallery-{{ ai_gen_id }} class="ai-inkjet-gallery-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-inkjet-header-{{ ai_gen_id }}">
    <div class="ai-inkjet-pill-{{ ai_gen_id }}">
      <span class="ai-inkjet-dot-{{ ai_gen_id }}"></span>
      {{ block.settings.pill_text }}
    </div>
    <div class="ai-inkjet-line-{{ ai_gen_id }}"></div>
    <h2 class="ai-inkjet-title-{{ ai_gen_id }}">
      {{ block.settings.title_text }} <em>{{ block.settings.title_gradient_text }}</em>
    </h2>
  </div>

  <div class="ai-inkjet-top-{{ ai_gen_id }}">
    {% for i in (1..4) %}
      {% liquid
        assign image_key = 'top_image_' | append: i
        assign caption_key = 'top_caption_' | append: i
        assign url_key = 'top_url_' | append: i
        assign show_tag_key = 'top_show_tag_' | append: i

        assign image = block.settings[image_key]
        assign caption = block.settings[caption_key]
        assign url = block.settings[url_key]
        assign show_tag = block.settings[show_tag_key]
      %}

      {% if url != blank %}
        <a href="{{ url }}" class="ai-inkjet-item-{{ ai_gen_id }} {% if i == 1 %}hero{% endif %}">
      {% else %}
        <div class="ai-inkjet-item-{{ ai_gen_id }} {% if i == 1 %}hero{% endif %}">
      {% endif %}

        {% if image != blank %}
          <img
            src="{{ image | image_url: width: 800 }}"
            alt="{{ image.alt | escape }}"
            loading="lazy"
            width="{{ image.width }}"
            height="{{ image.height }}"
          >
        {% else %}
          <div class="ai-inkjet-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}

        {% if show_tag and i == 1 %}
          <div class="ai-inkjet-tag-{{ ai_gen_id }}">{{ block.settings.tag_text }}</div>
        {% endif %}

        {% if caption != blank %}
          <div class="ai-inkjet-caption-{{ ai_gen_id }}">{{ caption }}</div>
        {% endif %}

      {% if url != blank %}
        </a>
      {% else %}
        </div>
      {% endif %}
    {% endfor %}
  </div>

  <div class="ai-inkjet-bottom-{{ ai_gen_id }}">
    {% for i in (1..8) %}
      {% liquid
        assign image_key = 'bottom_image_' | append: i
        assign caption_key = 'bottom_caption_' | append: i
        assign url_key = 'bottom_url_' | append: i

        assign image = block.settings[image_key]
        assign caption = block.settings[caption_key]
        assign url = block.settings[url_key]
      %}

      {% if url != blank %}
        <a href="{{ url }}" class="ai-inkjet-item-{{ ai_gen_id }}">
      {% else %}
        <div class="ai-inkjet-item-{{ ai_gen_id }}">
      {% endif %}

        {% if image != blank %}
          <img
            src="{{ image | image_url: width: 400 }}"
            alt="{{ image.alt | escape }}"
            loading="lazy"
            width="{{ image.width }}"
            height="{{ image.height }}"
          >
        {% else %}
          <div class="ai-inkjet-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}

        {% if caption != blank %}
          <div class="ai-inkjet-caption-{{ ai_gen_id }}">{{ caption }}</div>
        {% endif %}

      {% if url != blank %}
        </a>
      {% else %}
        </div>
      {% endif %}
    {% endfor %}
  </div>
</inkjet-gallery-{{ ai_gen_id }}>

<script>
  (function() {
    class InkjetGallery{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }
    customElements.define('inkjet-gallery-{{ ai_gen_id }}', InkjetGallery{{ ai_gen_id }});
  })();
</script>

