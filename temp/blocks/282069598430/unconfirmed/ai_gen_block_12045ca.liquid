{% doc %}
  @prompt
    <!DOCTYPE html>
    <html lang="th">
    <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Section 1 — ป้ายอิงค์เจ็ท</title>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Thai:wght@400;600;700;800;900&display=swap" rel="stylesheet">
    <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: #f3f7fa; font-family: 'Noto Sans Thai', -apple-system, sans-serif; color: #1A202C; }
    
    :root {
      --c1: #17a9bb; --c1v: #14c9df; --c1l: #e3f8fb;
      --ink: #1A202C; --ink15: #E5E7EB;
    }
    
    .gs { max-width: 1160px; margin: 0 auto; padding: 48px 20px 56px; }
    
    /* HEADER */
    .sh {
      display: grid;
      grid-template-columns: auto 1fr auto;
      align-items: center;
      gap: 16px;
      margin-bottom: 24px;
    }
    .sh-pill {
      display: inline-flex; align-items: center; gap: 6px;
      font-size: 10px; font-weight: 800; letter-spacing: .12em; text-transform: uppercase;
      padding: 5px 13px; border-radius: 99px; white-space: nowrap;
      background: var(--c1l); color: var(--c1); border: 1px solid rgba(23,169,187,.3);
    }
    .sh-dot { width: 5px; height: 5px; border-radius: 50%; background: var(--c1); }
    .sh-line { height: 1px; background: var(--ink15); }
    .sh-title { font-size: clamp(17px,2.4vw,22px); font-weight: 800; letter-spacing: -.025em; white-space: nowrap; }
    .sh-title em { font-style: normal; background: linear-gradient(90deg,#14c9df,#17a9bb); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
    
    /* LAYOUT */
    .ig-top {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr 1fr;
      gap: 8px;
      height: 260px;
      margin-bottom: 8px;
    }
    .ig-bottom {
      display: flex; gap: 8px;
      overflow-x: auto; padding-bottom: 6px;
      scrollbar-width: thin; scrollbar-color: rgba(20,201,223,.3) transparent;
    }
    .ig-bottom::-webkit-scrollbar { height: 3px; }
    .ig-bottom::-webkit-scrollbar-thumb { background: rgba(20,201,223,.3); border-radius: 99px; }
    
    /* ITEM */
    .gi {
      position: relative; overflow: hidden; border-radius: 12px;
      background: #dde5ef; cursor: pointer; flex-shrink: 0;
    }
    .gi img {
      width: 100%; height: 100%; object-fit: cover; display: block;
      transition: transform .5s cubic-bezier(.16,1,.3,1);
    }
    .gi:hover img { transform: scale(1.08); }
    
    .gi-cap {
      position: absolute; bottom: 0; left: 0; right: 0;
      padding: 32px 11px 10px;
      background: linear-gradient(to top, rgba(8,8,20,.76) 0%, transparent 100%);
      color: #fff; font-size: 11px; font-weight: 700; line-height: 1.35;
      transform: translateY(6px); opacity: 0;
      transition: transform .22s, opacity .22s;
    }
    .gi:hover .gi-cap { transform: translateY(0); opacity: 1; }
    .gi.hero .gi-cap { opacity: 1; transform: none; font-size: 14px; padding: 48px 16px 14px; }
    
    .gi-tag {
      position: absolute; top: 9px; left: 9px;
      font-size: 9px; font-weight: 800; letter-spacing: .08em; text-transform: uppercase;
      padding: 3px 8px; border-radius: 99px;
      background: rgba(20,201,223,.88); color: #fff;
      border: 1px solid rgba(255,255,255,.25);
    }
    
    /* scroll row items */
    .ig-bottom .gi { width: 160px; height: 130px; flex: 0 0 160px; }
    
    @media (max-width: 900px) {
      .ig-top { grid-template-columns: 1.5fr 1fr 1fr; height: 200px; }
      .ig-top .gi:last-child { display: none; }
    }
    @media (max-width: 580px) {
      .ig-top { grid-template-columns: 1fr 1fr; height: 160px; }
      .ig-top .gi:nth-child(3), .ig-top .gi:last-child { display: none; }
      .sh { grid-template-columns: 1fr; gap: 8px; }
      .sh-line { display: none; }
      .gs { padding: 32px 14px 40px; }
    }
    @media (prefers-reduced-motion: reduce) {
      .gi img, .gi-cap { transition: none; }
    }
    </style>
    </head>
