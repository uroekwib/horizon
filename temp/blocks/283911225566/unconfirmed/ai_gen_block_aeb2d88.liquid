{% doc %}
  @prompt
    Create an interactive e-book viewer for Shopify with a realistic page-flipping animation, inspired by this catalogue reference:
    https://cdn.shopify.com/s/files/1/0098/2653/3433/files/Octopus_Media_Solutions_catalogue_2026.pdf?v=1775702103
    
    The experience should feel like a premium digital catalogue, similar to opening and turning pages in a real printed book.
    Use a double-page spread layout, realistic paper shadows, visible page edges, and smooth page curl animation.
    The book should open from the centre like a physical magazine or catalogue, with natural left and right page turning interaction.
    
    Visually, the design should follow the mood and structure of the reference catalogue, including clean corporate editorial layout, large showcase images, balanced text blocks, and a polished presentation style.
    
    Use a dark surrounding background to make the book stand out, and ensure the reading experience feels immersive and elegant rather than like a standard slider.
    
    The layout must be fully responsive for desktop and mobile, while preserving the premium catalogue feeling across devices.
    
    Build it as a Shopify-compatible section using Liquid, CSS, and JavaScript, with the interaction focused on a realistic flipbook experience rather than a normal carousel.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-ebook-viewer-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding }}px 20px;
    position: relative;
    overflow: hidden;
  }

  .ai-ebook-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    position: relative;
  }

  .ai-ebook-stage-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    perspective: 2000px;
    perspective-origin: center center;
  }

  .ai-ebook-book-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    margin: 0 auto;
    transform-style: preserve-3d;
    transition: transform 0.6s ease;
  }

  .ai-ebook-spread-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: 2 / 1.4;
    display: flex;
    box-shadow: 0 20px 60px rgba(0, 0, 0, {{ block.settings.shadow_opacity }});
    background: #ffffff;
  }

  .ai-ebook-page-{{ ai_gen_id }} {
    position: absolute;
    width: 50%;
    height: 100%;
    background: #ffffff;
    overflow: hidden;
    backface-visibility: hidden;
    transform-style: preserve-3d;
    transition: transform {{ block.settings.flip_duration }}s cubic-bezier(0.645, 0.045, 0.355, 1);
  }

  .ai-ebook-page-left-{{ ai_gen_id }} {
    left: 0;
    transform-origin: right center;
    box-shadow: inset -3px 0 8px rgba(0, 0, 0, 0.1);
  }

  .ai-ebook-page-right-{{ ai_gen_id }} {
    right: 0;
    transform-origin: left center;
    box-shadow: inset 3px 0 8px rgba(0, 0, 0, 0.1);
  }

  .ai-ebook-page-content-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    padding: {{ block.settings.page_padding }}px;
    display: flex;
    flex-direction: column;
    position: relative;
    background: #ffffff;
  }

  .ai-ebook-page-image-{{ ai_gen_id }} {
    width: 100%;
    height: 60%;
    object-fit: cover;
    margin-bottom: 20px;
  }

  .ai-ebook-page-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
    margin: 0 0 12px 0;
    line-height: 1.2;
  }

  .ai-ebook-page-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.body_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
    flex-grow: 1;
  }

  .ai-ebook-page-number-{{ ai_gen_id }} {
    position: absolute;
    bottom: {{ block.settings.page_padding }}px;
    font-size: 11px;
    color: #999;
  }

  .ai-ebook-page-left-{{ ai_gen_id }} .ai-ebook-page-number-{{ ai_gen_id }} {
    left: {{ block.settings.page_padding }}px;
  }

  .ai-ebook-page-right-{{ ai_gen_id }} .ai-ebook-page-number-{{ ai_gen_id }} {
    right: {{ block.settings.page_padding }}px;
  }

  .ai-ebook-spine-{{ ai_gen_id }} {
    position: absolute;
    left: 50%;
    top: 0;
    width: 2px;
    height: 100%;
    background: linear-gradient(to right, rgba(0, 0, 0, 0.15), rgba(0, 0, 0, 0.05), rgba(0, 0, 0, 0.15));
    transform: translateX(-50%);
    z-index: 10;
  }

  .ai-ebook-flipping-{{ ai_gen_id }} {
    position: absolute;
    width: 50%;
    height: 100%;
    top: 0;
    background: #ffffff;
    transform-style: preserve-3d;
    pointer-events: none;
    z-index: 5;
  }

  .ai-ebook-flipping-left-{{ ai_gen_id }} {
    left: 0;
    transform-origin: right center;
  }

  .ai-ebook-flipping-right-{{ ai_gen_id }} {
    right: 0;
    transform-origin: left center;
  }

  .ai-ebook-flipping-{{ ai_gen_id }}.flipping {
    animation: ai-ebook-flip-{{ ai_gen_id }} {{ block.settings.flip_duration }}s cubic-bezier(0.645, 0.045, 0.355, 1) forwards;
  }

  @keyframes ai-ebook-flip-{{ ai_gen_id }} {
    0% {
      transform: rotateY(0deg);
    }
    100% {
      transform: rotateY(-180deg);
    }
  }

  .ai-ebook-controls-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 20px;
    margin-top: 40px;
  }

  .ai-ebook-nav-button-{{ ai_gen_id }} {
    background: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    padding: 12px 24px;
    border-radius: {{ block.settings.button_radius }}px;
    cursor: pointer;
    font-size: 14px;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .ai-ebook-nav-button-{{ ai_gen_id }}:hover:not(:disabled) {
    background: {{ block.settings.button_hover_color }};
    transform: translateY(-2px);
  }

  .ai-ebook-nav-button-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-ebook-page-indicator-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.text_color }};
    min-width: 80px;
    text-align: center;
  }

  .ai-ebook-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f5f5f5;
    color: #999;
    font-size: 14px;
  }

  @media screen and (max-width: 768px) {
    .ai-ebook-spread-{{ ai_gen_id }} {
      aspect-ratio: 1 / 1.4;
    }

    .ai-ebook-page-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-ebook-page-left-{{ ai_gen_id }} {
      display: none;
    }

    .ai-ebook-spine-{{ ai_gen_id }} {
      display: none;
    }

    .ai-ebook-page-content-{{ ai_gen_id }} {
      padding: {{ block.settings.page_padding | times: 0.6 }}px;
    }

    .ai-ebook-page-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }

    .ai-ebook-page-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.body_size | times: 0.9 }}px;
    }

    .ai-ebook-controls-{{ ai_gen_id }} {
      margin-top: 24px;
    }
  }
{% endstyle %}

<ebook-viewer-{{ ai_gen_id }} class="ai-ebook-viewer-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-ebook-container-{{ ai_gen_id }}">
    <div class="ai-ebook-stage-{{ ai_gen_id }}">
      <div class="ai-ebook-book-{{ ai_gen_id }}">
        <div class="ai-ebook-spread-{{ ai_gen_id }}" data-spread-container>
          <div class="ai-ebook-spine-{{ ai_gen_id }}"></div>
          
          <div class="ai-ebook-page-{{ ai_gen_id }} ai-ebook-page-left-{{ ai_gen_id }}" data-page-left>
            <div class="ai-ebook-page-content-{{ ai_gen_id }}">
              {% if block.settings.page_1_image %}
                <img 
                  src="{{ block.settings.page_1_image | image_url: width: 800 }}" 
                  alt="{{ block.settings.page_1_title | escape }}"
                  class="ai-ebook-page-image-{{ ai_gen_id }}"
                  loading="lazy"
                >
              {% endif %}
              {% if block.settings.page_1_title != blank %}
                <h3 class="ai-ebook-page-title-{{ ai_gen_id }}">{{ block.settings.page_1_title }}</h3>
              {% endif %}
              {% if block.settings.page_1_text != blank %}
                <div class="ai-ebook-page-text-{{ ai_gen_id }}">{{ block.settings.page_1_text }}</div>
              {% endif %}
              <div class="ai-ebook-page-number-{{ ai_gen_id }}">1</div>
            </div>
          </div>

          <div class="ai-ebook-page-{{ ai_gen_id }} ai-ebook-page-right-{{ ai_gen_id }}" data-page-right>
            <div class="ai-ebook-page-content-{{ ai_gen_id }}">
              {% if block.settings.page_2_image %}
                <img 
                  src="{{ block.settings.page_2_image | image_url: width: 800 }}" 
                  alt="{{ block.settings.page_2_title | escape }}"
                  class="ai-ebook-page-image-{{ ai_gen_id }}"
                  loading="lazy"
                >
              {% endif %}
              {% if block.settings.page_2_title != blank %}
                <h3 class="ai-ebook-page-title-{{ ai_gen_id }}">{{ block.settings.page_2_title }}</h3>
              {% endif %}
              {% if block.settings.page_2_text != blank %}
                <div class="ai-ebook-page-text-{{ ai_gen_id }}">{{ block.settings.page_2_text }}</div>
              {% endif %}
              <div class="ai-ebook-page-number-{{ ai_gen_id }}">2</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="ai-ebook-controls-{{ ai_gen_id }}">
      <button 
        class="ai-ebook-nav-button-{{ ai_gen_id }}" 
        data-prev-button
        aria-label="Previous page"
      >
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M10 12L6 8L10 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Previous
      </button>
      
      <div class="ai-ebook-page-indicator-{{ ai_gen_id }}" data-page-indicator>
        <span data-current-page>1</span> / <span data-total-pages>8</span>
      </div>
      
      <button 
        class="ai-ebook-nav-button-{{ ai_gen_id }}" 
        data-next-button
        aria-label="Next page"
      >
        Next
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M6 12L10 8L6 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  </div>
</ebook-viewer-{{ ai_gen_id }}>

<script>
(function() {
  class EbookViewer{{ ai_gen_id }} extends HTMLElement {
    constructor() {
      super();
      this.currentPage = 0;
      this.isFlipping = false;
      this.isMobile = window.innerWidth <= 768;
      
      this.pages = [
        {
          left: {
            image: {{ block.settings.page_1_image | image_url: width: 800 | json }},
            title: {{ block.settings.page_1_title | json }},
            text: {{ block.settings.page_1_text | json }},
            number: 1
          },
          right: {
            image: {{ block.settings.page_2_image | image_url: width: 800 | json }},
            title: {{ block.settings.page_2_title | json }},
            text: {{ block.settings.page_2_text | json }},
            number: 2
          }
        },
        {
          left: {
            image: {{ block.settings.page_3_image | image_url: width: 800 | json }},
            title: {{ block.settings.page_3_title | json }},
            text: {{ block.settings.page_3_text | json }},
            number: 3
          },
          right: {
            image: {{ block.settings.page_4_image | image_url: width: 800 | json }},
            title: {{ block.settings.page_4_title | json }},
            text: {{ block.settings.page_4_text | json }},
            number: 4
          }
        },
        {
          left: {
            image: {{ block.settings.page_5_image | image_url: width: 800 | json }},
            title: {{ block.settings.page_5_title | json }},
            text: {{ block.settings.page_5_text | json }},
            number: 5
          },
          right: {
            image: {{ block.settings.page_6_image | image_url: width: 800 | json }},
            title: {{ block.settings.page_6_title | json }},
            text: {{ block.settings.page_6_text | json }},
            number: 6
          }
        },
        {
          left: {
            image: {{ block.settings.page_7_image | image_url: width: 800 | json }},
            title: {{ block.settings.page_7_title | json }},
            text: {{ block.settings.page_7_text | json }},
            number: 7
          },
          right: {
            image: {{ block.settings.page_8_image | image_url: width: 800 | json }},
            title: {{ block.settings.page_8_title | json }},
            text: {{ block.settings.page_8_text | json }},
            number: 8
          }
        }
      ];
    }

    connectedCallback() {
      this.prevButton = this.querySelector('[data-prev-button]');
      this.nextButton = this.querySelector('[data-next-button]');
      this.pageIndicator = this.querySelector('[data-current-page]');
      this.totalPagesEl = this.querySelector('[data-total-pages]');
      this.pageLeft = this.querySelector('[data-page-left]');
      this.pageRight = this.querySelector('[data-page-right]');

      this.totalPagesEl.textContent = this.isMobile ? this.pages.length * 2 : this.pages.length * 2;
      
      this.prevButton.addEventListener('click', () => this.previousPage());
      this.nextButton.addEventListener('click', () => this.nextPage());
      
      this.updateControls();
      this.renderCurrentSpread();

      window.addEventListener('resize', () => {
        const wasMobile = this.isMobile;
        this.isMobile = window.innerWidth <= 768;
        if (wasMobile !== this.isMobile) {
          this.renderCurrentSpread();
        }
      });
    }

    renderCurrentSpread() {
      const spread = this.pages[this.currentPage];
      if (!spread) return;

      if (this.isMobile) {
        this.renderPage(this.pageRight, spread.right);
        this.pageLeft.style.display = 'none';
      } else {
        this.renderPage(this.pageLeft, spread.left);
        this.renderPage(this.pageRight, spread.right);
        this.pageLeft.style.display = 'block';
      }
    }

    renderPage(pageEl, pageData) {
      if (!pageEl || !pageData) return;

      const content = pageEl.querySelector('.ai-ebook-page-content-{{ ai_gen_id }}');
      if (!content) return;

      let html = '';

      if (pageData.image) {
        html += `<img src="${pageData.image}" alt="${pageData.title || ''}" class="ai-ebook-page-image-{{ ai_gen_id }}" loading="lazy">`;
      }

      if (pageData.title) {
        html += `<h3 class="ai-ebook-page-title-{{ ai_gen_id }}">${pageData.title}</h3>`;
      }

      if (pageData.text) {
        html += `<div class="ai-ebook-page-text-{{ ai_gen_id }}">${pageData.text}</div>`;
      }

      html += `<div class="ai-ebook-page-number-{{ ai_gen_id }}">${pageData.number}</div>`;

      content.innerHTML = html;
    }

    nextPage() {
      if (this.isFlipping || this.currentPage >= this.pages.length - 1) return;
      
      this.isFlipping = true;
      this.currentPage++;
      
      setTimeout(() => {
        this.renderCurrentSpread();
        this.updateControls();
        this.isFlipping = false;
      }, {{ block.settings.flip_duration | times: 1000 }});
    }

    previousPage() {
      if (this.isFlipping || this.currentPage <= 0) return;
      
      this.isFlipping = true;
      this.currentPage--;
      
      setTimeout(() => {
        this.renderCurrentSpread();
        this.updateControls();
        this.isFlipping = false;
      }, {{ block.settings.flip_duration | times: 1000 }});
    }

    updateControls() {
      const displayPage = this.isMobile ? (this.currentPage * 2) + 2 : (this.currentPage * 2) + 2;
      this.pageIndicator.textContent = displayPage;
      
      this.prevButton.disabled = this.currentPage === 0;
      this.nextButton.disabled = this.currentPage >= this.pages.length - 1;
    }
  }

  customElements.define('ebook-viewer-{{ ai_gen_id }}', EbookViewer{{ ai_gen_id }});
})();
</script>

