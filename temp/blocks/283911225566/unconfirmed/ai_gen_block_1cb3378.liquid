      "label": "Text after gradient",
      "default": "2026"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Size",
      "min": 24,
      "max": 72,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Color",
      "default": "#1A202C"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Octopus Media Solutions"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "สำรวจผลิตภัณฑ์และบริการครบวงจรสำหรับป้ายโฆษณา วัสดุจัดแสดง และงานติดตั้ง POP"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitle color",
      "default": "#6B7280"
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description color",
      "default": "#6B7280"
    },
    {
      "type": "header",
      "content": "Statistics"
    },
    {
      "type": "checkbox",
      "id": "show_stats",
      "label": "Show statistics",
      "default": true
    },
    {
      "type": "text",
      "id": "stat_1_number",
      "label": "Stat 1 number",
