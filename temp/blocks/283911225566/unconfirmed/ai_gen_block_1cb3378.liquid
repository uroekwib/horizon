      "default": "rgba(20, 201, 223, 0.10)"
    },
    {
      "type": "color",
      "id": "badge_border_color",
      "label": "Border",
      "default": "rgba(20, 201, 223, 0.22)"
    },
    {
      "type": "color",
      "id": "badge_text_color",
