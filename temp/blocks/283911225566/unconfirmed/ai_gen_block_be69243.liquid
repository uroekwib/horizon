{% doc %}
  @prompt
    Create a Shopify section for an online PDF catalogue viewer.
    The merchant should be able to select a PDF file from Shopify files and display it on the page as an interactive flipbook.
    
    The viewer should:
    
    open like a real book
    show 2 pages on desktop
    show 1 page on mobile
    keep the first and last page as single pages
    support swipe on mobile
    support keyboard navigation on desktop
    use smooth page flip animation
    stay centred on the page
    be wider and not look too narrow
    
    Make it feel premium, similar to a real catalogue, not a basic PDF embed or slider.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-flipbook-container-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-flipbook-wrapper-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-flipbook-book-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    margin: 0 auto;
    perspective: 2000px;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .ai-flipbook-pages-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    max-width: {{ block.settings.book_width }}%;
    aspect-ratio: 2 / 1.4;
    transform-style: preserve-3d;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
  }

  .ai-flipbook-page-{{ ai_gen_id }} {
    position: absolute;
    width: 50%;
    height: 100%;
    top: 0;
    background: #ffffff;
    transform-style: preserve-3d;
    transform-origin: left center;
    transition: transform {{ block.settings.flip_duration }}s cubic-bezier(0.645, 0.045, 0.355, 1);
    box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.1);
  }

  .ai-flipbook-page-{{ ai_gen_id }}.ai-flipbook-left-{{ ai_gen_id }} {
    left: 0;
    transform-origin: right center;
  }

  .ai-flipbook-page-{{ ai_gen_id }}.ai-flipbook-right-{{ ai_gen_id }} {
    right: 0;
    transform-origin: left center;
  }

  .ai-flipbook-page-{{ ai_gen_id }}.ai-flipbook-flipped-{{ ai_gen_id }} {
    transform: rotateY(-180deg);
    z-index: 1;
  }

  .ai-flipbook-page-front-{{ ai_gen_id }},
  .ai-flipbook-page-back-{{ ai_gen_id }} {
    position: absolute;
    width: 100%;
    height: 100%;
    backface-visibility: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .ai-flipbook-page-back-{{ ai_gen_id }} {
    transform: rotateY(180deg);
  }

  .ai-flipbook-page-front-{{ ai_gen_id }} iframe,
  .ai-flipbook-page-back-{{ ai_gen_id }} iframe {
    width: 100%;
    height: 100%;
    border: none;
    pointer-events: none;
  }

  .ai-flipbook-controls-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 20px;
    margin-top: 30px;
  }

  .ai-flipbook-button-{{ ai_gen_id }} {
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: none;
    padding: 12px 24px;
    border-radius: {{ block.settings.button_border_radius }}px;
    cursor: pointer;
    font-size: 14px;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .ai-flipbook-button-{{ ai_gen_id }}:hover:not(:disabled) {
    background-color: {{ block.settings.button_hover_background }};
    transform: translateY(-2px);
  }

  .ai-flipbook-button-{{ ai_gen_id }}:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .ai-flipbook-page-counter-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.text_color }};
    min-width: 80px;
    text-align: center;
  }

  .ai-flipbook-empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    background-color: #f5f5f5;
    border-radius: 8px;
  }

  .ai-flipbook-empty-state-{{ ai_gen_id }} svg {
    width: 80px;
    height: 80px;
    margin-bottom: 20px;
    opacity: 0.3;
  }

  .ai-flipbook-empty-state-{{ ai_gen_id }} p {
    color: #666;
    font-size: 16px;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-flipbook-pages-{{ ai_gen_id }} {
      aspect-ratio: 1 / 1.4;
    }

    .ai-flipbook-page-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-flipbook-page-{{ ai_gen_id }}.ai-flipbook-left-{{ ai_gen_id }} {
      display: none;
    }

    .ai-flipbook-controls-{{ ai_gen_id }} {
      gap: 12px;
      margin-top: 20px;
    }

    .ai-flipbook-button-{{ ai_gen_id }} {
      padding: 10px 18px;
      font-size: 13px;
    }
  }
{% endstyle %}

<catalogue-flipbook-{{ ai_gen_id }}
  class="ai-flipbook-container-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
  data-total-pages="{{ block.settings.total_pages }}"
  data-flip-duration="{{ block.settings.flip_duration }}"
>
  <div class="ai-flipbook-wrapper-{{ ai_gen_id }}">
    {% if block.settings.pdf_file %}
      <div class="ai-flipbook-book-{{ ai_gen_id }}">
        <div class="ai-flipbook-pages-{{ ai_gen_id }}">
          {% for i in (1..block.settings.total_pages) %}
            {% assign page_class = 'ai-flipbook-page-' | append: ai_gen_id %}
            {% if i == 1 %}
              {% assign page_class = page_class | append: ' ai-flipbook-right-' | append: ai_gen_id %}
            {% elsif i == block.settings.total_pages %}
              {% assign page_class = page_class | append: ' ai-flipbook-left-' | append: ai_gen_id %}
            {% else %}
              {% assign is_even = i | modulo: 2 %}
              {% if is_even == 0 %}
                {% assign page_class = page_class | append: ' ai-flipbook-left-' | append: ai_gen_id %}
              {% else %}
                {% assign page_class = page_class | append: ' ai-flipbook-right-' | append: ai_gen_id %}
              {% endif %}
            {% endif %}

            <div class="{{ page_class }}" data-page="{{ i }}">
              <div class="ai-flipbook-page-front-{{ ai_gen_id }}">
                <iframe
                  src="{{ block.settings.pdf_file }}#page={{ i }}&view=FitH&toolbar=0&navpanes=0&scrollbar=0"
                  loading="lazy"
                ></iframe>
              </div>
              {% if i < block.settings.total_pages %}
                <div class="ai-flipbook-page-back-{{ ai_gen_id }}">
                  {% assign next_page = i | plus: 1 %}
                  <iframe
                    src="{{ block.settings.pdf_file }}#page={{ next_page }}&view=FitH&toolbar=0&navpanes=0&scrollbar=0"
                    loading="lazy"
                  ></iframe>
                </div>
              {% endif %}
            </div>
          {% endfor %}
        </div>
      </div>

      <div class="ai-flipbook-controls-{{ ai_gen_id }}">
        <button
          class="ai-flipbook-button-{{ ai_gen_id }} ai-flipbook-prev-{{ ai_gen_id }}"
          aria-label="Previous page"
        >
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M10 12L6 8L10 4" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Previous
        </button>

        <div class="ai-flipbook-page-counter-{{ ai_gen_id }}">
          <span class="ai-flipbook-current-{{ ai_gen_id }}">1</span>
          /
          <span class="ai-flipbook-total-{{ ai_gen_id }}">{{ block.settings.total_pages }}</span>
        </div>

        <button
          class="ai-flipbook-button-{{ ai_gen_id }} ai-flipbook-next-{{ ai_gen_id }}"
          aria-label="Next page"
        >
          Next
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M6 4L10 8L6 12" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    {% else %}
      <div class="ai-flipbook-empty-state-{{ ai_gen_id }}">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
          <polyline points="14 2 14 8 20 8"/>
          <line x1="16" y1="13" x2="8" y2="13"/>
          <line x1="16" y1="17" x2="8" y2="17"/>
          <polyline points="10 9 9 9 8 9"/>
        </svg>
        <p>Select a PDF file to display your catalogue</p>
      </div>
    {% endif %}
  </div>
</catalogue-flipbook-{{ ai_gen_id }}>

<script>
  (function() {
    class CatalogueFlipbook{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentPage = 1;
        this.totalPages = parseInt(this.dataset.totalPages) || 1;
        this.flipDuration = parseFloat(this.dataset.flipDuration) || 0.8;
        this.isFlipping = false;
        this.touchStartX = 0;
        this.touchEndX = 0;
      }

      connectedCallback() {
        this.prevButton = this.querySelector('.ai-flipbook-prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.ai-flipbook-next-{{ ai_gen_id }}');
        this.currentPageDisplay = this.querySelector('.ai-flipbook-current-{{ ai_gen_id }}');
        this.pages = this.querySelectorAll('.ai-flipbook-page-{{ ai_gen_id }}');
        this.book = this.querySelector('.ai-flipbook-book-{{ ai_gen_id }}');

        if (this.prevButton && this.nextButton) {
          this.setupEventListeners();
          this.updateControls();
        }
      }

      setupEventListeners() {
        this.prevButton.addEventListener('click', () => this.previousPage());
        this.nextButton.addEventListener('click', () => this.nextPage());

        document.addEventListener('keydown', (e) => {
          if (e.key === 'ArrowLeft') {
            this.previousPage();
          } else if (e.key === 'ArrowRight') {
            this.nextPage();
          }
        });

        if (this.book) {
          this.book.addEventListener('touchstart', (e) => {
            this.touchStartX = e.changedTouches[0].screenX;
          });

          this.book.addEventListener('touchend', (e) => {
            this.touchEndX = e.changedTouches[0].screenX;
            this.handleSwipe();
          });
        }
      }

      handleSwipe() {
        const swipeThreshold = 50;
        const diff = this.touchStartX - this.touchEndX;

        if (Math.abs(diff) > swipeThreshold) {
          if (diff > 0) {
            this.nextPage();
          } else {
            this.previousPage();
          }
        }
      }

      nextPage() {
        if (this.isFlipping || this.currentPage >= this.totalPages) return;

        this.isFlipping = true;
        this.currentPage++;

        const pageToFlip = this.querySelector(`[data-page="${this.currentPage - 1}"]`);
        if (pageToFlip && pageToFlip.classList.contains('ai-flipbook-right-{{ ai_gen_id }}')) {
          pageToFlip.classList.add('ai-flipbook-flipped-{{ ai_gen_id }}');
        }

        this.updateControls();

        setTimeout(() => {
          this.isFlipping = false;
        }, this.flipDuration * 1000);
      }

      previousPage() {
        if (this.isFlipping || this.currentPage <= 1) return;

        this.isFlipping = true;
        this.currentPage--;

        const pageToFlip = this.querySelector(`[data-page="${this.currentPage}"]`);
        if (pageToFlip && pageToFlip.classList.contains('ai-flipbook-right-{{ ai_gen_id }}')) {
          pageToFlip.classList.remove('ai-flipbook-flipped-{{ ai_gen_id }}');
        }

        this.updateControls();

        setTimeout(() => {
          this.isFlipping = false;
        }, this.flipDuration * 1000);
      }

      updateControls() {
        if (this.currentPageDisplay) {
          this.currentPageDisplay.textContent = this.currentPage;
        }

        if (this.prevButton) {
          this.prevButton.disabled = this.currentPage <= 1;
        }

        if (this.nextButton) {
          this.nextButton.disabled = this.currentPage >= this.totalPages;
        }
      }
    }

    customElements.define('catalogue-flipbook-{{ ai_gen_id }}', CatalogueFlipbook{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "PDF catalogue viewer",
  "settings": [
    {
      "type": "header",
      "content": "PDF file"
    },
    {
      "type": "url",
      "id": "pdf_file",
      "label": "PDF file URL"
    },
    {
      "type": "paragraph",
      "content": "Upload your PDF to Shopify Files, then paste the URL here. The PDF will display as an interactive flipbook."
    },
    {
      "type": "range",
      "id": "total_pages",
      "label": "Total pages",
      "min": 1,
      "max": 100,
      "step": 1,
      "default": 10
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Container width",
      "min": 800,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "default": 1200
    },
    {
      "type": "range",
      "id": "book_width",
      "label": "Book width",
      "min": 60,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 90
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 50
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 50
    },
    {
      "type": "header",
      "content": "Animation"
    },
    {
      "type": "range",
      "id": "flip_duration",
      "label": "Flip duration",
      "min": 0.5,
      "max": 2,
      "step": 0.1,
      "unit": "s",
      "default": 0.8
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#f5f5f5"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Button background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_hover_background",
      "label": "Button hover background",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Button border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "PDF catalogue viewer"
    }
  ]
}
{% endschema %}