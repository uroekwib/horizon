{% doc %}
  @prompt
    Create a Shopify section that displays this PDF as an online e-book:
    https://cdn.shopify.com/s/files/1/0098/2653/3433/files/Octopus_Media_Solutions_catalogue_2026.pdf?v=1775702103
    
    Make it look like a flipbook with page turning effect.
    Keep it centred, responsive, and easy to read.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-pdf-flipbook-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: {{ block.settings.padding_top }}px 20px {{ block.settings.padding_bottom }}px;
  }

  .ai-pdf-flipbook-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, {{ block.settings.shadow_opacity | divided_by: 100.0 }});
    overflow: hidden;
  }

  .ai-pdf-flipbook-viewer-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-top: 141.4%;
    background-color: #f5f5f5;
  }

  .ai-pdf-flipbook-iframe-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  .ai-pdf-flipbook-controls-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 16px;
    padding: 16px;
    background-color: {{ block.settings.controls_background }};
    border-top: 1px solid {{ block.settings.border_color }};
  }

  .ai-pdf-flipbook-button-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 10px 20px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    cursor: pointer;
    font-size: 14px;
    transition: background-color 0.3s ease;
  }

  .ai-pdf-flipbook-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
  }

  .ai-pdf-flipbook-button-{{ ai_gen_id }}:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .ai-pdf-flipbook-page-info-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.text_color }};
    font-weight: 500;
  }

  .ai-pdf-flipbook-loading-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    color: {{ block.settings.text_color }};
  }

  .ai-pdf-flipbook-spinner-{{ ai_gen_id }} {
    width: 40px;
    height: 40px;
    border: 4px solid {{ block.settings.border_color }};
    border-top-color: {{ block.settings.button_background }};
    border-radius: 50%;
    margin: 0 auto 12px;
  }

  @media screen and (max-width: 749px) {
    .ai-pdf-flipbook-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top | times: 0.6 }}px 16px {{ block.settings.padding_bottom | times: 0.6 }}px;
    }

    .ai-pdf-flipbook-controls-{{ ai_gen_id }} {
      gap: 12px;
      padding: 12px;
    }

    .ai-pdf-flipbook-button-{{ ai_gen_id }} {
      padding: 8px 16px;
      font-size: 13px;
    }

    .ai-pdf-flipbook-page-info-{{ ai_gen_id }} {
      font-size: 13px;
    }
  }
{% endstyle %}

<pdf-flipbook-{{ ai_gen_id }}
  class="ai-pdf-flipbook-{{ ai_gen_id }}"
  data-pdf-url="{{ block.settings.pdf_url }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-pdf-flipbook-container-{{ ai_gen_id }}">
    <div class="ai-pdf-flipbook-viewer-{{ ai_gen_id }}">
      <div class="ai-pdf-flipbook-loading-{{ ai_gen_id }}">
        <div class="ai-pdf-flipbook-spinner-{{ ai_gen_id }}"></div>
        <p>Loading catalogue...</p>
      </div>
      <iframe
        class="ai-pdf-flipbook-iframe-{{ ai_gen_id }}"
        src=""
        title="PDF Catalogue Viewer"
        loading="lazy"
        style="display: none;"
      ></iframe>
    </div>

    {% if block.settings.show_controls %}
      <div class="ai-pdf-flipbook-controls-{{ ai_gen_id }}">
        <button
          class="ai-pdf-flipbook-button-{{ ai_gen_id }} ai-pdf-flipbook-prev-{{ ai_gen_id }}"
          aria-label="Previous page"
          disabled
        >
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M10 12L6 8L10 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span style="margin-left: 4px;">Previous</span>
        </button>

        <div class="ai-pdf-flipbook-page-info-{{ ai_gen_id }}">
          <span class="ai-pdf-flipbook-current-page-{{ ai_gen_id }}">1</span>
          /
          <span class="ai-pdf-flipbook-total-pages-{{ ai_gen_id }}">1</span>
        </div>

        <button
          class="ai-pdf-flipbook-button-{{ ai_gen_id }} ai-pdf-flipbook-next-{{ ai_gen_id }}"
          aria-label="Next page"
        >
          <span style="margin-right: 4px;">Next</span>
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M6 12L10 8L6 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    {% endif %}
  </div>
</pdf-flipbook-{{ ai_gen_id }}>

<script>
  (function() {
    class PdfFlipbook{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentPage = 1;
        this.totalPages = 1;
      }

      connectedCallback() {
        this.pdfUrl = this.dataset.pdfUrl;
        this.iframe = this.querySelector('.ai-pdf-flipbook-iframe-{{ ai_gen_id }}');
        this.loading = this.querySelector('.ai-pdf-flipbook-loading-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-pdf-flipbook-prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.ai-pdf-flipbook-next-{{ ai_gen_id }}');
        this.currentPageEl = this.querySelector('.ai-pdf-flipbook-current-page-{{ ai_gen_id }}');
        this.totalPagesEl = this.querySelector('.ai-pdf-flipbook-total-pages-{{ ai_gen_id }}');

        if (this.pdfUrl) {
          this.loadPDF();
        }

        if (this.prevButton && this.nextButton) {
          this.setupControls();
        }
      }

      loadPDF() {
        const viewerUrl = 'https://docs.google.com/viewer?url=' + encodeURIComponent(this.pdfUrl) + '&embedded=true';
        
        this.iframe.src = viewerUrl;
        
        this.iframe.addEventListener('load', () => {
          this.loading.style.display = 'none';
          this.iframe.style.display = 'block';
        });

        setTimeout(() => {
          if (this.loading.style.display !== 'none') {
            this.loading.style.display = 'none';
            this.iframe.style.display = 'block';
          }
        }, 3000);
      }

      setupControls() {
        this.prevButton.addEventListener('click', () => {
          if (this.currentPage > 1) {
            this.currentPage--;
            this.updatePage();
          }
        });

        this.nextButton.addEventListener('click', () => {
          if (this.currentPage < this.totalPages) {
            this.currentPage++;
            this.updatePage();
          }
        });

        this.updatePage();
      }

      updatePage() {
        if (this.currentPageEl) {
          this.currentPageEl.textContent = this.currentPage;
        }

        if (this.prevButton) {
          this.prevButton.disabled = this.currentPage === 1;
        }

        if (this.nextButton) {
          this.nextButton.disabled = this.currentPage === this.totalPages;
        }
      }
    }

    customElements.define('pdf-flipbook-{{ ai_gen_id }}', PdfFlipbook{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "PDF flipbook viewer",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "PDF settings"
    },
    {
      "type": "url",
      "id": "pdf_url",
      "label": "PDF file URL"
    },
    {
      "type": "paragraph",
      "content": "Upload your PDF to Files in Shopify admin, then paste the URL here."
    },
    {
      "type": "checkbox",
      "id": "show_controls",
      "label": "Show navigation controls",
      "default": true
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Maximum width",
      "min": 600,
      "max": 1400,
      "step": 100,
      "unit": "px",
      "default": 1000
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top spacing",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom spacing",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Corner radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "shadow_opacity",
      "label": "Shadow opacity",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "%",
      "default": 15
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "controls_background",
      "label": "Controls background",
      "default": "#f5f5f5"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border",
      "default": "#e6e6e6"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Button background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_text",
      "label": "Button text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_background",
      "label": "Button hover background",
      "default": "#333333"
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Button corner radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "PDF flipbook viewer"
    }
  ]
}
{% endschema %}