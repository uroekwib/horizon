              <div class="ai-pdf-toc-page-title-{{ ai_gen_id }}">{{ section.settings.toc_page_1 }}</div>
            </div>
          {% endif %}

          {% if section.settings.toc_page_2 != blank %}
            <div
              class="ai-pdf-toc-card-{{ ai_gen_id }}"
              data-page="2"
              role="button"
              tabindex="0"
              aria-label="Jump to page 2"
            >
              <div class="ai-pdf-toc-page-number-{{ ai_gen_id }}">2</div>
              <div class="ai-pdf-toc-page-title-{{ ai_gen_id }}">{{ section.settings.toc_page_2 }}</div>
            </div>
          {% endif %}

          {% if section.settings.toc_page_3 != blank %}
            <div
              class="ai-pdf-toc-card-{{ ai_gen_id }}"
              data-page="3"
              role="button"
              tabindex="0"
              aria-label="Jump to page 3"
            >
              <div class="ai-pdf-toc-page-number-{{ ai_gen_id }}">3</div>
              <div class="ai-pdf-toc-page-title-{{ ai_gen_id }}">{{ section.settings.toc_page_3 }}</div>
            </div>
          {% endif %}

          {% if section.settings.toc_page_4 != blank %}
            <div
              class="ai-pdf-toc-card-{{ ai_gen_id }}"
              data-page="4"
              role="button"
              tabindex="0"
              aria-label="Jump to page 4"
            >
              <div class="ai-pdf-toc-page-number-{{ ai_gen_id }}">4</div>
              <div class="ai-pdf-toc-page-title-{{ ai_gen_id }}">{{ section.settings.toc_page_4 }}</div>
            </div>
          {% endif %}

          {% if section.settings.toc_page_5 != blank %}
            <div
              class="ai-pdf-toc-card-{{ ai_gen_id }}"
              data-page="5"
              role="button"
              tabindex="0"
              aria-label="Jump to page 5"
            >
              <div class="ai-pdf-toc-page-number-{{ ai_gen_id }}">5</div>
              <div class="ai-pdf-toc-page-title-{{ ai_gen_id }}">{{ section.settings.toc_page_5 }}</div>
            </div>
          {% endif %}

          {% if section.settings.toc_page_6 != blank %}
            <div
              class="ai-pdf-toc-card-{{ ai_gen_id }}"
              data-page="6"
              role="button"
              tabindex="0"
              aria-label="Jump to page 6"
            >
              <div class="ai-pdf-toc-page-number-{{ ai_gen_id }}">6</div>
              <div class="ai-pdf-toc-page-title-{{ ai_gen_id }}">{{ section.settings.toc_page_6 }}</div>
            </div>
          {% endif %}

          {% if section.settings.toc_page_7 != blank %}
            <div
              class="ai-pdf-toc-card-{{ ai_gen_id }}"
              data-page="7"
              role="button"
              tabindex="0"
              aria-label="Jump to page 7"
            >
              <div class="ai-pdf-toc-page-number-{{ ai_gen_id }}">7</div>
              <div class="ai-pdf-toc-page-title-{{ ai_gen_id }}">{{ section.settings.toc_page_7 }}</div>
            </div>
          {% endif %}

          {% if section.settings.toc_page_8 != blank %}
            <div
              class="ai-pdf-toc-card-{{ ai_gen_id }}"
              data-page="8"
              role="button"
              tabindex="0"
              aria-label="Jump to page 8"
            >
              <div class="ai-pdf-toc-page-number-{{ ai_gen_id }}">8</div>
              <div class="ai-pdf-toc-page-title-{{ ai_gen_id }}">{{ section.settings.toc_page_8 }}</div>
            </div>
          {% endif %}

          {% if section.settings.show_download_card %}
            <a
              href="{{ section.settings.pdf_url }}"
              download
              class="ai-pdf-toc-card-{{ ai_gen_id }} ai-pdf-toc-card-download-{{ ai_gen_id }}"
              aria-label="Download full PDF catalogue"
            >
              <svg class="ai-pdf-toc-download-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              <div class="ai-pdf-toc-page-number-{{ ai_gen_id }}">PDF</div>
              <div class="ai-pdf-toc-page-title-{{ ai_gen_id }}">Download full catalogue</div>
            </a>
          {% endif %}
        </div>
      </div>
    {% endif %}
  </div>
</pdf-catalogue-viewer-{{ ai_gen_id }}>

<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>

<script>
  (function() {
    class PdfCatalogueViewer{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.pdfDoc = null;
        this.currentPage = 1;
        this.totalPages = 0;
        this.pageRendering = false;
        this.pageNumPending = null;
        this.scale = 1.5;
        this.isMobile = window.innerWidth < 750;
        this.renderedPages = new Map();
      }

      connectedCallback() {
        const pdfUrl = this.dataset.pdfUrl;
        if (!pdfUrl) {
          this.showError('PDF URL not provided');
          return;
        }

        pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';

        this.loadingEl = this.querySelector('#loading-{{ ai_gen_id }}');
        this.canvasContainer = this.querySelector('#canvas-container-{{ ai_gen_id }}');
        this.pageInfo = this.querySelector('#page-info-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('#prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('#next-{{ ai_gen_id }}');

        this.loadPDF(pdfUrl);
        this.setupEventListeners();
        this.setupTOCListeners();
      }

      async loadPDF(url) {
        try {
          const loadingTask = pdfjsLib.getDocument(url);
          this.pdfDoc = await loadingTask.promise;
          this.totalPages = this.pdfDoc.numPages;

          this.loadingEl.classList.add('hidden');
          this.canvasContainer.style.display = 'flex';

          this.renderPage(this.currentPage);
          this.updatePageInfo();
        } catch (error) {
          this.showError('Failed to load PDF: ' + error.message);
        }
      }

      async renderPage(num) {
        if (this.pageRendering) {
          this.pageNumPending = num;
          return;
        }

        this.pageRendering = true;
        this.canvasContainer.innerHTML = '';

        if (num === 1) {
          await this.renderSinglePage(1);
        } else if (num === this.totalPages && this.totalPages % 2 === 0) {
          await this.renderSinglePage(this.totalPages);
        } else if (this.isMobile) {
          await this.renderSinglePage(num);
        } else {
          const leftPage = num % 2 === 0 ? num - 1 : num;
          const rightPage = leftPage + 1;

          if (leftPage >= 1 && leftPage <= this.totalPages) {
            await this.renderSinglePage(leftPage);
          }
          if (rightPage <= this.totalPages) {
            await this.renderSinglePage(rightPage);
          }
        }

        this.pageRendering = false;

        if (this.pageNumPending !== null) {
          const pending = this.pageNumPending;
          this.pageNumPending = null;
          this.renderPage(pending);
        }
      }

      async renderSinglePage(pageNum) {
        const cacheKey = `page-${pageNum}`;

        if (this.renderedPages.has(cacheKey)) {
          const cachedCanvas = this.renderedPages.get(cacheKey);
          this.canvasContainer.appendChild(cachedCanvas.cloneNode(true));
          return;
        }

        const page = await this.pdfDoc.getPage(pageNum);
        const viewport = page.getViewport({ scale: this.scale });

        const canvas = document.createElement('canvas');
        canvas.className = 'ai-pdf-page-canvas-{{ ai_gen_id }}';
        const context = canvas.getContext('2d');

        canvas.height = viewport.height;
        canvas.width = viewport.width;

        const renderContext = {
          canvasContext: context,
          viewport: viewport
        };

        await page.render(renderContext).promise;

        this.renderedPages.set(cacheKey, canvas.cloneNode(true));
        this.canvasContainer.appendChild(canvas);
      }

      showError(message) {
        this.loadingEl.textContent = message;
        this.loadingEl.style.color = '#D82C0D';
      }

      updatePageInfo() {
        const displayPage = this.isMobile || this.currentPage === 1 || this.currentPage === this.totalPages
          ? this.currentPage
          : this.currentPage % 2 === 0 ? this.currentPage - 1 : this.currentPage;

        const endPage = this.isMobile || displayPage === 1 || displayPage === this.totalPages
          ? displayPage
          : Math.min(displayPage + 1, this.totalPages);

        if (displayPage === endPage) {
          this.pageInfo.textContent = `Page ${displayPage} of ${this.totalPages}`;
        } else {
          this.pageInfo.textContent = `Pages ${displayPage}-${endPage} of ${this.totalPages}`;
        }

        this.prevButton.disabled = this.currentPage <= 1;
        this.nextButton.disabled = this.currentPage >= this.totalPages;
      }

      goToPrevious() {
        if (this.currentPage <= 1) return;

        if (this.isMobile || this.currentPage === 2) {
          this.currentPage--;
        } else {
          this.currentPage = Math.max(1, this.currentPage - 2);
        }

        this.renderPage(this.currentPage);
        this.updatePageInfo();
      }

      goToNext() {
        if (this.currentPage >= this.totalPages) return;

        if (this.isMobile || this.currentPage === 1 || this.currentPage === this.totalPages - 1) {
          this.currentPage++;
        } else {
          this.currentPage = Math.min(this.totalPages, this.currentPage + 2);
        }

        this.renderPage(this.currentPage);
        this.updatePageInfo();
      }

      goToPage(pageNum) {
        const num = parseInt(pageNum);
        if (num < 1 || num > this.totalPages) return;

        this.currentPage = num;
        this.renderPage(this.currentPage);
        this.updatePageInfo();

        this.querySelector('.ai-pdf-viewer-wrapper-{{ ai_gen_id }}').scrollIntoView({
          behavior: 'smooth',
          block: 'start'
        });
      }

      setupEventListeners() {
        this.prevButton.addEventListener('click', () => this.goToPrevious());
        this.nextButton.addEventListener('click', () => this.goToNext());

        document.addEventListener('keydown', (e) => {
          if (e.key === 'ArrowLeft') this.goToPrevious();
          if (e.key === 'ArrowRight') this.goToNext();
        });

        let touchStartX = 0;
        let touchEndX = 0;

        this.canvasContainer.addEventListener('touchstart', (e) => {
          touchStartX = e.changedTouches[0].screenX;
        });

        this.canvasContainer.addEventListener('touchend', (e) => {
          touchEndX = e.changedTouches[0].screenX;
          this.handleSwipe();
        });

        const handleSwipe = () => {
          if (touchEndX < touchStartX - 50) this.goToNext();
          if (touchEndX > touchStartX + 50) this.goToPrevious();
        };

        this.handleSwipe = handleSwipe;

        window.addEventListener('resize', () => {
          const wasMobile = this.isMobile;
          this.isMobile = window.innerWidth < 750;

          if (wasMobile !== this.isMobile) {
            this.renderPage(this.currentPage);
            this.updatePageInfo();
          }
        });
      }

      setupTOCListeners() {
        const tocCards = this.querySelectorAll('.ai-pdf-toc-card-{{ ai_gen_id }}:not(.ai-pdf-toc-card-download-{{ ai_gen_id }})');

        tocCards.forEach(card => {
          card.addEventListener('click', () => {
            const pageNum = card.dataset.page;
            if (pageNum) this.goToPage(pageNum);
          });

          card.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' || e.key === ' ') {
              e.preventDefault();
              const pageNum = card.dataset.page;
              if (pageNum) this.goToPage(pageNum);
            }
          });
        });
      }
    }

    customElements.define('pdf-catalogue-viewer-{{ ai_gen_id }}', PdfCatalogueViewer{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "PDF catalogue viewer",
  "tag": "section",
  "class": "section-pdf-catalogue",
  "settings": [
    {
      "type": "header",
      "content": "PDF settings"
    },
    {
      "type": "url",
      "id": "pdf_url",
      "label": "PDF URL"
    },
    {
      "type": "range",
      "id": "viewer_max_width",
      "label": "Viewer max width",
      "min": 800,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "default": 1200
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#f3f7fa"
    },
    {
      "type": "color",
      "id": "viewer_background",
      "label": "Viewer background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "controls_background",
      "label": "Controls background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border",
      "default": "#e6e6e6"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Button background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_text",
      "label": "Button text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_background",
      "label": "Button hover background",
      "default": "#333333"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Viewer border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Button border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 4
