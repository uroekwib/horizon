    {
      "type": "text",
      "id": "toc_title",
      "label": "Title",
      "default": "Table of Contents"
    },
    {
      "type": "range",
      "id": "toc_title_size",
      "label": "Title size",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card background",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "label": "Card border radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "checkbox",
      "id": "show_download_card",
      "label": "Show download card",
      "default": true
    },
