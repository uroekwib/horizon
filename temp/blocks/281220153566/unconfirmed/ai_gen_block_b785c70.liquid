{% doc %}
  @prompt
    multicolumn cards ดยอ้างอิงโครงสร้างมาตรฐานของ Dawn section multicolumn
    รองรับ mobile slider เมื่อจำนวน block มากกว่าจำนวนคอลัมน์มือถือ
    
    loop section.blocks เพื่อแสดง image / title / text / link
    
    ใช้ image_tag + sizes + widths แบบ responsive
    
    มี schema ครบทั้ง settings, blocks, presets Desktop: columns_desktop เลือกได้ 1–6 คอลัมน์ และครบจำนวนนี้แล้วให้ขึ้นบรรทัดใหม่อัตโนมัติ
    
    Mobile: columns_mobile เลือกได้ 1 หรือ 2 คอลัมน์ และครบจำนวนนี้แล้วให้ขึ้นบรรทัดใหม่อัตโนมัติ
    
    ใช้ class grid ของ Shopify ในรูปแบบ grid--{{ section.settings.columns_mobile }}-col-tablet-down และ grid--{{ section.settings.columns_desktop }}-col-desktop
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-multicolumn-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-multicolumn-container-{{ ai_gen_id }} {
    padding: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px;
  }

  .ai-multicolumn-heading-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: {{ block.settings.heading_spacing }}px;
  }

  .ai-multicolumn-grid-{{ ai_gen_id }} {
    display: grid;
    gap: {{ block.settings.column_gap }}px;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-multicolumn-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
      {% if block.settings.enable_mobile_slider %}
        display: flex;
        overflow-x: auto;
        scroll-snap-type: x mandatory;
        -webkit-overflow-scrolling: touch;
        gap: {{ block.settings.column_gap }}px;
        padding-bottom: 16px;
      {% endif %}
    }

    {% if block.settings.enable_mobile_slider %}
      .ai-multicolumn-item-{{ ai_gen_id }} {
        flex: 0 0 calc((100% - {{ block.settings.column_gap | times: block.settings.columns_mobile | minus: block.settings.column_gap }}px) / {{ block.settings.columns_mobile }});
        scroll-snap-align: start;
      }
    {% endif %}
  }

  @media screen and (min-width: 750px) {
    .ai-multicolumn-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    }
  }

  .ai-multicolumn-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-multicolumn-image-wrapper-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.image_spacing }}px;
    {% if block.settings.image_width == 'full' %}
      width: 100%;
    {% else %}
      width: {{ block.settings.image_width }}px;
      {% if block.settings.text_alignment == 'center' %}
        margin-left: auto;
        margin-right: auto;
      {% elsif block.settings.text_alignment == 'right' %}
        margin-left: auto;
      {% endif %}
    {% endif %}
  }

  .ai-multicolumn-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-multicolumn-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1;
    background-color: #f4f4f4;
    border-radius: {{ block.settings.image_border_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-multicolumn-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-multicolumn-title-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.title_spacing }}px;
    font-size: {{ block.settings.title_size }}px;
  }

  .ai-multicolumn-text-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.text_spacing }}px;
    color: rgba(var(--color-foreground), 0.75);
  }

  .ai-multicolumn-link-{{ ai_gen_id }} {
    display: inline-block;
    text-decoration: underline;
    color: rgb(var(--color-foreground));
    margin-top: auto;
  }

  .ai-multicolumn-link-{{ ai_gen_id }}:hover {
    opacity: 0.7;
  }
{% endstyle %}

<multicolumn-cards-{{ ai_gen_id }} class="ai-multicolumn-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-multicolumn-container-{{ ai_gen_id }} page-width">
    {% if block.settings.heading != blank %}
      <div class="ai-multicolumn-heading-{{ ai_gen_id }}">
        <h2>{{ block.settings.heading }}</h2>
      </div>
    {% endif %}

    <ul class="ai-multicolumn-grid-{{ ai_gen_id }} grid grid--{{ block.settings.columns_mobile }}-col-tablet-down grid--{{ block.settings.columns_desktop }}-col-desktop">
      {% for i in (1..6) %}
        {% liquid
          assign image_key = 'image_' | append: i
          assign title_key = 'title_' | append: i
          assign text_key = 'text_' | append: i
          assign link_label_key = 'link_label_' | append: i
          assign link_key = 'link_' | append: i

          assign image = block.settings[image_key]
          assign title = block.settings[title_key]
          assign text = block.settings[text_key]
          assign link_label = block.settings[link_label_key]
          assign link = block.settings[link_key]

          assign has_content = false
          if image != blank or title != blank or text != blank or link_label != blank
            assign has_content = true
          endif
        %}

        {% if has_content %}
          <li class="ai-multicolumn-item-{{ ai_gen_id }}">
            {% if image != blank %}
              <div class="ai-multicolumn-image-wrapper-{{ ai_gen_id }}">
                {% liquid
                  assign widths = '165, 330, 535, 750, 1070, 1500'
                  assign sizes = '(min-width: 990px) calc((100vw - 130px) / ' | append: block.settings.columns_desktop | append: '), (min-width: 750px) calc((100vw - 120px) / ' | append: block.settings.columns_desktop | append: '), calc((100vw - 35px) / ' | append: block.settings.columns_mobile | append: ')'
                %}
                {{
                  image
                  | image_url: width: 1500
                  | image_tag:
                    loading: 'lazy',
                    class: 'ai-multicolumn-image-' | append: ai_gen_id,
                    widths: widths,
                    sizes: sizes
                }}
              </div>
            {% elsif block.settings.show_placeholder_images %}
              <div class="ai-multicolumn-image-wrapper-{{ ai_gen_id }}">
                <div class="ai-multicolumn-image-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              </div>
            {% endif %}

            {% if title != blank %}
              <h3 class="ai-multicolumn-title-{{ ai_gen_id }}">{{ title }}</h3>
            {% endif %}

            {% if text != blank %}
              <div class="ai-multicolumn-text-{{ ai_gen_id }}">{{ text }}</div>
            {% endif %}

            {% if link_label != blank and link != blank %}
              <a href="{{ link }}" class="ai-multicolumn-link-{{ ai_gen_id }}">
                {{ link_label }}
              </a>
            {% endif %}
          </li>
        {% endif %}
      {% endfor %}
    </ul>
  </div>
</multicolumn-cards-{{ ai_gen_id }}>

