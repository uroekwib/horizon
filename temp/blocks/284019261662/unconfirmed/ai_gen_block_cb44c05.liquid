      "default": "https://cdn.shopify.com/s/files/1/0098/2653/3433/files/Octopus_Media_Solutions_catalogue_2026.pdf?v=1775702103"
    },
    {
      "type": "header",
      "content": "Hero section"
    },
    {
      "type": "text",
      "id": "hero_title",
      "label": "Title",
      "default": "แคตตาล็อกสินค้า 2026"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title size",
      "min": 24,
