    {% if block.settings.show_toc %}
      <div class="ai-catalogue-toc-{{ ai_gen_id }}">
        <h2 class="ai-catalogue-toc-title-{{ ai_gen_id }}">{{ block.settings.toc_title }}</h2>
        <div class="ai-catalogue-toc-grid-{{ ai_gen_id }}">
          {% for i in (1..12) %}
            {% assign toc_page_key = 'toc_' | append: i | append: '_page' %}
            {% assign toc_title_key = 'toc_' | append: i | append: '_title' %}
            {% assign toc_page = block.settings[toc_page_key] %}
            {% assign toc_title = block.settings[toc_title_key] %}
            
            {% if toc_title != blank %}
              <div class="ai-catalogue-toc-card-{{ ai_gen_id }}" data-page="{{ toc_page }}">
                <div class="ai-catalogue-toc-page-{{ ai_gen_id }}">หน้า {{ toc_page }}</div>
                <div class="ai-catalogue-toc-item-title-{{ ai_gen_id }}">{{ toc_title }}</div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    {% endif %}

    {% if block.settings.show_cta %}
      <div class="ai-catalogue-cta-{{ ai_gen_id }}">
        <h2 class="ai-catalogue-cta-title-{{ ai_gen_id }}">{{ block.settings.cta_title }}</h2>
        <div class="ai-catalogue-cta-buttons-{{ ai_gen_id }}">
          {% if block.settings.line_url != blank %}
            <a href="{{ block.settings.line_url }}" class="ai-catalogue-cta-button-{{ ai_gen_id }}" target="_blank">
              {{ block.settings.line_button_text }}
            </a>
          {% endif %}
          {% if block.settings.website_url != blank %}
            <a href="{{ block.settings.website_url }}" class="ai-catalogue-cta-button-{{ ai_gen_id }}">
              {{ block.settings.website_button_text }}
            </a>
          {% endif %}
        </div>
      </div>
    {% endif %}
  </div>
</pdf-catalogue-viewer-{{ ai_gen_id }}>

<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
<script>
  (function() {
    pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';

    class PdfCatalogueViewer{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.pdfDoc = null;
        this.currentPage = 1;
        this.totalPages = 0;
        this.renderedPages = new Map();
        this.isMobile = window.innerWidth < 750;
      }

      connectedCallback() {
        this.pdfUrl = this.dataset.pdfUrl;
        this.setupElements();
        this.setupEventListeners();
      }

      setupElements() {
        this.heroButton = this.querySelector('[data-action="open-catalogue"]');
        this.loadingSection = this.querySelector('.ai-catalogue-loading-{{ ai_gen_id }}');
        this.loadingBar = this.querySelector('.ai-catalogue-loading-bar-{{ ai_gen_id }}');
        this.viewerWrapper = this.querySelector('.ai-catalogue-viewer-wrapper-{{ ai_gen_id }}');
        this.flipbookContainer = this.querySelector('.ai-catalogue-flipbook-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('[data-action="prev"]');
        this.nextButton = this.querySelector('[data-action="next"]');
        this.currentPageSpan = this.querySelector('[data-current-page]');
        this.totalPagesSpan = this.querySelector('[data-total-pages]');
        this.progressFill = this.querySelector('.ai-catalogue-progress-fill-{{ ai_gen_id }}');
        this.thumbnailsContainer = this.querySelector('.ai-catalogue-thumbnails-{{ ai_gen_id }}');
        this.tocCards = this.querySelectorAll('.ai-catalogue-toc-card-{{ ai_gen_id }}');
      }

      setupEventListeners() {
        this.heroButton.addEventListener('click', () => this.loadPDF());
        this.prevButton.addEventListener('click', () => this.previousPage());
        this.nextButton.addEventListener('click', () => this.nextPage());
        
        this.tocCards.forEach(card => {
          card.addEventListener('click', () => {
            const page = parseInt(card.dataset.page);
            if (page) {
              this.goToPage(page);
              this.viewerWrapper.scrollIntoView({ behavior: 'smooth' });
            }
          });
        });

        window.addEventListener('resize', () => {
          const wasMobile = this.isMobile;
          this.isMobile = window.innerWidth < 750;
          if (wasMobile !== this.isMobile && this.pdfDoc) {
            this.renderCurrentPage();
          }
        });
      }

      async loadPDF() {
        this.loadingSection.classList.add('active');
        
        try {
          const loadingTask = pdfjsLib.getDocument(this.pdfUrl);
          
          loadingTask.onProgress = (progress) => {
            if (progress.total > 0) {
              const percent = (progress.loaded / progress.total) * 100;
              this.loadingBar.style.width = percent + '%';
            }
          };

          this.pdfDoc = await loadingTask.promise;
          this.totalPages = this.pdfDoc.numPages;
          this.totalPagesSpan.textContent = this.totalPages;
          
          this.loadingSection.classList.remove('active');
          this.viewerWrapper.classList.add('active');
          
          await this.renderCurrentPage();
          this.renderThumbnails();
          this.updateControls();
          
          this.viewerWrapper.scrollIntoView({ behavior: 'smooth' });
        } catch (error) {
          console.error('Error loading PDF:', error);
          alert('ไม่สามารถโหลด PDF ได้ กรุณาลองใหม่อีกครั้ง');
          this.loadingSection.classList.remove('active');
        }
      }

      async renderPage(pageNum, container, scale = 1.5) {
        const page = await this.pdfDoc.getPage(pageNum);
        const viewport = page.getViewport({ scale });
        
        const canvas = document.createElement('canvas');
        const context = canvas.getContext('2d');
        canvas.height = viewport.height;
        canvas.width = viewport.width;
        
        await page.render({
          canvasContext: context,
          viewport: viewport
        }).promise;
        
        container.innerHTML = '';
        container.appendChild(canvas);
        
        return canvas;
      }

      async renderCurrentPage() {
        this.flipbookContainer.innerHTML = '';
        
        if (this.isMobile) {
          const pageDiv = document.createElement('div');
          pageDiv.className = 'ai-catalogue-page-{{ ai_gen_id }}';
          this.flipbookContainer.appendChild(pageDiv);
          await this.renderPage(this.currentPage, pageDiv);
        } else {
          if (this.currentPage === 1) {
            const pageDiv = document.createElement('div');
            pageDiv.className = 'ai-catalogue-page-{{ ai_gen_id }}';
            pageDiv.style.left = '25%';
            this.flipbookContainer.appendChild(pageDiv);
            await this.renderPage(1, pageDiv);
          } else if (this.currentPage === this.totalPages && this.totalPages % 2 === 0) {
            const pageDiv = document.createElement('div');
            pageDiv.className = 'ai-catalogue-page-{{ ai_gen_id }}';
            pageDiv.style.left = '0';
            this.flipbookContainer.appendChild(pageDiv);
            await this.renderPage(this.currentPage, pageDiv);
          } else {
            const leftPage = this.currentPage % 2 === 0 ? this.currentPage : this.currentPage - 1;
            const rightPage = leftPage + 1;
            
            if (leftPage >= 1 && leftPage <= this.totalPages) {
              const leftDiv = document.createElement('div');
              leftDiv.className = 'ai-catalogue-page-{{ ai_gen_id }}';
              leftDiv.style.left = '0';
              this.flipbookContainer.appendChild(leftDiv);
              await this.renderPage(leftPage, leftDiv);
            }
            
            if (rightPage <= this.totalPages) {
              const rightDiv = document.createElement('div');
              rightDiv.className = 'ai-catalogue-page-{{ ai_gen_id }}';
              rightDiv.style.left = '50%';
              this.flipbookContainer.appendChild(rightDiv);
              await this.renderPage(rightPage, rightDiv);
            }
          }
        }
        
        this.updateControls();
      }

      async renderThumbnails() {
        if (!this.thumbnailsContainer) return;
        
        this.thumbnailsContainer.innerHTML = '';
        
        for (let i = 1; i <= this.totalPages; i++) {
          const thumbDiv = document.createElement('div');
          thumbDiv.className = 'ai-catalogue-thumbnail-{{ ai_gen_id }}';
          thumbDiv.dataset.page = i;
          
          thumbDiv.addEventListener('click', () => {
            this.goToPage(i);
            this.flipbookContainer.scrollIntoView({ behavior: 'smooth' });
          });
          
          this.thumbnailsContainer.appendChild(thumbDiv);
          await this.renderPage(i, thumbDiv, 0.3);
        }
        
        this.updateThumbnailActive();
      }

      updateThumbnailActive() {
        if (!this.thumbnailsContainer) return;
        
        const thumbnails = this.thumbnailsContainer.querySelectorAll('.ai-catalogue-thumbnail-{{ ai_gen_id }}');
        thumbnails.forEach(thumb => {
          const page = parseInt(thumb.dataset.page);
          if (this.isMobile) {
            thumb.classList.toggle('active', page === this.currentPage);
          } else {
            const leftPage = this.currentPage % 2 === 0 ? this.currentPage : this.currentPage - 1;
            const rightPage = leftPage + 1;
            thumb.classList.toggle('active', page === leftPage || page === rightPage);
          }
        });
      }

      previousPage() {
        if (this.isMobile) {
          if (this.currentPage > 1) {
            this.currentPage--;
            this.renderCurrentPage();
          }
        } else {
          if (this.currentPage === 1) return;
          if (this.currentPage === 2) {
            this.currentPage = 1;
          } else if (this.currentPage % 2 === 0) {
            this.currentPage -= 2;
          } else {
            this.currentPage -= 2;
          }
          this.renderCurrentPage();
        }
      }

      nextPage() {
        if (this.isMobile) {
          if (this.currentPage < this.totalPages) {
            this.currentPage++;
            this.renderCurrentPage();
          }
        } else {
          if (this.currentPage === 1) {
            this.currentPage = 2;
          } else if (this.currentPage % 2 === 0) {
            this.currentPage += 2;
          } else {
            this.currentPage += 2;
          }
          if (this.currentPage > this.totalPages) {
            this.currentPage = this.totalPages;
          }
          this.renderCurrentPage();
        }
      }

      goToPage(pageNum) {
        if (pageNum < 1 || pageNum > this.totalPages) return;
        this.currentPage = pageNum;
        this.renderCurrentPage();
      }

      updateControls() {
        this.currentPageSpan.textContent = this.currentPage;
        
        if (this.isMobile) {
          this.prevButton.disabled = this.currentPage === 1;
          this.nextButton.disabled = this.currentPage === this.totalPages;
        } else {
          this.prevButton.disabled = this.currentPage === 1;
          this.nextButton.disabled = this.currentPage >= this.totalPages;
        }
        
        const progress = (this.currentPage / this.totalPages) * 100;
        this.progressFill.style.width = progress + '%';
        
        this.updateThumbnailActive();
      }
    }

    customElements.define('pdf-catalogue-viewer-{{ ai_gen_id }}', PdfCatalogueViewer{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
