<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
<script>
  (function() {
    pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';

    class PdfCatalogueViewer{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.pdfDoc = null;
        this.currentPage = 1;
        this.totalPages = 0;
        this.pageRendering = false;
        this.pageNumPending = null;
        this.scale = 1.5;
        this.isMobile = window.innerWidth < 750;
        this.touchStartX = 0;
        this.touchEndX = 0;
      }

      connectedCallback() {
        this.pdfUrl = this.dataset.pdfUrl;
        if (!this.pdfUrl) {
          console.error('PDF URL not provided');
          return;
        }

        this.loadingEl = this.querySelector('.ai-pdf-loading-{{ ai_gen_id }}');
        this.pagesContainer = this.querySelector('.ai-pdf-pages-container-{{ ai_gen_id }}');
        this.pageWrapper = this.querySelector('.ai-pdf-page-wrapper-{{ ai_gen_id }}');
        this.prevBtn = this.querySelector('.ai-pdf-prev-{{ ai_gen_id }}');
        this.nextBtn = this.querySelector('.ai-pdf-next-{{ ai_gen_id }}');
        this.currentPageEl = this.querySelector('.ai-pdf-current-page-{{ ai_gen_id }}');
        this.totalPagesEl = this.querySelector('.ai-pdf-total-pages-{{ ai_gen_id }}');

        this.loadPDF();
        this.setupEventListeners();
        this.setupTOCListeners();
      }

      async loadPDF() {
        try {
          const loadingTask = pdfjsLib.getDocument(this.pdfUrl);
          this.pdfDoc = await loadingTask.promise;
          this.totalPages = this.pdfDoc.numPages;
          this.totalPagesEl.textContent = this.totalPages;
          
          this.loadingEl.classList.add('hidden');
          this.pagesContainer.classList.add('loaded');
          
          this.renderPages();
        } catch (error) {
          console.error('Error loading PDF:', error);
          this.loadingEl.innerHTML = '<p>Unable to load PDF. Please try again.</p>';
        }
      }

      async renderPages() {
        if (this.pageRendering) {
          this.pageNumPending = this.currentPage;
          return;
        }

        this.pageRendering = true;
        this.pageWrapper.innerHTML = '';

        const isCover = this.currentPage === 1;
        const isLastPage = this.currentPage === this.totalPages;
        const showSpread = !this.isMobile && !isCover && !isLastPage && this.currentPage < this.totalPages;

        if (isCover || isLastPage || this.isMobile) {
          await this.renderPage(this.currentPage);
        } else {
          await this.renderPage(this.currentPage);
          if (this.currentPage + 1 <= this.totalPages) {
            await this.renderPage(this.currentPage + 1);
          }
        }

        this.updateControls();
        this.pageRendering = false;

        if (this.pageNumPending !== null) {
          this.currentPage = this.pageNumPending;
          this.pageNumPending = null;
          this.renderPages();
        }
      }

      async renderPage(pageNum) {
        try {
          const page = await this.pdfDoc.getPage(pageNum);
          const viewport = page.getViewport({ scale: this.scale });

          const canvas = document.createElement('canvas');
          const context = canvas.getContext('2d');
          canvas.height = viewport.height;
          canvas.width = viewport.width;

          const pageDiv = document.createElement('div');
          pageDiv.className = 'ai-pdf-page-{{ ai_gen_id }}';
          pageDiv.appendChild(canvas);
          this.pageWrapper.appendChild(pageDiv);

          const renderContext = {
            canvasContext: context,
            viewport: viewport
          };

          await page.render(renderContext).promise;
        } catch (error) {
          console.error('Error rendering page:', error);
        }
      }

      updateControls() {
        this.currentPageEl.textContent = this.currentPage;
        this.prevBtn.disabled = this.currentPage === 1;
        this.nextBtn.disabled = this.currentPage >= this.totalPages;
      }

      goToPrevious() {
        if (this.currentPage <= 1) return;

        const isCover = this.currentPage === 2;
        const wasSpread = this.currentPage > 2 && !this.isMobile;

        if (isCover) {
          this.currentPage = 1;
        } else if (wasSpread) {
          this.currentPage = Math.max(1, this.currentPage - 2);
        } else {
          this.currentPage--;
        }

        this.renderPages();
      }

      goToNext() {
        if (this.currentPage >= this.totalPages) return;

        const isCover = this.currentPage === 1;
        const isSpread = !this.isMobile && this.currentPage > 1 && this.currentPage < this.totalPages - 1;

        if (isCover) {
          this.currentPage = 2;
        } else if (isSpread) {
          this.currentPage = Math.min(this.totalPages, this.currentPage + 2);
        } else {
          this.currentPage++;
        }

        this.renderPages();
      }

      jumpToPage(pageNum) {
        if (pageNum < 1 || pageNum > this.totalPages) return;
        this.currentPage = pageNum;
        this.renderPages();
        
        const viewerSection = this.querySelector('.ai-pdf-viewer-section-{{ ai_gen_id }}');
        if (viewerSection) {
          viewerSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      }

      setupEventListeners() {
        this.prevBtn.addEventListener('click', () => this.goToPrevious());
        this.nextBtn.addEventListener('click', () => this.goToNext());

        document.addEventListener('keydown', (e) => {
          if (e.key === 'ArrowLeft') this.goToPrevious();
          if (e.key === 'ArrowRight') this.goToNext();
        });

        this.pagesContainer.addEventListener('touchstart', (e) => {
          this.touchStartX = e.changedTouches[0].screenX;
        });

        this.pagesContainer.addEventListener('touchend', (e) => {
          this.touchEndX = e.changedTouches[0].screenX;
          this.handleSwipe();
        });

        window.addEventListener('resize', () => {
          const wasMobile = this.isMobile;
          this.isMobile = window.innerWidth < 750;
          if (wasMobile !== this.isMobile) {
            this.renderPages();
          }
        });
      }

      handleSwipe() {
        const swipeThreshold = 50;
        const diff = this.touchStartX - this.touchEndX;

        if (Math.abs(diff) > swipeThreshold) {
          if (diff > 0) {
            this.goToNext();
          } else {
            this.goToPrevious();
          }
        }
      }

      setupTOCListeners() {
        const tocCards = this.querySelectorAll('.ai-pdf-toc-card-{{ ai_gen_id }}[data-page]');
        
        tocCards.forEach(card => {
          card.addEventListener('click', () => {
            const pageNumber = parseInt(card.dataset.page);
            this.jumpToPage(pageNumber);
          });

          card.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' || e.key === ' ') {
              e.preventDefault();
              const pageNumber = parseInt(card.dataset.page);
              this.jumpToPage(pageNumber);
            }
          });
        });
      }
    }

    customElements.define('pdf-catalogue-viewer-{{ ai_gen_id }}', PdfCatalogueViewer{{ ai_gen_id }});
  })();
</script>

