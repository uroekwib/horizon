{% doc %}
  @prompt
    Create a Shopify section for an online e-book catalogue viewer.
    The merchant should be able to select a PDF file from Shopify files and display it as a standalone HTML viewer (not iframe).
    
    Use this PDF as reference:
    https://cdn.shopify.com/s/files/1/0098/2653/3433/files/Octopus_Media_Solutions_catalogue_2026.pdf?v=1775702103
    
    Requirements:
    
    Render PDF using pdf.js (canvas or images), not embed
    Ensure the PDF always loads correctly (fix loading issues)
    Convert pages to optimized images (WebP or canvas)
    Use lazy loading (do not load all pages at once)
    
    Viewer behaviour:
    
    Smooth page flip animation (flipbook style)
    Desktop: show 2-page spread
    Mobile: show 1 page
    First page = cover only, last page = single
    Support swipe (mobile) and keyboard navigation (desktop)
    
    Layout:
    
    Viewer must be centred horizontally on the page
    Increase width so it does not look narrow
    Keep proper page ratio and fit within screen
    Clean, premium catalogue style
    
    Add:
    
    Previous / Next navigation
    Page counter
    Optional demo mode (preview before full load)
    
    Important:
    
    Do not use iframe or basic PDF embed
    Must work inside Shopify section (Liquid + CSS + JS)
    Ensure responsive and smooth performance
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-pdf-viewer-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 40px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-pdf-viewer-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    position: relative;
  }

  .ai-pdf-viewer-loading-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: {{ block.settings.text_color }};
    font-size: 16px;
  }

  .ai-pdf-viewer-error-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #d82c0d;
    font-size: 16px;
  }

  .ai-pdf-viewer-canvas-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    background: {{ block.settings.page_background }};
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
    margin-bottom: 20px;
  }

  .ai-pdf-viewer-pages-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: flex-start;
    gap: 2px;
    padding: 20px;
    min-height: 400px;
  }

  .ai-pdf-viewer-page-{{ ai_gen_id }} {
    flex: 1;
    max-width: 50%;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .ai-pdf-viewer-page-{{ ai_gen_id }}.loaded {
    opacity: 1;
  }

  .ai-pdf-viewer-page-{{ ai_gen_id }} canvas {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-pdf-viewer-single-page-{{ ai_gen_id }} {
    max-width: 100%;
  }

  .ai-pdf-viewer-controls-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 20px;
    padding: 20px;
    background: {{ block.settings.controls_background }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-pdf-viewer-button-{{ ai_gen_id }} {
    background: {{ block.settings.button_background }};
    color: {{ block.settings.button_text }};
    border: none;
    padding: 12px 24px;
    border-radius: {{ block.settings.button_border_radius }}px;
    cursor: pointer;
    font-size: 14px;
    transition: background 0.3s ease;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .ai-pdf-viewer-button-{{ ai_gen_id }}:hover:not(:disabled) {
    background: {{ block.settings.button_hover_background }};
  }

  .ai-pdf-viewer-button-{{ ai_gen_id }}:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .ai-pdf-viewer-page-info-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: 14px;
    font-weight: 500;
  }

  @media screen and (max-width: 749px) {
    .ai-pdf-viewer-{{ ai_gen_id }} {
      padding: 20px 10px;
    }

    .ai-pdf-viewer-pages-{{ ai_gen_id }} {
      padding: 10px;
    }

    .ai-pdf-viewer-page-{{ ai_gen_id }} {
      max-width: 100%;
    }

    .ai-pdf-viewer-controls-{{ ai_gen_id }} {
      flex-wrap: wrap;
      gap: 10px;
    }

    .ai-pdf-viewer-button-{{ ai_gen_id }} {
      padding: 10px 16px;
      font-size: 12px;
    }
  }

  .ai-pdf-viewer-swipe-hint-{{ ai_gen_id }} {
    text-align: center;
    color: {{ block.settings.text_color }};
    font-size: 12px;
    opacity: 0.7;
    margin-top: 10px;
  }

  @media screen and (min-width: 750px) {
    .ai-pdf-viewer-swipe-hint-{{ ai_gen_id }} {
      display: none;
    }
  }
{% endstyle %}

<pdf-catalogue-viewer-{{ ai_gen_id }}
  class="ai-pdf-viewer-{{ ai_gen_id }}"
  data-pdf-url="{{ block.settings.pdf_file }}"
  data-show-spread="{{ block.settings.show_spread }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-pdf-viewer-container-{{ ai_gen_id }}">
    <div class="ai-pdf-viewer-loading-{{ ai_gen_id }}" id="loading-{{ ai_gen_id }}">
      กำลังโหลดแคตตาล็อก...
    </div>
    <div class="ai-pdf-viewer-error-{{ ai_gen_id }}" id="error-{{ ai_gen_id }}" style="display: none;">
      ไม่สามารถโหลด PDF ได้ กรุณาตรวจสอบไฟล์
    </div>
    <div class="ai-pdf-viewer-canvas-container-{{ ai_gen_id }}" id="canvas-container-{{ ai_gen_id }}" style="display: none;">
      <div class="ai-pdf-viewer-pages-{{ ai_gen_id }}" id="pages-{{ ai_gen_id }}"></div>
    </div>
    <div class="ai-pdf-viewer-controls-{{ ai_gen_id }}" id="controls-{{ ai_gen_id }}" style="display: none;">
      <button class="ai-pdf-viewer-button-{{ ai_gen_id }}" id="prev-{{ ai_gen_id }}">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
        ก่อนหน้า
      </button>
      <div class="ai-pdf-viewer-page-info-{{ ai_gen_id }}" id="page-info-{{ ai_gen_id }}">
        <span id="current-page-{{ ai_gen_id }}">1</span> / <span id="total-pages-{{ ai_gen_id }}">0</span>
      </div>
      <button class="ai-pdf-viewer-button-{{ ai_gen_id }}" id="next-{{ ai_gen_id }}">
        ถัดไป
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    </div>
    <div class="ai-pdf-viewer-swipe-hint-{{ ai_gen_id }}">
      ปัดซ้าย-ขวาเพื่อเปลี่ยนหน้า
    </div>
  </div>
</pdf-catalogue-viewer-{{ ai_gen_id }}>

<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
<script>
  (function() {
    pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';

    class PdfCatalogueViewer{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.pdfDoc = null;
        this.currentPage = 1;
        this.totalPages = 0;
        this.isRendering = false;
        this.pageCache = new Map();
        this.touchStartX = 0;
        this.touchEndX = 0;
      }

      connectedCallback() {
        this.pdfUrl = this.dataset.pdfUrl;
        this.showSpread = this.dataset.showSpread === 'true';
        
        this.loadingEl = this.querySelector('#loading-{{ ai_gen_id }}');
        this.errorEl = this.querySelector('#error-{{ ai_gen_id }}');
        this.canvasContainer = this.querySelector('#canvas-container-{{ ai_gen_id }}');
        this.pagesContainer = this.querySelector('#pages-{{ ai_gen_id }}');
        this.controlsEl = this.querySelector('#controls-{{ ai_gen_id }}');
        this.prevBtn = this.querySelector('#prev-{{ ai_gen_id }}');
        this.nextBtn = this.querySelector('#next-{{ ai_gen_id }}');
        this.currentPageEl = this.querySelector('#current-page-{{ ai_gen_id }}');
        this.totalPagesEl = this.querySelector('#total-pages-{{ ai_gen_id }}');

        if (!this.pdfUrl) {
          this.showError();
          return;
        }

        this.setupEventListeners();
        this.loadPDF();
      }

      setupEventListeners() {
        this.prevBtn.addEventListener('click', () => this.previousPage());
        this.nextBtn.addEventListener('click', () => this.nextPage());

        document.addEventListener('keydown', (e) => {
          if (e.key === 'ArrowLeft') this.previousPage();
          if (e.key === 'ArrowRight') this.nextPage();
        });

        this.canvasContainer.addEventListener('touchstart', (e) => {
          this.touchStartX = e.changedTouches[0].screenX;
        });

        this.canvasContainer.addEventListener('touchend', (e) => {
          this.touchEndX = e.changedTouches[0].screenX;
          this.handleSwipe();
        });
      }

      handleSwipe() {
        const swipeThreshold = 50;
        const diff = this.touchStartX - this.touchEndX;

        if (Math.abs(diff) > swipeThreshold) {
          if (diff > 0) {
            this.nextPage();
          } else {
            this.previousPage();
          }
        }
      }

      async loadPDF() {
        try {
          const loadingTask = pdfjsLib.getDocument(this.pdfUrl);
          this.pdfDoc = await loadingTask.promise;
          this.totalPages = this.pdfDoc.numPages;
          this.totalPagesEl.textContent = this.totalPages;
          
          this.loadingEl.style.display = 'none';
          this.canvasContainer.style.display = 'block';
          this.controlsEl.style.display = 'flex';
          
          await this.renderPages();
        } catch (error) {
          console.error('PDF loading error:', error);
          this.showError();
        }
      }

      showError() {
        this.loadingEl.style.display = 'none';
        this.errorEl.style.display = 'block';
      }

      async renderPages() {
        if (this.isRendering) return;
        this.isRendering = true;

        this.pagesContainer.innerHTML = '';

        const isMobile = window.innerWidth < 750;
        const isFirstPage = this.currentPage === 1;
        const isLastPage = this.currentPage === this.totalPages;
        const shouldShowSpread = this.showSpread && !isMobile && !isFirstPage && !isLastPage;

        if (shouldShowSpread) {
          const leftPage = this.currentPage;
          const rightPage = this.currentPage + 1;

          if (rightPage <= this.totalPages) {
            await this.renderPage(leftPage, false);
            await this.renderPage(rightPage, false);
          } else {
            await this.renderPage(leftPage, true);
          }
        } else {
          await this.renderPage(this.currentPage, true);
        }

        this.updateControls();
        this.isRendering = false;
      }

      async renderPage(pageNum, isSingle) {
        if (this.pageCache.has(pageNum)) {
          const cachedCanvas = this.pageCache.get(pageNum);
          this.appendCanvas(cachedCanvas.cloneNode(true), isSingle);
          return;
        }

        const page = await this.pdfDoc.getPage(pageNum);
        const viewport = page.getViewport({ scale: 2.0 });
        
        const canvas = document.createElement('canvas');
        const context = canvas.getContext('2d');
        canvas.height = viewport.height;
        canvas.width = viewport.width;

        await page.render({
          canvasContext: context,
          viewport: viewport
        }).promise;

        this.pageCache.set(pageNum, canvas.cloneNode(true));
        this.appendCanvas(canvas, isSingle);
      }

      appendCanvas(canvas, isSingle) {
        const pageDiv = document.createElement('div');
        pageDiv.className = 'ai-pdf-viewer-page-{{ ai_gen_id }}';
        if (isSingle) {
          pageDiv.classList.add('ai-pdf-viewer-single-page-{{ ai_gen_id }}');
        }
        pageDiv.appendChild(canvas);
        this.pagesContainer.appendChild(pageDiv);

        setTimeout(() => {
          pageDiv.classList.add('loaded');
        }, 50);
      }

      updateControls() {
        const isMobile = window.innerWidth < 750;
        const isFirstPage = this.currentPage === 1;
        const isLastPage = this.currentPage === this.totalPages;
        const shouldShowSpread = this.showSpread && !isMobile && !isFirstPage && !isLastPage;

        this.currentPageEl.textContent = this.currentPage;
        this.prevBtn.disabled = this.currentPage === 1;
        
        if (shouldShowSpread) {
          this.nextBtn.disabled = this.currentPage >= this.totalPages - 1;
        } else {
          this.nextBtn.disabled = this.currentPage >= this.totalPages;
        }
      }

      previousPage() {
        if (this.currentPage <= 1) return;

        const isMobile = window.innerWidth < 750;
        const shouldShowSpread = this.showSpread && !isMobile;

        if (shouldShowSpread && this.currentPage > 2) {
          this.currentPage -= 2;
        } else {
          this.currentPage -= 1;
        }

        this.renderPages();
      }

      nextPage() {
        if (this.currentPage >= this.totalPages) return;

        const isMobile = window.innerWidth < 750;
        const isFirstPage = this.currentPage === 1;
        const shouldShowSpread = this.showSpread && !isMobile && !isFirstPage;

        if (shouldShowSpread && this.currentPage < this.totalPages - 1) {
          this.currentPage += 2;
        } else {
          this.currentPage += 1;
        }

        if (this.currentPage > this.totalPages) {
          this.currentPage = this.totalPages;
        }

        this.renderPages();
      }
    }

    customElements.define('pdf-catalogue-viewer-{{ ai_gen_id }}', PdfCatalogueViewer{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "PDF catalogue viewer",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "PDF file"
    },
    {
      "type": "url",
      "id": "pdf_file",
      "label": "PDF file URL"
    },
    {
      "type": "paragraph",
      "content": "Upload your PDF to Shopify Files and paste the URL here"
    },
    {
      "type": "header",
      "content": "Display settings"
    },
    {
      "type": "checkbox",
      "id": "show_spread",
      "label": "Show 2-page spread on desktop",
      "default": true
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Maximum width",
      "min": 800,
      "max": 1600,
      "step": 100,
      "unit": "px",
      "default": 1200
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#f5f5f5"
    },
    {
      "type": "color",
      "id": "page_background",
      "label": "Page background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "controls_background",
      "label": "Controls background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Button style"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_hover_background",
      "label": "Hover background",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "button_text",
      "label": "Text",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "PDF catalogue viewer"
    }
  ]
}
{% endschema %}
