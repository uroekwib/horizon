{% doc %}
  @prompt
    Create a Shopify section for viewing this PDF catalogue:
    https://cdn.shopify.com/s/files/1/0098/2653/3433/files/Octopus_Media_Solutions_catalogue_2026.pdf?v=1775702103
    
    Render the PDF properly using pdf.js, not iframe or embed.
    Show the viewer in the centre of the page, make it wider, and display the pages clearly.
    Add simple Previous and Next buttons, mobile swipe, and smooth page loading.
    On desktop show 2 pages, on mobile show 1 page.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-pdf-viewer-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 40px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-pdf-viewer-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-pdf-viewer-canvas-wrapper-{{ ai_gen_id }} {
    position: relative;
    background-color: {{ block.settings.canvas_background }};
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
    margin-bottom: 20px;
    touch-action: pan-y;
  }

  .ai-pdf-viewer-canvas-container-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: flex-start;
    gap: 2px;
    padding: 20px;
    min-height: 400px;
  }

  .ai-pdf-viewer-canvas-{{ ai_gen_id }} {
    max-width: 100%;
    height: auto;
    display: block;
  }

  .ai-pdf-viewer-loading-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    color: {{ block.settings.text_color }};
    font-size: 16px;
  }

  .ai-pdf-viewer-controls-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
  }

  .ai-pdf-viewer-button-{{ ai_gen_id }} {
    padding: 12px 24px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    cursor: pointer;
    font-size: 14px;
    transition: background-color 0.3s ease;
    min-width: 100px;
  }

  .ai-pdf-viewer-button-{{ ai_gen_id }}:hover:not(:disabled) {
    background-color: {{ block.settings.button_hover_background }};
  }

  .ai-pdf-viewer-button-{{ ai_gen_id }}:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .ai-pdf-viewer-page-info-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: 14px;
    min-width: 100px;
    text-align: center;
  }

  @media screen and (max-width: 749px) {
    .ai-pdf-viewer-{{ ai_gen_id }} {
      padding: 20px 10px;
    }

    .ai-pdf-viewer-canvas-container-{{ ai_gen_id }} {
      padding: 10px;
      gap: 0;
    }

    .ai-pdf-viewer-controls-{{ ai_gen_id }} {
      gap: 10px;
    }

    .ai-pdf-viewer-button-{{ ai_gen_id }} {
      padding: 10px 20px;
      min-width: 80px;
      font-size: 13px;
    }
  }
{% endstyle %}

<pdf-viewer-{{ ai_gen_id }}
  class="ai-pdf-viewer-{{ ai_gen_id }}"
  data-pdf-url="{{ block.settings.pdf_url }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-pdf-viewer-container-{{ ai_gen_id }}">
    <div class="ai-pdf-viewer-canvas-wrapper-{{ ai_gen_id }}">
      <div class="ai-pdf-viewer-canvas-container-{{ ai_gen_id }}">
        <canvas class="ai-pdf-viewer-canvas-{{ ai_gen_id }}" data-page="1"></canvas>
        <canvas class="ai-pdf-viewer-canvas-{{ ai_gen_id }}" data-page="2"></canvas>
      </div>
      <div class="ai-pdf-viewer-loading-{{ ai_gen_id }}">Loading PDF...</div>
    </div>

    <div class="ai-pdf-viewer-controls-{{ ai_gen_id }}">
      <button class="ai-pdf-viewer-button-{{ ai_gen_id }} ai-pdf-viewer-prev-{{ ai_gen_id }}" disabled>
        Previous
      </button>
      <div class="ai-pdf-viewer-page-info-{{ ai_gen_id }}">
        <span class="ai-pdf-viewer-current-{{ ai_gen_id }}">1</span> / <span class="ai-pdf-viewer-total-{{ ai_gen_id }}">-</span>
      </div>
      <button class="ai-pdf-viewer-button-{{ ai_gen_id }} ai-pdf-viewer-next-{{ ai_gen_id }}">
        Next
      </button>
    </div>
  </div>
</pdf-viewer-{{ ai_gen_id }}>

<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>

<script>
  (function() {
    class PdfViewer{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.pdfDoc = null;
        this.currentPage = 1;
        this.totalPages = 0;
        this.rendering = false;
        this.scale = 1.5;
        this.touchStartX = 0;
        this.touchEndX = 0;
      }

      connectedCallback() {
        this.pdfUrl = this.dataset.pdfUrl;
        this.canvasContainer = this.querySelector('.ai-pdf-viewer-canvas-container-{{ ai_gen_id }}');
        this.canvases = this.querySelectorAll('.ai-pdf-viewer-canvas-{{ ai_gen_id }}');
        this.loadingEl = this.querySelector('.ai-pdf-viewer-loading-{{ ai_gen_id }}');
        this.prevBtn = this.querySelector('.ai-pdf-viewer-prev-{{ ai_gen_id }}');
        this.nextBtn = this.querySelector('.ai-pdf-viewer-next-{{ ai_gen_id }}');
        this.currentPageEl = this.querySelector('.ai-pdf-viewer-current-{{ ai_gen_id }}');
        this.totalPagesEl = this.querySelector('.ai-pdf-viewer-total-{{ ai_gen_id }}');

        this.isMobile = window.innerWidth < 750;

        if (this.isMobile) {
          this.canvases[1].style.display = 'none';
        }

        if (typeof pdfjsLib !== 'undefined') {
          pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';
          this.loadPDF();
        }

        this.setupEventListeners();
      }

      setupEventListeners() {
        this.prevBtn.addEventListener('click', () => this.previousPage());
        this.nextBtn.addEventListener('click', () => this.nextPage());

        this.canvasContainer.addEventListener('touchstart', (e) => {
          this.touchStartX = e.changedTouches[0].screenX;
        });

        this.canvasContainer.addEventListener('touchend', (e) => {
          this.touchEndX = e.changedTouches[0].screenX;
          this.handleSwipe();
        });

        window.addEventListener('resize', () => {
          const wasMobile = this.isMobile;
          this.isMobile = window.innerWidth < 750;
          
          if (wasMobile !== this.isMobile) {
            if (this.isMobile) {
              this.canvases[1].style.display = 'none';
            } else {
              this.canvases[1].style.display = 'block';
            }
            this.renderPages();
          }
        });
      }

      handleSwipe() {
        const swipeThreshold = 50;
        const diff = this.touchStartX - this.touchEndX;

        if (Math.abs(diff) > swipeThreshold) {
          if (diff > 0) {
            this.nextPage();
          } else {
            this.previousPage();
          }
        }
      }

      async loadPDF() {
        try {
          const loadingTask = pdfjsLib.getDocument(this.pdfUrl);
          this.pdfDoc = await loadingTask.promise;
          this.totalPages = this.pdfDoc.numPages;
          this.totalPagesEl.textContent = this.totalPages;
          this.loadingEl.style.display = 'none';
          this.renderPages();
          this.updateButtons();
        } catch (error) {
          this.loadingEl.textContent = 'Error loading PDF';
          console.error('Error loading PDF:', error);
        }
      }

      async renderPages() {
        if (!this.pdfDoc || this.rendering) return;
        this.rendering = true;

        try {
          if (this.isMobile) {
            await this.renderPage(this.currentPage, this.canvases[0]);
          } else {
            await this.renderPage(this.currentPage, this.canvases[0]);
            if (this.currentPage < this.totalPages) {
              await this.renderPage(this.currentPage + 1, this.canvases[1]);
            } else {
              const ctx = this.canvases[1].getContext('2d');
              ctx.clearRect(0, 0, this.canvases[1].width, this.canvases[1].height);
            }
          }
        } catch (error) {
          console.error('Error rendering pages:', error);
        }

        this.rendering = false;
      }

      async renderPage(pageNum, canvas) {
        if (pageNum > this.totalPages) return;

        const page = await this.pdfDoc.getPage(pageNum);
        const viewport = page.getViewport({ scale: this.scale });
        const context = canvas.getContext('2d');

        canvas.height = viewport.height;
        canvas.width = viewport.width;

        const renderContext = {
          canvasContext: context,
          viewport: viewport
        };

        await page.render(renderContext).promise;
      }

      previousPage() {
        if (this.currentPage <= 1) return;
        
        if (this.isMobile) {
          this.currentPage--;
        } else {
          this.currentPage = Math.max(1, this.currentPage - 2);
        }
        
        this.currentPageEl.textContent = this.currentPage;
        this.renderPages();
        this.updateButtons();
      }

      nextPage() {
        if (this.isMobile) {
          if (this.currentPage >= this.totalPages) return;
          this.currentPage++;
        } else {
          if (this.currentPage >= this.totalPages) return;
          this.currentPage = Math.min(this.totalPages, this.currentPage + 2);
        }
        
        this.currentPageEl.textContent = this.currentPage;
        this.renderPages();
        this.updateButtons();
      }

      updateButtons() {
        this.prevBtn.disabled = this.currentPage <= 1;
        
        if (this.isMobile) {
          this.nextBtn.disabled = this.currentPage >= this.totalPages;
        } else {
          this.nextBtn.disabled = this.currentPage >= this.totalPages;
        }
      }
    }

    customElements.define('pdf-viewer-{{ ai_gen_id }}', PdfViewer{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "PDF catalogue viewer",
  "settings": [
    {
      "type": "header",
      "content": "PDF file"
    },
    {
      "type": "text",
      "id": "pdf_url",
      "label": "PDF URL",
      "default": "https://cdn.shopify.com/s/files/1/0098/2653/3433/files/Octopus_Media_Solutions_catalogue_2026.pdf?v=1775702103"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Maximum width",
      "min": 800,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "default": 1200
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#f3f7fa"
    },
    {
      "type": "color",
      "id": "canvas_background",
      "label": "Canvas background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Button background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_text",
      "label": "Button text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_background",
      "label": "Button hover background",
      "default": "#333333"
    },
    {
      "type": "header",
      "content": "Button style"
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "PDF catalogue viewer"
    }
  ]
}
{% endschema %}
