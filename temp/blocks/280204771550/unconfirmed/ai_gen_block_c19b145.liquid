{% doc %}
  @prompt
    อยากได้ blockโชว์ product card ที่ filter มาจาก collection/subcollection
    
    เราจะโชว์ collection pill 8-10 อัน พอกดให้ active ก็จะโชว์ subcillection pils ออกมาเพิ่มเติม ให้กดเพื่อเลือก filter และแสดงแต่ product cards ที่อยู่ภายใต้หมวดนั้น ๆ ออกมา โดยเป็นการโหลดหน้า url ของ collection หรือ subcollection นั้น ๆ ออกมา, subcoll เตรียมไว้แล้ว เป็น list Metafields ชื่อ subcollections, พอเรากดเลือก  Collection ก็จะเปลี่ยน url เลย แล้วก็มี subcoll โชว์ และกดก็เปลี่ยน url ไปต่อ, collection สามารถ select เลือกภาพ icon เล็ก ๆ ไว้หน้าข้อความของแต่ละ pill ได้
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-collection-filter-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-collection-filter__wrapper-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.spacing }}px;
  }

  .ai-collection-filter__pills-container-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: {{ block.settings.pill_gap }}px;
  }

  .ai-collection-filter__pill-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: {{ block.settings.pill_padding_vertical }}px {{ block.settings.pill_padding_horizontal }}px;
    background-color: {{ block.settings.pill_background }};
    color: {{ block.settings.pill_text_color }};
    border: {{ block.settings.pill_border_width }}px solid {{ block.settings.pill_border_color }};
    border-radius: {{ block.settings.pill_border_radius }}px;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s ease;
    font-size: {{ block.settings.pill_font_size }}px;
  }

  .ai-collection-filter__pill-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.pill_hover_background }};
    color: {{ block.settings.pill_hover_text_color }};
    border-color: {{ block.settings.pill_hover_border_color }};
  }

  .ai-collection-filter__pill-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.pill_active_background }};
    color: {{ block.settings.pill_active_text_color }};
    border-color: {{ block.settings.pill_active_border_color }};
  }

  .ai-collection-filter__pill-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    object-fit: contain;
    flex-shrink: 0;
  }

  .ai-collection-filter__subcollections-{{ ai_gen_id }} {
    display: none;
    flex-wrap: wrap;
    gap: {{ block.settings.pill_gap }}px;
    padding-left: {{ block.settings.subcollection_indent }}px;
  }

  .ai-collection-filter__subcollections-{{ ai_gen_id }}.visible {
    display: flex;
  }

  .ai-collection-filter__products-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.products_per_row_desktop }}, 1fr);
    gap: {{ block.settings.product_gap }}px;
    margin-top: {{ block.settings.spacing }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-collection-filter__products-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.products_per_row_mobile }}, 1fr);
    }
  }

  .ai-collection-filter__product-card-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
    text-decoration: none;
    color: inherit;
  }

  .ai-collection-filter__product-image-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: {{ block.settings.product_image_radius }}px;
  }

  .ai-collection-filter__product-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_title_size }}px;
    margin: 0;
  }

  .ai-collection-filter__product-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_price_size }}px;
    color: {{ block.settings.product_price_color }};
  }

  .ai-collection-filter__loading-{{ ai_gen_id }} {
    text-align: center;
    padding: 40px;
    color: {{ block.settings.pill_text_color }};
  }

  .ai-collection-filter__empty-{{ ai_gen_id }} {
    text-align: center;
    padding: 40px;
    color: {{ block.settings.pill_text_color }};
  }
{% endstyle %}

<collection-filter-{{ ai_gen_id }}
  class="ai-collection-filter-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
  data-current-collection="{{ collection.handle }}"
>
  <div class="ai-collection-filter__wrapper-{{ ai_gen_id }}">
    <div class="ai-collection-filter__pills-container-{{ ai_gen_id }}">
      {% for i in (1..10) %}
        {% liquid
          assign collection_key = 'collection_' | append: i
          assign icon_key = 'collection_' | append: i | append: '_icon'
          assign selected_collection = block.settings[collection_key]
          assign collection_icon = block.settings[icon_key]
        %}

        {% if selected_collection != blank %}
          <a
            href="{{ selected_collection.url }}"
            class="ai-collection-filter__pill-{{ ai_gen_id }} {% if collection.handle == selected_collection.handle %}active{% endif %}"
            data-collection-handle="{{ selected_collection.handle }}"
            data-collection-index="{{ i }}"
          >
            {% if collection_icon != blank %}
              <img
                src="{{ collection_icon | image_url: width: 100 }}"
                alt="{{ selected_collection.title }}"
                class="ai-collection-filter__pill-icon-{{ ai_gen_id }}"
                width="100"
                height="100"
                loading="lazy"
              >
            {% endif %}
            {{ selected_collection.title }}
          </a>

          {% if collection.handle == selected_collection.handle and selected_collection.metafields.custom.subcollections != blank %}
            <div class="ai-collection-filter__subcollections-{{ ai_gen_id }} visible" data-parent-collection="{{ selected_collection.handle }}">
              {% for subcollection in selected_collection.metafields.custom.subcollections.value %}
                <a
                  href="{{ subcollection.url }}"
                  class="ai-collection-filter__pill-{{ ai_gen_id }} {% if collection.handle == subcollection.handle %}active{% endif %}"
                  data-subcollection-handle="{{ subcollection.handle }}"
                >
                  {{ subcollection.title }}
                </a>
              {% endfor %}
            </div>
          {% endif %}
        {% endif %}
      {% endfor %}
    </div>

    <div class="ai-collection-filter__products-{{ ai_gen_id }}" id="ai-collection-products-{{ ai_gen_id }}">
      {% if collection.products.size > 0 %}
        {% for product in collection.products limit: block.settings.products_limit %}
          <a href="{{ product.url }}" class="ai-collection-filter__product-card-{{ ai_gen_id }}">
            {% if product.featured_image %}
              <img
                src="{{ product.featured_image | image_url: width: 600 }}"
                alt="{{ product.featured_image.alt | escape }}"
                class="ai-collection-filter__product-image-{{ ai_gen_id }}"
                width="600"
                height="600"
                loading="lazy"
              >
            {% else %}
              <div class="ai-collection-filter__product-image-{{ ai_gen_id }}" style="background-color: #f4f4f4;">
                {{ 'product-1' | placeholder_svg_tag }}
              </div>
            {% endif %}
            <h3 class="ai-collection-filter__product-title-{{ ai_gen_id }}">{{ product.title }}</h3>
            <div class="ai-collection-filter__product-price-{{ ai_gen_id }}">{{ product.price | money }}</div>
          </a>
        {% endfor %}
      {% else %}
        <div class="ai-collection-filter__empty-{{ ai_gen_id }}">
          ไม่มีสินค้าในหมวดนี้
        </div>
      {% endif %}
    </div>
  </div>
</collection-filter-{{ ai_gen_id }}>

<script>
  (function() {
    class CollectionFilter{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentCollection = this.dataset.currentCollection;
      }

      connectedCallback() {
        this.pills = this.querySelectorAll('.ai-collection-filter__pill-{{ ai_gen_id }}');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.pills.forEach((pill) => {
          pill.addEventListener('click', (e) => {
            const collectionHandle = pill.dataset.collectionHandle;
            const subcollectionHandle = pill.dataset.subcollectionHandle;

            if (collectionHandle) {
              const collectionIndex = pill.dataset.collectionIndex;
              const subcollectionsContainer = this.querySelector(`.ai-collection-filter__subcollections-{{ ai_gen_id }}[data-parent-collection="${collectionHandle}"]`);

              this.querySelectorAll('.ai-collection-filter__subcollections-{{ ai_gen_id }}').forEach((container) => {
                if (container !== subcollectionsContainer) {
                  container.classList.remove('visible');
                }
              });

              if (subcollectionsContainer) {
                subcollectionsContainer.classList.add('visible');
              }
            }
          });
        });
      }
    }

    customElements.define('collection-filter-{{ ai_gen_id }}', CollectionFilter{{ ai_gen_id }});
  })();
</script>

