{% doc %}
  @prompt
    อยากได้ blockโชว์ product card ที่ filter มาจาก collection/subcollection
    
    เราจะโชว์ collection pill 8-10 อัน พอกดให้ active ก็จะโชว์ subcillection pils ออกมาเพิ่มเติม ให้กดเพื่อเลือก filter และแสดงแต่ product cards ที่อยู่ภายใต้หมวดนั้น ๆ ออกมา โดยเป็นการโหลดหน้า url ของ collection หรือ subcollection นั้น ๆ ออกมา, subcoll เตรียมไว้แล้ว เป็น Subcollections
    
    Collection (List) 
    
    พอเรากดเลือก Collection ก็จะเปลี่ยน url เลย แล้วก็มี subcollections โชว์ pills ออกมา โดยที่เมื่อเราเลือก subcoll สลับไปมาภายใต้ coll เดียวกัน url จะไม่ได้เปลี่ยนนะ
    
    collection สามารถ select เลือกภาพ icon เล็ก ๆ ไว้หน้าข้อความของแต่ละ pill ได้
    , coll, subcoll pilss ขึ้นถูกต้องแล้ว แต่ เกิดข้อผิดพลาดในการโหลดสินค้า ซึ่งไม่ควรเกิดขึ้น, ระดับ collection เมื่อกดแล้วต้องเปลี่ยน url ไปก่อนด้วย
    
    ส่วน product ที่โหลดขึ้นมาตอนนี้มีสินค้าซ้ำกัน 3 ครั้ง, product card โหลดมาแล้ว แต่ข้อมูลมาไม่ถูกต้อง รูปไม่ขึ้น ราคาไม่ขึ้น
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-collection-filter-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-collection-filter__container-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.spacing }}px;
  }

  .ai-collection-filter__pills-wrapper-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.pill_spacing }}px;
  }

  .ai-collection-filter__pills-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: {{ block.settings.pill_spacing }}px;
  }

  .ai-collection-filter__pill-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: {{ block.settings.pill_padding_vertical }}px {{ block.settings.pill_padding_horizontal }}px;
    background-color: {{ block.settings.pill_background }};
    color: {{ block.settings.pill_text_color }};
    border: {{ block.settings.pill_border_width }}px solid {{ block.settings.pill_border_color }};
    border-radius: {{ block.settings.pill_border_radius }}px;
    font-size: {{ block.settings.pill_font_size }}px;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-collection-filter__pill-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.pill_hover_background }};
    color: {{ block.settings.pill_hover_text_color }};
    border-color: {{ block.settings.pill_hover_border_color }};
  }

  .ai-collection-filter__pill-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.pill_active_background }};
    color: {{ block.settings.pill_active_text_color }};
    border-color: {{ block.settings.pill_active_border_color }};
  }

  .ai-collection-filter__pill-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    object-fit: contain;
    flex-shrink: 0;
  }

  .ai-collection-filter__subcollections-{{ ai_gen_id }} {
    display: none;
    opacity: 0;
    max-height: 0;
    overflow: hidden;
    transition: opacity 0.3s ease, max-height 0.3s ease;
  }

  .ai-collection-filter__subcollections-{{ ai_gen_id }}.active {
    display: block;
    opacity: 1;
    max-height: 500px;
  }

  .ai-collection-filter__products-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.products_per_row_desktop }}, 1fr);
    gap: {{ block.settings.product_grid_gap }}px;
    margin-top: {{ block.settings.spacing }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-collection-filter__products-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.products_per_row_mobile }}, 1fr);
    }
  }

  .ai-collection-filter__product-card-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
    text-decoration: none;
    color: inherit;
  }

  .ai-collection-filter__product-image-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: {{ block.settings.product_image_radius }}px;
  }

  .ai-collection-filter__product-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_title_size }}px;
    font-weight: 500;
    margin: 0;
  }

  .ai-collection-filter__product-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_price_size }}px;
    color: {{ block.settings.product_price_color }};
  }

  .ai-collection-filter__loading-{{ ai_gen_id }} {
    display: none;
    text-align: center;
    padding: 40px;
    font-size: 16px;
    color: #666;
  }

  .ai-collection-filter__loading-{{ ai_gen_id }}.active {
    display: block;
  }

  .ai-collection-filter__empty-{{ ai_gen_id }} {
    text-align: center;
    padding: 40px;
    font-size: 16px;
    color: #999;
  }
{% endstyle %}

<collection-filter-{{ ai_gen_id }}
  class="ai-collection-filter-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
  data-products-per-page="{{ block.settings.products_per_page }}"
>
  <div class="ai-collection-filter__container-{{ ai_gen_id }}">
    <div class="ai-collection-filter__pills-wrapper-{{ ai_gen_id }}">
      <div class="ai-collection-filter__pills-{{ ai_gen_id }}" data-type="collections">
        {% for i in (1..10) %}
          {% liquid
            assign collection_key = 'collection_' | append: i
            assign icon_key = 'collection_' | append: i | append: '_icon'
            assign collection = block.settings[collection_key]
            assign icon = block.settings[icon_key]
          %}
          {% if collection != blank %}
            <a
              href="{{ collection.url }}"
              class="ai-collection-filter__pill-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}"
              data-collection-handle="{{ collection.handle }}"
              data-collection-index="{{ i }}"
            >
              {% if icon != blank %}
                <img
                  src="{{ icon | image_url: width: 100 }}"
                  alt="{{ collection.title }}"
                  class="ai-collection-filter__pill-icon-{{ ai_gen_id }}"
                  width="100"
                  height="100"
                  loading="lazy"
                >
              {% endif %}
              <span>{{ collection.title }}</span>
            </a>
          {% endif %}
        {% endfor %}
      </div>

      {% for i in (1..10) %}
        {% liquid
          assign collection_key = 'collection_' | append: i
          assign collection = block.settings[collection_key]
        %}
        {% if collection != blank %}
          <div
            class="ai-collection-filter__subcollections-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}"
            data-parent-collection="{{ i }}"
          >
            <div class="ai-collection-filter__pills-{{ ai_gen_id }}" data-type="subcollections">
              {% if collection.metafields.custom.subcollections != blank %}
                {% for subcollection in collection.metafields.custom.subcollections.value %}
                  <button
                    type="button"
                    class="ai-collection-filter__pill-{{ ai_gen_id }}"
                    data-subcollection-handle="{{ subcollection.handle }}"
                  >
                    <span>{{ subcollection.title }}</span>
                  </button>
                {% endfor %}
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <div class="ai-collection-filter__loading-{{ ai_gen_id }}">
      กำลังโหลด...
    </div>

    <div class="ai-collection-filter__products-{{ ai_gen_id }}" data-products-container></div>
  </div>
</collection-filter-{{ ai_gen_id }}>

<script>
  (function() {
    class CollectionFilter{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.collectionPills = this.querySelectorAll('[data-collection-handle]');
        this.subcollectionPills = this.querySelectorAll('[data-subcollection-handle]');
        this.subcollectionContainers = this.querySelectorAll('.ai-collection-filter__subcollections-{{ ai_gen_id }}');
        this.productsContainer = this.querySelector('[data-products-container]');
        this.loadingIndicator = this.querySelector('.ai-collection-filter__loading-{{ ai_gen_id }}');
        this.productsPerPage = parseInt(this.dataset.productsPerPage) || 12;
        this.currentCollectionHandle = null;
        this.currentSubcollectionHandle = null;
      }

      connectedCallback() {
        this.setupEventListeners();
        const firstCollection = this.querySelector('[data-collection-handle]');
        if (firstCollection) {
          this.currentCollectionHandle = firstCollection.dataset.collectionHandle;
          this.loadProducts(this.currentCollectionHandle);
        }
      }

      setupEventListeners() {
        this.collectionPills.forEach(pill => {
          pill.addEventListener('click', (e) => {
            e.preventDefault();
            const handle = pill.dataset.collectionHandle;
            const index = pill.dataset.collectionIndex;
            
            window.history.pushState({}, '', pill.href);
            
            this.collectionPills.forEach(p => p.classList.remove('active'));
            pill.classList.add('active');
            
            this.subcollectionContainers.forEach(container => {
              container.classList.remove('active');
            });
            
            const targetSubcollections = this.querySelector(`[data-parent-collection="${index}"]`);
            if (targetSubcollections) {
              targetSubcollections.classList.add('active');
            }
            
            this.querySelectorAll('[data-subcollection-handle]').forEach(sp => {
              sp.classList.remove('active');
            });
            
            this.currentCollectionHandle = handle;
            this.currentSubcollectionHandle = null;
            
            this.loadProducts(handle);
          });
        });

        this.subcollectionPills.forEach(pill => {
          pill.addEventListener('click', () => {
            const handle = pill.dataset.subcollectionHandle;
            
            const parentContainer = pill.closest('.ai-collection-filter__subcollections-{{ ai_gen_id }}');
            if (parentContainer) {
              parentContainer.querySelectorAll('[data-subcollection-handle]').forEach(p => {
                p.classList.remove('active');
              });
            }
            pill.classList.add('active');
            
            this.currentSubcollectionHandle = handle;
            
            this.loadProducts(handle);
          });
        });
      }

      async loadProducts(collectionHandle) {
        if (!collectionHandle) {
          this.productsContainer.innerHTML = '<div class="ai-collection-filter__empty-{{ ai_gen_id }}">กรุณาเลือก collection</div>';
          return;
        }

        this.loadingIndicator.classList.add('active');
        this.productsContainer.innerHTML = '';

        try {
          const url = `/collections/${collectionHandle}?view=json`;
          const response = await fetch(url);
          
          if (!response.ok) {
            throw new Error(`HTTP error! status: ${response.status}`);
          }
          
          const html = await response.text();
          const parser = new DOMParser();
          const doc = parser.parseFromString(html, 'text/html');
          const jsonScript = doc.querySelector('script[type="application/json"]');
          
          if (!jsonScript) {
            throw new Error('No JSON data found');
          }
          
          const data = JSON.parse(jsonScript.textContent);
          
          this.loadingIndicator.classList.remove('active');
          
          if (data.products && data.products.length > 0) {
            this.renderProducts(data.products.slice(0, this.productsPerPage));
          } else {
            this.productsContainer.innerHTML = '<div class="ai-collection-filter__empty-{{ ai_gen_id }}">ไม่พบสินค้าในหมวดนี้</div>';
          }
        } catch (error) {
          console.error('Error loading products:', error);
          this.loadingIndicator.classList.remove('active');
          this.productsContainer.innerHTML = '<div class="ai-collection-filter__empty-{{ ai_gen_id }}">เกิดข้อผิดพลาดในการโหลดสินค้า</div>';
        }
      }

      renderProducts(products) {
        this.productsContainer.innerHTML = products.map(product => {
          const imageUrl = product.featured_image || '';
          const price = product.price || 0;
          
          return `
            <a href="${product.url}" class="ai-collection-filter__product-card-{{ ai_gen_id }}">
              ${imageUrl ? `<img src="${imageUrl}" alt="${this.escapeHtml(product.title)}" class="ai-collection-filter__product-image-{{ ai_gen_id }}" loading="lazy">` : ''}
              <h3 class="ai-collection-filter__product-title-{{ ai_gen_id }}">${this.escapeHtml(product.title)}</h3>
              <div class="ai-collection-filter__product-price-{{ ai_gen_id }}">
                ${this.formatPrice(price)}
              </div>
            </a>
          `;
        }).join('');
      }

      escapeHtml(text) {
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
      }

      formatPrice(price) {
        return new Intl.NumberFormat('th-TH', {
          style: 'currency',
          currency: 'THB'
        }).format(price / 100);
      }
    }

    customElements.define('collection-filter-{{ ai_gen_id }}', CollectionFilter{{ ai_gen_id }});
  })();
</script>

