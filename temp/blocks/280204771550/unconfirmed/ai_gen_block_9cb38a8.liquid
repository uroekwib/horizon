{% doc %}
  @prompt
    อยากได้ blockโชว์ product card ที่ filter มาจาก collection/subcollection
    
    เราจะโชว์ collection pill 8-10 อัน พอกดให้ active ก็จะโชว์ subcillection pils ออกมาเพิ่มเติม ให้กดเพื่อเลือก filter และแสดงแต่ product cards ที่อยู่ภายใต้หมวดนั้น ๆ ออกมา โดยเป็นการโหลดหน้า url ของ collection หรือ subcollection นั้น ๆ ออกมา, subcoll เตรียมไว้แล้ว เป็น list Metafields ชื่อ subcollections, พอเรากดเลือก  Collection ก็จะเปลี่ยน url เลย แล้วก็มี subcoll โชว์ และกดก็เปลี่ยน url ไปต่อ, collection สามารถกำหนด icon svg ไว้หน้าข้อความของแต่ละ pill ได้, แต่ละ collection สามารถใส่รูป svg icon ไว้หน้าข้อความของแต่ละ pill ได้
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-collection-filter-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-collection-filter__container-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.spacing }}px;
  }

  .ai-collection-filter__pills-wrapper-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: {{ block.settings.pill_gap }}px;
  }

  .ai-collection-filter__pill-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: {{ block.settings.pill_padding_vertical }}px {{ block.settings.pill_padding_horizontal }}px;
    background-color: {{ block.settings.pill_background }};
    color: {{ block.settings.pill_text_color }};
    border: {{ block.settings.pill_border_width }}px solid {{ block.settings.pill_border_color }};
    border-radius: {{ block.settings.pill_border_radius }}px;
    font-size: {{ block.settings.pill_font_size }}px;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-collection-filter__pill-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.pill_hover_background }};
    color: {{ block.settings.pill_hover_text_color }};
    border-color: {{ block.settings.pill_hover_border_color }};
  }

  .ai-collection-filter__pill-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.pill_active_background }};
    color: {{ block.settings.pill_active_text_color }};
    border-color: {{ block.settings.pill_active_border_color }};
  }

  .ai-collection-filter__pill-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    flex-shrink: 0;
  }

  .ai-collection-filter__pill-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    fill: currentColor;
  }

  .ai-collection-filter__subcollections-{{ ai_gen_id }} {
    display: none;
    flex-wrap: wrap;
    gap: {{ block.settings.pill_gap }}px;
    padding-left: {{ block.settings.subcollection_indent }}px;
  }

  .ai-collection-filter__subcollections-{{ ai_gen_id }}.visible {
    display: flex;
  }

  .ai-collection-filter__products-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.products_per_row_desktop }}, 1fr);
    gap: {{ block.settings.product_gap }}px;
    margin-top: {{ block.settings.spacing }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-collection-filter__products-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.products_per_row_mobile }}, 1fr);
    }
  }

  .ai-collection-filter__product-card-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
    text-decoration: none;
    color: inherit;
  }

  .ai-collection-filter__product-image-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.product_image_radius }}px;
    background-color: #f5f5f5;
  }

  .ai-collection-filter__product-image-{{ ai_gen_id }} img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-collection-filter__product-info-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .ai-collection-filter__product-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_title_size }}px;
    font-weight: 500;
    margin: 0;
  }

  .ai-collection-filter__product-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_price_size }}px;
    color: {{ block.settings.product_price_color }};
  }

  .ai-collection-filter__loading-{{ ai_gen_id }} {
    display: none;
    text-align: center;
    padding: 40px;
    color: #666;
  }

  .ai-collection-filter__loading-{{ ai_gen_id }}.visible {
    display: block;
  }

  .ai-collection-filter__empty-{{ ai_gen_id }} {
    text-align: center;
    padding: 40px;
    color: #999;
    font-style: italic;
  }
{% endstyle %}

<collection-filter-{{ ai_gen_id }}
  class="ai-collection-filter-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
  data-products-per-page="{{ block.settings.products_per_page }}"
>
  <div class="ai-collection-filter__container-{{ ai_gen_id }}">
    <div class="ai-collection-filter__pills-wrapper-{{ ai_gen_id }}" data-main-collections>
      {% for i in (1..10) %}
        {% liquid
          assign collection_key = 'collection_' | append: i
          assign icon_key = 'collection_' | append: i | append: '_icon'
          assign collection = block.settings[collection_key]
          assign icon_svg = block.settings[icon_key]
        %}

        {% if collection != blank %}
          <a
            href="{{ collection.url }}"
            class="ai-collection-filter__pill-{{ ai_gen_id }} {% if collection.handle == collection.handle %}{% endif %}"
            data-collection-handle="{{ collection.handle }}"
            data-collection-index="{{ i }}"
          >
            {% if icon_svg != blank %}
              <span class="ai-collection-filter__pill-icon-{{ ai_gen_id }}">
                {{ icon_svg }}
              </span>
            {% endif %}
            <span>{{ collection.title }}</span>
          </a>
        {% endif %}
      {% endfor %}
    </div>

    {% for i in (1..10) %}
      {% liquid
        assign collection_key = 'collection_' | append: i
        assign collection = block.settings[collection_key]
      %}

      {% if collection != blank and collection.metafields.custom.subcollections != blank %}
        <div
          class="ai-collection-filter__subcollections-{{ ai_gen_id }}"
          data-parent-collection="{{ i }}"
        >
          {% for subcollection in collection.metafields.custom.subcollections.value %}
            <a
              href="{{ subcollection.url }}"
              class="ai-collection-filter__pill-{{ ai_gen_id }}"
              data-subcollection-handle="{{ subcollection.handle }}"
            >
              <span>{{ subcollection.title }}</span>
            </a>
          {% endfor %}
        </div>
      {% endif %}
    {% endfor %}

    <div class="ai-collection-filter__loading-{{ ai_gen_id }}" data-loading>
      {{ block.settings.loading_text }}
    </div>

    <div class="ai-collection-filter__products-{{ ai_gen_id }}" data-products-grid>
      {% if collection %}
        {% for product in collection.products limit: block.settings.products_per_page %}
          <a
            href="{{ product.url }}"
            class="ai-collection-filter__product-card-{{ ai_gen_id }}"
          >
            <div class="ai-collection-filter__product-image-{{ ai_gen_id }}">
              {% if product.featured_image %}
                <img
                  src="{{ product.featured_image | image_url: width: 600 }}"
                  alt="{{ product.featured_image.alt | escape }}"
                  loading="lazy"
                  width="600"
                  height="600"
                >
              {% else %}
                <div class="ai-collection-filter__product-placeholder-{{ ai_gen_id }}">
                  {{ 'product-1' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>
            <div class="ai-collection-filter__product-info-{{ ai_gen_id }}">
              <h3 class="ai-collection-filter__product-title-{{ ai_gen_id }}">{{ product.title }}</h3>
              <div class="ai-collection-filter__product-price-{{ ai_gen_id }}">{{ product.price | money }}</div>
            </div>
          </a>
        {% endfor %}
      {% else %}
        <div class="ai-collection-filter__empty-{{ ai_gen_id }}">
          {{ block.settings.empty_state_text }}
        </div>
      {% endif %}
    </div>
  </div>
</collection-filter-{{ ai_gen_id }}>

<script>
  (function() {
    class CollectionFilter{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.mainCollections = this.querySelector('[data-main-collections]');
        this.subcollectionContainers = this.querySelectorAll('[data-parent-collection]');
        this.productsGrid = this.querySelector('[data-products-grid]');
        this.loadingIndicator = this.querySelector('[data-loading]');
        this.productsPerPage = parseInt(this.dataset.productsPerPage) || 12;
        this.currentCollectionIndex = null;
      }

      connectedCallback() {
        this.setupEventListeners();
        this.checkCurrentUrl();
      }

      setupEventListeners() {
        this.mainCollections.addEventListener('click', (e) => {
          const pill = e.target.closest('.ai-collection-filter__pill-{{ ai_gen_id }}');
          if (!pill) return;

          e.preventDefault();
          const collectionHandle = pill.dataset.collectionHandle;
          const collectionIndex = pill.dataset.collectionIndex;

          this.setActiveMainCollection(pill, collectionIndex);
          this.loadCollection(collectionHandle);
        });

        this.subcollectionContainers.forEach((container) => {
          container.addEventListener('click', (e) => {
            const pill = e.target.closest('.ai-collection-filter__pill-{{ ai_gen_id }}');
            if (!pill) return;

            e.preventDefault();
            const subcollectionHandle = pill.dataset.subcollectionHandle;

            this.setActiveSubcollection(pill);
            this.loadCollection(subcollectionHandle);
          });
        });
      }

      setActiveMainCollection(activePill, collectionIndex) {
        this.mainCollections.querySelectorAll('.ai-collection-filter__pill-{{ ai_gen_id }}').forEach((p) => {
          p.classList.remove('active');
        });
        activePill.classList.add('active');

        this.subcollectionContainers.forEach((container) => {
          container.classList.remove('visible');
        });

        const subcollectionContainer = this.querySelector(`[data-parent-collection="${collectionIndex}"]`);
        if (subcollectionContainer) {
          subcollectionContainer.classList.add('visible');
        }

        this.currentCollectionIndex = collectionIndex;
      }

      setActiveSubcollection(activePill) {
        const parentContainer = activePill.closest('[data-parent-collection]');
        if (parentContainer) {
          parentContainer.querySelectorAll('.ai-collection-filter__pill-{{ ai_gen_id }}').forEach((p) => {
            p.classList.remove('active');
          });
        }
        activePill.classList.add('active');
      }

      checkCurrentUrl() {
        const currentPath = window.location.pathname;
        const collectionMatch = currentPath.match(/\/collections\/([^\/]+)/);

        if (collectionMatch) {
          const currentHandle = collectionMatch[1];

          this.mainCollections.querySelectorAll('.ai-collection-filter__pill-{{ ai_gen_id }}').forEach((pill) => {
            if (pill.dataset.collectionHandle === currentHandle) {
              const collectionIndex = pill.dataset.collectionIndex;
              this.setActiveMainCollection(pill, collectionIndex);
            }
          });

          this.subcollectionContainers.forEach((container) => {
            container.querySelectorAll('.ai-collection-filter__pill-{{ ai_gen_id }}').forEach((pill) => {
              if (pill.dataset.subcollectionHandle === currentHandle) {
                this.setActiveSubcollection(pill);
              }
            });
          });
        }
      }

      async loadCollection(collectionHandle) {
        this.loadingIndicator.classList.add('visible');
        this.productsGrid.style.opacity = '0.5';

        try {
          const response = await fetch(`/collections/${collectionHandle}?view=json`);
          if (!response.ok) {
            const fallbackResponse = await fetch(`/collections/${collectionHandle}`);
            const html = await fallbackResponse.text();
            this.parseAndRenderProducts(html);
          } else {
            const data = await response.json();
            this.renderProducts(data.products);
          }

          window.history.pushState({}, '', `/collections/${collectionHandle}`);
        } catch (error) {
          console.error('Error loading collection:', error);
          window.location.href = `/collections/${collectionHandle}`;
        } finally {
          this.loadingIndicator.classList.remove('visible');
          this.productsGrid.style.opacity = '1';
        }
      }

      parseAndRenderProducts(html) {
        const parser = new DOMParser();
        const doc = parser.parseFromString(html, 'text/html');
        const productCards = doc.querySelectorAll('.product-card, [data-product-card]');

        if (productCards.length === 0) {
          this.productsGrid.innerHTML = '<div class="ai-collection-filter__empty-{{ ai_gen_id }}">ไม่พบสินค้าในหมวดนี้</div>';
          return;
        }

        let productsHtml = '';
        productCards.forEach((card, index) => {
          if (index < this.productsPerPage) {
            const link = card.querySelector('a');
            const img = card.querySelector('img');
            const title = card.querySelector('.product-card__title, [data-product-title]');
            const price = card.querySelector('.price, [data-product-price]');

            if (link && title) {
              productsHtml += `
                <a href="${link.href}" class="ai-collection-filter__product-card-{{ ai_gen_id }}">
                  <div class="ai-collection-filter__product-image-{{ ai_gen_id }}">
                    ${img ? `<img src="${img.src}" alt="${img.alt || ''}" loading="lazy">` : ''}
                  </div>
                  <div class="ai-collection-filter__product-info-{{ ai_gen_id }}">
                    <h3 class="ai-collection-filter__product-title-{{ ai_gen_id }}">${title.textContent.trim()}</h3>
                    ${price ? `<div class="ai-collection-filter__product-price-{{ ai_gen_id }}">${price.textContent.trim()}</div>` : ''}
                  </div>
                </a>
              `;
            }
          }
        });

        this.productsGrid.innerHTML = productsHtml || '<div class="ai-collection-filter__empty-{{ ai_gen_id }}">ไม่พบสินค้าในหมวดนี้</div>';
      }

      renderProducts(products) {
        if (!products || products.length === 0) {
          this.productsGrid.innerHTML = '<div class="ai-collection-filter__empty-{{ ai_gen_id }}">ไม่พบสินค้าในหมวดนี้</div>';
          return;
        }

        let productsHtml = '';
        products.slice(0, this.productsPerPage).forEach((product) => {
          const imageUrl = product.featured_image ? product.featured_image : '';
          const price = product.price ? (product.price / 100).toFixed(2) : '';

          productsHtml += `
            <a href="/products/${product.handle}" class="ai-collection-filter__product-card-{{ ai_gen_id }}">
              <div class="ai-collection-filter__product-image-{{ ai_gen_id }}">
                ${imageUrl ? `<img src="${imageUrl}" alt="${product.title}" loading="lazy">` : ''}
              </div>
              <div class="ai-collection-filter__product-info-{{ ai_gen_id }}">
                <h3 class="ai-collection-filter__product-title-{{ ai_gen_id }}">${product.title}</h3>
                ${price ? `<div class="ai-collection-filter__product-price-{{ ai_gen_id }}">฿${price}</div>` : ''}
              </div>
            </a>
          `;
        });

        this.productsGrid.innerHTML = productsHtml;
      }
    }

    customElements.define('collection-filter-{{ ai_gen_id }}', CollectionFilter{{ ai_gen_id }});
  })();
</script>

