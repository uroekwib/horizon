{% doc %}
  @prompt
    อยากได้ blockโชว์ product card ที่ filter มาจาก collection/subcollection
    
    เราจะโชว์ collection pill 8-10 อัน พอกดให้ active ก็จะโชว์ subcillection pils ออกมาเพิ่มเติม ให้กดเพื่อเลือก filter และแสดงแต่ product cards ที่อยู่ภายใต้หมวดนั้น ๆ ออกมา โดยเป็นการโหลดหน้า url ของ collection หรือ subcollection นั้น ๆ ออกมา, subcoll เตรียมไว้แล้ว เป็น list Metafields ชื่อ subcollections, พอเรากดเลือก  Collection ก็จะเปลี่ยน url เลย แล้วก็มี subcoll โชว์ โดยที่เมื่อเราเลือก subcoll สลับไปมาภายใต้ coll เดียวกัน url จะไม่ได้เปลี่ยนนะ , collection สามารถ select เลือกภาพ icon เล็ก ๆ ไว้หน้าข้อความของแต่ละ pill ได้, ไม่มี subcoll ที่เป็น metafields กำหนดไว้แสดงออกมา ผิดปกตินะ  Metafields list
    Subcollections
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-collection-filter-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-collection-filter__container-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.spacing }}px;
  }

  .ai-collection-filter__pills-wrapper-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.pill_spacing }}px;
  }

  .ai-collection-filter__pills-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: {{ block.settings.pill_spacing }}px;
  }

  .ai-collection-filter__pill-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: {{ block.settings.pill_padding_vertical }}px {{ block.settings.pill_padding_horizontal }}px;
    background-color: {{ block.settings.pill_background }};
    color: {{ block.settings.pill_text_color }};
    border: {{ block.settings.pill_border_width }}px solid {{ block.settings.pill_border_color }};
    border-radius: {{ block.settings.pill_border_radius }}px;
    cursor: pointer;
    transition: all 0.3s ease;
    text-decoration: none;
    font-size: {{ block.settings.pill_font_size }}px;
  }

  .ai-collection-filter__pill-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.pill_hover_background }};
    color: {{ block.settings.pill_hover_text_color }};
    border-color: {{ block.settings.pill_hover_border_color }};
  }

  .ai-collection-filter__pill-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.pill_active_background }};
    color: {{ block.settings.pill_active_text_color }};
    border-color: {{ block.settings.pill_active_border_color }};
  }

  .ai-collection-filter__pill-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    object-fit: contain;
    flex-shrink: 0;
  }

  .ai-collection-filter__subcollections-{{ ai_gen_id }} {
    display: none;
    opacity: 0;
    max-height: 0;
    overflow: hidden;
    transition: opacity 0.3s ease, max-height 0.3s ease;
  }

  .ai-collection-filter__subcollections-{{ ai_gen_id }}.active {
    display: block;
    opacity: 1;
    max-height: 500px;
  }

  .ai-collection-filter__products-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.products_per_row_desktop }}, 1fr);
    gap: {{ block.settings.product_gap }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-collection-filter__products-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.products_per_row_mobile }}, 1fr);
    }
  }

  .ai-collection-filter__product-card-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ai-collection-filter__product-image-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: {{ block.settings.product_image_radius }}px;
  }

  .ai-collection-filter__product-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_title_size }}px;
    color: {{ block.settings.product_title_color }};
    margin: 0;
  }

  .ai-collection-filter__product-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_price_size }}px;
    color: {{ block.settings.product_price_color }};
  }

  .ai-collection-filter__loading-{{ ai_gen_id }} {
    text-align: center;
    padding: 40px;
    color: {{ block.settings.pill_text_color }};
  }
{% endstyle %}

<collection-filter-{{ ai_gen_id }}
  class="ai-collection-filter-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
  data-current-collection="{{ collection.handle }}"
>
  <div class="ai-collection-filter__container-{{ ai_gen_id }}">
    <div class="ai-collection-filter__pills-wrapper-{{ ai_gen_id }}">
      <div class="ai-collection-filter__pills-{{ ai_gen_id }}" data-type="collections">
        {% for i in (1..10) %}
          {% liquid
            assign collection_key = 'collection_' | append: i
            assign icon_key = 'collection_' | append: i | append: '_icon'
            assign selected_collection = block.settings[collection_key]
            assign collection_icon = block.settings[icon_key]
          %}

          {% if selected_collection != blank %}
            <a
              href="{{ selected_collection.url }}"
              class="ai-collection-filter__pill-{{ ai_gen_id }} {% if collection.handle == selected_collection.handle %}active{% endif %}"
              data-collection-handle="{{ selected_collection.handle }}"
              data-collection-index="{{ i }}"
            >
              {% if collection_icon != blank %}
                <img
                  src="{{ collection_icon | image_url: width: 100 }}"
                  alt="{{ selected_collection.title }}"
                  class="ai-collection-filter__pill-icon-{{ ai_gen_id }}"
                  width="100"
                  height="100"
                  loading="lazy"
                >
              {% endif %}
              <span>{{ selected_collection.title }}</span>
            </a>
          {% endif %}
        {% endfor %}
      </div>

      <div class="ai-collection-filter__subcollections-{{ ai_gen_id }}" data-type="subcollections"></div>
    </div>

    <div class="ai-collection-filter__products-{{ ai_gen_id }}" data-products-container>
      {% if collection.products.size > 0 %}
        {% for product in collection.products limit: block.settings.products_limit %}
          <div class="ai-collection-filter__product-card-{{ ai_gen_id }}" data-product-card>
            <a href="{{ product.url }}">
              {% if product.featured_image %}
                <img
                  src="{{ product.featured_image | image_url: width: 600 }}"
                  alt="{{ product.featured_image.alt | escape }}"
                  class="ai-collection-filter__product-image-{{ ai_gen_id }}"
                  width="600"
                  height="600"
                  loading="lazy"
                >
              {% else %}
                <div class="ai-collection-filter__product-image-{{ ai_gen_id }}">
                  {{ 'product-1' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </a>
            <h3 class="ai-collection-filter__product-title-{{ ai_gen_id }}">
              <a href="{{ product.url }}">{{ product.title }}</a>
            </h3>
            <div class="ai-collection-filter__product-price-{{ ai_gen_id }}">
              {{ product.price | money }}
            </div>
          </div>
        {% endfor %}
      {% else %}
        <div class="ai-collection-filter__loading-{{ ai_gen_id }}">
          ไม่พบสินค้าในหมวดนี้
        </div>
      {% endif %}
    </div>
  </div>
</collection-filter-{{ ai_gen_id }}>

<script>
  (function() {
    class CollectionFilter{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.collectionPills = this.querySelectorAll('[data-collection-handle]');
        this.subcollectionsContainer = this.querySelector('[data-type="subcollections"]');
        this.productsContainer = this.querySelector('[data-products-container]');
        this.currentCollection = this.dataset.currentCollection;
        this.activeCollectionIndex = null;
      }

      connectedCallback() {
        this.setupCollectionPills();
        this.loadSubcollectionsForActiveCollection();
      }

      setupCollectionPills() {
        this.collectionPills.forEach((pill) => {
          pill.addEventListener('click', (e) => {
            e.preventDefault();
            const collectionHandle = pill.dataset.collectionHandle;
            const collectionIndex = pill.dataset.collectionIndex;

            if (this.activeCollectionIndex === collectionIndex) {
              return;
            }

            this.activeCollectionIndex = collectionIndex;
            this.updateActivePill(pill);
            this.loadSubcollections(collectionHandle);
            this.loadCollectionProducts(collectionHandle);
            window.history.pushState({}, '', pill.href);
          });
        });
      }

      updateActivePill(activePill) {
        this.collectionPills.forEach((pill) => {
          pill.classList.remove('active');
        });
        activePill.classList.add('active');
      }

      loadSubcollectionsForActiveCollection() {
        const activePill = this.querySelector('.ai-collection-filter__pill-{{ ai_gen_id }}.active');
        if (activePill) {
          const collectionHandle = activePill.dataset.collectionHandle;
          const collectionIndex = activePill.dataset.collectionIndex;
          this.activeCollectionIndex = collectionIndex;
          this.loadSubcollections(collectionHandle);
        }
      }

      async loadSubcollections(collectionHandle) {
        try {
          const response = await fetch(`/collections/${collectionHandle}?section_id=collection-metafields`);
          const text = await response.text();
          
          const tempDiv = document.createElement('div');
          tempDiv.innerHTML = text;
          
          const metafieldsElement = tempDiv.querySelector('[data-subcollections-list]');
          
          if (metafieldsElement) {
            const subcollectionsJson = metafieldsElement.textContent.trim();
            
            if (subcollectionsJson) {
              const subcollections = JSON.parse(subcollectionsJson);
              
              if (subcollections && subcollections.length > 0) {
                this.renderSubcollections(subcollections, collectionHandle);
                return;
              }
            }
          }
          
          this.subcollectionsContainer.innerHTML = '';
          this.subcollectionsContainer.classList.remove('active');
        } catch (error) {
          console.error('Error loading subcollections:', error);
          this.subcollectionsContainer.innerHTML = '';
          this.subcollectionsContainer.classList.remove('active');
        }
      }

      renderSubcollections(subcollections, parentHandle) {
        const pillsHtml = subcollections.map((subcol) => {
          return `
            <a
              href="/collections/${subcol.handle}"
              class="ai-collection-filter__pill-{{ ai_gen_id }}"
              data-subcollection-handle="${subcol.handle}"
              data-parent-handle="${parentHandle}"
            >
              <span>${subcol.title}</span>
            </a>
          `;
        }).join('');

        this.subcollectionsContainer.innerHTML = `
          <div class="ai-collection-filter__pills-{{ ai_gen_id }}">
            ${pillsHtml}
          </div>
        `;

        this.subcollectionsContainer.classList.add('active');

        this.subcollectionsContainer.querySelectorAll('[data-subcollection-handle]').forEach((pill) => {
          pill.addEventListener('click', (e) => {
            e.preventDefault();
            const subcollectionHandle = pill.dataset.subcollectionHandle;

            this.subcollectionsContainer.querySelectorAll('.ai-collection-filter__pill-{{ ai_gen_id }}').forEach((p) => {
              p.classList.remove('active');
            });
            pill.classList.add('active');

            this.loadCollectionProducts(subcollectionHandle);
          });
        });
      }

      async loadCollectionProducts(collectionHandle) {
        this.productsContainer.innerHTML = '<div class="ai-collection-filter__loading-{{ ai_gen_id }}">กำลังโหลด...</div>';

        try {
          const response = await fetch(`/collections/${collectionHandle}`);
          const html = await response.text();
          const parser = new DOMParser();
          const doc = parser.parseFromString(html, 'text/html');
          const products = doc.querySelectorAll('[data-product-card]');

          if (products.length > 0) {
            let productsHtml = '';
            products.forEach((product) => {
              productsHtml += product.outerHTML;
            });
            this.productsContainer.innerHTML = productsHtml;
          } else {
            this.productsContainer.innerHTML = '<div class="ai-collection-filter__loading-{{ ai_gen_id }}">ไม่พบสินค้าในหมวดนี้</div>';
          }
        } catch (error) {
          console.error('Error loading products:', error);
          this.productsContainer.innerHTML = '<div class="ai-collection-filter__loading-{{ ai_gen_id }}">เกิดข้อผิดพลาดในการโหลดสินค้า</div>';
        }
      }
    }

    customElements.define('collection-filter-{{ ai_gen_id }}', CollectionFilter{{ ai_gen_id }});
  })();
</script>

