{% doc %}
  @prompt
    product list 6 cards per row for desktop and 2 for mobile showing products filtered from specific tag 
    min 12 max 18 products 
    minimal loading as possible for the best performance score, no js blocking issue, เปลี่ยนเป็นเลือกจาก collection, รูป landscape 4:3 มีแค่ชื่อใต้ภาพ, font-weight 700 size 12px กำหนด padding top bottom ได้หน่อย
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-grid-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
  }

  .ai-product-grid-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    width: 100%;
  }

  @media screen and (max-width: 749px) {
    .ai-product-grid-container-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .ai-product-card-{{ ai_gen_id }} {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .ai-product-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 75%;
    overflow: hidden;
    background-color: #f5f5f5;
  }

  .ai-product-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-product-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-product-placeholder-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
    opacity: 0.3;
  }

  .ai-product-title-{{ ai_gen_id }} {
    margin-top: 8px;
    font-size: 12px;
    font-weight: 700;
    line-height: 1.3;
    color: {{ block.settings.title_color }};
  }

  .ai-empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 40px 20px;
    color: #666;
    font-size: 14px;
  }
{% endstyle %}

<product-grid-{{ ai_gen_id }} class="ai-product-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.collection != blank %}
    {% assign collection = block.settings.collection %}
    {% assign product_limit = block.settings.product_limit %}
    {% assign products = collection.products | slice: 0, product_limit %}

    {% if products.size > 0 %}
      <div class="ai-product-grid-container-{{ ai_gen_id }}">
        {% for product in products %}
          <a href="{{ product.url }}" class="ai-product-card-{{ ai_gen_id }}">
            <div class="ai-product-image-wrapper-{{ ai_gen_id }}">
              {% if product.featured_image %}
                <img
                  src="{{ product.featured_image | image_url: width: 600 }}"
                  alt="{{ product.featured_image.alt | escape }}"
                  class="ai-product-image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="600"
                  height="450"
                >
              {% else %}
                <div class="ai-product-placeholder-{{ ai_gen_id }}">
                  {{ 'product-1' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>
            <div class="ai-product-title-{{ ai_gen_id }}">{{ product.title }}</div>
          </a>
        {% endfor %}
      </div>
    {% else %}
      <div class="ai-empty-state-{{ ai_gen_id }}">
        ไม่มีสินค้าในคอลเลกชันนี้
      </div>
    {% endif %}
  {% else %}
    <div class="ai-empty-state-{{ ai_gen_id }}">
      กรุณาเลือกคอลเลกชัน
    </div>
  {% endif %}
</product-grid-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        const images = this.querySelectorAll('.ai-product-image-{{ ai_gen_id }}');
        images.forEach(img => {
          img.setAttribute('decoding', 'async');
        });
      }
    }

    customElements.define('product-grid-{{ ai_gen_id }}', ProductGrid{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Product grid",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "คอลเลกชัน"
    },
    {
      "type": "range",
      "id": "product_limit",
      "label": "จำนวนสินค้า",
      "min": 12,
      "max": 18,
      "step": 1,
      "default": 12
    },
    {
      "type": "header",
      "content": "การจัดวาง"
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "ระยะห่างระหว่างสินค้า",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding บน",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding ล่าง",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "สไตล์"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "สีชื่อสินค้า",
      "default": "#000000"
    }
  ],
  "presets": [
    {
      "name": "Product grid"
    }
  ]
}
{% endschema %}
