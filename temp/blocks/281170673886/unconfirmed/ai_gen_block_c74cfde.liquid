{% doc %}
  @prompt
    อยากได้ div heading ที่มีเส้น ขีดคั่นข้างใต้เป็นเป็น divider ที่สวยสีสันหน่อย
    .oc-title-with-line {
      /* ดึงสีข้อความจากแบรนด์ของคุณมาใช้ (Cyan) */
      color: var(--brand-cyan, #17a9bb); 
      font-family: 'Google Sans', 'Noto Sans Thai', sans-serif;
      font-weight: 700;
      font-size: clamp(1.125rem, 2vw, 1.5rem); /* ให้ขนาดตัวอักษรยืดหยุ่นตามหน้าจอ */
      margin-bottom: 24px;
      padding-bottom: 12px; /* ระยะห่างระหว่างตัวหนังสือกับเส้น */
      position: relative;
      display: block;
      width: 100%; /* ให้กางเต็มความกว้าง */
    }
    
    .oc-title-with-line::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      width: 100%; /* ความยาวของเส้น (กางสุดขอบ) */
      height: 3px; /* ความหนาของเส้น */
      border-radius: 2px;
      /* ไล่สีจากฟ้าพาสเทลไปม่วงพาสเทล (อิงจากโทน --brand-grad-2 ของคุณแต่หมุนเป็น 90 องศา) */
      background: linear-gradient(90deg, #c3f9ff 0%, #c78ff2 100%);
    }
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-title-divider-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-title-divider__heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 {{ block.settings.spacing_bottom }}px 0;
    padding-bottom: {{ block.settings.line_spacing }}px;
    position: relative;
    display: block;
    width: 100%;
  }

  .ai-title-divider__heading-{{ ai_gen_id }}::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: {{ block.settings.line_width }}%;
    height: {{ block.settings.line_height }}px;
    border-radius: {{ block.settings.line_border_radius }}px;
    {% if block.settings.gradient_enabled %}
      background: linear-gradient({{ block.settings.gradient_angle }}deg, {{ block.settings.gradient_color_start }} 0%, {{ block.settings.gradient_color_end }} 100%);
    {% else %}
      background-color: {{ block.settings.line_color }};
    {% endif %}
  }

  @media screen and (max-width: 749px) {
    .ai-title-divider__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }
  }
{% endstyle %}

<div class="ai-title-divider-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading_text != blank %}
    <h2 class="ai-title-divider__heading-{{ ai_gen_id }}">
      {{ block.settings.heading_text }}
    </h2>
  {% else %}
    <h2 class="ai-title-divider__heading-{{ ai_gen_id }}">
      Heading with divider
    </h2>
  {% endif %}
</div>

{% schema %}
{
  "name": "Heading with divider",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading_text",
      "label": "Heading text",
      "default": "Your heading here"
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Font",
      "default": "system_ui_n4"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Font size",
      "min": 14,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Text color",
      "default": "#17a9bb"
    },
    {
      "type": "range",
      "id": "spacing_bottom",
      "label": "Bottom spacing",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "header",
      "content": "Divider line"
    },
    {
      "type": "checkbox",
      "id": "gradient_enabled",
      "label": "Enable gradient",
      "default": true
    },
    {
      "type": "color",
      "id": "gradient_color_start",
      "label": "Gradient start color",
      "default": "#c3f9ff"
    },
    {
      "type": "color",
      "id": "gradient_color_end",
      "label": "Gradient end color",
      "default": "#c78ff2"
    },
    {
      "type": "range",
      "id": "gradient_angle",
      "label": "Gradient angle",
      "min": 0,
      "max": 360,
      "step": 10,
      "unit": "deg",
      "default": 90
    },
    {
      "type": "color",
      "id": "line_color",
      "label": "Solid color",
      "default": "#c3f9ff"
    },
    {
      "type": "range",
      "id": "line_width",
      "label": "Line width",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "line_height",
      "label": "Line thickness",
      "min": 1,
      "max": 10,
      "step": 1,
      "unit": "px",
      "default": 3
    },
    {
      "type": "range",
      "id": "line_border_radius",
      "label": "Line border radius",
      "min": 0,
      "max": 10,
      "step": 1,
      "unit": "px",
      "default": 2
    },
    {
      "type": "range",
      "id": "line_spacing",
      "label": "Space between text and line",
      "min": 4,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Heading with divider"
    }
  ]
}
{% endschema %}
