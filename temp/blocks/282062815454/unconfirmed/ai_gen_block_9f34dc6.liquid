    {
      "type": "checkbox",
      "id": "step_1_enabled",
      "label": "Enable step 1",
      "default": true
    },
    {
      "type": "text",
      "id": "step_1_title",
      "label": "Title",
      "default": "Foundation Work"
    },
    {
      "type": "textarea",
      "id": "step_1_description",
      "label": "Description",
      "default": "Concrete footing and anchor preparation for structural stability"
    },
    {
      "type": "image_picker",
      "id": "step_1_image",
      "label": "Image"
    },
    {
      "type": "url",
      "id": "step_1_link",
      "label": "Link"
    },
