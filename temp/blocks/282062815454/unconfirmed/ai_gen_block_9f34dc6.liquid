        {
          "value": "gradient",
          "label": "Gradient"
        },
        {
          "value": "image",
          "label": "Image"
        },
        {
          "value": "image_overlay",
          "label": "Image with overlay"
        },
        {
          "value": "glass",
          "label": "Glass effect"
        }
      ],
      "default": "gradient"
    },
    {
      "type": "color",
