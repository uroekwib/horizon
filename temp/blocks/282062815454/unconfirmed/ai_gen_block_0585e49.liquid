<script>
  (function() {
    class PoleSignProcess{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.isScrolling = false;
      }

      connectedCallback() {
        this.stepsContainer = this.querySelector('[data-steps-container]');
        this.paginationContainer = this.querySelector('[data-pagination]');
        this.progressBar = this.querySelector('.ai-pole-sign-process__progress-bar-{{ ai_gen_id }}');
        this.cards = Array.from(this.querySelectorAll('.ai-pole-sign-process__step-card-{{ ai_gen_id }}'));
        
        this.setupPagination();
        this.setupScrollListener();
        this.setupIntersectionObserver();
        this.updateActiveCard(0);
      }

      setupPagination() {
        if (!this.paginationContainer || !this.cards.length) return;

        this.cards.forEach((card, index) => {
          const dot = document.createElement('button');
          dot.className = 'ai-pole-sign-process__dot-{{ ai_gen_id }}';
          dot.setAttribute('aria-label', `Go to step ${index + 1}`);
          dot.addEventListener('click', () => this.scrollToCard(index));
          this.paginationContainer.appendChild(dot);
        });

        this.dots = Array.from(this.paginationContainer.querySelectorAll('.ai-pole-sign-process__dot-{{ ai_gen_id }}'));
      }

      setupScrollListener() {
        if (!this.stepsContainer) return;

        let scrollTimeout;
        this.stepsContainer.addEventListener('scroll', () => {
          this.isScrolling = true;
          clearTimeout(scrollTimeout);
          
          scrollTimeout = setTimeout(() => {
            this.isScrolling = false;
            this.updateActiveCardFromScroll();
          }, 150);

          this.updateProgressBar();
        });
      }

      setupIntersectionObserver() {
        const options = {
          root: null,
          threshold: 0.2,
          rootMargin: '0px'
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry, index) => {
            if (entry.isIntersecting) {
              setTimeout(() => {
                entry.target.classList.add('animate-in');
              }, index * 100);
            }
          });
        }, options);

        this.cards.forEach(card => observer.observe(card));
      }

      updateActiveCardFromScroll() {
        if (!this.stepsContainer) return;

        const scrollLeft = this.stepsContainer.scrollLeft;
        const cardWidth = this.cards[0].offsetWidth + 32;
        const newIndex = Math.round(scrollLeft / cardWidth);
        
        this.updateActiveCard(newIndex);
      }

      updateActiveCard(index) {
        if (index < 0 || index >= this.cards.length) return;

        this.currentIndex = index;

        this.cards.forEach((card, i) => {
          if (i === index) {
            card.classList.add('active');
          } else {
            card.classList.remove('active');
          }
        });

        if (this.dots) {
          this.dots.forEach((dot, i) => {
            if (i === index) {
              dot.classList.add('active');
            } else {
              dot.classList.remove('active');
            }
          });
        }
      }

      updateProgressBar() {
        if (!this.progressBar || !this.stepsContainer) return;

        const scrollLeft = this.stepsContainer.scrollLeft;
        const scrollWidth = this.stepsContainer.scrollWidth - this.stepsContainer.clientWidth;
        const progress = (scrollLeft / scrollWidth) * 100;
        
        this.progressBar.style.width = `${progress}%`;
      }

      scrollToCard(index) {
        if (!this.stepsContainer || index < 0 || index >= this.cards.length) return;

        const card = this.cards[index];
        const cardWidth = card.offsetWidth + 32;
        const scrollPosition = cardWidth * index;

        this.stepsContainer.scrollTo({
          left: scrollPosition,
          behavior: 'smooth'
        });

        this.updateActiveCard(index);
      }
    }

    customElements.define('pole-sign-process-{{ ai_gen_id }}', PoleSignProcess{{ ai_gen_id }});
  })();
</script>

