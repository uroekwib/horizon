{% doc %}
  @prompt
    x-scrollable button links pill shape with dynamic color setting for scheme and font size 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-pill-links-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-pill-links-wrapper-{{ ai_gen_id }} {
    overflow-x: auto;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    scrollbar-color: {{ block.settings.color_scheme.settings.border }} transparent;
  }

  .ai-pill-links-wrapper-{{ ai_gen_id }}::-webkit-scrollbar {
    height: 6px;
  }

  .ai-pill-links-wrapper-{{ ai_gen_id }}::-webkit-scrollbar-track {
    background: transparent;
  }

  .ai-pill-links-wrapper-{{ ai_gen_id }}::-webkit-scrollbar-thumb {
    background-color: {{ block.settings.color_scheme.settings.border }};
    border-radius: 3px;
  }

  .ai-pill-links-container-{{ ai_gen_id }} {
    display: inline-flex;
    gap: {{ block.settings.gap }}px;
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    min-width: 100%;
  }

  .ai-pill-link-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.pill_padding_vertical }}px {{ block.settings.pill_padding_horizontal }}px;
    background-color: {{ block.settings.color_scheme.settings.variant_background_color }};
    color: {{ block.settings.color_scheme.settings.variant_text_color }};
    border: {{ block.settings.border_width }}px solid {{ block.settings.color_scheme.settings.variant_border_color }};
    border-radius: 100px;
    text-decoration: none;
    white-space: nowrap;
    font-size: {{ block.settings.font_size }}px;
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .ai-pill-link-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.color_scheme.settings.variant_hover_background_color }};
    color: {{ block.settings.color_scheme.settings.variant_hover_text_color }};
    border-color: {{ block.settings.color_scheme.settings.variant_hover_border_color }};
  }

  .ai-pill-link-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.color_scheme.settings.selected_variant_background_color }};
    color: {{ block.settings.color_scheme.settings.selected_variant_text_color }};
    border-color: {{ block.settings.color_scheme.settings.selected_variant_border_color }};
  }

  .ai-pill-link-{{ ai_gen_id }}.active:hover {
    background-color: {{ block.settings.color_scheme.settings.selected_variant_hover_background_color }};
    color: {{ block.settings.color_scheme.settings.selected_variant_hover_text_color }};
    border-color: {{ block.settings.color_scheme.settings.selected_variant_hover_border_color }};
  }

  @media screen and (min-width: 750px) {
    .ai-pill-links-wrapper-{{ ai_gen_id }} {
      width: {{ block.settings.desktop_width_percent }}%;
      margin: 0 auto;
    }
  }
{% endstyle %}

<pill-links-{{ ai_gen_id }} class="ai-pill-links-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-pill-links-wrapper-{{ ai_gen_id }}">
    <div class="ai-pill-links-container-{{ ai_gen_id }}">
      {% for i in (1..10) %}
        {% liquid
          assign link_enabled_key = 'link_' | append: i | append: '_enabled'
          assign link_text_key = 'link_' | append: i | append: '_text'
          assign link_url_key = 'link_' | append: i | append: '_url'
          
          assign link_enabled = block.settings[link_enabled_key]
          assign link_text = block.settings[link_text_key]
          assign link_url = block.settings[link_url_key]
        %}

        {% if link_enabled and link_text != blank %}
          <a
            href="{{ link_url }}"
            class="ai-pill-link-{{ ai_gen_id }}"
            data-link-index="{{ i }}"
          >
            {{ link_text }}
          </a>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</pill-links-{{ ai_gen_id }}>

<script>
  (function() {
    class PillLinks{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.links = this.querySelectorAll('.ai-pill-link-{{ ai_gen_id }}');
        this.currentUrl = window.location.pathname;
        this.highlightActiveLink();
      }

      highlightActiveLink() {
        this.links.forEach((link) => {
          const linkUrl = new URL(link.href).pathname;
          if (linkUrl === this.currentUrl) {
            link.classList.add('active');
          }
        });
      }
    }

    customElements.define('pill-links-{{ ai_gen_id }}', PillLinks{{ ai_gen_id }});
  })();
</script>

