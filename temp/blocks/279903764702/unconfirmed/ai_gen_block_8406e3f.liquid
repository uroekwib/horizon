{% doc %}
  @prompt
    Create a customizable announcement bar block that supports adding small SVG icons alongside text. The block should allow merchants to:
    - Add custom SVG icon code or select from common icon options (shipping, sale, info, star, etc.)
    - Control icon size and spacing
    - Position icon before or after text
    - Customize icon color to match text or use custom color
    - Maintain responsive design and accessibility
    The solution should integrate seamlessly with Horizon theme's announcement bar section and follow Shopify theme best practices.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-announcement-icon-bar-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: {{ block.settings.icon_spacing }}px;
    width: 100%;
    padding: {{ block.settings.vertical_padding }}px {{ block.settings.horizontal_padding }}px;
    background-color: {{ block.settings.background_color }};
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    text-align: center;
  }

  .ai-announcement-icon-bar-{{ ai_gen_id }} a {
    color: inherit;
    text-decoration: none;
  }

  .ai-announcement-icon-bar-{{ ai_gen_id }} a:hover {
    opacity: 0.8;
  }

  .ai-announcement-icon-bar__content-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.icon_spacing }}px;
    {% if block.settings.icon_position == 'after' %}
      flex-direction: row-reverse;
    {% endif %}
  }

  .ai-announcement-icon-bar__icon-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
  }

  .ai-announcement-icon-bar__icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    {% if block.settings.icon_color_mode == 'match_text' %}
      fill: {{ block.settings.text_color }};
      stroke: {{ block.settings.text_color }};
    {% else %}
      fill: {{ block.settings.icon_custom_color }};
      stroke: {{ block.settings.icon_custom_color }};
    {% endif %}
  }

  .ai-announcement-icon-bar__text-{{ ai_gen_id }} {
    line-height: 1.4;
  }

  @media screen and (max-width: 749px) {
    .ai-announcement-icon-bar-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
      padding: {{ block.settings.vertical_padding | times: 0.8 }}px {{ block.settings.horizontal_padding | times: 0.8 }}px;
    }

    .ai-announcement-icon-bar__icon-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.9 }}px;
      height: {{ block.settings.icon_size | times: 0.9 }}px;
    }

    .ai-announcement-icon-bar__content-{{ ai_gen_id }} {
      gap: {{ block.settings.icon_spacing | times: 0.8 }}px;
    }
  }
{% endstyle %}

<div class="ai-announcement-icon-bar-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.link != blank %}
    <a href="{{ block.settings.link }}">
      <div class="ai-announcement-icon-bar__content-{{ ai_gen_id }}">
        {% if block.settings.icon_type != 'none' %}
          <div class="ai-announcement-icon-bar__icon-{{ ai_gen_id }}">
            {% case block.settings.icon_type %}
              {% when 'shipping' %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="1" y="3" width="15" height="13"></rect>
                  <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
                  <circle cx="5.5" cy="18.5" r="2.5"></circle>
                  <circle cx="18.5" cy="18.5" r="2.5"></circle>
                </svg>
              {% when 'sale' %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="9" cy="9" r="2"></circle>
                  <circle cx="15" cy="15" r="2"></circle>
                  <path d="M10.16 3.958a1.5 1.5 0 0 1 3.68 0l1.558 5.536a1.5 1.5 0 0 0 1.066 1.066l5.536 1.558a1.5 1.5 0 0 1 0 3.68l-5.536 1.558a1.5 1.5 0 0 0-1.066 1.066l-1.558 5.536a1.5 1.5 0 0 1-3.68 0l-1.558-5.536a1.5 1.5 0 0 0-1.066-1.066l-5.536-1.558a1.5 1.5 0 0 1 0-3.68l5.536-1.558a1.5 1.5 0 0 0 1.066-1.066l1.558-5.536Z"></path>
                </svg>
              {% when 'info' %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10"></circle>
                  <line x1="12" y1="16" x2="12" y2="12"></line>
                  <line x1="12" y1="8" x2="12.01" y2="8"></line>
                </svg>
              {% when 'star' %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" stroke="none">
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                </svg>
              {% when 'gift' %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 12 20 22 4 22 4 12"></polyline>
                  <rect x="2" y="7" width="20" height="5"></rect>
                  <line x1="12" y1="22" x2="12" y2="7"></line>
                  <path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"></path>
                  <path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"></path>
                </svg>
              {% when 'heart' %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
                </svg>
              {% when 'bell' %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path>
                  <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
                </svg>
              {% when 'clock' %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10"></circle>
                  <polyline points="12 6 12 12 16 14"></polyline>
                </svg>
              {% when 'custom' %}
                {{ block.settings.custom_svg }}
            {% endcase %}
          </div>
        {% endif %}
        {% if block.settings.text != blank %}
          <div class="ai-announcement-icon-bar__text-{{ ai_gen_id }}">
            {{ block.settings.text }}
          </div>
        {% endif %}
      </div>
    </a>
  {% else %}
    <div class="ai-announcement-icon-bar__content-{{ ai_gen_id }}">
      {% if block.settings.icon_type != 'none' %}
        <div class="ai-announcement-icon-bar__icon-{{ ai_gen_id }}">
          {% case block.settings.icon_type %}
            {% when 'shipping' %}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="1" y="3" width="15" height="13"></rect>
                <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
                <circle cx="5.5" cy="18.5" r="2.5"></circle>
                <circle cx="18.5" cy="18.5" r="2.5"></circle>
              </svg>
            {% when 'sale' %}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="9" cy="9" r="2"></circle>
                <circle cx="15" cy="15" r="2"></circle>
                <path d="M10.16 3.958a1.5 1.5 0 0 1 3.68 0l1.558 5.536a1.5 1.5 0 0 0 1.066 1.066l5.536 1.558a1.5 1.5 0 0 1 0 3.68l-5.536 1.558a1.5 1.5 0 0 0-1.066 1.066l-1.558 5.536a1.5 1.5 0 0 1-3.68 0l-1.558-5.536a1.5 1.5 0 0 0-1.066-1.066l-5.536-1.558a1.5 1.5 0 0 1 0-3.68l5.536-1.558a1.5 1.5 0 0 0 1.066-1.066l1.558-5.536Z"></path>
              </svg>
            {% when 'info' %}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"></circle>
                <line x1="12" y1="16" x2="12" y2="12"></line>
                <line x1="12" y1="8" x2="12.01" y2="8"></line>
              </svg>
            {% when 'star' %}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" stroke="none">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
              </svg>
            {% when 'gift' %}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 12 20 22 4 22 4 12"></polyline>
                <rect x="2" y="7" width="20" height="5"></rect>
                <line x1="12" y1="22" x2="12" y2="7"></line>
                <path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"></path>
                <path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"></path>
              </svg>
            {% when 'heart' %}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
              </svg>
            {% when 'bell' %}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path>
                <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
              </svg>
            {% when 'clock' %}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"></circle>
                <polyline points="12 6 12 12 16 14"></polyline>
              </svg>
            {% when 'custom' %}
              {{ block.settings.custom_svg }}
          {% endcase %}
        </div>
      {% endif %}
      {% if block.settings.text != blank %}
        <div class="ai-announcement-icon-bar__text-{{ ai_gen_id }}">
          {{ block.settings.text }}
        </div>
      {% endif %}
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Announcement with icon",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "text",
      "label": "Text",
      "default": "Free shipping on orders over ฿1,000"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "Icon"
    },
    {
      "type": "select",
      "id": "icon_type",
      "label": "Icon type",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "shipping",
          "label": "Shipping"
        },
        {
          "value": "sale",
          "label": "Sale"
        },
        {
          "value": "info",
          "label": "Info"
        },
        {
          "value": "star",
          "label": "Star"
        },
        {
          "value": "gift",
          "label": "Gift"
        },
        {
          "value": "heart",
          "label": "Heart"
        },
        {
          "value": "bell",
          "label": "Bell"
        },
        {
          "value": "clock",
          "label": "Clock"
        },
        {
          "value": "custom",
          "label": "Custom SVG"
        }
      ],
      "default": "shipping"
    },
    {
      "type": "html",
      "id": "custom_svg",
      "label": "Custom SVG code",
      "info": "Paste your SVG code here. Only used when 'Custom SVG' is selected."
    },
    {
      "type": "select",
      "id": "icon_position",
      "label": "Icon position",
      "options": [
        {
          "value": "before",
          "label": "Before text"
        },
        {
          "value": "after",
          "label": "After text"
        }
      ],
      "default": "before"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 12,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "icon_spacing",
      "label": "Icon spacing",
      "min": 4,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "select",
      "id": "icon_color_mode",
      "label": "Icon color",
      "options": [
        {
          "value": "match_text",
          "label": "Match text color"
        },
        {
          "value": "custom",
          "label": "Custom color"
        }
      ],
      "default": "match_text"
    },
    {
      "type": "color",
      "id": "icon_custom_color",
      "label": "Custom icon color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Text size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "vertical_padding",
      "label": "Vertical padding",
      "min": 4,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "horizontal_padding",
      "label": "Horizontal padding",
      "min": 8,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 16
    }
  ],
  "presets": [
    {
      "name": "Announcement with icon"
    }
  ]
}
{% endschema %}
