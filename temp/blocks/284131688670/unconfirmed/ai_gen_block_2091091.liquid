{% doc %}
  @prompt
    Create a PDF catalogue viewer block for Shopify OS 2.0 using PDF.js library with the following features:
    
    1. Double-page spread toggle — button to switch between single-page and two-page spread (book/magazine open layout), with icon indicating current mode
    2. Zoom in/out buttons (+ and -) — correct zoom behavior: clicking + increases scale, clicking - decreases scale, with min/max limits (0.5x to 3x), zoom centered on current view
    3. Fit to screen button — auto-scales PDF to fill viewer container width, responsive on desktop and mobile
    4. Page navigation — prev/next buttons with current page / total pages display
    5. Responsive layout — single-page forced on small screens even if double-page mode selected
    
    Block settings: pdf_url, catalogue_title, viewer_height (default 700px), accent_color
    Toolbar layout: [Fit Screen] [−] [Zoom%] [+] [Single|Double toggle] [◀ Page X / Y ▶]
    Use PDF.js from CDN. Render pages to canvas elements. In double-page mode, render two consecutive pages side by side. Zoom state persists when toggling spread mode.
    
    มือถือไม่ต้องมีให้เห็นเลยว่า double ได้ แต่มีให้ดูเต็มจอเลยได้อะ
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-pdf-viewer-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    max-width: 100%;
    background-color: #f5f5f5;
    border-radius: 8px;
    overflow: hidden;
  }

  .ai-pdf-viewer-header-{{ ai_gen_id }} {
    background-color: {{ block.settings.accent_color }};
    color: #ffffff;
    padding: 16px 20px;
    font-size: 18px;
    font-weight: 600;
  }

  .ai-pdf-viewer-toolbar-{{ ai_gen_id }} {
    background-color: #ffffff;
    border-bottom: 1px solid #e6e6e6;
    padding: 12px 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .ai-pdf-viewer-toolbar-group-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .ai-pdf-viewer-button-{{ ai_gen_id }} {
    background-color: #ffffff;
    border: 1px solid #dfdfdf;
    border-radius: 4px;
    padding: 8px 12px;
    font-size: 14px;
    cursor: pointer;
    transition: all 0.2s ease;
    color: #000000;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .ai-pdf-viewer-button-{{ ai_gen_id }}:hover {
    background-color: #f5f5f5;
    border-color: #000000;
  }

  .ai-pdf-viewer-button-{{ ai_gen_id }}:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .ai-pdf-viewer-button-{{ ai_gen_id }}:disabled:hover {
    background-color: #ffffff;
    border-color: #dfdfdf;
  }

  .ai-pdf-viewer-zoom-display-{{ ai_gen_id }} {
    font-size: 14px;
    font-weight: 600;
    min-width: 50px;
    text-align: center;
    color: #000000;
  }

  .ai-pdf-viewer-page-info-{{ ai_gen_id }} {
    font-size: 14px;
    color: #000000;
  }

  .ai-pdf-viewer-canvas-container-{{ ai_gen_id }} {
    background-color: #e6e6e6;
    height: {{ block.settings.viewer_height }}px;
    overflow: auto;
    position: relative;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 20px;
  }

  .ai-pdf-viewer-canvas-wrapper-{{ ai_gen_id }} {
    display: flex;
    gap: 10px;
    align-items: flex-start;
    justify-content: center;
  }

  .ai-pdf-viewer-canvas-{{ ai_gen_id }} {
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
    background-color: #ffffff;
  }

  .ai-pdf-viewer-loading-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 16px;
    color: #666666;
  }

  .ai-pdf-viewer-error-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 16px;
    color: #d82c0d;
    text-align: center;
    padding: 20px;
  }

  @media screen and (max-width: 749px) {
    .ai-pdf-viewer-toolbar-{{ ai_gen_id }} {
      padding: 10px 12px;
      gap: 8px;
    }

    .ai-pdf-viewer-button-{{ ai_gen_id }} {
      padding: 6px 10px;
      font-size: 13px;
    }

    .ai-pdf-viewer-canvas-container-{{ ai_gen_id }} {
      padding: 10px;
    }

    .ai-pdf-viewer-spread-toggle-{{ ai_gen_id }} {
      display: none;
    }
  }
{% endstyle %}

<pdf-catalogue-viewer-{{ ai_gen_id }}
  class="ai-pdf-viewer-{{ ai_gen_id }}"
  data-pdf-url="{{ block.settings.pdf_url }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.catalogue_title != blank %}
    <div class="ai-pdf-viewer-header-{{ ai_gen_id }}">
      {{ block.settings.catalogue_title }}
    </div>
  {% endif %}

  <div class="ai-pdf-viewer-toolbar-{{ ai_gen_id }}">
    <div class="ai-pdf-viewer-toolbar-group-{{ ai_gen_id }}">
      <button
        class="ai-pdf-viewer-button-{{ ai_gen_id }} ai-pdf-viewer-fit-button-{{ ai_gen_id }}"
        aria-label="Fit to screen"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"></path>
        </svg>
        Fit
      </button>
    </div>

    <div class="ai-pdf-viewer-toolbar-group-{{ ai_gen_id }}">
      <button
        class="ai-pdf-viewer-button-{{ ai_gen_id }} ai-pdf-viewer-zoom-out-{{ ai_gen_id }}"
        aria-label="Zoom out"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.35-4.35M8 11h6"></path>
        </svg>
      </button>
      <div class="ai-pdf-viewer-zoom-display-{{ ai_gen_id }}">100%</div>
      <button
        class="ai-pdf-viewer-button-{{ ai_gen_id }} ai-pdf-viewer-zoom-in-{{ ai_gen_id }}"
        aria-label="Zoom in"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.35-4.35M11 8v6M8 11h6"></path>
        </svg>
      </button>
    </div>

    <div class="ai-pdf-viewer-toolbar-group-{{ ai_gen_id }} ai-pdf-viewer-spread-toggle-{{ ai_gen_id }}">
      <button
        class="ai-pdf-viewer-button-{{ ai_gen_id }} ai-pdf-viewer-toggle-spread-{{ ai_gen_id }}"
        aria-label="Toggle spread mode"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="2" y="3" width="20" height="18" rx="2"></rect>
          <line x1="12" y1="3" x2="12" y2="21"></line>
        </svg>
        <span class="ai-pdf-viewer-spread-label-{{ ai_gen_id }}">Double</span>
      </button>
    </div>

    <div class="ai-pdf-viewer-toolbar-group-{{ ai_gen_id }}">
      <button
        class="ai-pdf-viewer-button-{{ ai_gen_id }} ai-pdf-viewer-prev-{{ ai_gen_id }}"
        aria-label="Previous page"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>
      <div class="ai-pdf-viewer-page-info-{{ ai_gen_id }}">
        <span class="ai-pdf-viewer-current-page-{{ ai_gen_id }}">1</span> / <span class="ai-pdf-viewer-total-pages-{{ ai_gen_id }}">1</span>
      </div>
      <button
        class="ai-pdf-viewer-button-{{ ai_gen_id }} ai-pdf-viewer-next-{{ ai_gen_id }}"
        aria-label="Next page"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    </div>
  </div>

  <div class="ai-pdf-viewer-canvas-container-{{ ai_gen_id }}">
    <div class="ai-pdf-viewer-loading-{{ ai_gen_id }}">Loading PDF...</div>
    <div class="ai-pdf-viewer-canvas-wrapper-{{ ai_gen_id }}" style="display: none;"></div>
  </div>
</pdf-catalogue-viewer-{{ ai_gen_id }}>

<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>

<script>
  (function() {
    pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';

    class PdfCatalogueViewer{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.pdfDoc = null;
        this.currentPage = 1;
        this.scale = 1.0;
        this.isDoubleSpread = false;
        this.isMobile = window.innerWidth < 750;
      }

      connectedCallback() {
        this.pdfUrl = this.dataset.pdfUrl;
        this.loadingEl = this.querySelector('.ai-pdf-viewer-loading-{{ ai_gen_id }}');
        this.canvasWrapper = this.querySelector('.ai-pdf-viewer-canvas-wrapper-{{ ai_gen_id }}');
        this.canvasContainer = this.querySelector('.ai-pdf-viewer-canvas-container-{{ ai_gen_id }}');
        this.currentPageEl = this.querySelector('.ai-pdf-viewer-current-page-{{ ai_gen_id }}');
        this.totalPagesEl = this.querySelector('.ai-pdf-viewer-total-pages-{{ ai_gen_id }}');
        this.zoomDisplay = this.querySelector('.ai-pdf-viewer-zoom-display-{{ ai_gen_id }}');
        this.spreadLabel = this.querySelector('.ai-pdf-viewer-spread-label-{{ ai_gen_id }}');

        this.setupEventListeners();
        
        if (this.pdfUrl) {
          this.loadPDF();
        } else {
          this.showError('No PDF URL provided. Please add a PDF URL in the block settings.');
        }

        window.addEventListener('resize', () => {
          const wasMobile = this.isMobile;
          this.isMobile = window.innerWidth < 750;
          if (wasMobile !== this.isMobile && this.pdfDoc) {
            this.renderPage();
          }
        });
      }

      setupEventListeners() {
        this.querySelector('.ai-pdf-viewer-zoom-in-{{ ai_gen_id }}').addEventListener('click', () => this.zoomIn());
        this.querySelector('.ai-pdf-viewer-zoom-out-{{ ai_gen_id }}').addEventListener('click', () => this.zoomOut());
        this.querySelector('.ai-pdf-viewer-fit-button-{{ ai_gen_id }}').addEventListener('click', () => this.fitToScreen());
        this.querySelector('.ai-pdf-viewer-prev-{{ ai_gen_id }}').addEventListener('click', () => this.prevPage());
        this.querySelector('.ai-pdf-viewer-next-{{ ai_gen_id }}').addEventListener('click', () => this.nextPage());
        this.querySelector('.ai-pdf-viewer-toggle-spread-{{ ai_gen_id }}').addEventListener('click', () => this.toggleSpread());
      }

      async loadPDF() {
        try {
          this.loadingEl.textContent = 'Loading PDF...';
          this.loadingEl.style.display = 'block';
          
          const loadingTask = pdfjsLib.getDocument(this.pdfUrl);
          this.pdfDoc = await loadingTask.promise;
          
          this.totalPagesEl.textContent = this.pdfDoc.numPages;
          this.loadingEl.style.display = 'none';
          this.canvasWrapper.style.display = 'flex';
          
          this.fitToScreen();
        } catch (error) {
          this.showError('Failed to load PDF. Please check the URL and try again.');
          console.error('PDF loading error:', error);
        }
      }

      showError(message) {
        this.loadingEl.style.display = 'none';
        const errorEl = document.createElement('div');
        errorEl.className = 'ai-pdf-viewer-error-{{ ai_gen_id }}';
        errorEl.textContent = message;
        this.canvasContainer.appendChild(errorEl);
      }

      async renderPage() {
        if (!this.pdfDoc) return;

        this.canvasWrapper.innerHTML = '';

        const effectiveSpread = this.isMobile ? false : this.isDoubleSpread;
        const pagesToRender = effectiveSpread ? [this.currentPage, this.currentPage + 1] : [this.currentPage];

        for (const pageNum of pagesToRender) {
          if (pageNum > this.pdfDoc.numPages) continue;

          const page = await this.pdfDoc.getPage(pageNum);
          const viewport = page.getViewport({ scale: this.scale });

          const canvas = document.createElement('canvas');
          canvas.className = 'ai-pdf-viewer-canvas-{{ ai_gen_id }}';
          const context = canvas.getContext('2d');
          canvas.height = viewport.height;
          canvas.width = viewport.width;

          const renderContext = {
            canvasContext: context,
            viewport: viewport
          };

          await page.render(renderContext).promise;
          this.canvasWrapper.appendChild(canvas);
        }

        this.updateControls();
      }

      updateControls() {
        const effectiveSpread = this.isMobile ? false : this.isDoubleSpread;
        const displayPage = effectiveSpread && this.currentPage < this.pdfDoc.numPages 
          ? `${this.currentPage}-${this.currentPage + 1}` 
          : this.currentPage;
        
        this.currentPageEl.textContent = displayPage;
        this.zoomDisplay.textContent = Math.round(this.scale * 100) + '%';

        const prevButton = this.querySelector('.ai-pdf-viewer-prev-{{ ai_gen_id }}');
        const nextButton = this.querySelector('.ai-pdf-viewer-next-{{ ai_gen_id }}');

        prevButton.disabled = this.currentPage <= 1;
        
        if (effectiveSpread) {
          nextButton.disabled = this.currentPage >= this.pdfDoc.numPages - 1;
        } else {
          nextButton.disabled = this.currentPage >= this.pdfDoc.numPages;
        }
      }

      zoomIn() {
        if (this.scale < 3.0) {
          this.scale = Math.min(3.0, this.scale + 0.2);
          this.renderPage();
        }
      }

      zoomOut() {
        if (this.scale > 0.5) {
          this.scale = Math.max(0.5, this.scale - 0.2);
          this.renderPage();
        }
      }

      async fitToScreen() {
        if (!this.pdfDoc) return;

        const page = await this.pdfDoc.getPage(1);
        const viewport = page.getViewport({ scale: 1.0 });
        
        const containerWidth = this.canvasContainer.clientWidth - 40;
        const effectiveSpread = this.isMobile ? false : this.isDoubleSpread;
        const pageWidth = effectiveSpread ? viewport.width * 2 + 10 : viewport.width;
        
        this.scale = containerWidth / pageWidth;
        this.renderPage();
      }

      prevPage() {
        const effectiveSpread = this.isMobile ? false : this.isDoubleSpread;
        const step = effectiveSpread ? 2 : 1;
        
        if (this.currentPage > 1) {
          this.currentPage = Math.max(1, this.currentPage - step);
          this.renderPage();
        }
      }

      nextPage() {
        const effectiveSpread = this.isMobile ? false : this.isDoubleSpread;
        const step = effectiveSpread ? 2 : 1;
        
        if (effectiveSpread) {
          if (this.currentPage < this.pdfDoc.numPages - 1) {
            this.currentPage = Math.min(this.pdfDoc.numPages - 1, this.currentPage + step);
            this.renderPage();
          }
        } else {
          if (this.currentPage < this.pdfDoc.numPages) {
            this.currentPage = Math.min(this.pdfDoc.numPages, this.currentPage + step);
            this.renderPage();
          }
        }
      }

      toggleSpread() {
        this.isDoubleSpread = !this.isDoubleSpread;
        
        if (this.isDoubleSpread) {
          this.spreadLabel.textContent = 'Single';
          if (this.currentPage % 2 === 0) {
            this.currentPage = Math.max(1, this.currentPage - 1);
          }
        } else {
          this.spreadLabel.textContent = 'Double';
        }
        
        this.renderPage();
      }
    }

    customElements.define('pdf-catalogue-viewer-{{ ai_gen_id }}', PdfCatalogueViewer{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "PDF catalogue viewer",
  "settings": [
    {
      "type": "header",
      "content": "PDF settings"
    },
    {
      "type": "url",
      "id": "pdf_url",
      "label": "PDF URL"
    },
    {
      "type": "text",
      "id": "catalogue_title",
      "label": "Catalogue title",
      "default": "Product Catalogue"
    },
    {
      "type": "header",
      "content": "Display settings"
    },
    {
      "type": "range",
      "id": "viewer_height",
      "label": "Viewer height",
      "min": 400,
      "max": 1000,
      "step": 50,
      "unit": "px",
      "default": 700
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#000000"
    }
  ],
  "presets": [
    {
      "name": "PDF catalogue viewer"
    }
  ]
}
{% endschema %}
