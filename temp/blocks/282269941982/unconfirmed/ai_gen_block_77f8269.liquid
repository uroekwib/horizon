{% doc %}
  @prompt
    x-scrollable button links pill shape with dynamic color setting from scheme and font size , ขอเผื่อ 14 links, อยากได้เส้นไกด์แนวตั้งหนา 2 px มุมมน แต่งซ้ายสุดเท่ ๆ ก่อนเริ่ม pills, เส้น guide ชิดไปทางซ้ายสุดเท่าระยะ section อื่น
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-scrollable-pills-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    position: relative;
  }

  .ai-scrollable-pills-container-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 16px;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-scrollable-pills-guide-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: 2px;
    height: 40px;
    background-color: {{ block.settings.guide_color }};
    border-radius: 1px;
  }

  .ai-scrollable-pills-wrapper-{{ ai_gen_id }} {
    flex: 1;
    overflow-x: auto;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .ai-scrollable-pills-wrapper-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .ai-scrollable-pills-list-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.pill_gap }}px;
    padding: 8px 0;
    margin: 0;
    list-style: none;
  }

  .ai-scrollable-pills-item-{{ ai_gen_id }} {
    flex-shrink: 0;
  }

  .ai-scrollable-pills-link-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.pill_padding_vertical }}px {{ block.settings.pill_padding_horizontal }}px;
    background-color: {{ block.settings.color_scheme.settings.background }};
    color: {{ block.settings.color_scheme.settings.foreground }};
    border: 1px solid {{ block.settings.color_scheme.settings.border }};
    border-radius: 100px;
    text-decoration: none;
    font-size: {{ block.settings.font_size }}px;
    white-space: nowrap;
    transition: all 0.2s ease;
  }

  .ai-scrollable-pills-link-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.color_scheme.settings.primary }};
    color: {{ block.settings.color_scheme.settings.background }};
    border-color: {{ block.settings.color_scheme.settings.primary }};
  }

  @media screen and (max-width: 749px) {
    .ai-scrollable-pills-container-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<scrollable-pills-{{ ai_gen_id }}
  class="ai-scrollable-pills-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-scrollable-pills-container-{{ ai_gen_id }}">
    <div class="ai-scrollable-pills-guide-{{ ai_gen_id }}"></div>
    <div class="ai-scrollable-pills-wrapper-{{ ai_gen_id }}">
      <ul class="ai-scrollable-pills-list-{{ ai_gen_id }}">
        {% for i in (1..14) %}
          {% liquid
            assign link_text_key = 'link_' | append: i | append: '_text'
            assign link_url_key = 'link_' | append: i | append: '_url'
            assign link_text = block.settings[link_text_key]
            assign link_url = block.settings[link_url_key]
          %}
          {% if link_text != blank %}
            <li class="ai-scrollable-pills-item-{{ ai_gen_id }}">
              <a
                href="{{ link_url }}"
                class="ai-scrollable-pills-link-{{ ai_gen_id }}"
              >
                {{ link_text }}
              </a>
            </li>
          {% endif %}
        {% endfor %}
      </ul>
    </div>
  </div>
</scrollable-pills-{{ ai_gen_id }}>

<script>
  (function() {
    class ScrollablePills{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.wrapper = this.querySelector('.ai-scrollable-pills-wrapper-{{ ai_gen_id }}');
        this.setupScrollBehavior();
      }

      setupScrollBehavior() {
        if (!this.wrapper) return;

        let isDown = false;
        let startX;
        let scrollLeft;

        this.wrapper.addEventListener('mousedown', (e) => {
          isDown = true;
          this.wrapper.style.cursor = 'grabbing';
          startX = e.pageX - this.wrapper.offsetLeft;
          scrollLeft = this.wrapper.scrollLeft;
        });

        this.wrapper.addEventListener('mouseleave', () => {
          isDown = false;
          this.wrapper.style.cursor = 'grab';
        });

        this.wrapper.addEventListener('mouseup', () => {
          isDown = false;
          this.wrapper.style.cursor = 'grab';
        });

        this.wrapper.addEventListener('mousemove', (e) => {
          if (!isDown) return;
          e.preventDefault();
          const x = e.pageX - this.wrapper.offsetLeft;
          const walk = (x - startX) * 2;
          this.wrapper.scrollLeft = scrollLeft - walk;
        });
      }
    }

    customElements.define('scrollable-pills-{{ ai_gen_id }}', ScrollablePills{{ ai_gen_id }});
  })();
</script>

