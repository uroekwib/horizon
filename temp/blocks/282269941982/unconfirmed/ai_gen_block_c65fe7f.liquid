{% doc %}
  @prompt
    x-scrollable primary button links pill shape with dynamic color setting from scheme and font size , ขอเผื่อ 14 links, อยากได้เส้นไกด์แนวตั้งหนา 2 px มุมมน แต่งซ้ายสุดเท่ ๆ ก่อนเริ่ม pills, เส้น guide ชิดไปทางซ้ายสุดเท่าระยะ section อื่น, กำหนดpaddingของbuttonเพิ่มได้, อยากได้เส้นไกด์แนวตั้งหนา 2 px มุมมน แต่งซ้ายสุดเท่ ๆ ก่อนเริ่ม pills, เส้น guide ชิดไปทางซ้ายสุดเท่าระยะ section อื่น
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-pill-nav-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    position: relative;
  }

  .ai-pill-nav-outer-{{ ai_gen_id }} {
    width: 100%;
    max-width: var(--page-width);
    margin: 0 auto;
    padding-left: var(--page-gutter);
    padding-right: var(--page-gutter);
  }

  .ai-pill-nav-container-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.guide_gap }}px;
  }

  .ai-pill-nav-guide-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: 2px;
    height: {{ block.settings.guide_height }}px;
    background-color: {{ block.settings.guide_color }};
    border-radius: 1px;
  }

  .ai-pill-nav-scroll-wrapper-{{ ai_gen_id }} {
    flex: 1;
    overflow-x: auto;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .ai-pill-nav-scroll-wrapper-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .ai-pill-nav-list-{{ ai_gen_id }} {
    display: flex;
    gap: 12px;
    list-style: none;
    margin: 0;
    padding: 0;
    min-width: min-content;
  }

  .ai-pill-nav-item-{{ ai_gen_id }} {
    flex-shrink: 0;
  }

  .ai-pill-nav-link-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    background-color: {{ block.settings.color_scheme.settings.primary_button_background }};
    color: {{ block.settings.color_scheme.settings.primary_button_text }};
    border: {{ block.settings.border_width }}px solid {{ block.settings.color_scheme.settings.primary_button_border }};
    border-radius: 100px;
    text-decoration: none;
    font-size: {{ block.settings.font_size }}px;
    white-space: nowrap;
    transition: all 0.3s ease;
  }

  .ai-pill-nav-link-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.color_scheme.settings.primary_button_hover_background }};
    color: {{ block.settings.color_scheme.settings.primary_button_hover_text }};
    border-color: {{ block.settings.color_scheme.settings.primary_button_hover_border }};
  }

  @media screen and (max-width: 749px) {
    .ai-pill-nav-guide-{{ ai_gen_id }} {
      height: {{ block.settings.guide_height | times: 0.8 }}px;
    }

    .ai-pill-nav-link-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_vertical | times: 0.8 }}px {{ block.settings.padding_horizontal | times: 0.8 }}px;
      font-size: {{ block.settings.font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<pill-nav-{{ ai_gen_id }} class="ai-pill-nav-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-pill-nav-outer-{{ ai_gen_id }}">
    <div class="ai-pill-nav-container-{{ ai_gen_id }}">
      <div class="ai-pill-nav-guide-{{ ai_gen_id }}"></div>
      <div class="ai-pill-nav-scroll-wrapper-{{ ai_gen_id }}">
        <ul class="ai-pill-nav-list-{{ ai_gen_id }}">
          {% for i in (1..14) %}
            {% liquid
              assign link_text_key = 'link_' | append: i | append: '_text'
              assign link_url_key = 'link_' | append: i | append: '_url'
              assign link_text = block.settings[link_text_key]
              assign link_url = block.settings[link_url_key]
            %}
            {% if link_text != blank %}
              <li class="ai-pill-nav-item-{{ ai_gen_id }}">
                <a href="{{ link_url }}" class="ai-pill-nav-link-{{ ai_gen_id }}">
                  {{ link_text }}
                </a>
              </li>
            {% endif %}
          {% endfor %}
        </ul>
      </div>
    </div>
  </div>
</pill-nav-{{ ai_gen_id }}>

<script>
  (function() {
    class PillNav{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.scrollWrapper = this.querySelector('.ai-pill-nav-scroll-wrapper-{{ ai_gen_id }}');
        this.setupScrollBehavior();
      }

      setupScrollBehavior() {
        if (!this.scrollWrapper) return;

        let isDown = false;
        let startX;
        let scrollLeft;

        this.scrollWrapper.addEventListener('mousedown', (e) => {
          isDown = true;
          this.scrollWrapper.style.cursor = 'grabbing';
          startX = e.pageX - this.scrollWrapper.offsetLeft;
          scrollLeft = this.scrollWrapper.scrollLeft;
        });

        this.scrollWrapper.addEventListener('mouseleave', () => {
          isDown = false;
          this.scrollWrapper.style.cursor = 'grab';
        });

        this.scrollWrapper.addEventListener('mouseup', () => {
          isDown = false;
          this.scrollWrapper.style.cursor = 'grab';
        });

        this.scrollWrapper.addEventListener('mousemove', (e) => {
          if (!isDown) return;
          e.preventDefault();
          const x = e.pageX - this.scrollWrapper.offsetLeft;
          const walk = (x - startX) * 2;
          this.scrollWrapper.scrollLeft = scrollLeft - walk;
        });
      }
    }

    customElements.define('pill-nav-{{ ai_gen_id }}', PillNav{{ ai_gen_id }});
  })();
</script>

