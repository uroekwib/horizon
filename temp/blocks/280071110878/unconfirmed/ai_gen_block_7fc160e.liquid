{% doc %}
  @prompt
    collection filter and then sub collection list
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-collection-filter-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-collection-filter__container-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .ai-collection-filter__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-collection-filter__title-{{ ai_gen_id }} {
    margin: 0 0 8px;
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.text_color }};
  }

  .ai-collection-filter__description-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.text_color }};
    opacity: 0.8;
  }

  .ai-collection-filter__filters-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: {{ block.settings.text_alignment }};
  }

  .ai-collection-filter__button-{{ ai_gen_id }} {
    padding: 10px 20px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    cursor: pointer;
    transition: all 0.3s ease;
    font-size: {{ block.settings.button_font_size }}px;
  }

  .ai-collection-filter__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  .ai-collection-filter__button-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.button_active_background }};
    color: {{ block.settings.button_active_text_color }};
    border-color: {{ block.settings.button_active_border_color }};
  }

  .ai-collection-filter__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-collection-filter__item-{{ ai_gen_id }} {
    display: none;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .ai-collection-filter__item-{{ ai_gen_id }}.visible {
    display: block;
    opacity: 1;
  }

  .ai-collection-filter__card-{{ ai_gen_id }} {
    position: relative;
    display: flex;
    flex-direction: column;
    height: 100%;
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    transition: transform 0.3s ease;
  }

  .ai-collection-filter__card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
  }

  .ai-collection-filter__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    overflow: hidden;
    background-color: #f5f5f5;
  }

  .ai-collection-filter__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-collection-filter__image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-collection-filter__image-placeholder-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
    opacity: 0.3;
  }

  .ai-collection-filter__content-{{ ai_gen_id }} {
    padding: 16px;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .ai-collection-filter__item-title-{{ ai_gen_id }} {
    margin: 0 0 8px;
    font-size: {{ block.settings.card_title_size }}px;
    color: {{ block.settings.text_color }};
  }

  .ai-collection-filter__item-description-{{ ai_gen_id }} {
    margin: 0 0 12px;
    font-size: {{ block.settings.card_description_size }}px;
    color: {{ block.settings.text_color }};
    opacity: 0.7;
    flex-grow: 1;
  }

  .ai-collection-filter__link-{{ ai_gen_id }} {
    display: inline-block;
    padding: 8px 16px;
    background-color: {{ block.settings.link_background }};
    color: {{ block.settings.link_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.link_border_radius }}px;
    font-size: 14px;
    text-align: center;
    transition: all 0.3s ease;
  }

  .ai-collection-filter__link-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.link_hover_background }};
    color: {{ block.settings.link_hover_text_color }};
  }

  .ai-collection-filter__empty-{{ ai_gen_id }} {
    text-align: center;
    padding: 40px 20px;
    color: {{ block.settings.text_color }};
    opacity: 0.6;
    display: none;
  }

  .ai-collection-filter__empty-{{ ai_gen_id }}.visible {
    display: block;
  }

  @media screen and (max-width: 749px) {
    .ai-collection-filter__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-collection-filter__filters-{{ ai_gen_id }} {
      justify-content: center;
    }
  }
{% endstyle %}

<collection-filter-{{ ai_gen_id }}
  class="ai-collection-filter-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-collection-filter__container-{{ ai_gen_id }}">
    {% if block.settings.title != blank or block.settings.description != blank %}
      <div class="ai-collection-filter__header-{{ ai_gen_id }}">
        {% if block.settings.title != blank %}
          <h2 class="ai-collection-filter__title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
        {% endif %}
        {% if block.settings.description != blank %}
          <div class="ai-collection-filter__description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-collection-filter__filters-{{ ai_gen_id }}">
      <button
        class="ai-collection-filter__button-{{ ai_gen_id }} active"
        data-filter="all"
      >
        {{ block.settings.all_button_text }}
      </button>
      {% for i in (1..5) %}
        {% assign collection_key = 'collection_' | append: i %}
        {% assign label_key = 'collection_' | append: i | append: '_label' %}
        {% assign collection = block.settings[collection_key] %}
        {% assign label = block.settings[label_key] %}
        
        {% if collection != blank %}
          <button
            class="ai-collection-filter__button-{{ ai_gen_id }}"
            data-filter="category-{{ i }}"
          >
            {% if label != blank %}
              {{ label }}
            {% else %}
              {{ collection.title }}
            {% endif %}
          </button>
        {% endif %}
      {% endfor %}
    </div>

    <div class="ai-collection-filter__grid-{{ ai_gen_id }}">
      {% for i in (1..5) %}
        {% assign collection_key = 'collection_' | append: i %}
        {% assign collection = block.settings[collection_key] %}
        
        {% if collection != blank %}
          {% for sub_collection in collection.products limit: block.settings.items_per_collection %}
            <div
              class="ai-collection-filter__item-{{ ai_gen_id }} visible"
              data-category="category-{{ i }}"
            >
              <div class="ai-collection-filter__card-{{ ai_gen_id }}">
                <div class="ai-collection-filter__image-wrapper-{{ ai_gen_id }}">
                  {% if sub_collection.featured_image %}
                    <img
                      src="{{ sub_collection.featured_image | image_url: width: 600 }}"
                      alt="{{ sub_collection.featured_image.alt | escape }}"
                      class="ai-collection-filter__image-{{ ai_gen_id }}"
                      loading="lazy"
                      width="600"
                      height="600"
                    >
                  {% else %}
                    <div class="ai-collection-filter__image-placeholder-{{ ai_gen_id }}">
                      {{ 'product-1' | placeholder_svg_tag }}
                    </div>
                  {% endif %}
                </div>
                <div class="ai-collection-filter__content-{{ ai_gen_id }}">
                  <h3 class="ai-collection-filter__item-title-{{ ai_gen_id }}">{{ sub_collection.title }}</h3>
                  {% if block.settings.show_description and sub_collection.description != blank %}
                    <div class="ai-collection-filter__item-description-{{ ai_gen_id }}">
                      {{ sub_collection.description | strip_html | truncate: 100 }}
                    </div>
                  {% endif %}
                  {% if block.settings.show_link %}
                    <a
                      href="{{ sub_collection.url }}"
                      class="ai-collection-filter__link-{{ ai_gen_id }}"
                    >
                      {{ block.settings.link_text }}
                    </a>
                  {% endif %}
                </div>
              </div>
            </div>
          {% endfor %}
        {% endif %}
      {% endfor %}
    </div>

    <div class="ai-collection-filter__empty-{{ ai_gen_id }}">
      {{ block.settings.empty_message }}
    </div>
  </div>
</collection-filter-{{ ai_gen_id }}>

<script>
  (function() {
    class CollectionFilter{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.buttons = this.querySelectorAll('.ai-collection-filter__button-{{ ai_gen_id }}');
        this.items = this.querySelectorAll('.ai-collection-filter__item-{{ ai_gen_id }}');
        this.emptyMessage = this.querySelector('.ai-collection-filter__empty-{{ ai_gen_id }}');
        
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.buttons.forEach((button) => {
          button.addEventListener('click', () => {
            const filter = button.getAttribute('data-filter');
            this.filterItems(filter);
            this.updateActiveButton(button);
          });
        });
      }

      filterItems(filter) {
        let visibleCount = 0;

        this.items.forEach((item) => {
          const category = item.getAttribute('data-category');
          
          if (filter === 'all' || category === filter) {
            item.classList.add('visible');
            visibleCount++;
          } else {
            item.classList.remove('visible');
          }
        });

        if (visibleCount === 0) {
          this.emptyMessage.classList.add('visible');
        } else {
          this.emptyMessage.classList.remove('visible');
        }
      }

      updateActiveButton(activeButton) {
        this.buttons.forEach((button) => {
          button.classList.remove('active');
        });
        activeButton.classList.add('active');
      }
    }

    customElements.define('collection-filter-{{ ai_gen_id }}', CollectionFilter{{ ai_gen_id }});
  })();
</script>

