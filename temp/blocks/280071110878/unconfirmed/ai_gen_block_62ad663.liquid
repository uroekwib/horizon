{% doc %}
  @prompt
    Prompt สำหรับ Sidekick:
    
    Create a Shopify section block for collection pages that displays a dynamic grid of sub-collection cards.
    Requirements:
    
    This block will be used inside collection page templates
    It should fetch and display all collections that are "children" of the current collection, identified by a shared handle prefix (e.g. if current collection handle is signage, show all collections whose handle starts with signage-)
    Each card should show: collection featured image, collection title, and a link to that collection
    Grid layout: 2 columns on mobile, 3–4 columns on desktop, using CSS Grid
    Cards should be fully dynamic — no hardcoded collection handles
    The block should work without needing any app, using only native Liquid and collections object
    Style the cards cleanly with border-radius, subtle shadow, and hover effect
    Section settings should allow: number of columns (desktop), image aspect ratio, show/hide collection description
    
    Metafield — ใส่ metafield subcollections ในแต่ละ collection แล้ว reference จาก block
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-subcollection-grid-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-subcollection-grid__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  @media screen and (min-width: 750px) {
    .ai-subcollection-grid__container-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    }
  }

  .ai-subcollection-card-{{ ai_gen_id }} {
    position: relative;
    display: flex;
    flex-direction: column;
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    background-color: {{ block.settings.card_background_color }};
    box-shadow: 0 2px 8px rgba(0, 0, 0, {{ block.settings.card_shadow_opacity | divided_by: 100.0 }});
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    text-decoration: none;
  }

  .ai-subcollection-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, {{ block.settings.card_shadow_opacity | divided_by: 100.0 | times: 1.5 }});
  }

  .ai-subcollection-card__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  {% if block.settings.image_aspect_ratio == 'square' %}
    .ai-subcollection-card__image-wrapper-{{ ai_gen_id }} {
      padding-bottom: 100%;
    }
  {% elsif block.settings.image_aspect_ratio == 'portrait' %}
    .ai-subcollection-card__image-wrapper-{{ ai_gen_id }} {
      padding-bottom: 133%;
    }
  {% elsif block.settings.image_aspect_ratio == 'landscape' %}
    .ai-subcollection-card__image-wrapper-{{ ai_gen_id }} {
      padding-bottom: 75%;
    }
  {% else %}
    .ai-subcollection-card__image-wrapper-{{ ai_gen_id }} {
      padding-bottom: 100%;
    }
  {% endif %}

  .ai-subcollection-card__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-subcollection-card__placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-subcollection-card__placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-subcollection-card__content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-subcollection-card__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size }}px;
    font-weight: 600;
    color: {{ block.settings.title_color }};
    margin: 0;
    line-height: 1.3;
  }

  .ai-subcollection-card__description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_font_size }}px;
    color: {{ block.settings.description_color }};
    margin: 0;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .ai-subcollection-empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 40px 20px;
    color: #666;
    font-size: 14px;
  }
{% endstyle %}

<div
  class="ai-subcollection-grid-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {% if collection.metafields.custom.subcollections != blank %}
    {% assign subcollections = collection.metafields.custom.subcollections.value %}
    
    {% if subcollections.size > 0 %}
      <div class="ai-subcollection-grid__container-{{ ai_gen_id }}">
        {% for subcollection in subcollections %}
          <a
            href="{{ subcollection.url }}"
            class="ai-subcollection-card-{{ ai_gen_id }}"
          >
            <div class="ai-subcollection-card__image-wrapper-{{ ai_gen_id }}">
              {% if subcollection.featured_image %}
                <img
                  src="{{ subcollection.featured_image | image_url: width: 800 }}"
                  alt="{{ subcollection.featured_image.alt | default: subcollection.title | escape }}"
                  loading="lazy"
                  width="800"
                  height="800"
                  class="ai-subcollection-card__image-{{ ai_gen_id }}"
                >
              {% else %}
                <div class="ai-subcollection-card__placeholder-{{ ai_gen_id }}">
                  {{ 'collection-1' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>

            <div class="ai-subcollection-card__content-{{ ai_gen_id }}">
              <h3 class="ai-subcollection-card__title-{{ ai_gen_id }}">
                {{ subcollection.title }}
              </h3>

              {% if block.settings.show_description and subcollection.description != blank %}
                <div class="ai-subcollection-card__description-{{ ai_gen_id }}">
                  {{ subcollection.description | strip_html | truncate: 120 }}
                </div>
              {% endif %}
            </div>
          </a>
        {% endfor %}
      </div>
    {% else %}
      <div class="ai-subcollection-empty-state-{{ ai_gen_id }}">
        ไม่พบ sub-collections ในคอลเลกชันนี้<br>
        กรุณาเพิ่ม metafield "subcollections" ในการตั้งค่าคอลเลกชัน
      </div>
    {% endif %}
  {% else %}
    <div class="ai-subcollection-empty-state-{{ ai_gen_id }}">
      ไม่พบ metafield "subcollections"<br>
      กรุณาสร้าง metafield ชื่อ "subcollections" ประเภท "List of collections" ในการตั้งค่าคอลเลกชัน
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Sub-collection grid",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Desktop columns",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Mobile columns",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        }
      ],
      "default": "2"
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Grid gap",
      "min": 8,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Card style"
    },
    {
      "type": "select",
      "id": "image_aspect_ratio",
      "label": "Image aspect ratio",
      "options": [
        {
          "value": "square",
          "label": "Square (1:1)"
        },
        {
          "value": "portrait",
          "label": "Portrait (3:4)"
        },
        {
          "value": "landscape",
          "label": "Landscape (4:3)"
        }
      ],
      "default": "square"
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "card_padding",
      "label": "Card padding",
      "min": 8,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "card_shadow_opacity",
      "label": "Shadow opacity",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "%",
      "default": 10
    },
    {
      "type": "color",
      "id": "card_background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show description",
      "default": true
    },
    {
      "type": "range",
      "id": "title_font_size",
      "label": "Title size",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "description_font_size",
      "label": "Description size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description color",
      "default": "#666666"
    }
  ],
  "presets": [
    {
      "name": "Sub-collection grid"
    }
  ]
}
{% endschema %}
