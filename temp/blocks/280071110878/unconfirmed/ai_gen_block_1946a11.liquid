{% doc %}
  @prompt
    Prompt สำหรับ Sidekick:
    
    Create a Shopify section block for collection pages that displays a dynamic grid of sub-collection cards.
    Requirements:
    
    This block will be used inside collection page templates
    It should fetch and display all collections that are "children" of the current collection, identified by a shared handle prefix (e.g. if current collection handle is signage, show all collections whose handle starts with signage-)
    Each card should show: collection featured image, collection title, and a link to that collection
    Grid layout: 2 columns on mobile, 3–4 columns on desktop, using CSS Grid
    Cards should be fully dynamic — no hardcoded collection handles
    The block should work without needing any app, using only native Liquid and collections object
    Style the cards cleanly with border-radius, subtle shadow, and hover effect
    Section settings should allow: number of columns (desktop), image aspect ratio, show/hide collection description
    
    Metafield — ใส่ metafield subcollections ในแต่ละ collection แล้ว reference จาก block, collection มี pill button เซ็ตใส่รูป svg icon แล้วตามด้วยชื่อได้ พอกด filter collection ก็ค่อยโชว์ subcollection pill button ซ้อนตามมา, icon กำหนดแยกให้แต่ละ parent , ขอ 8 parent collection
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-collection-filter-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-collection-filter__container-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.spacing_between_levels }}px;
  }

  .ai-collection-filter__level-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: {{ block.settings.pill_gap }}px;
    align-items: center;
  }

  .ai-collection-filter__level-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.label_font_size }}px;
    color: {{ block.settings.label_color }};
    font-weight: 600;
    margin-right: 8px;
  }

  .ai-collection-pill-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: {{ block.settings.pill_padding_vertical }}px {{ block.settings.pill_padding_horizontal }}px;
    background-color: {{ block.settings.pill_background }};
    color: {{ block.settings.pill_text_color }};
    border: {{ block.settings.pill_border_width }}px solid {{ block.settings.pill_border_color }};
    border-radius: {{ block.settings.pill_border_radius }}px;
    text-decoration: none;
    font-size: {{ block.settings.pill_font_size }}px;
    transition: all 0.3s ease;
    cursor: pointer;
    white-space: nowrap;
  }

  .ai-collection-pill-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.pill_hover_background }};
    color: {{ block.settings.pill_hover_text_color }};
    border-color: {{ block.settings.pill_hover_border_color }};
    transform: translateY(-2px);
  }

  .ai-collection-pill-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.pill_active_background }};
    color: {{ block.settings.pill_active_text_color }};
    border-color: {{ block.settings.pill_active_border_color }};
  }

  .ai-collection-pill__icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-collection-pill__icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    fill: currentColor;
  }

  .ai-collection-pill__icon-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ai-collection-filter__subcollections-{{ ai_gen_id }} {
    display: none;
    padding-left: {{ block.settings.subcollection_indent }}px;
  }

  .ai-collection-filter__subcollections-{{ ai_gen_id }}.visible {
    display: flex;
  }

  @media screen and (max-width: 749px) {
    .ai-collection-filter__level-{{ ai_gen_id }} {
      gap: {{ block.settings.pill_gap | times: 0.75 }}px;
    }

    .ai-collection-pill-{{ ai_gen_id }} {
      padding: {{ block.settings.pill_padding_vertical | times: 0.8 }}px {{ block.settings.pill_padding_horizontal | times: 0.8 }}px;
      font-size: {{ block.settings.pill_font_size | times: 0.9 }}px;
    }

    .ai-collection-pill__icon-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.85 }}px;
      height: {{ block.settings.icon_size | times: 0.85 }}px;
    }
  }
{% endstyle %}

<collection-filter-{{ ai_gen_id }}
  class="ai-collection-filter-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-collection-filter__container-{{ ai_gen_id }}">
    {% if block.settings.show_level_label %}
      <div class="ai-collection-filter__level-{{ ai_gen_id }}">
        <span class="ai-collection-filter__level-label-{{ ai_gen_id }}">{{ block.settings.main_level_label }}</span>
      </div>
    {% endif %}

    <div class="ai-collection-filter__level-{{ ai_gen_id }}" data-level="main">
      {% assign parent_1 = block.settings.parent_1 %}
      {% assign parent_2 = block.settings.parent_2 %}
      {% assign parent_3 = block.settings.parent_3 %}
      {% assign parent_4 = block.settings.parent_4 %}
      {% assign parent_5 = block.settings.parent_5 %}
      {% assign parent_6 = block.settings.parent_6 %}
      {% assign parent_7 = block.settings.parent_7 %}
      {% assign parent_8 = block.settings.parent_8 %}

      {% assign parents = '' | split: '' %}
      {% if parent_1 != blank %}
        {% assign parents = parents | concat: parent_1 %}
      {% endif %}
      {% if parent_2 != blank %}
        {% assign parents = parents | concat: parent_2 %}
      {% endif %}
      {% if parent_3 != blank %}
        {% assign parents = parents | concat: parent_3 %}
      {% endif %}
      {% if parent_4 != blank %}
        {% assign parents = parents | concat: parent_4 %}
      {% endif %}
      {% if parent_5 != blank %}
        {% assign parents = parents | concat: parent_5 %}
      {% endif %}
      {% if parent_6 != blank %}
        {% assign parents = parents | concat: parent_6 %}
      {% endif %}
      {% if parent_7 != blank %}
        {% assign parents = parents | concat: parent_7 %}
      {% endif %}
      {% if parent_8 != blank %}
        {% assign parents = parents | concat: parent_8 %}
      {% endif %}

      {% if parents.size > 0 %}
        {% for i in (1..8) %}
          {% assign parent_key = 'parent_' | append: i %}
          {% assign icon_key = 'icon_' | append: i %}
          {% assign parent_collection = block.settings[parent_key] %}
          {% assign parent_icon = block.settings[icon_key] %}

          {% if parent_collection != blank %}
            <button
              type="button"
              class="ai-collection-pill-{{ ai_gen_id }} {% if collection.handle == parent_collection.handle %}active{% endif %}"
              data-collection-handle="{{ parent_collection.handle }}"
              data-has-subcollections="{% if parent_collection.metafields.custom.subcollections != blank %}true{% else %}false{% endif %}"
            >
              {% if parent_icon != blank %}
                <span class="ai-collection-pill__icon-{{ ai_gen_id }}">
                  <img
                    src="{{ parent_icon | image_url: width: 100 }}"
                    alt="{{ parent_collection.title }}"
                    loading="lazy"
                  >
                </span>
              {% elsif parent_collection.metafields.custom.icon != blank %}
                <span class="ai-collection-pill__icon-{{ ai_gen_id }}">
                  <img
                    src="{{ parent_collection.metafields.custom.icon | image_url: width: 100 }}"
                    alt="{{ parent_collection.title }}"
                    loading="lazy"
                  >
                </span>
              {% endif %}
              <span>{{ parent_collection.title }}</span>
            </button>
          {% endif %}
        {% endfor %}
      {% else %}
        <div style="padding: 20px; color: #666; font-size: 14px;">
          กรุณาเลือก parent collections ในการตั้งค่า block
        </div>
      {% endif %}
    </div>

    {% for i in (1..8) %}
      {% assign parent_key = 'parent_' | append: i %}
      {% assign parent_collection = block.settings[parent_key] %}

      {% if parent_collection != blank and parent_collection.metafields.custom.subcollections != blank %}
        {% assign subcollections = parent_collection.metafields.custom.subcollections.value %}
        
        <div
          class="ai-collection-filter__subcollections-{{ ai_gen_id }} ai-collection-filter__level-{{ ai_gen_id }}"
          data-parent="{{ parent_collection.handle }}"
          data-level="sub"
        >
          {% if block.settings.show_level_label %}
            <span class="ai-collection-filter__level-label-{{ ai_gen_id }}">{{ block.settings.sub_level_label }}</span>
          {% endif %}

          {% for subcollection in subcollections %}
            <a
              href="{{ subcollection.url }}"
              class="ai-collection-pill-{{ ai_gen_id }} {% if collection.handle == subcollection.handle %}active{% endif %}"
            >
              {% if subcollection.metafields.custom.icon != blank %}
                <span class="ai-collection-pill__icon-{{ ai_gen_id }}">
                  <img
                    src="{{ subcollection.metafields.custom.icon | image_url: width: 100 }}"
                    alt="{{ subcollection.title }}"
                    loading="lazy"
                  >
                </span>
              {% endif %}
              <span>{{ subcollection.title }}</span>
            </a>
          {% endfor %}
        </div>
      {% endif %}
    {% endfor %}
  </div>
</collection-filter-{{ ai_gen_id }}>

<script>
  (function() {
    class CollectionFilter{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentActiveParent = null;
      }

      connectedCallback() {
        this.parentButtons = this.querySelectorAll('[data-level="main"] .ai-collection-pill-{{ ai_gen_id }}');
        this.subcollectionLevels = this.querySelectorAll('[data-level="sub"]');
        
        this.setupEventListeners();
        this.showActiveSubcollections();
      }

      setupEventListeners() {
        this.parentButtons.forEach((button) => {
          button.addEventListener('click', (e) => {
            const handle = button.getAttribute('data-collection-handle');
            const hasSubcollections = button.getAttribute('data-has-subcollections') === 'true';

            if (hasSubcollections) {
              e.preventDefault();
              this.toggleSubcollections(handle, button);
            } else {
              window.location.href = `/collections/${handle}`;
            }
          });
        });
      }

      toggleSubcollections(parentHandle, button) {
        const subcollectionLevel = this.querySelector(`[data-parent="${parentHandle}"]`);
        
        if (!subcollectionLevel) return;

        const isCurrentlyVisible = subcollectionLevel.classList.contains('visible');

        this.subcollectionLevels.forEach((level) => {
          level.classList.remove('visible');
        });

        this.parentButtons.forEach((btn) => {
          btn.classList.remove('active');
        });

        if (!isCurrentlyVisible) {
          subcollectionLevel.classList.add('visible');
          button.classList.add('active');
          this.currentActiveParent = parentHandle;
        } else {
          this.currentActiveParent = null;
        }
      }

      showActiveSubcollections() {
        const activeButton = this.querySelector('[data-level="main"] .ai-collection-pill-{{ ai_gen_id }}.active');
        
        if (activeButton) {
          const handle = activeButton.getAttribute('data-collection-handle');
          const hasSubcollections = activeButton.getAttribute('data-has-subcollections') === 'true';
          
          if (hasSubcollections) {
            const subcollectionLevel = this.querySelector(`[data-parent="${handle}"]`);
            if (subcollectionLevel) {
              subcollectionLevel.classList.add('visible');
              this.currentActiveParent = handle;
            }
          }
        }

        const activeSubButton = this.querySelector('[data-level="sub"] .ai-collection-pill-{{ ai_gen_id }}.active');
        if (activeSubButton) {
          const parentLevel = activeSubButton.closest('[data-parent]');
          if (parentLevel) {
            const parentHandle = parentLevel.getAttribute('data-parent');
            parentLevel.classList.add('visible');
            
            const parentButton = this.querySelector(`[data-collection-handle="${parentHandle}"]`);
            if (parentButton) {
              parentButton.classList.add('active');
            }
          }
        }
      }
    }

    customElements.define('collection-filter-{{ ai_gen_id }}', CollectionFilter{{ ai_gen_id }});
  })();
</script>

