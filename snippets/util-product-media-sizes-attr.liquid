{%- doc -%}
  Calculate the sizes attribute for product media images in the product media gallery.

  Optimised for:
  - Shopify 2.0 image_url + image_tag
  - More precise real-world rendered widths
  - Better control for desktop layouts where media often does not exceed ~620px
  - Single column, two-column grid, and large_first_image patterns

  @param {object} block
  @param {object} section
  @param {object} settings
  @param {boolean} [is_first_image]
  @param {boolean} [is_single_column]
  @param {boolean} [needs_both_sizes]
{%- enddoc -%}

{%- liquid
  assign block_settings = block.settings
  assign is_single_column = is_single_column | default: false
  assign needs_both_sizes = needs_both_sizes | default: false
  assign is_first_image = is_first_image | default: false

  assign calculate_single_column = false
  assign calculate_grid_column = false

  if needs_both_sizes
    if is_first_image
      assign calculate_single_column = true
    else
      assign calculate_grid_column = true
    endif
  elsif is_single_column
    assign calculate_single_column = true
  else
    assign calculate_grid_column = true
  endif

  assign section_gap = section.settings.gap | default: 24
  assign image_gap = block_settings.image_gap | default: 16

  case settings.page_width
    when 'narrow'
      assign single_equal_max = 520
      assign single_unequal_max = 560
      assign grid_equal_max = 250
      assign grid_unequal_max = 270
      assign bp_xl = '1400px'
    when 'wide'
      assign single_equal_max = 620
      assign single_unequal_max = 680
      assign grid_equal_max = 300
      assign grid_unequal_max = 330
      assign bp_xl = '1600px'
    else
      assign single_equal_max = 580
      assign single_unequal_max = 620
      assign grid_equal_max = 280
      assign grid_unequal_max = 300
      assign bp_xl = '1500px'
  endcase

  if section.settings.equal_columns
    assign single_max = single_equal_max
    assign grid_max = grid_equal_max
  else
    assign single_max = single_unequal_max
    assign grid_max = grid_unequal_max
  endif

  if block_settings.extend_media
    assign single_max = single_max | plus: 40
    assign grid_max = grid_max | plus: 20
  endif

  if calculate_single_column
    if section.settings.equal_columns
      assign sizes = '(min-width: [bp_xl]) [single_max]px, (min-width: 1200px) min(46vw, [single_max]px), (min-width: 990px) calc(50vw - [section_gap]px), (min-width: 750px) calc(50vw - [section_gap]px), calc(100vw - 32px)'
      assign sizes = sizes | replace: '[bp_xl]', bp_xl | replace: '[single_max]', single_max | replace: '[section_gap]', section_gap
    else
      assign sizes = '(min-width: [bp_xl]) [single_max]px, (min-width: 1200px) min(calc(100vw - 27rem), [single_max]px), (min-width: 990px) calc(100vw - 27rem), (min-width: 750px) calc(100vw - 24rem), calc(100vw - 32px)'
      assign sizes = sizes | replace: '[bp_xl]', bp_xl | replace: '[single_max]', single_max
    endif
  else
    if section.settings.equal_columns
      assign sizes = '(min-width: [bp_xl]) [grid_max]px, (min-width: 1200px) min(22vw, [grid_max]px), (min-width: 990px) calc(25vw - [image_gap]px), (min-width: 750px) calc(25vw - [image_gap]px), calc(100vw - 32px)'
      assign sizes = sizes | replace: '[bp_xl]', bp_xl | replace: '[grid_max]', grid_max | replace: '[image_gap]', image_gap
    else
      assign sizes = '(min-width: [bp_xl]) [grid_max]px, (min-width: 1200px) min(calc((100vw - 27rem) / 2 - [image_gap]px), [grid_max]px), (min-width: 990px) calc((100vw - 27rem) / 2 - [image_gap]px), (min-width: 750px) calc((100vw - 24rem) / 2 - [image_gap]px), calc(100vw - 32px)'
      assign sizes = sizes | replace: '[bp_xl]', bp_xl | replace: '[grid_max]', grid_max | replace: '[image_gap]', image_gap
    endif
  endif

  echo sizes
-%}