<script>
  /* Teleport both bars to <body> to escape any transform/will-change stacking context */
  document.addEventListener('DOMContentLoaded', function() {
    var bar  = document.getElementById('octopus-social-bar');
    var mbar = document.getElementById('octopus-mobile-bar');
    if (bar  && bar.parentElement  !== document.body) document.body.appendChild(bar);
    if (mbar && mbar.parentElement !== document.body) document.body.appendChild(mbar);
  });
</script>

{% schema %}
{
  "name": "Social Bar",
  "settings": [
    { "type": "header", "content": "Links" },
    { "type": "url", "id": "facebook_url", "label": "Facebook URL" },
    { "type": "url", "id": "line_url",     "label": "LINE URL" },
    { "type": "url", "id": "map_url",      "label": "Google Maps URL" },
    { "type": "header", "content": "Mobile Marquee" },
    { "type": "text", "id": "marquee_text_1", "label": "ข้อความที่ 1", "default": "ป้าย · สติ๊กเกอร์ · สื่อสิ่งพิมพ์" },
    { "type": "text", "id": "marquee_text_2", "label": "ข้อความที่ 2", "default": "ออกแบบ · ผลิต · ติดตั้ง" },
    { "type": "text", "id": "marquee_text_3", "label": "ข้อความที่ 3", "default": "พิมพ์คุณภาพสูง รับงานด่วน" }
  ],
  "presets": [{ "name": "Social Bar" }]
}
{% endschema %}
