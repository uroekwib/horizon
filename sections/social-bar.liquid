{% comment %} Social Bar — Desktop: floating right | Mobile: sticky bottom bar {% endcomment %}

{% style %}
  .octopus-social-bar,
  .octopus-mobile-bar {
    font-family: 'Google Sans', 'Noto Sans Thai', sans-serif;
  }

  /* ═══ DESKTOP: floating right bar ═══ */
  .octopus-social-bar {
    position: fixed !important;
    right: 0 !important;
    bottom: 120px !important;
    top: auto !important;
    left: auto !important;
    width: 52px;
    padding: 12px 0;
    border-top-left-radius: 20px;
    border-bottom-left-radius: 20px;
    background: linear-gradient(160deg, rgba(223,213,254,.75) 0%, rgba(215,252,240,.75) 100%);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    box-shadow: -2px 4px 20px rgba(23,169,187,0.15);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    z-index: 9999 !important;
  }

  .octopus-social-bar__btn {
    width: 38px; height: 38px;
    display: flex; align-items: center; justify-content: center;
    text-decoration: none;
    transition: transform 0.2s ease;
  }
  .octopus-social-bar__btn:hover { transform: scale(1.15); }
  .octopus-social-bar__btn svg {
    width: 38px; height: 38px;
    filter: drop-shadow(0 2px 6px rgba(23,169,187,0.2));
  }

  /* ═══ MOBILE: sticky bottom bar ═══ */
  .octopus-mobile-bar {
    position: fixed !important;
    bottom: 0 !important;
    left: 0 !important;
    right: 0 !important;
    top: auto !important;
    height: 62px;
    display: none;
    align-items: center;
    background: linear-gradient(108deg, rgba(223,213,254,.95) 0%, rgba(215,252,240,.95) 100%);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-top: 1px solid rgba(255,255,255,0.6);
    box-shadow: 0 -2px 16px rgba(23,169,187,0.15);
    overflow: hidden;
    z-index: 9999 !important;
  }

  /* Left: marquee */
  .octopus-mobile-bar__left {
    flex: 1 1 auto;
    min-width: 0;
    height: 100%;
    overflow: hidden;
    display: flex;
    align-items: center;
    padding-left: 14px;
    position: relative;
  }
  .octopus-mobile-bar__left::after {
    content: '';
    position: absolute; right: 0; top: 0; bottom: 0; width: 28px;
    background: linear-gradient(to right, transparent, rgba(220,240,248,0.95));
    pointer-events: none;
  }

  .octopus-marquee-track {
    display: flex;
    white-space: nowrap;
    animation: octopus-marquee 24s linear infinite;
  }
  .octopus-marquee-track span {
    font-size: 12px; font-weight: 700; color: #1a2332;
    letter-spacing: 0.02em; padding-right: 40px;
    display: inline-flex; align-items: center; gap: 5px;
  }
  .octopus-marquee-dot {
    display: inline-block; width: 5px; height: 5px; border-radius: 50%;
    background: linear-gradient(135deg, #14c9df, #17a9bb); flex-shrink: 0;
  }
  @keyframes octopus-marquee {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* Right: icons */
  .octopus-mobile-bar__right {
    flex: 0 0 auto;
    height: 100%;
    display: flex; align-items: center;
    gap: 4px; padding: 0 12px 0 10px;
    border-left: 1px solid rgba(255,255,255,0.6);
  }
  .octopus-mobile-bar__icon {
    width: 40px; height: 40px;
    display: flex; align-items: center; justify-content: center;
    text-decoration: none; transition: transform 0.15s ease;
    -webkit-tap-highlight-color: transparent;
  }
  .octopus-mobile-bar__icon:active { transform: scale(0.88); }
  .octopus-mobile-bar__icon svg {
    width: 36px; height: 36px;
    filter: drop-shadow(0 2px 5px rgba(23,169,187,0.2));
  }

  /* ═══ Responsive ═══ */
  @media (max-width: 749px) {
    .octopus-social-bar { display: none !important; }
    .octopus-mobile-bar { display: flex !important; }
  }
{% endstyle %}

{%- assign fb_url   = section.settings.facebook_url -%}
{%- assign line_url = section.settings.line_url -%}
