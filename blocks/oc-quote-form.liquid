{% comment %}
  oc-quote-form.liquid — Octopus Media Solutions
  Namespace : custom | Key : quote_form_id | Type : Integer
{% endcomment %}

{% assign form_id = product.metafields.custom.quote_form_id | default: 1 %}
{% assign form_url = 'https://alphadigital.media/form.php?form=' | append: form_id %}

<div id="oc-quote-wrap" style="width:100%;margin-top:16px">
  <iframe
    id="oc-quote-frame"
    src="{{ form_url }}"
    width="100%"
    height="860"
    frameborder="0"
    scrolling="no"
    loading="lazy"
    title="ขอใบเสนอราคา"
    style="display:block;border:none;overflow:hidden;border-radius:12px;transition:height .3s ease">
  </iframe>
</div>

<script>
(function(){
  window.addEventListener('message', function(e) {
    if (e.data && e.data.type === 'oc-form-height') {
      var f = document.getElementById('oc-quote-frame');
      if (f) f.style.height = (e.data.height + 40) + 'px';
    }
  });
})();
</script>

{% schema %}
{
  "name": "Quote Form",
}
{% endschema %}