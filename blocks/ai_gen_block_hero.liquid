                <img src="{{ block.settings.card_12_image | image_url: width: 400 }}" alt="{{ block.settings.card_12_image.alt | escape }}" loading="lazy" width="180" height="{{ block.settings.card_half_height }}">
              {%- else -%}
                <div class="oc-hero-placeholder-{{ ai_gen_id }}">{{ 'product-1' | placeholder_svg_tag }}</div>
              {%- endif -%}
              {%- if block.settings.card_12_title != blank -%}
                <div class="oc-hero-card-overlay-{{ ai_gen_id }}"><p class="oc-hero-card-title-{{ ai_gen_id }}">{{ block.settings.card_12_title }}</p></div>
              {%- endif -%}
              {%- if block.settings.card_12_link != blank -%}</a>{%- endif -%}
            </div>
            </div>

          {%- endfor -%}

        </div>{%- comment -%} /scroll {%- endcomment -%}
      </div>{%- comment -%} /bento {%- endcomment -%}
    </div>{%- comment -%} /right {%- endcomment -%}

  </div>{%- comment -%} /wrap {%- endcomment -%}
</div>


<script>
  (function() {
    // Wrap Thai characters with Noto Sans Thai font-family
    // (Google Sans handles Latin, Noto handles Thai U+0E00-U+0E7F)
    var heading = document.querySelector('.oc-hero-h1-{{ ai_gen_id }}');
    if (!heading) return;
    var thaiRe = /[\u0E00-\u0E7F]+/g;
    heading.childNodes.forEach(function(node) {
      if (node.nodeType !== 3) return; // text nodes only
      var t = node.textContent;
      if (!thaiRe.test(t)) return;
      thaiRe.lastIndex = 0;
      var span = document.createElement('span');
      span.innerHTML = t.replace(thaiRe, function(m) {
        return '<span style="font-family:var(--font-body--family)">' + m + '</span>';
      });
      node.replaceWith(span);
    });
  })();
</script>





