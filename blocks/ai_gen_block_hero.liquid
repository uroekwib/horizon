{% doc %}
  @prompt SaaS-style hero section — Thai signage company.
  Left: headline + buttons + stats. Right: auto-scrolling bento HERO.
  CSS ported to reference Octopus design system tokens / classes.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}


{% style %}
  /* ─────────────────────────────────────────────
     LAYOUT — section-specific only
     Tokens & typography borrowed from custom_css
  ───────────────────────────────────────────── */

  .oc-hero-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    min-height: 320px;
    position: relative;
    overflow: hidden;
    /* ── override Horizon narrow-page-width constraint
       ถ้า parent ใช้ .page-width-narrow / .page-width-content
       ให้ reset กลับเป็น full --page-width ── */
    --page-content-width: var(--page-width);
  }

  .oc-hero-wrap-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    max-width: 1400px;
    margin: 0 auto;
    padding: {{ block.settings.padding_top }}px 40px {{ block.settings.padding_bottom }}px;
    align-items: center;
  }

  /* ── Left ── */
  .oc-hero-left-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 20px;
    z-index: 2;
  }

  /* heading size driven by Liquid setting — all other type tokens from custom_css */
  .oc-hero-h1-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    line-height: 1.1;
    font-weight: 700;
    color: var(--oc-ink);
    margin: 0;
    font-family: var(--oc-font-display);
    /* em → rainbow: handled globally by custom_css em,i rule */
  }

  /* Divider */
  .oc-hero-divider-{{ ai_gen_id }} {
    width: 100%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--oc-ink-15), transparent);
  }

  /* Stats row */
  .oc-hero-stats-{{ ai_gen_id }} {
    display: flex;
    gap: 25px;
    flex-wrap: wrap;
  }

  .oc-hero-stat-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  /* stat number size is Liquid-driven — font-family & color from tokens */
  .oc-hero-stat-num-{{ ai_gen_id }} {
    font-family: var(--oc-font-display);
    font-size: {{ block.settings.stat_number_size }}px;
    font-weight: 700;
    color: var(--oc-ink);
  }

  .oc-hero-stat-lbl-{{ ai_gen_id }} {
    font-family: var(--font-body--family);
    font-size: var(--font-sm--size);
    color: var(--oc-ink-40);
  }

  /* ── Right — bento gallery ── */
  .oc-hero-right-{{ ai_gen_id }} {
    position: relative;
    height: 100%;
    min-height: 320px;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .oc-hero-bento-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100%;
    mask-image: linear-gradient(to right, transparent 0%, black 10%, black 90%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 10%, black 90%, transparent 100%);
  }

  /* scroll speed is Liquid-driven */
  .oc-hero-scroll-{{ ai_gen_id }} {
    display: flex;
    gap: 16px;
    animation: oc-bento-scroll-{{ ai_gen_id }} {{ block.settings.scroll_speed }}s linear infinite;
  }

  .oc-hero-bento-{{ ai_gen_id }}:hover .oc-hero-scroll-{{ ai_gen_id }} {
    animation-play-state: paused;
  }

  @keyframes oc-bento-scroll-{{ ai_gen_id }} {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .oc-hero-col-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 16px;
    flex-shrink: 0;
  }

  /* card base — glass style uses oc-glass tokens, radius from --oc-radius-lg */
  .oc-hero-card-{{ ai_gen_id }} {
    background: var(--oc-glass);
    backdrop-filter: var(--oc-blur);
    -webkit-backdrop-filter: var(--oc-blur);
    border: 1px solid var(--oc-glass-border-subtle);
    border-radius: var(--oc-radius-lg);
    box-shadow: var(--oc-shadow-sm);
    overflow: hidden;
    position: relative;
    transition: transform var(--oc-dur-base) var(--oc-ease-expo);
  }

  .oc-hero-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: var(--oc-shadow-md);
  }

  /* card sizes are Liquid-driven */
  .oc-hero-card-tall-{{ ai_gen_id }} {
    width: 180px;
    height: {{ block.settings.card_tall_height }}px;
  }

  .oc-hero-card-half-{{ ai_gen_id }} {
    width: 180px;
    height: {{ block.settings.card_half_height }}px;
  }

  .oc-hero-card-link-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    height: 100%;
    position: relative;
    text-decoration: none;
  }

  .oc-hero-card-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* hover overlay */
  .oc-hero-card-overlay-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.80), transparent);
    padding: 16px 12px 12px;
    transform: translateY(100%);
    transition: transform var(--oc-dur-base) var(--oc-ease-expo);
  }

  .oc-hero-card-{{ ai_gen_id }}:hover .oc-hero-card-overlay-{{ ai_gen_id }} {
    transform: translateY(0);
  }

  .oc-hero-card-title-{{ ai_gen_id }} {
    font-family: var(--font-body--family);
    font-size: 14px;
    font-weight: 600;
    color: #ffffff;
    margin: 0;
    line-height: 1.3;
  }

  /* placeholder when no image set */
  .oc-hero-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background: var(--oc-ink-05);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .oc-hero-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.2;
  }

  /* ── Responsive ── */
  @media screen and (max-width: 989px) {
    .oc-hero-wrap-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 40px;
      padding: {{ block.settings.padding_top_mobile }}px 24px {{ block.settings.padding_bottom_mobile }}px;
    }

    .oc-hero-h1-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
    }

    .oc-hero-right-{{ ai_gen_id }} { min-height: 280px; }

    .oc-hero-card-tall-{{ ai_gen_id }} {
      width: 140px;
      height: {{ block.settings.card_tall_height | times: 0.8 | round }}px;
    }

    .oc-hero-card-half-{{ ai_gen_id }} {
      width: 140px;
      height: {{ block.settings.card_half_height | times: 0.8 | round }}px;
    }

    .oc-hero-stat-num-{{ ai_gen_id }} {
      font-size: {{ block.settings.stat_number_size_mobile }}px;
    }

    .oc-hero-card-title-{{ ai_gen_id }} { font-size: 12px; }
  }
{% endstyle %}


