{% doc %}
  Clean Bento Hero
  - respects base.css section grid
  - supports full width / page width properly
  - no hard-coded max-width
{% enddoc %}

{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{%- liquid
  assign section_mode = 'section--full-width'
  if block.settings.section_width == 'page'
    assign section_mode = 'section--page-width'
  endif

  assign page_width_class = 'page-width-wide'
  case block.settings.page_width_preset
    when 'normal'
      assign page_width_class = 'page-width-normal'
    when 'narrow'
      assign page_width_class = 'page-width-narrow'
    when 'content'
      assign page_width_class = 'page-width-content'
    else
      assign page_width_class = 'page-width-wide'
  endcase
-%}

{% style %}
  .oc-hero-{{ ai_gen_id }} {
    position: relative;
    min-height: 320px;
    overflow: clip;
  }

  .oc-hero-inner-{{ ai_gen_id }} {
    width: 100%;
    min-width: 0;
  }

  .oc-hero-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    align-items: center;
    gap: 60px;
    width: 100%;
    min-width: 0;
    padding:
      {{ block.settings.padding_top }}px
      0
      {{ block.settings.padding_bottom }}px;
  }

  .oc-hero-left-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 20px;
    min-width: 0;
    position: relative;
    z-index: 2;
  }

  .oc-hero-h1-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.heading_size }}px;
    line-height: 1.1;
    font-weight: 700;
    color: var(--oc-ink);
    font-family: var(--oc-font-display);
  }

  .oc-hero-actions-{{ ai_gen_id }} {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .oc-hero-divider-{{ ai_gen_id }} {
    width: 100%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--oc-ink-15), transparent);
  }

  .oc-hero-stats-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: 25px;
  }

  .oc-hero-stat-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }

  .oc-hero-stat-num-{{ ai_gen_id }} {
    font-family: var(--oc-font-display);
    font-size: {{ block.settings.stat_number_size }}px;
    font-weight: 700;
    color: var(--oc-ink);
    line-height: 1;
  }

  .oc-hero-stat-lbl-{{ ai_gen_id }} {
    font-family: var(--font-body--family);
    font-size: var(--font-sm--size);
    color: var(--oc-ink-40);
    line-height: 1.4;
  }

  .oc-hero-right-{{ ai_gen_id }} {
    position: relative;
    min-width: 0;
    min-height: 320px;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .oc-hero-bento-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    min-width: 0;
    mask-image: linear-gradient(to right, transparent 0%, black 10%, black 90%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 10%, black 90%, transparent 100%);
  }

  .oc-hero-scroll-{{ ai_gen_id }} {
    display: flex;
    gap: 16px;
    width: max-content;
    animation: oc-bento-scroll-{{ ai_gen_id }} {{ block.settings.scroll_speed }}s linear infinite;
    will-change: transform;
  }

  .oc-hero-bento-{{ ai_gen_id }}:hover .oc-hero-scroll-{{ ai_gen_id }} {
    animation-play-state: paused;
  }

  @keyframes oc-bento-scroll-{{ ai_gen_id }} {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  .oc-hero-col-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 16px;
    flex: 0 0 auto;
  }

  .oc-hero-card-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: var(--oc-radius-lg);
    border: 1px solid var(--oc-glass-border-subtle);
    background: var(--oc-glass);
    backdrop-filter: var(--oc-blur);
    -webkit-backdrop-filter: var(--oc-blur);
    box-shadow: var(--oc-shadow-sm);
    transition:
      transform var(--oc-dur-base) var(--oc-ease-expo),
      box-shadow var(--oc-dur-base) var(--oc-ease-expo);
  }

  .oc-hero-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: var(--oc-shadow-md);
  }

  .oc-hero-card-tall-{{ ai_gen_id }} {
    width: 180px;
    height: {{ block.settings.card_tall_height }}px;
  }

  .oc-hero-card-half-{{ ai_gen_id }} {
    width: 180px;
    height: {{ block.settings.card_half_height }}px;
  }

  .oc-hero-card-link-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    height: 100%;
    color: inherit;
    text-decoration: none;
  }

  .oc-hero-card-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .oc-hero-card-overlay-{{ ai_gen_id }} {
    position: absolute;
    right: 0;
    bottom: 0;
    left: 0;
    padding: 16px 12px 12px;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.8), transparent);
    transform: translateY(100%);
    transition: transform var(--oc-dur-base) var(--oc-ease-expo);
  }

  .oc-hero-card-{{ ai_gen_id }}:hover .oc-hero-card-overlay-{{ ai_gen_id }} {
    transform: translateY(0);
  }

  .oc-hero-card-title-{{ ai_gen_id }} {
    margin: 0;
    font-size: 14px;
    font-weight: 600;
    line-height: 1.3;
    color: #fff;
    font-family: var(--font-body--family);
  }

  .oc-hero-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--oc-ink-05);
  }

  .oc-hero-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.2;
  }

  @media screen and (max-width: 989px) {
    .oc-hero-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 40px;
      padding:
        {{ block.settings.padding_top_mobile }}px
        0
        {{ block.settings.padding_bottom_mobile }}px;
    }

    .oc-hero-h1-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
    }

    .oc-hero-right-{{ ai_gen_id }} {
      min-height: 280px;
    }

    .oc-hero-card-tall-{{ ai_gen_id }} {
      width: 140px;
      height: {{ block.settings.card_tall_height | times: 0.8 | round }}px;
    }

    .oc-hero-card-half-{{ ai_gen_id }} {
      width: 140px;
      height: {{ block.settings.card_half_height | times: 0.8 | round }}px;
    }

    .oc-hero-stat-num-{{ ai_gen_id }} {
      font-size: {{ block.settings.stat_number_size_mobile }}px;
    }

    .oc-hero-card-title-{{ ai_gen_id }} {
      font-size: 12px;
    }
  }
{% endstyle %}

