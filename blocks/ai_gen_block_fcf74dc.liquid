{% doc %}
  FAQ tabs with chip navigation — Octopus CI
  - Chips: Google Sans / Noto Sans Thai, CI gradient active state
  - Content: no padding, no background, no border
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-faq-tabs-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-faq-chips-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: {{ block.settings.chip_gap }}px;
    margin-top: 10 px;
    margin-bottom: 10 px;
  }

  /* ── Chip base ── */
  .ai-faq-chip-{{ ai_gen_id }} {
  font-family: 'Google Sans', 'Noto Sans Thai', sans-serif;
  padding: 6px 14px;
  border-radius: 6px;
  background: rgba(23,169,187,0.09);
  border: none;
  color: #17a9bb;
  font-size: {{ block.settings.chip_font_size }}px;
  font-weight: 500;
  cursor: pointer;
  white-space: nowrap;
  letter-spacing: 0.03em;
  transition: background 0.2s;
}

.ai-faq-chip-{{ ai_gen_id }}:hover {
  background: rgba(23,169,187,0.18);
}

.ai-faq-chip-{{ ai_gen_id }}.active {
  background: linear-gradient(135deg, #14c9df, #17a9bb);
  color: #fff;
  box-shadow: 0 2px 8px rgba(20,201,223,0.28);
}

  /* Active = CI gradient */
  .ai-faq-chip-{{ ai_gen_id }}.active {
    background: linear-gradient(90deg, #14c9df 0%, #17a9bb 35%, #818CF8 65%, #A78BFA 100%);
    background-size: 200% 100%;
    /*border-color: transparent;*/
    color: #fff;
    box-shadow: 0 4px 20px rgba(20, 201, 223, 0.30);
    animation: faq-chip-shimmer-{{ ai_gen_id }} 4s ease infinite;
  }

  .ai-faq-chip-{{ ai_gen_id }}.active:hover {
    filter: brightness(1.06);
    transform: translateY(-1px);
    color: #fff;
  }

  @keyframes faq-chip-shimmer-{{ ai_gen_id }} {
    0%   { background-position: 0% 50%; }
    50%  { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  /* ── Content panel — no padding, no bg, no border ── */
  .ai-faq-content-container-{{ ai_gen_id }} {
    min-height: {{ block.settings.content_min_height }}px;
    margin-top: 10px;
  }

  .ai-faq-content-panel-{{ ai_gen_id }} {
    display: none;
    opacity: 0;
    transition: opacity 0.25s ease;
  }

  .ai-faq-content-panel-{{ ai_gen_id }}.active {
    display: block;
    opacity: 1;
  }

  .ai-faq-content-text-{{ ai_gen_id }} {
    font-family: 'Google Sans', 'Noto Sans Thai', sans-serif;
    font-size: {{ block.settings.content_text_size }}px;
    color: {{ block.settings.content_text_color }};
    line-height: 1.75;
  }

  .ai-faq-content-text-{{ ai_gen_id }} p {
    margin: 0 0 10px 0;
  }

  .ai-faq-content-text-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-faq-tabs-{{ ai_gen_id }} { width: 100%; }
    .ai-faq-chip-{{ ai_gen_id }} {
      font-size: {{ block.settings.chip_font_size | minus: 1 }}px;
    }
    .ai-faq-content-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.content_text_size | minus: 1 }}px;
    }
  }
{% endstyle %}

<faq-tabs-{{ ai_gen_id }} class="ai-faq-tabs-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-faq-chips-{{ ai_gen_id }}">
    {% for i in (1..12) %}
      {% assign heading_key = 'item_' | append: i | append: '_heading' %}
      {% assign heading_val = block.settings[heading_key] %}
      {% if heading_val != blank %}
        <button class="ai-faq-chip-{{ ai_gen_id }}" data-target="item-{{ i }}" type="button">
          {{ heading_val }}
        </button>
      {% endif %}
    {% endfor %}
  </div>

  <div class="ai-faq-content-container-{{ ai_gen_id }}">
    {% for i in (1..12) %}
      {% assign heading_key = 'item_' | append: i | append: '_heading' %}
      {% assign content_key = 'item_' | append: i | append: '_content' %}
      {% assign heading_val = block.settings[heading_key] %}
      {% if heading_val != blank %}
        <div class="ai-faq-content-panel-{{ ai_gen_id }}" data-panel-id="item-{{ i }}">
          <div class="ai-faq-content-text-{{ ai_gen_id }}">
            {{ block.settings[content_key] }}
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</faq-tabs-{{ ai_gen_id }}>

<script>
(function() {
  class FaqTabs extends HTMLElement {
    connectedCallback() {
      this.chips  = this.querySelectorAll('.ai-faq-chip-{{ ai_gen_id }}');
      this.panels = this.querySelectorAll('.ai-faq-content-panel-{{ ai_gen_id }}');

      this.chips.forEach(chip => {
        chip.addEventListener('click', () => {
          const target = chip.dataset.target;
          this.chips.forEach(c => c.classList.remove('active'));
          this.panels.forEach(p => p.classList.remove('active'));
          chip.classList.add('active');
          const panel = this.querySelector(`[data-panel-id="${target}"]`);
          if (panel) panel.classList.add('active');
        });
      });

      // Show first item by default
      if (this.chips.length > 0) {
        this.chips[0].classList.add('active');
        const first = this.querySelector(`[data-panel-id="${this.chips[0].dataset.target}"]`);
        if (first) first.classList.add('active');
      }
    }
  }

  const tag = 'faq-tabs-{{ ai_gen_id }}';
  if (!customElements.get(tag)) customElements.define(tag, FaqTabs);
})();
</script>

