{%- doc -%}
  Octopus Media header menu block

  Variants:
   - 'mobile'   → mobile drawer (Horizon native)
   - default    → desktop nav + 3-column mega drawer

  Mega drawer:
   - Col 0 = parent collections from menu children
   - Col 1 = subcollections from metafield custom.subcol_megamenu
   - Col 2 = products loaded by AJAX from selected subcollection
{%- enddoc -%}

{% liquid
  assign block_settings = block.settings
%}

{% case variant %}

  {% when 'mobile' %}
    <div
      class="header__drawer"
      ref="headerDrawerContainer"
      data-hydration-key="header-drawer-mobile"
      {{ block.shopify_attributes }}
    >
      {% render 'header-drawer',
        linklist: block_settings.menu,
        data_header_drawer_type: 'mobile-drawer'
      %}
    </div>

  {% else %}

    {% liquid
      assign color_scheme_classes = ''
      assign cs_key = 'color_scheme_' | append: section.settings.menu_row
      assign current_cs = block_settings.color_scheme
      assign parent_cs = section.settings[cs_key]

      if parent_cs.id != current_cs.id
        assign color_scheme_classes = ' color-' | append: current_cs
      endif
      if parent_cs.settings.background.rgb == current_cs.settings.background.rgb
        assign color_scheme_classes = color_scheme_classes | append: ' color-scheme-matches-parent'
      endif

      assign page_width_class = 'page-width-wide'
      case block_settings.page_width_preset
        when 'normal'
          assign page_width_class = 'page-width-normal'
        when 'narrow'
          assign page_width_class = 'page-width-narrow'
        when 'content'
          assign page_width_class = 'page-width-content'
      endcase
    %}

    {% capture children %}
      {% for link in block_settings.menu.links %}
        <li
          class="menu-list__list-item"
          role="presentation"
          on:focus="/activate"
          on:blur="/deactivate"
          on:pointerenter="/activate"
          on:pointerleave="/deactivate"
        >
          {% assign is_mega_toggle_only = false %}
{% if link.title == 'สินค้าและบริการ' and link.links != blank %}
  {% assign is_mega_toggle_only = true %}
{% endif %}

{% if is_mega_toggle_only %}
  <button
    type="button"
    data-skip-node-update="true"
    class="menu-list__link button-unstyled{% if link.active %} menu-list__link--active{% endif %}"
    aria-controls="submenu-{{ forloop.index }}"
    aria-haspopup="true"
    aria-expanded="false"
    ref="menuitem"
  >
    <span class="menu-list__link-title">{{- link.title -}}</span>
  </button>
{% else %}
  <a
    href="{{ link.url }}"
    data-skip-node-update="true"
    class="menu-list__link{% if link.active %} menu-list__link--active{% endif %}"
    {% if link.links != blank %}
      aria-controls="submenu-{{ forloop.index }}"
      aria-haspopup="true"
      aria-expanded="false"
    {% endif %}
    {% if link.current %}aria-current="page"{% endif %}
    ref="menuitem"
  >
    <span class="menu-list__link-title">{{- link.title -}}</span>
  </a>
{% endif %}

          {% if link.links != blank %}
            <div class="menu-list__submenu{{ color_scheme_classes }}" ref="submenu[]">
              <div
                id="submenu-{{ forloop.index }}"
                class="menu-list__submenu-inner oc-mega-inner {{ page_width_class }}"
                style="{% render 'submenu-font-styles', settings: block_settings %}"
              >
                <div
                  class="oc-mega-panel oc-mega-v4"
                  style="
                    --oc-col0-width: {{ block_settings.col0_width }}px;
                    --oc-col1-width: {{ block_settings.col1_width }}px;
                    --oc-l0-font-size: {{ block_settings.l0_font_size }}px;
                    --oc-l1-font-size: {{ block_settings.l1_font_size }}px;
                    --oc-thumb-title-font-size: {{ block_settings.thumb_title_font_size }}px;
                    --oc-thumb-height: {{ block_settings.thumb_height }}px;
                    --oc-thumb-image-width: {{ block_settings.thumb_image_width }}px;
                    --oc-drawer-min-height: {{ block_settings.drawer_min_height }}px;
                  "
                >
                  <div class="oc-mega__cats">
                    <div class="oc-mega__cats-head">{{ link.title }}</div>
                    <div class="oc-mega__cats-scroll" role="tablist" aria-label="{{ link.title | escape }}">
                      {% for l0 in link.links %}
                        {%- liquid
                          assign l0_coll = l0.object
                          assign l0_handle = ''
                          if l0_coll != blank
                            assign l0_handle = l0_coll.handle
                          endif
                        -%}
                        <button
                          type="button"
                          class="oc-mega__cat{% if forloop.first %} active{% endif %}"
                          data-grp="{{ forloop.index0 }}"
                          data-coll="{{ l0_handle }}"
                          data-url="{{ l0.url }}"
                          role="tab"
                          aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
                          tabindex="{% if forloop.first %}0{% else %}-1{% endif %}"
                        >
                          <span class="oc-mega__cat-label">{{- l0.title -}}</span>
                          <span class="oc-mega__cat-arrow" aria-hidden="true">›</span>
                        </button>
                      {% endfor %}
                    </div>
                    <div class="oc-mega__cats-foot">
                      <a href="{{ link.url }}" class="oc-mega__alllink">
                        <span>{{ 'actions.view_all' | t | default: 'ดูทั้งหมด' }}</span>
                        <span aria-hidden="true">→</span>
                      </a>
                    </div>
                  </div>

                  <div class="oc-mega__subs">
                    {% for l0 in link.links %}
                      {%- liquid
                        assign l0_coll = l0.object
                        assign l0_handle = ''
                        assign subcols = blank
                        assign has_meta = false

                        if l0_coll != blank
                          assign l0_handle = l0_coll.handle
                          assign subcols = l0_coll.metafields.custom.subcol_megamenu.value
                        endif

                        if subcols != blank and subcols.size > 0
                          assign has_meta = true
                        endif
                      -%}

                      <div
                        class="oc-mega__sub-pane{% if forloop.first %} active{% endif %}"
                        data-grp="{{ forloop.index0 }}"
                        data-handle="{{ l0_handle }}"
                      >
                        <div class="oc-mega__sub-head">{{ l0.title }}</div>
                        <div class="oc-mega__sub-scroll" role="listbox" aria-label="{{ l0.title | escape }}">
                          {% if has_meta %}
                            {% for subcol in subcols %}
                              <button
                                type="button"
                                class="oc-mega__sub{% if forloop.first and forloop.parentloop.first %} active{% endif %}"
                                data-coll="{{ subcol.handle }}"
                                data-url="{{ subcol.url }}"
                                role="option"
                                aria-selected="{% if forloop.first and forloop.parentloop.first %}true{% else %}false{% endif %}"
                              >
                                <span class="oc-mega__sub-dot" aria-hidden="true"></span>
                                <span class="oc-mega__sub-label">{{- subcol.title -}}</span>
                              </button>
                            {% endfor %}
                          {% else %}
                            {% for l1 in l0.links %}
                              {%- liquid
                                assign l1_coll = l1.object
                                assign l1_handle = ''
                                if l1_coll != blank
                                  assign l1_handle = l1_coll.handle
                                endif
                              -%}
                              <button
                                type="button"
                                class="oc-mega__sub{% if forloop.first and forloop.parentloop.first %} active{% endif %}"
                                data-coll="{{ l1_handle }}"
                                data-url="{{ l1.url }}"
                                role="option"
                                aria-selected="{% if forloop.first and forloop.parentloop.first %}true{% else %}false{% endif %}"
                              >
                                <span class="oc-mega__sub-dot" aria-hidden="true"></span>
                                <span class="oc-mega__sub-label">{{- l1.title -}}</span>
                              </button>
                            {% endfor %}
                          {% endif %}
                        </div>
                        <a href="{{ l0.url }}" class="oc-mega__sub-seeall">
                          <span>{{ 'actions.view_all' | t | default: 'ดูทั้งหมด' }}</span>
                          <span aria-hidden="true">→</span>
                        </a>
                      </div>
                    {% endfor %}
                  </div>

                  <div class="oc-mega__products">
                    <div class="oc-mega__prod-head">
                      <span>{{ 'general.search.products' | t | default: 'สินค้าแนะนำ' }}</span>
                    </div>
                    <div
                      class="oc-mega__product-panel"
                      data-card-count="{{ block_settings.mega_thumb_count }}"
                      data-product-limit="{{ block_settings.product_limit }}"
                      aria-live="polite"
                      aria-busy="false"
                    ></div>
                  </div>
                </div>
          {% endif %}
        </li>
      {% endfor %}

      <li
        class="menu-list__list-item"
        role="presentation"
        slot="more"
        on:focus="/activate"
        on:blur="/deactivate"
        on:pointerenter="/activate"
        on:pointerleave="/deactivate"
      >
        <button role="listitem" class="menu-list__link button-unstyled">
          <span class="menu-list__link-title">{{ 'actions.more' | t }}</span>
        </button>
      </li>
    {% endcapture %}

    <header-menu
      ref="headerMenu"
      class="header-menu"
      {{ block.shopify_attributes }}
      data-hydration-key="header-menu"
    >
      <div class="header-menu__inner">
        <nav
          class="menu-list"
          aria-label="{{ 'accessibility.header_navigation_label' | t }}"
          style="
            {% render 'menu-font-styles', settings: block_settings %}
            --oc-top-menu-font-size: {{ block_settings.top_menu_font_size }}px;
          "
        >
          {% assign overflow_class = 'overflow-menu' | append: color_scheme_classes %}
          {% render 'overflow-list',
            class: overflow_class,
            ref: 'overflowMenu',
            children: children,
            minimum-items: 2,
            data-testid: 'header-menu-overflow-list',
            attributes: 'data-skip-node-update'
          %}
        </nav>
      </div>

      <script
        src="{{ 'header-menu.js' | asset_url }}"
        type="module"
        fetchpriority="low"
      ></script>
    </header-menu>


    <script>
      (function () {
        'use strict';

        function isDesktopMenu() {
          var hdr = document.getElementById('header-component');
          return hdr && hdr.getAttribute('data-menu-style') === 'menu';
        }

        var _cache = {};

        function esc(s) {
          return String(s || '')
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;');
        }

        function normalizeShopifyImage(src) {
          if (!src) return null;
          src = String(src);

          if (src.indexOf('//') === 0) src = window.location.protocol + src;

          if (src.indexOf('http') !== 0 && src.indexOf('//') !== 0) {
            src = src.indexOf('/') === 0 ? window.location.origin + src : window.location.origin + '/' + src;
          }

          return src;
        }

        function resizeImg(src, width, height) {
          src = normalizeShopifyImage(src);
          if (!src) return null;

          src = src.replace(/_(pico|icon|thumb|small|compact|medium|large|grande|original|\d+x\d*)(?=\.[a-zA-Z]{3,4}(\?[^.]*)?$)/, '');
          return src.replace(/(\.[a-zA-Z]{3,4})(\?[^.]*)?$/, '_' + width + 'x' + height + '$1$2');
        }

        function getProductImage(product) {
          if (!product) return null;

          if (typeof product.featured_image === 'string' && product.featured_image) return product.featured_image;

          if (product.featured_image && typeof product.featured_image === 'object') {
            if (product.featured_image.src) return product.featured_image.src;
            if (product.featured_image.url) return product.featured_image.url;
          }

          if (Array.isArray(product.images) && product.images.length) {
            var first = product.images[0];
            if (typeof first === 'string') return first;
            if (first && first.src) return first.src;
            if (first && first.url) return first.url;
          }

          if (product.image && product.image.src) return product.image.src;

          return null;
        }

        function formatMoneyFromCents(cents) {
          if (typeof cents !== 'number') return '';
          try {
            return new Intl.NumberFormat('th-TH', {
              style: 'currency',
              currency: 'THB',
              maximumFractionDigits: 0
            }).format(cents / 100);
          } catch (e) {
            return '';
          }
        }

        function fetchProducts(handle, limit) {
          if (!handle) return Promise.resolve([]);

          var cacheKey = handle + '::' + limit;

          if (Array.isArray(_cache[cacheKey])) {
            return Promise.resolve(_cache[cacheKey]);
          }

          if (_cache[cacheKey] && typeof _cache[cacheKey].then === 'function') {
            return _cache[cacheKey];
          }

          _cache[cacheKey] = fetch('/collections/' + encodeURIComponent(handle) + '/products.json?limit=' + encodeURIComponent(limit), {
            credentials: 'same-origin'
          })
            .then(function (res) {
              if (!res.ok) throw new Error('Fetch failed: ' + res.status);
              return res.json();
            })
            .then(function (data) {
              var products = Array.isArray(data.products) ? data.products : [];
              _cache[cacheKey] = products;
              return products;
            })
            .catch(function () {
              _cache[cacheKey] = [];
              return [];
            });

          return _cache[cacheKey];
        }

        function OcMegaV4(panel) {
          this.panel = panel;
          this.productPanel = panel.querySelector('.oc-mega__product-panel');
          this.catItems = Array.from(panel.querySelectorAll('.oc-mega__cat'));
          this.subPanes = Array.from(panel.querySelectorAll('.oc-mega__sub-pane'));
          this.cardCount = parseInt(this.productPanel.dataset.cardCount || 4, 10);
          this.productLimit = parseInt(this.productPanel.dataset.productLimit || 8, 10);

          var styles = getComputedStyle(this.panel);
          this.thumbImageWidth = parseInt(styles.getPropertyValue('--oc-thumb-image-width') || 500, 10);
          this.thumbImageHeight = Math.round(this.thumbImageWidth * 3 / 4);

          this.activeHandle = '';
          this.bind();
          this.boot();
        }

        OcMegaV4.prototype.bind = function () {
          var self = this;

          this.catItems.forEach(function (cat) {
            var activate = function () {
              self.selectCategory(Number(cat.dataset.grp), cat);
            };

            cat.addEventListener('mouseenter', activate);
            cat.addEventListener('focus', activate);
            cat.addEventListener('click', function (e) {
              e.preventDefault();
              activate();
            });

            cat.addEventListener('keydown', function (e) {
              var idx = self.catItems.indexOf(cat);
              var nextIdx = idx;

              if (e.key === 'ArrowDown' || e.key === 'ArrowRight') nextIdx = Math.min(self.catItems.length - 1, idx + 1);
              if (e.key === 'ArrowUp' || e.key === 'ArrowLeft') nextIdx = Math.max(0, idx - 1);

              if (nextIdx !== idx) {
                e.preventDefault();
                self.catItems[nextIdx].focus();
              }

              if (e.key === 'Enter' || e.key === ' ') {
                e.preventDefault();
                activate();
              }
            });
          });

          this.panel.addEventListener('mouseenter', function (e) {
            var sub = e.target.closest('.oc-mega__sub');
            if (sub) self.selectSub(sub);
          }, true);

          this.panel.addEventListener('focusin', function (e) {
            var sub = e.target.closest('.oc-mega__sub');
            if (sub) self.selectSub(sub);
          });

          this.panel.addEventListener('click', function (e) {
            var sub = e.target.closest('.oc-mega__sub');
            if (!sub) return;
            e.preventDefault();
            self.selectSub(sub);
          });
        };

        OcMegaV4.prototype.boot = function () {
          if (!this.catItems.length) return;
          this.selectCategory(0, this.catItems[0]);
        };

        OcMegaV4.prototype.selectCategory = function (grp, cat) {
          this.catItems.forEach(function (item, idx) {
            var isActive = idx === grp && item === cat;
            item.classList.toggle('active', isActive);
            item.setAttribute('aria-selected', isActive ? 'true' : 'false');
            item.setAttribute('tabindex', isActive ? '0' : '-1');
          });

          this.subPanes.forEach(function (pane) {
            pane.classList.toggle('active', Number(pane.dataset.grp) === grp);
          });

          var activePane = this.panel.querySelector('.oc-mega__sub-pane.active');
          var firstSub = activePane ? activePane.querySelector('.oc-mega__sub') : null;

          if (firstSub) {
            this.selectSub(firstSub);
            this.prefetchNext(activePane, firstSub);
          } else {
            this.render([], '', cat ? cat.dataset.url : '');
          }
        };

        OcMegaV4.prototype.selectSub = function (sub) {
          var activePane = sub.closest('.oc-mega__sub-pane');
          if (!activePane) return;

          activePane.querySelectorAll('.oc-mega__sub').forEach(function (item) {
            var isActive = item === sub;
            item.classList.toggle('active', isActive);
            item.setAttribute('aria-selected', isActive ? 'true' : 'false');
          });

          this.loadProducts(sub.dataset.coll, sub.dataset.url || activePane.dataset.url || '');
        };

        OcMegaV4.prototype.prefetchNext = function (pane, current) {
          var next = current && current.nextElementSibling ? current.nextElementSibling : null;
          if (next && next.dataset && next.dataset.coll) {
            fetchProducts(next.dataset.coll, this.productLimit);
          }
        };

        OcMegaV4.prototype.loadProducts = function (handle, collUrl) {
          var self = this;

          if (!handle) {
            self.render([], handle, collUrl);
            return;
          }

          if (self.activeHandle === handle && self.productPanel.innerHTML.trim() !== '') {
            return;
          }

          self.activeHandle = handle;
          self.productPanel.setAttribute('aria-busy', 'true');
          self.productPanel.innerHTML = '<div class="oc-mega__prod-scroll"><p class="oc-mega__loading">กำลังโหลด…</p></div>';

          fetchProducts(handle, self.productLimit).then(function (products) {
            if (self.activeHandle !== handle) return;
            self.render(products, handle, collUrl);
          });
        };

        OcMegaV4.prototype.render = function (products, handle, collUrl) {
          var pp = this.productPanel;
          var cardCount = this.cardCount;
          var url = collUrl || (handle ? '/collections/' + handle : '#');
          var imageW = this.thumbImageWidth;
          var imageH = this.thumbImageHeight;

          pp.setAttribute('aria-busy', 'false');

          if (!products || !products.length) {
            pp.innerHTML =
              '<div class="oc-mega__prod-scroll">' +
                '<p class="oc-mega__empty">ไม่พบสินค้าในหมวดนี้</p>' +
              '</div>' +
              (url !== '#'
                ? '<a href="' + esc(url) + '" class="oc-mega__prod-viewall"><span>ดูทั้งหมด</span><span aria-hidden="true">→</span></a>'
                : '');
            return;
          }

          var cards = products.slice(0, cardCount);
          var html = '<div class="oc-mega__prod-scroll"><div class="oc-mega__prod-grid">';

          cards.forEach(function (p) {
            var rawImg = getProductImage(p);
            var src = rawImg ? resizeImg(rawImg, imageW, imageH) : null;
            var productUrl = '/products/' + esc(p.handle);
            var price = '';
            if (typeof p.price_min === 'number') price = formatMoneyFromCents(p.price_min);
            else if (Array.isArray(p.variants) && p.variants.length && typeof p.variants[0].price === 'number') price = formatMoneyFromCents(p.variants[0].price);
            else if (Array.isArray(p.variants) && p.variants.length && p.variants[0].price) price = formatMoneyFromCents(parseInt(p.variants[0].price, 10));

            html += '<a href="' + productUrl + '" class="oc-mega__card">';
            if (src) {
              html += '<img class="oc-mega__card-img" src="' + esc(src) + '" alt="' + esc(p.title) + '" loading="lazy" width="320" height="240">';
            } else {
              html += '<div class="oc-mega__card-img oc-mega__card-img--ph"></div>';
            }
            html += '<div class="oc-mega__card-body">';
            html += '<div class="oc-mega__card-name">' + esc(p.title) + '</div>';
            if (price) html += '<div class="oc-mega__card-price">' + esc(price) + '</div>';
            html += '</div></a>';
          });

          html += '</div></div>';
          html += '<a href="' + esc(url) + '" class="oc-mega__prod-viewall"><span>ดูทั้งหมด</span><span aria-hidden="true">→</span></a>';
          pp.innerHTML = html;
        };

        function tryInit() {
          if (!isDesktopMenu()) return;
          document.querySelectorAll('.oc-mega-v4').forEach(function (panel) {
            if (!panel._ocMegaV4) {
              panel._ocMegaV4 = new OcMegaV4(panel);
            }
          });
        }

        tryInit();

        var obs = new MutationObserver(function (mutations) {
          var found = mutations.some(function (m) {
            return Array.from(m.addedNodes).some(function (n) {
              return n.nodeType === 1 && (
                n.matches('.oc-mega-v4') ||
                (n.querySelector && n.querySelector('.oc-mega-v4'))
              );
            });
          });

          if (found) tryInit();
        });

        obs.observe(document.body, { childList: true, subtree: true });

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', function () {
            tryInit();
            setTimeout(tryInit, 300);
          });
        } else {
          setTimeout(tryInit, 100);
          setTimeout(tryInit, 300);
        }
      })();
    </script>

    <script>
      (function () {
        'use strict';

        function isDesktopMenu() {
          var hdr = document.getElementById('header-component');
          return hdr && hdr.getAttribute('data-menu-style') === 'menu';
        }

        var OPEN_DELAY = 140;
        var CLOSE_DELAY = 520;
        var openTimer = null;
        var closeTimer = null;

        function clearOpen() { if (openTimer) { clearTimeout(openTimer); openTimer = null; } }
        function clearClose() { if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; } }

        function getOpenTrigger() {
          return document.querySelector('.menu-list__list-item .menu-list__link[aria-haspopup][aria-expanded="true"]');
        }

        function closeAll() {
          document.querySelectorAll('.menu-list__list-item .menu-list__link[aria-haspopup][aria-expanded="true"]').forEach(function (t) {
            t.setAttribute('aria-expanded', 'false');
          });
        }

        function openTrigger(trigger) {
          if (!trigger) return;
          closeAll();
          trigger.setAttribute('aria-expanded', 'true');
        }

        function bindItems(root) {
          if (!isDesktopMenu()) return;

          root.querySelectorAll('.menu-list__list-item').forEach(function (item) {
            if (item._ocHoverBound) return;
            item._ocHoverBound = true;

            var trigger = item.querySelector('.menu-list__link[aria-haspopup]');
            if (!trigger) return;

            item.addEventListener('mouseenter', function () {
              clearOpen();
              clearClose();

              if (trigger.getAttribute('aria-expanded') === 'true') return;

              if (getOpenTrigger()) {
                openTrigger(trigger);
              } else {
                openTimer = setTimeout(function () {
                  openTrigger(trigger);
                }, OPEN_DELAY);
              }
            });

            item.addEventListener('focusin', function () {
              clearOpen();
              clearClose();
              openTrigger(trigger);
            });

            item.addEventListener('keydown', function (e) {
              if ((e.key === 'Enter' || e.key === ' ') && document.activeElement === trigger) {
                e.preventDefault();
                if (trigger.getAttribute('aria-expanded') === 'true') {
                  trigger.setAttribute('aria-expanded', 'false');
                } else {
                  openTrigger(trigger);
                }
              }

              if (e.key === 'Escape') {
                trigger.setAttribute('aria-expanded', 'false');
                trigger.focus();
              }
            });
          });
        }

        function attachHeaderGuard() {
          if (!isDesktopMenu()) return;
          var hdr = document.getElementById('header-component');
          if (!hdr || hdr._ocGuardBound) return;
          hdr._ocGuardBound = true;

          hdr.addEventListener('mouseover', function () {
            clearClose();
          });

          hdr.addEventListener('mouseleave', function () {
            clearOpen();
            closeTimer = setTimeout(closeAll, CLOSE_DELAY);
          });

          document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') {
              clearOpen();
              clearClose();
              closeAll();
            }
          });
        }

        bindItems(document);
        attachHeaderGuard();

        var obs = new MutationObserver(function () {
          bindItems(document);
          attachHeaderGuard();
        });

        obs.observe(document.body, { childList: true, subtree: true });
      })();
    </script>


{% endcase %}

{% style %}
  .header__underlay {
    --color-submenu: rgb({{ block_settings.color_scheme.settings.background.rgba }});
  }
{% endstyle %}

{% stylesheet %}
.header__drawer {
  --header-drawer-min-height: 60px;
  display: flex;
  min-height: var(--header-drawer-min-height);
  align-items: center;
}

#header-component[data-menu-style='drawer'] .header__drawer {
  display: flex;
  min-height: var(--header-drawer-min-height);
}

@media screen and (min-width: 750px) {
  #header-component[data-menu-style='menu'] .header__drawer {
    display: none;
    min-height: 0;
  }
}

.header--compact .header__drawer {
  min-height: var(--minimum-touch-target);
}

.menu-list {
  --menu-horizontal-gap: var(--gap-xl);
  --menu-vertical-gap: var(--gap-xl);
  display: flex;
  height: 100%;
}

.menu-list__list {
  display: flex;
  justify-content: var(--grid-area-alignment);
}

.menu-list__list-item {
  flex-shrink: 0;
  white-space: nowrap;
  display: flex;
  align-items: center;
  height: 100%;
}

.menu-list__list-item[aria-hidden='true'] {
  visibility: hidden;
}

.menu-list__link {
  font-family: var(--menu-top-level-font-family);
  font-style: var(--menu-top-level-font-style);
  font-weight: var(--menu-top-level-font-weight);
  font-size: var(--oc-top-menu-font-size, var(--menu-top-level-font-size));
  line-height: var(--menu-top-level-font-line-height);
  text-transform: var(--menu-top-level-font-case);
  color: var(--menu-top-level-font-color);
  text-decoration: none;
  display: flex;
  flex-direction: column;
  justify-content: center;
  cursor: pointer;
  height: 100%;
  margin-block: 0;
}

.menu-list__link:hover,
.menu-list__link:focus {
  color: var(--menu-top-level-font-color);
}

@media screen and (min-width: 750px) {
  .menu-list__link {
    font-size: var(--oc-top-menu-font-size, var(--menu-top-level-font-size-desktop));
  }
}

.menu-list__link-title {
  padding-inline: calc(var(--gap-xl) / 2);
}

[slot='overflow'] .menu-list__link-title {
  padding-inline: 0;
}

.menu-list__list-item:not([slot='overflow']) {
  flex-direction: column;
}

.menu-list__list-item:not([slot='overflow'])::after {
  content: '';
  width: 100%;
  height: var(--header-padding);
  margin-bottom: calc(-1 * var(--header-padding));
}

[slot='overflow'] > .menu-list__link::after {
  content: none;
}

.menu-list:where(:has(.menu-list__list-item:hover)),
.menu-list:where(:has(.menu-list__list-item:focus-within)),
.menu-list:where(:has(.menu-list__list-item:not([aria-hidden='true']) .menu-list__link--active)) .menu-list__link {
  color: rgb(var(--menu-top-level-font-color-rgb) / var(--opacity-subdued-text));
}

.menu-list:not(:has(.menu-list__list-item:hover)) .menu-list__link--active,
.menu-list .menu-list__list-item:where(:hover, :focus-within) .menu-list__link,
.menu-list .menu-list__list-item[slot='overflow'] .menu-list__link[aria-expanded='true'] {
  color: var(--menu-top-level-font-color);
}

.overflow-menu::part(list) {
  --focus-outline-size: calc(var(--focus-outline-offset) + var(--focus-outline-width));
  gap: 0;
  margin-inline: calc(-1 * var(--menu-horizontal-gap) / 2);
}

.overflow-menu {
  background-color: transparent;
  padding: var(--focus-outline-size);
  margin: calc(-1 * var(--focus-outline-size));
}

.menu-list__submenu,
.overflow-menu::part(overflow) {
  --submenu-padding-block-start: var(--padding-3xl);
  --submenu-padding-block-end: var(--padding-3xl);
  background-color: transparent;
}

.header__row[style*='--border-bottom-width: 0px'] .menu-list__submenu.color-scheme-matches-parent,
.header__row[style*='--border-bottom-width: 0px'] .overflow-menu.color-scheme-matches-parent::part(overflow) {
  --submenu-padding-block-start: 0px;
}

.menu-list__list-item:where(:not([slot='overflow'])) > .menu-list__submenu,
.overflow-menu::part(overflow) {
  --submenu-content-opacity: 0;
  --submenu-content-animation: opacity calc(var(--submenu-animation-speed) * 0.75) var(--animation-easing);
  visibility: hidden;
  position: absolute;
  width: 100%;
  left: 0;
  top: calc(100% - 1px + var(--border-bottom-width) - (var(--full-open-header-height) - var(--submenu-height)));
  z-index: var(--layer-header-menu);
  padding-inline: var(--padding-inline);
  clip-path: rect(var(--header-height) 100% var(--full-open-header-height) 0);
  transition: clip-path var(--submenu-animation-speed) var(--ease-out-cubic);
}

[data-submenu-overlap-bottom-row] .menu-list__list-item:where(:not([slot='overflow'])) > .menu-list__submenu,
[data-submenu-overlap-bottom-row] .overflow-menu::part(overflow) {
  clip-path: rect(var(--top-row-height) 100% var(--full-open-header-height) 0);
}

.menu-list__list-item:has([aria-expanded='true']) > .menu-list__submenu,
.overflow-menu:has([slot="overflow"] [aria-expanded='true'])::part(overflow-list),
.menu-list__submenu:is(:hover),
.overflow-menu::part(overflow):hover {
  --submenu-content-opacity: 1;
  visibility: visible;
}

.overflow-menu::part(overflow) {
  --menu-top-level-font-size: var(--font-size--xlarge);
  display: grid;
  grid-template-columns: var(--full-page-grid-with-margins);
}

.overflow-menu::part(overflow-list) {
  position: relative;
  display: grid;
  grid-template-columns: minmax(auto, 200px) 1fr;
  grid-template-areas: 'left right';
  grid-template-rows: max-content;
  grid-gap: 0;
  grid-column: 2;
}

.menu-list__list-item:is([slot='overflow']) {
  --menu-top-level-font-color: var(--color-foreground);
  --menu-top-level-font-color-rgb: var(--color-foreground-rgb);
  display: contents;
  white-space: normal;
}

.menu-list__list-item:is([slot='overflow']) .menu-list__link {
  grid-area: left;
  grid-row: auto;
  height: min-content;
  font-size: var(--font-size--xl);
  transition: var(--submenu-content-animation);
}

.menu-list__list-item:is([slot='overflow']) .menu-list__submenu {
  visibility: hidden;
  grid-row: 1;
  grid-area: right;
  grid-row-end: span calc(var(--overflow-count) + 1);
  padding-inline-start: var(--menu-horizontal-gap);
}

.menu-list__list-item:is([slot='overflow']) .menu-list__submenu-inner {
  transform: none;
  grid-column: unset;
  padding-block: 0;
}

.menu-list__list-item:is([slot='overflow']) .menu-list__link[aria-expanded='true'] + .menu-list__submenu {
  visibility: visible;
}

.header-menu {
  height: 100%;
}

.menu-list__submenu-inner,
.overflow-menu::part(overflow-list) {
  padding-block-start: var(--submenu-padding-block-start);
  padding-block-end: var(--submenu-padding-block-end);
  padding-inline: var(--section-padding-inline);
  opacity: var(--submenu-content-opacity);
  transition: var(--submenu-content-animation);
  transform: translateY(calc(var(--full-open-header-height) - var(--submenu-height)));
  max-height: calc(82vh - var(--header-height));
  overflow: hidden;
  overflow-x: hidden;
}

.oc-mega-inner {
  position: relative;
  display: flex;
  justify-content: space-between;
  padding-block: 0 !important;
  padding-inline: 0 !important;
  overflow: hidden !important;
  flex-wrap: nowrap !important;
  align-items: stretch;
  max-width: var(--page-width);
  width: 100%;
  margin-inline: auto;
  box-sizing: border-box;
}

.oc-mega-panel {
  --oc-cyan: #17a9bb;
  --oc-cyan-vv: #14c9df;
  --oc-indigo: #818CF8;
  --oc-purple: #A78BFA;
  --oc-purple-d: #7C3AED;
  --oc-ink: #1A202C;
  --oc-ink-70: #374151;
  --oc-ink-40: #6B7280;
  --oc-ink-15: #E5E7EB;
  --oc-ink-05: #F9FAFB;
  --oc-radius: 14px;
  --oc-radius-lg: 22px;
  --oc-radius-pill: 999px;
  --oc-glass-shadow: 0 20px 60px rgba(100,100,160,0.18);
  display: flex;
  width: 100%;
  min-height: max(var(--oc-drawer-min-height, 260px), 420px);
  max-height: calc(82vh - var(--header-height, 64px));
  background: #fff;
  border: 1px solid rgba(0,0,0,0.06);
  border-top: 0;
  border-radius: 0 0 var(--oc-radius-lg) var(--oc-radius-lg);
  box-shadow: var(--oc-glass-shadow);
  overflow: hidden;
}

.oc-mega__cats {
  width: min(var(--oc-col0-width, 230px), 260px);
  min-width: 190px;
  background: var(--oc-ink-05);
  border-right: 1px solid var(--oc-ink-15);
  display: flex;
  flex-direction: column;
}

.oc-mega__cats-head,
.oc-mega__sub-head,
.oc-mega__prod-head {
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--oc-ink-40);
  padding: 14px 20px 10px;
  border-bottom: 1px solid var(--oc-ink-15);
  flex-shrink: 0;
}

.oc-mega__prod-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.oc-mega__cats-scroll,
.oc-mega__sub-scroll,
.oc-mega__prod-scroll {
  flex: 1;
  min-height: 0;
  overflow-y: auto;
  overflow-x: hidden;
  scrollbar-width: thin;
  scrollbar-color: rgba(20, 201, 223, 0.25) transparent;
}

.oc-mega__cats-scroll::-webkit-scrollbar,
.oc-mega__sub-scroll::-webkit-scrollbar,
.oc-mega__prod-scroll::-webkit-scrollbar {
  width: 4px;
}

.oc-mega__cats-scroll::-webkit-scrollbar-thumb,
.oc-mega__sub-scroll::-webkit-scrollbar-thumb,
.oc-mega__prod-scroll::-webkit-scrollbar-thumb {
  background: rgba(20, 201, 223, 0.25);
  border-radius: 99px;
}

.oc-mega__cats-scroll { padding: 6px 0; }
.oc-mega__sub-scroll { padding: 6px 8px; }
.oc-mega__prod-scroll { padding: 12px 16px; }

.oc-mega__cat,
.oc-mega__sub {
  width: 100%;
  border: 0;
  background: transparent;
  text-align: left;
  cursor: pointer;
  font: inherit;
}

.oc-mega__cat {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 11px 14px 11px 18px;
  color: var(--oc-ink-70);
  font-size: var(--oc-l0-font-size, 13px);
  font-weight: 500;
  position: relative;
  transition: background .12s ease, color .12s ease;
}

.oc-mega__cat-label,
.oc-mega__sub-label {
  min-width: 0;
  white-space: normal;
  word-break: break-word;
}

.oc-mega__cat:hover,
.oc-mega__cat.active {
  background: #fff;
  color: var(--oc-cyan);
}

.oc-mega__cat.active {
  font-weight: 600;
}

.oc-mega__cat.active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 6px;
  bottom: 6px;
  width: 3px;
  border-radius: 0 3px 3px 0;
  background: linear-gradient(180deg, var(--oc-cyan-vv), var(--oc-cyan));
}

.oc-mega__cat-arrow {
  margin-left: auto;
  opacity: .38;
  transform: translateX(-2px);
  transition: opacity .15s ease, transform .15s ease;
}

.oc-mega__cat.active .oc-mega__cat-arrow {
  opacity: .8;
  transform: translateX(0);
}

.oc-mega__cats-foot,
.oc-mega__sub-seeall,
.oc-mega__prod-viewall {
  height: 42px;
  border-top: 1px solid var(--oc-ink-15);
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.oc-mega__alllink,
.oc-mega__sub-seeall,
.oc-mega__prod-viewall {
  width: 100%;
  padding-inline: 18px;
  text-decoration: none;
  color: var(--oc-cyan);
  font-size: 12px;
  font-weight: 600;
  gap: 6px;
  transition: background .15s ease, gap .2s ease;
}

.oc-mega__alllink {
  display: inline-flex;
  align-items: center;
}

.oc-mega__sub-seeall,
.oc-mega__prod-viewall {
  justify-content: center;
}

.oc-mega__alllink:hover,
.oc-mega__sub-seeall:hover,
.oc-mega__prod-viewall:hover {
  background: rgba(20, 201, 223, .04);
  gap: 10px;
}

.oc-mega__subs {
  width: min(var(--oc-col1-width, 230px), 300px);
  min-width: 220px;
  border-right: 1px solid var(--oc-ink-15);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.oc-mega__sub-pane {
  display: none;
  flex-direction: column;
  flex: 1;
  min-height: 0;
}

.oc-mega__sub-pane.active {
  display: flex;
}

.oc-mega__sub {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 12px;
  border-radius: 8px;
  color: var(--oc-ink-70);
  font-size: var(--oc-l1-font-size, 13px);
  font-weight: 500;
  transition: background .12s ease, color .12s ease, transform .12s ease;
}

.oc-mega__sub:hover,
.oc-mega__sub.active {
  background: rgba(20, 201, 223, .06);
  color: var(--oc-ink);
  transform: translateX(2px);
}

.oc-mega__sub.active {
  color: var(--oc-cyan);
}

.oc-mega__sub-dot {
  width: 5px;
  height: 5px;
  min-width: 5px;
  border-radius: 99px;
  background: var(--oc-ink-15);
  transition: background .12s ease, transform .12s ease;
}

.oc-mega__sub:hover .oc-mega__sub-dot,
.oc-mega__sub.active .oc-mega__sub-dot {
  background: var(--oc-cyan);
  transform: scale(1.35);
}

.oc-mega__products {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.oc-mega__product-panel {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-height: 0;
}

.oc-mega__prod-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10px;
  align-content: start;
}

.oc-mega__card {
  display: flex;
  flex-direction: column;
  border: 1px solid var(--oc-ink-15);
  border-radius: 10px;
  overflow: hidden;
  text-decoration: none;
  color: var(--oc-ink-70);
  background: #fff;
  transition: border-color .18s ease, box-shadow .18s ease, transform .18s ease;
}

.oc-mega__card:hover {
  border-color: rgba(20, 201, 223, .3);
  box-shadow: 0 2px 12px rgba(20, 201, 223, .1);
  transform: translateY(-1px);
}

.oc-mega__card-img {
  width: 100%;
  aspect-ratio: 4 / 3;
  object-fit: cover;
  display: block;
  background: var(--oc-ink-05);
}

.oc-mega__card-img--ph {
  min-height: 120px;
}

.oc-mega__card-body {
  width: 100%;
  padding: 8px 9px 10px;
}

.oc-mega__card-name {
  font-size: max(11px, var(--oc-thumb-title-font-size, 11px));
  font-weight: 600;
  line-height: 1.35;
  color: var(--oc-ink);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  min-height: 2.7em;
}

.oc-mega__card-price {
  margin-top: 3px;
  font-size: 11px;
  font-weight: 700;
  color: var(--oc-cyan);
}

.oc-mega__loading,
.oc-mega__empty {
  font-size: 12px;
  color: var(--oc-ink-40);
  padding: 16px 0 8px;
  margin: 0;
}

@media screen and (max-width: 1199px) {
  .oc-mega__cats {
    width: min(var(--oc-col0-width, 230px), 220px);
  }

  .oc-mega__subs {
    width: min(var(--oc-col1-width, 230px), 250px);
  }
}

@media screen and (max-width: 989px) {
  .oc-mega-panel {
    flex-direction: column;
    max-height: min(80vh, 760px);
  }

  .oc-mega__cats,
  .oc-mega__subs {
    width: 100%;
    min-width: 0;
    border-right: 0;
    border-bottom: 1px solid var(--oc-ink-15);
  }

  .oc-mega__cats {
    background: #fff;
  }

  .oc-mega__cats-head {
    display: none;
  }

  .oc-mega__cats-scroll {
    display: flex;
    flex-direction: row;
    overflow-x: auto;
    overflow-y: hidden;
    padding: 8px;
    gap: 4px;
  }

  .oc-mega__cat {
    flex: 0 0 auto;
    white-space: nowrap;
    padding: 8px 14px;
    border-radius: 999px;
    background: var(--oc-ink-05);
  }

  .oc-mega__cat.active::before,
  .oc-mega__cat-arrow {
    display: none;
  }

  .oc-mega__prod-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
}

@media screen and (max-width: 640px) {
  .oc-mega__prod-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (prefers-reduced-motion: reduce) {
  .menu-list__submenu,
  .menu-list__submenu-inner,
  .oc-mega__cat,
  .oc-mega__sub,
  .oc-mega__card,
  .oc-mega__alllink,
  .oc-mega__sub-seeall,
  .oc-mega__prod-viewall {
    transition: none !important;
  }
}
{% endstylesheet %}

