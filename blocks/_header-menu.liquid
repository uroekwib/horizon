{%- doc -%}
  Renders the Octopus Media header menu block.

  Variants:
   - 'mobile'           → mobile drawer (Horizon native, unchanged)
   - 'navigation_bar'   → horizontal scroll bar (Horizon native, unchanged)
   - (default)          → desktop nav + optional 3-column mega drawer

  Mega drawer:
   - Triggered by a configurable label button (e.g. "สินค้าและบริการ")
   - Reads from a dedicated link_list: mega_menu
     · Level 0 = top-level links  (e.g. ป้าย, สติ๊กเกอร์)
     · Level 1 = children of each (e.g. อักษรโลหะ, กัดกรด)
   - Products loaded via AJAX from /collections/{handle}/products.json
   - No icons — text only for collection items
   - CSS tokens: uses --oc-* from custom.css.liquid; no new colour declarations

  @param {string} [variant]     - 'mobile' | 'navigation_bar' | default desktop
  @param {string} [transparent] - transparent header flag
{%- enddoc -%}

{% liquid
  assign block_settings = block.settings
%}

{% case variant %}

  {# ═══════════════════════════════════════════════════════════
     MOBILE DRAWER  (Horizon native — unchanged)
  ═══════════════════════════════════════════════════════════ #}
  {% when 'mobile' %}
    <div
      class="header__drawer"
      ref="headerDrawerContainer"
      data-hydration-key="header-drawer-mobile"
      {{ block.shopify_attributes }}
    >
      {% render 'header-drawer',
        linklist: block_settings.menu,
        data_header_drawer_type: 'mobile-drawer'
      %}
    </div>

  {# ═══════════════════════════════════════════════════════════
     NAVIGATION BAR  (mobile scroll bar — Horizon native, unchanged)
  ═══════════════════════════════════════════════════════════ #}
  {% when 'navigation_bar' %}
    {% if block_settings.navigation_bar == true %}
      <div
        class="menu-list menu-list--mobile{% if transparent == blank %} color-{{ block_settings.color_scheme_navigation_bar }}{% endif %}"
        style="--menu-horizontal-gap: 15px; --mobile-nav-margin: auto;"
        data-hydration-key="header-menu-mobile-navigation-bar"
      >
        <div class="menu-list__scroll-container">
          <ul class="menu-list__list list-unstyled" role="list">
            {% for link in block_settings.menu.links %}
              <li>
                <a
                  href="{{ link.url }}"
                  id="MenuItem-{{ link.handle }}"
                  class="menu-list__item"
                  {% if link.current %}aria-current="page"{% endif %}
                >
                  {{- link.title -}}
                </a>
              </li>
            {% endfor %}
          </ul>
        </div>
      </div>
    {% endif %}

  {# ═══════════════════════════════════════════════════════════
     DESKTOP NAV  (default — mega drawer + regular links)
  ═══════════════════════════════════════════════════════════ #}
  {% else %}

    {# ── resolve colour scheme classes (same logic as Horizon native) ── #}
    {% liquid
      assign mega_ll       = block_settings.mega_menu
      assign mega_label    = block_settings.mega_trigger_label | default: 'สินค้าและบริการ'
      assign mega_col0_hd  = block_settings.mega_col0_title    | default: 'หมวดหมู่'
      assign mega_thumbs   = block_settings.mega_thumb_count   | default: 4

      assign color_scheme_classes = ''
      assign cs_key               = 'color_scheme_' | append: section.settings.menu_row
      assign current_cs           = block_settings.color_scheme
      assign parent_cs            = section.settings[cs_key]

      if parent_cs.id != current_cs.id
        assign color_scheme_classes = ' color-' | append: current_cs
      endif
      if parent_cs.settings.background.rgb == current_cs.settings.background.rgb
        assign color_scheme_classes = color_scheme_classes | append: ' color-scheme-matches-parent'
      endif
    %}

    {% capture children %}

      {# ── 1. MEGA DRAWER TRIGGER (only when mega_menu link list is set) ── #}
      {% if mega_ll != blank %}
        <li
          class="menu-list__list-item"
          role="presentation"
          on:focus="/activate"
          on:blur="/deactivate"
          on:pointerenter="/activate"
          on:pointerleave="/deactivate"
        >
          {%- liquid
            assign mega_href = mega_ll.links[0].url | default: '/collections'
          -%}
          <a
            href="{{ mega_href }}"
            class="menu-list__link"
            aria-controls="oc-mega-{{ block.id }}"
            aria-haspopup="true"
            aria-expanded="false"
            ref="menuitem"
          >
            <span class="menu-list__link-title">{{ mega_label }}</span>
          </a>

          <div class="menu-list__submenu{{ color_scheme_classes }}" ref="submenu[]">
            <div
              id="oc-mega-{{ block.id }}"
              class="menu-list__submenu-inner oc-mega-inner"
              style="{% render 'submenu-font-styles', settings: block_settings %}"
            >
              <div class="oc-mega-panel">

                {# ── COL 0 — main collections (L0) ── #}
                <div class="oc-mega__col0">
                  <div class="oc-mega__col-hd">{{ mega_col0_hd }}</div>
                  <ul class="oc-mega__l0-list list-unstyled" role="listbox">
                    {% for l0 in mega_ll.links %}
                      <li
                        class="oc-mega__l0-item{% if forloop.first %} on{% endif %}"
                        data-grp="{{ forloop.index0 }}"
                        data-coll="{{ l0.url | split: '/collections/' | last | split: '?' | first }}"
                        role="option"
                        aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
                        tabindex="0"
                      >
                        {{- l0.title -}}
                      </li>
                    {% endfor %}
                  </ul>
                </div>

                {# ── COL 1 — sub-collections (L1) ── #}
                <div class="oc-mega__col1">
                  {% for l0 in mega_ll.links %}
                    <div
                      class="oc-mega__l1-group{% unless forloop.first %} oc-hidden{% endunless %}"
                      data-grp="{{ forloop.index0 }}"
                      role="listbox"
                      aria-label="{{ l0.title | escape }}"
                    >
                      <div class="oc-mega__col-hd">{{ l0.title }}</div>
                      <ul class="oc-mega__l1-list list-unstyled">
                        {% for l1 in l0.links %}
                          {%- assign l1_coll = l1.url | split: '/collections/' | last | split: '?' | first -%}
                          <li
                            class="oc-mega__l1-item{% if forloop.first and forloop.parentloop.first %} on{% endif %}"
                            data-coll="{{ l1_coll }}"
                            data-url="{{ l1.url }}"
                            role="option"
                            aria-selected="{% if forloop.first and forloop.parentloop.first %}true{% else %}false{% endif %}"
                            tabindex="0"
                          >
                            {{- l1.title -}}
                          </li>
                        {% endfor %}
                      </ul>
                    </div>
                  {% endfor %}
                </div>

                {# ── COL 2 — products (AJAX, rendered by JS) ── #}
                <div class="oc-mega__col2">
                  <div
                    class="oc-mega__product-panel"
                    data-thumb-count="{{ mega_thumbs }}"
                    aria-live="polite"
                    aria-busy="false"
                  ></div>
                </div>

              </div>{# /.oc-mega-panel #}
            </div>{# /.menu-list__submenu-inner #}
          </div>{# /.menu-list__submenu #}
        </li>
      {% endif %}

      {# ── 2. REGULAR NAV LINKS (from block_settings.menu) ── #}
      {% for link in block_settings.menu.links %}
        <li
          class="menu-list__list-item"
          role="presentation"
          on:focus="/activate"
          on:blur="/deactivate"
          on:pointerenter="/activate"
          on:pointerleave="/deactivate"
        >
          <a
            href="{{ link.url }}"
            data-skip-node-update="true"
            class="menu-list__link{% if link.active %} menu-list__link--active{% endif %}"
            {% if link.current %}aria-current="page"{% endif %}
            ref="menuitem"
          >
            <span class="menu-list__link-title">{{ link.title }}</span>
          </a>
        </li>
      {% endfor %}

      {# ── 3. OVERFLOW "MORE" BUTTON ── #}
      <li
        class="menu-list__list-item"
        role="presentation"
        slot="more"
        on:focus="/activate"
        on:blur="/deactivate"
        on:pointerenter="/activate"
        on:pointerleave="/deactivate"
      >
        <button role="listitem" class="menu-list__link button-unstyled">
          <span class="menu-list__link-title">{{ 'actions.more' | t }}</span>
        </button>
      </li>

    {% endcapture %}

    <header-menu
      ref="headerMenu"
      class="header-menu"
      {{ block.shopify_attributes }}
      data-hydration-key="header-menu"
    >
      <div class="header-menu__inner">
        <nav
          class="menu-list"
          aria-label="{{ 'accessibility.header_navigation_label' | t }}"
          style="{% render 'menu-font-styles', settings: block_settings %}"
        >
          {% assign overflow_class = 'overflow-menu' | append: color_scheme_classes %}
          {% render 'overflow-list',
            class: overflow_class,
            ref: 'overflowMenu',
            children: children,
            minimum-items: 2,
            data-testid: 'header-menu-overflow-list',
            attributes: 'data-skip-node-update'
          %}
        </nav>
      </div>

      <script
        src="{{ 'header-menu.js' | asset_url }}"
        type="module"
        fetchpriority="low"
      ></script>
    </header-menu>

    {# ── MEGA MENU JAVASCRIPT ── #}
    <script>
    (function () {
      'use strict';

      /* ── Shared product cache (persists across open/close) ── */
      var _cache = {};

      /* ── Utility: safely escape HTML ── */
      function esc(str) {
        return String(str)
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;');
      }

      /* ── Resize Shopify CDN image URL ── */
      function resizeImg(src, size) {
        if (!src) return null;
        return src.replace(/(\.[a-z]{3,4})(\?.*)?$/i, '_' + size + '$1$2');
      }

      /* ─────────────────────────────────────────────────────── */
      function OcMega(panel) {
        this.panel        = panel;
        this.productPanel = panel.querySelector('.oc-mega__product-panel');
        this.thumbCount   = parseInt(this.productPanel.getAttribute('data-thumb-count') || 4, 10);
        this.activeHandle = null;
        this._bind();
        this._autoInit();
      }

      OcMega.prototype._bind = function () {
        var self = this;

        /* L0 — hover activates column, keyboard support */
        self.panel.querySelectorAll('.oc-mega__l0-item').forEach(function (item) {
          item.addEventListener('mouseenter', function () { self._selectL0(+item.dataset.grp); });
          item.addEventListener('focus',      function () { self._selectL0(+item.dataset.grp); });
          item.addEventListener('keydown',    function (e) {
            if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); self._selectL0(+item.dataset.grp); }
          });
        });

        /* L1 — hover prefetches, click / keyboard loads products */
        self.panel.querySelectorAll('.oc-mega__l1-item').forEach(function (item) {
          item.addEventListener('mouseenter', function () { self._prefetch(item.dataset.coll); });
          item.addEventListener('click',      function (e) { e.preventDefault(); self._selectL1(item); });
          item.addEventListener('focus',      function ()  { self._selectL1(item); });
          item.addEventListener('keydown',    function (e) {
            if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); self._selectL1(item); }
            /* Navigate L1 list with arrow keys */
            if (e.key === 'ArrowDown' || e.key === 'ArrowUp') {
              e.preventDefault();
              var items = Array.from(item.closest('.oc-mega__l1-list').querySelectorAll('.oc-mega__l1-item'));
              var idx   = items.indexOf(item);
              var next  = e.key === 'ArrowDown' ? items[idx + 1] : items[idx - 1];
              if (next) next.focus();
            }
          });
        });
      };

      OcMega.prototype._autoInit = function () {
        /* Activate first L0 and its first L1 immediately */
        var firstL1 = this.panel.querySelector('.oc-mega__l1-group[data-grp="0"] .oc-mega__l1-item');
        if (firstL1) this._loadProducts(firstL1.dataset.coll);
      };

      OcMega.prototype._selectL0 = function (grp) {
        this.panel.querySelectorAll('.oc-mega__l0-item').forEach(function (el) {
          var active = +el.dataset.grp === grp;
          el.classList.toggle('on', active);
          el.setAttribute('aria-selected', active ? 'true' : 'false');
        });
        this.panel.querySelectorAll('.oc-mega__l1-group').forEach(function (el) {
          var show = +el.dataset.grp === grp;
          el.classList.toggle('oc-hidden', !show);
        });
      };

      OcMega.prototype._selectL1 = function (item) {
        this.panel.querySelectorAll('.oc-mega__l1-item').forEach(function (el) {
          el.classList.remove('on');
          el.setAttribute('aria-selected', 'false');
        });
        item.classList.add('on');
        item.setAttribute('aria-selected', 'true');
        this._loadProducts(item.dataset.coll, item.dataset.url);
      };

      OcMega.prototype._prefetch = function (handle) {
        if (!handle || _cache[handle] !== undefined) return;
        fetch('/collections/' + handle + '/products.json?limit=8')
          .then(function (r) { return r.json(); })
          .then(function (d) { _cache[handle] = d.products || []; })
          .catch(function ()  { _cache[handle] = []; });
      };

      OcMega.prototype._loadProducts = function (handle, collUrl) {
        if (!handle) return;
        if (this.activeHandle === handle) return;
        this.activeHandle = handle;

        var self = this;
        self.productPanel.setAttribute('aria-busy', 'true');

        if (_cache[handle] !== undefined) {
          self._render(_cache[handle], handle, collUrl);
          return;
        }

        self.productPanel.innerHTML = '<p class="oc-mega__loading">กำลังโหลด...</p>';

        fetch('/collections/' + handle + '/products.json?limit=8')
          .then(function (r) { return r.json(); })
          .then(function (d) {
            _cache[handle] = d.products || [];
            if (self.activeHandle === handle) self._render(_cache[handle], handle, collUrl);
          })
          .catch(function () {
            _cache[handle] = [];
            if (self.activeHandle === handle) self._render([], handle, collUrl);
          });
      };

      OcMega.prototype._render = function (products, handle, collUrl) {
        this.productPanel.setAttribute('aria-busy', 'false');
        var tc  = this.thumbCount;
        var url = collUrl || ('/collections/' + handle);

        if (!products.length) {
          this.productPanel.innerHTML =
            '<p class="oc-mega__empty">ไม่พบสินค้าในหมวดนี้</p>' +
            '<a href="' + esc(url) + '" class="btn-g oc-mega__viewall">ดูทั้งหมด →</a>';
          return;
        }

        var thumbs  = products.slice(0, tc);
        var rest    = products.slice(tc);
        var cols    = Math.min(tc, thumbs.length);

        /* Thumbnails */
        var thumbsHtml = '<div class="oc-mega__thumbs" style="grid-template-columns:repeat(' + cols + ',minmax(0,1fr))">';
        thumbs.forEach(function (p) {
          var imgSrc = p.featured_image ? resizeImg(p.featured_image.src, '320x320') : null;
          var imgTag = imgSrc
            ? '<img src="' + esc(imgSrc) + '" alt="' + esc(p.title) + '" loading="lazy" width="160" height="160">'
            : '<div class="oc-mega__thumb-ph"></div>';
          thumbsHtml += '<a href="/products/' + esc(p.handle) + '" class="oc-mega__thumb">' +
            imgTag +
            '<span class="oc-mega__thumb-nm">' + esc(p.title) + '</span>' +
            '</a>';
        });
        thumbsHtml += '</div>';

        /* Remaining as text tags */
        var tagsHtml = '';
        if (rest.length) {
          tagsHtml = '<p class="oc-mega__tags-hd">สินค้าอื่นๆ ในหมวดนี้</p><div class="oc-mega__tags">';
          rest.forEach(function (p) {
            tagsHtml += '<a href="/products/' + esc(p.handle) + '" class="oc-mega__tag">' + esc(p.title) + '</a>';
          });
          tagsHtml += '</div>';
        }

        this.productPanel.innerHTML =
          thumbsHtml + tagsHtml +
          '<a href="' + esc(url) + '" class="btn-g oc-mega__viewall">ดูทั้งหมด →</a>';
      };

      /* ── Init all mega panels on page ── */
      function init() {
        document.querySelectorAll('.oc-mega-panel').forEach(function (panel) {
          if (!panel._ocMega) panel._ocMega = new OcMega(panel);
        });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
      } else {
        init();
      }
    })();
    </script>

{% endcase %}

{# ── colour underlay variable (Horizon requirement) ── #}
{% style %}
  .header__underlay {
    --color-submenu: rgb({{ block_settings.color_scheme.settings.background.rgba }});
  }
{% endstyle %}

{% stylesheet %}
/* ═══════════════════════════════════════════════════════════
   HORIZON NATIVE MENU STYLES  (unchanged from original block)
═══════════════════════════════════════════════════════════ */

.header__drawer {
  --header-drawer-min-height: 60px;
  display: flex;
  min-height: var(--header-drawer-min-height);
  align-items: center;
}

#header-component[data-menu-style='drawer'] .header__drawer {
  display: flex;
  min-height: var(--header-drawer-min-height);
}

@media screen and (min-width: 750px) {
  #header-component[data-menu-style='menu'] .header__drawer {
    display: none;
    min-height: 0;
  }
}

.header--compact .header__drawer {
  min-height: var(--minimum-touch-target);
}

.menu-list--mobile {
  &.menu-list { display: grid; }
  & .menu-list__list { width: max-content; margin-inline: auto; gap: var(--menu-horizontal-gap); }
  & li { width: max-content; padding-block: var(--padding-sm); }
  & li:first-of-type { padding-inline-start: var(--menu-horizontal-gap); }
  & li:last-of-type  { padding-inline-end:   var(--menu-horizontal-gap); }
  & a { color: var(--color-foreground); }
}

.menu-list__scroll-container {
  position: relative;
  overflow-x: auto;
  mask-image: linear-gradient(to right, transparent, #000 20px, #000 calc(100% - 20px), transparent);
  padding-block: var(--padding-2xs);
}

.menu-list {
  --menu-horizontal-gap: var(--gap-xl);
  --menu-vertical-gap:   var(--gap-xl);
  display: flex;
  height: 100%;
}

.menu-list__list {
  display: flex;
  justify-content: var(--grid-area-alignment);
}

.menu-list__list-item {
  flex-shrink: 0;
  white-space: nowrap;
  display: flex;
  align-items: center;
  height: 100%;
}

.menu-list__list-item[aria-hidden='true'] { visibility: hidden; }

.menu-list__link {
  font-family:    var(--menu-top-level-font-family);
  font-style:     var(--menu-top-level-font-style);
  font-weight:    var(--menu-top-level-font-weight);
  font-size:      var(--menu-top-level-font-size);
  line-height:    var(--menu-top-level-font-line-height);
  text-transform: var(--menu-top-level-font-case);
  color:          var(--menu-top-level-font-color);
  text-decoration: none;
  display: flex;
  flex-direction: column;
  justify-content: center;
  cursor: pointer;
  height: 100%;
  margin-block: 0;

  &:hover, &:focus { color: var(--menu-top-level-font-color); }

  @media screen and (min-width: 750px) {
    font-size: var(--menu-top-level-font-size-desktop);
  }
}

.menu-list__link-title { padding-inline: calc(var(--gap-xl) / 2); }
[slot='overflow'] .menu-list__link-title { padding-inline: 0; }

.menu-list__list-item:not([slot='overflow']) { flex-direction: column; }
.menu-list__list-item:not([slot='overflow'])::after {
  content: '';
  width: 100%;
  height: var(--header-padding);
  margin-bottom: calc(-1 * var(--header-padding));
}
[slot='overflow'] > .menu-list__link::after { content: none; }

.menu-list:where(:has(.menu-list__list-item:hover)),
.menu-list:where(:has(.menu-list__list-item:focus-within)),
.menu-list:where(:has(.menu-list__list-item:not([aria-hidden='true']) .menu-list__link--active)) {
  .menu-list__link { color: rgb(var(--menu-top-level-font-color-rgb) / var(--opacity-subdued-text)); }
}

/* stylelint-disable-next-line selector-max-specificity */
.menu-list:not(:has(.menu-list__list-item:hover)) .menu-list__link--active,
.menu-list .menu-list__list-item:where(:hover, :focus-within) .menu-list__link,
.menu-list .menu-list__list-item[slot='overflow'] .menu-list__link[aria-expanded='true'] {
  color: var(--menu-top-level-font-color);
}

.overflow-menu::part(list) {
  --focus-outline-size: calc(var(--focus-outline-offset) + var(--focus-outline-width));
  gap: 0;
  margin-inline: calc(-1 * var(--menu-horizontal-gap) / 2);
}

.overflow-menu {
  background-color: transparent;
  padding: var(--focus-outline-size);
  margin: calc(-1 * var(--focus-outline-size));
}

.menu-list__submenu,
.overflow-menu::part(overflow) {
  --submenu-padding-block-start: var(--padding-3xl);
  --submenu-padding-block-end:   var(--padding-3xl);
  background-color: transparent;
}

.header__row[style*='--border-bottom-width: 0px'] {
  .menu-list__submenu.color-scheme-matches-parent,
  .overflow-menu.color-scheme-matches-parent::part(overflow) {
    --submenu-padding-block-start: 0px;
  }
}

.menu-list__list-item:where(:not([slot='overflow'])) > .menu-list__submenu,
.overflow-menu::part(overflow) {
  --submenu-content-opacity: 0;
  --submenu-content-animation: opacity calc(var(--submenu-animation-speed) * 0.75) var(--animation-easing);

  visibility: hidden;
  position: absolute;
  width: 100%;
  left: 0;
  top: calc(100% - 1px + var(--border-bottom-width) - (var(--full-open-header-height) - var(--submenu-height)));
  z-index: var(--layer-header-menu);
  padding-inline: var(--padding-inline);
  clip-path: rect(var(--header-height) 100% var(--full-open-header-height) 0); /* stylelint-disable-line */
  transition: clip-path var(--submenu-animation-speed) var(--ease-out-cubic); /* stylelint-disable-line */
}

[data-submenu-overlap-bottom-row] {
  .menu-list__list-item:where(:not([slot='overflow'])) > .menu-list__submenu,
  .overflow-menu::part(overflow) {
    clip-path: rect(var(--top-row-height) 100% var(--full-open-header-height) 0); /* stylelint-disable-line */
  }
}

.menu-list__list-item:has([aria-expanded='true']) > .menu-list__submenu,
.overflow-menu:has([slot="overflow"] [aria-expanded='true'])::part(overflow-list),
.menu-list__submenu:is(:hover),
.overflow-menu::part(overflow):hover {
  --submenu-content-opacity: 1;
  visibility: visible;
}

.overflow-menu::part(overflow) {
  --menu-top-level-font-size: var(--font-size--xlarge);
  display: grid;
  grid-template-columns: var(--full-page-grid-with-margins);
}

.overflow-menu::part(overflow-list) {
  position: relative;
  display: grid;
  grid-template-columns: minmax(auto, 200px) 1fr;
  grid-template-areas: 'left right';
  grid-template-rows: max-content;
  grid-gap: 0;
  grid-column: 2;
}

.menu-list__list-item:is([slot='overflow']) {
  --menu-top-level-font-color:     var(--color-foreground);
  --menu-top-level-font-color-rgb: var(--color-foreground-rgb);

  display: contents;
  white-space: normal;

  .menu-list__link {
    grid-area: left;
    grid-row: auto;
    height: min-content;
    font-size: var(--font-size--xl);
    transition: var(--submenu-content-animation);
  }

  .menu-list__submenu {
    visibility: hidden;
    grid-row: 1;
    grid-area: right;
    grid-row-end: span calc(var(--overflow-count) + 1);
    padding-inline-start: var(--menu-horizontal-gap);
  }

  .menu-list__submenu-inner {
    transform: none;
    grid-column: unset;
    padding-block: 0;
  }

  .menu-list__link[aria-expanded='true'] + .menu-list__submenu { visibility: visible; }
}

.header-menu { height: 100%; }

.menu-list__submenu-inner {
  position: relative;
  display: flex;
  justify-content: space-between;
  flex-wrap: wrap;
}

.menu-list__submenu-inner,
.overflow-menu::part(overflow-list) {
  padding-block-start: var(--submenu-padding-block-start);
  padding-block-end:   var(--submenu-padding-block-end);
  padding-inline: var(--section-padding-inline);
  opacity: var(--submenu-content-opacity);
  transition: var(--submenu-content-animation);
  transform: translateY(calc(var(--full-open-header-height) - var(--submenu-height)));
  max-height: calc(80vh - var(--header-height));
  overflow-y: auto;
  overflow-x: hidden;
  scrollbar-width: thin;
  scrollbar-color: rgb(var(--color-foreground-rgb) / var(--opacity-40)) transparent;
}

.mega-menu__link {
  font-family:    var(--menu-child-font-family);
  font-style:     var(--menu-child-font-style);
  font-weight:    var(--menu-child-font-weight);
  font-size:      var(--menu-child-font-size);
  line-height:    var(--menu-child-font-line-height);
  text-transform: var(--menu-child-font-case);
  color: var(--menu-child-font-color);
  white-space: normal;
  text-decoration: none;
  display: inline-flex;
  padding: var(--padding-2xs) 0;
  &:hover { color: var(--menu-child-active-font-color); }
}

.mega-menu__link--parent {
  font-family:    var(--menu-parent-font-family);
  font-style:     var(--menu-parent-font-style);
  font-weight:    var(--menu-parent-font-weight);
  font-size:      var(--menu-parent-font-size);
  line-height:    var(--menu-parent-font-line-height);
  text-transform: var(--menu-parent-font-case);
  color: var(--menu-parent-font-color);
  &:hover { color: var(--menu-parent-active-font-color); }
}

@media screen and (max-width: 989px) {
  .mega-menu__content-list-item--hidden-tablet { display: none; }
}

.mega-menu__grid {
  display: grid;
  grid-template-columns: repeat(var(--menu-columns-tablet), minmax(0, 1fr));
  gap: var(--menu-vertical-gap) var(--menu-horizontal-gap);
  width: 100%;

  @media screen and (min-width: 990px) {
    grid-template-columns: repeat(var(--menu-columns-desktop), minmax(0, 1fr));
  }
}

.mega-menu__list {
  display: grid;
  grid-template-columns: subgrid;
  grid-column: span var(--menu-columns-tablet);
  gap: var(--menu-vertical-gap) var(--menu-horizontal-gap);

  @media screen and (min-width: 990px) {
    grid-column: span var(--menu-columns-desktop);
  }
}

.mega-menu__submenu { display: contents; }


/* ═══════════════════════════════════════════════════════════
   OC MEGA MENU — 3-COLUMN DRAWER
   Uses --oc-* tokens declared in custom.css.liquid exclusively.
   No new colour values.
═══════════════════════════════════════════════════════════ */

/* ── Override submenu-inner padding for our panel ── */
.oc-mega-inner {
  padding: 0 !important;
  overflow: hidden !important;
  flex-wrap: nowrap !important;
}

/* ── Outer panel: 3 flex columns ── */
.oc-mega-panel {
  display: flex;
  width: 100%;
  min-height: 380px;
  max-height: calc(80vh - var(--header-height, 64px));
}

/* ── Shared column resets ── */
.oc-mega__col0,
.oc-mega__col1,
.oc-mega__col2 {
  overflow-y: auto;
  scrollbar-width: thin;
  scrollbar-color: var(--oc-ink-15) transparent;
}

/* ── COL 0 — main collections ── */
.oc-mega__col0 {
  width: 185px;
  flex-shrink: 0;
  border-right: 1px solid var(--oc-ink-15);
  padding: 0 8px 12px;
}

/* ── COL 1 — sub-collections ── */
.oc-mega__col1 {
  width: 192px;
  flex-shrink: 0;
  border-right: 1px solid var(--oc-ink-15);
  padding: 0 8px 12px;
  background: var(--oc-ink-05);
}

/* ── COL 2 — products ── */
.oc-mega__col2 {
  flex: 1;
  padding: 14px 18px 16px;
  min-width: 0;
}

/* ── Column header (sticky) ── */
.oc-mega__col-hd {
  font-size: 10px;
  font-weight: 700;
  color: var(--oc-ink-40);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  padding: 12px 10px 7px;
  position: sticky;
  top: 0;
  z-index: 1;
  border-bottom: 1px solid var(--oc-ink-15);
  margin: 0 -8px 4px;
}

.oc-mega__col0 .oc-mega__col-hd {
  background: rgb(var(--color-background, 255 255 255));
}
.oc-mega__col1 .oc-mega__col-hd {
  background: var(--oc-ink-05);
}

/* ── List resets ── */
.oc-mega__l0-list,
.oc-mega__l1-list {
  list-style: none;
  padding: 0;
  margin: 0;
}

/* ── L0 items (text-only, no icons) ── */
.oc-mega__l0-item,
.oc-mega__l1-item {
  padding: 8px 10px;
  border-radius: var(--oc-radius-sm);
  font-size: 13px;
  line-height: 1.4;
  cursor: pointer;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 2px;
  color: var(--oc-ink-70, #374151);
  transition:
    background var(--oc-dur-fast) ease,
    color      var(--oc-dur-fast) ease;
}

.oc-mega__l0-item::after {
  content: '›';
  font-size: 14px;
  color: var(--oc-ink-15);
  flex-shrink: 0;
  margin-left: 4px;
  transition: color var(--oc-dur-fast) ease;
}

.oc-mega__l0-item:hover,
.oc-mega__l0-item.on {
  background: var(--oc-cyan-l);
  color: var(--oc-cyan);
}
.oc-mega__l0-item.on::after { color: var(--oc-cyan); }

.oc-mega__l1-item:hover,
.oc-mega__l1-item.on {
  background: var(--oc-purple-l);
  color: var(--oc-purple-d);
}

/* ── L1 group visibility ── */
.oc-mega__l1-group          { display: block; }
.oc-mega__l1-group.oc-hidden { display: none;  }

/* ── Thumbnails (4-up grid by default, overridden inline by JS) ── */
.oc-mega__thumbs {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr)); /* JS overrides via inline style */
  gap: 8px;
  margin-bottom: 14px;
}

.oc-mega__thumb {
  display: block;
  border: 1px solid var(--oc-ink-15);
  border-radius: var(--oc-radius-sm);
  overflow: hidden;
  text-decoration: none;
  transition: border-color var(--oc-dur-fast) ease;
}
.oc-mega__thumb:hover { border-color: var(--oc-cyan); }

.oc-mega__thumb img,
.oc-mega__thumb-ph {
  width: 100%;
  aspect-ratio: 1;
  object-fit: cover;
  display: block;
}
.oc-mega__thumb-ph { background: var(--oc-ink-05); }

.oc-mega__thumb-nm {
  display: block;
  padding: 4px 6px 5px;
  font-size: 10.5px;
  color: var(--oc-ink-40);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  border-top: 1px solid var(--oc-ink-15);
  line-height: 1.4;
}

/* ── Remaining products as text tags ── */
.oc-mega__tags-hd {
  font-size: 9.5px;
  font-weight: 700;
  color: var(--oc-ink-40);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  margin: 0 0 6px;
}

.oc-mega__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
  margin-bottom: 12px;
}

.oc-mega__tag {
  display: inline-flex;
  align-items: center;
  padding: 3px 10px;
  border-radius: var(--oc-radius-pill);
  background: var(--oc-ink-05);
  border: 1px solid var(--oc-ink-15);
  font-size: 11.5px;
  color: var(--oc-ink-40);
  text-decoration: none;
  white-space: nowrap;
  transition:
    background    var(--oc-dur-fast) ease,
    border-color  var(--oc-dur-fast) ease,
    color         var(--oc-dur-fast) ease;
}
.oc-mega__tag:hover {
  background: var(--oc-cyan-l);
  border-color: var(--oc-cyan);
  color: var(--oc-cyan);
}

/* ── View all button — reuses .btn-g from custom.css ── */
.oc-mega__viewall { margin-top: 4px; }

/* ── States ── */
.oc-mega__loading,
.oc-mega__empty {
  font-size: 12.5px;
  color: var(--oc-ink-40);
  padding: 20px 0 8px;
  margin: 0;
}

/* ── Responsive: collapse to 2 cols on mid-width ── */
@media screen and (max-width: 1199px) {
  .oc-mega__col0 { width: 160px; }
  .oc-mega__col1 { width: 168px; }
  .oc-mega__thumbs { grid-template-columns: repeat(2, minmax(0, 1fr)) !important; }
}

@media screen and (max-width: 989px) {
  .oc-mega-panel { flex-direction: column; max-height: none; }
  .oc-mega__col0,
  .oc-mega__col1 { width: 100%; border-right: none; border-bottom: 1px solid var(--oc-ink-15); }
  .oc-mega__col0 { max-height: 160px; }
  .oc-mega__col1 { max-height: 200px; }
}

@media (prefers-reduced-motion: reduce) {
  .oc-mega__l0-item,
  .oc-mega__l1-item,
  .oc-mega__thumb,
  .oc-mega__tag { transition: none !important; }
}
{% endstylesheet %}

