    { "type": "range", "id": "product_limit", "label": "Total products loaded", "min": 4, "max": 20, "step": 1, "default": 8 },
    { "type": "header", "content": "Font size" },
    { "type": "range", "id": "top_menu_font_size", "label": "Top menu font size (px)", "min": 12, "max": 24, "step": 1, "default": 16 },
    { "type": "range", "id": "l0_font_size", "label": "Left column font size (px)", "min": 11, "max": 20, "step": 1, "default": 13 },
    { "type": "range", "id": "l1_font_size", "label": "Middle column font size (px)", "min": 11, "max": 20, "step": 1, "default": 13 },
    { "type": "header", "content": "Theme colour" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "primary" }
  ]
}
