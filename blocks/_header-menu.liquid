{%- doc -%}
  Octopus Media header menu block

  Variants:
   - 'mobile'           → mobile drawer (Horizon native)
   - 'navigation_bar'   → horizontal scroll bar (Horizon native)
   - default            → desktop nav + 3-column mega drawer

  Mega drawer:
   - Col 0 = parent collections from menu children
   - Col 1 = subcollections from metafield custom.subcollections
   - Col 2 = products loaded by AJAX from selected subcollection
{%- enddoc -%}

{% liquid
  assign block_settings = block.settings
%}

{% case variant %}

  {% when 'mobile' %}
    <div
      class="header__drawer"
      ref="headerDrawerContainer"
      data-hydration-key="header-drawer-mobile"
      {{ block.shopify_attributes }}
    >
      {% render 'header-drawer',
        linklist: block_settings.menu,
        data_header_drawer_type: 'mobile-drawer'
      %}
    </div>

  {% when 'navigation_bar' %}
    <div
      class="menu-list menu-list--mobile"
      style="--menu-horizontal-gap: 15px; --mobile-nav-margin: auto;"
      data-hydration-key="header-menu-mobile-navigation-bar"
    >
      <div class="menu-list__scroll-container">
        <ul class="menu-list__list list-unstyled" role="list">
          {% for link in block_settings.menu.links %}
            <li>
              <a
                href="{{ link.url }}"
                id="MenuItem-{{ link.handle }}"
                class="menu-list__item"
                {% if link.current %}aria-current="page"{% endif %}
              >
                {{- link.title -}}
              </a>
            </li>
          {% endfor %}
        </ul>
      </div>
    </div>

  {% else %}

    {% liquid
      assign color_scheme_classes = ''
      assign cs_key = 'color_scheme_' | append: section.settings.menu_row
      assign current_cs = block_settings.color_scheme
      assign parent_cs = section.settings[cs_key]

      if parent_cs.id != current_cs.id
        assign color_scheme_classes = ' color-' | append: current_cs
      endif
      if parent_cs.settings.background.rgb == current_cs.settings.background.rgb
        assign color_scheme_classes = color_scheme_classes | append: ' color-scheme-matches-parent'
      endif
    %}

    {% capture children %}
      {% for link in block_settings.menu.links %}
        <li
          class="menu-list__list-item"
          role="presentation"
          on:focus="/activate"
          on:blur="/deactivate"
          on:pointerenter="/activate"
          on:pointerleave="/deactivate"
        >
          <a
            href="{{ link.url }}"
            data-skip-node-update="true"
            class="menu-list__link{% if link.active %} menu-list__link--active{% endif %}"
            {% if link.links != blank %}
              aria-controls="submenu-{{ forloop.index }}"
              aria-haspopup="true"
              aria-expanded="false"
            {% endif %}
            {% if link.current %}aria-current="page"{% endif %}
            ref="menuitem"
          >
            <span class="menu-list__link-title">{{- link.title -}}</span>
          </a>

          {% if link.links != blank %}
            <div class="menu-list__submenu{{ color_scheme_classes }}" ref="submenu[]">
              <div
                id="submenu-{{ forloop.index }}"
                class="menu-list__submenu-inner oc-mega-inner"
                style="{% render 'submenu-font-styles', settings: block_settings %}"
              >
                <div
                  class="oc-mega-panel"
                  style="
                    --oc-col0-width: {{ block_settings.col0_width }}px;
                    --oc-col1-width: {{ block_settings.col1_width }}px;
                    --oc-l0-font-size: {{ block_settings.l0_font_size }}px;
                    --oc-l1-font-size: {{ block_settings.l1_font_size }}px;
                    --oc-thumb-title-font-size: {{ block_settings.thumb_title_font_size }}px;
                    --oc-thumb-height: {{ block_settings.thumb_height }}px;
                    --oc-thumb-image-width: {{ block_settings.thumb_image_width }}px;
                    --oc-drawer-min-height: {{ block_settings.drawer_min_height }}px;
                  "
                >
                  <div class="oc-mega__col0">
                    <div class="oc-mega__col-hd">{{ link.title }}</div>
                    <ul class="oc-mega__l0-list list-unstyled" role="listbox">
                      {% for l0 in link.links %}
                        {%- liquid
                          assign l0_coll = l0.object
                          assign l0_handle = ''
                          if l0_coll != blank
                            assign l0_handle = l0_coll.handle
                          endif
                        -%}
                        <li
                          class="oc-mega__l0-item{% if forloop.first %} on{% endif %}"
                          data-grp="{{ forloop.index0 }}"
                          data-coll="{{ l0_handle }}"
                          data-url="{{ l0.url }}"
                          role="option"
                          aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
                          tabindex="0"
                        >
                          {{- l0.title -}}
                        </li>
                      {% endfor %}
                    </ul>
                  </div>

                  <div class="oc-mega__col1">
                    {% for l0 in link.links %}
                      {%- liquid
                        assign l0_coll = l0.object
                        assign l0_handle = ''
                        assign subcols = blank
                        assign has_meta = false

                        if l0_coll != blank
                          assign l0_handle = l0_coll.handle
                          assign subcols = l0_coll.metafields.custom.subcollections.value
                        endif

                        if subcols != blank and subcols.size > 0
                          assign has_meta = true
                        endif
                      -%}

                      <div
                        class="oc-mega__l1-group{% unless forloop.first %} oc-hidden{% endunless %}"
                        data-grp="{{ forloop.index0 }}"
                        data-handle="{{ l0_handle }}"
                        role="listbox"
                        aria-label="{{ l0.title | escape }}"
                      >
                        <div class="oc-mega__col-hd">{{ l0.title }}</div>
                        <ul class="oc-mega__l1-list list-unstyled">
                          {% if has_meta %}
                            {% for subcol in subcols %}
                              <li
                                class="oc-mega__l1-item{% if forloop.first and forloop.parentloop.first %} on{% endif %}"
                                data-coll="{{ subcol.handle }}"
                                data-url="{{ subcol.url }}"
                                role="option"
                                aria-selected="{% if forloop.first and forloop.parentloop.first %}true{% else %}false{% endif %}"
                                tabindex="0"
                              >
                                {{- subcol.title -}}
                              </li>
                            {% endfor %}
                          {% else %}
                            {% for l1 in l0.links %}
                              {%- liquid
                                assign l1_coll = l1.object
                                assign l1_handle = ''
                                if l1_coll != blank
                                  assign l1_handle = l1_coll.handle
                                endif
                              -%}
                              <li
                                class="oc-mega__l1-item{% if forloop.first and forloop.parentloop.first %} on{% endif %}"
                                data-coll="{{ l1_handle }}"
                                data-url="{{ l1.url }}"
                                role="option"
                                aria-selected="{% if forloop.first and forloop.parentloop.first %}true{% else %}false{% endif %}"
                                tabindex="0"
                              >
                                {{- l1.title -}}
                              </li>
                            {% endfor %}
                          {% endif %}
                        </ul>
                      </div>
                    {% endfor %}
                  </div>

                  <div class="oc-mega__col2">
                    <div
                      class="oc-mega__product-panel"
                      data-thumb-count="{{ block_settings.mega_thumb_count }}"
                      data-product-limit="{{ block_settings.product_limit }}"
                      aria-live="polite"
                      aria-busy="false"
                    ></div>
                  </div>
                </div>
              </div>
            </div>
          {% endif %}
        </li>
      {% endfor %}

      <li
        class="menu-list__list-item"
        role="presentation"
        slot="more"
        on:focus="/activate"
        on:blur="/deactivate"
        on:pointerenter="/activate"
        on:pointerleave="/deactivate"
      >
        <button role="listitem" class="menu-list__link button-unstyled">
          <span class="menu-list__link-title">{{ 'actions.more' | t }}</span>
        </button>
      </li>
    {% endcapture %}

    <header-menu
      ref="headerMenu"
      class="header-menu"
      {{ block.shopify_attributes }}
      data-hydration-key="header-menu"
    >
      <div class="header-menu__inner">
        <nav
          class="menu-list"
          aria-label="{{ 'accessibility.header_navigation_label' | t }}"
          style="
            {% render 'menu-font-styles', settings: block_settings %}
            --oc-top-menu-font-size: {{ block_settings.top_menu_font_size }}px;
          "
        >
          {% assign overflow_class = 'overflow-menu' | append: color_scheme_classes %}
          {% render 'overflow-list',
            class: overflow_class,
            ref: 'overflowMenu',
            children: children,
            minimum-items: 2,
            data-testid: 'header-menu-overflow-list',
            attributes: 'data-skip-node-update'
          %}
        </nav>
      </div>

      <script
        src="{{ 'header-menu.js' | asset_url }}"
        type="module"
        fetchpriority="low"
      ></script>
    </header-menu>

    <script>
      (function () {
        'use strict';

        var _cache = {};

        function esc(s) {
          return String(s || '')
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;');
        }

        function normalizeShopifyImage(src) {
          if (!src) return null;
          src = String(src);

          if (src.indexOf('//') === 0) src = window.location.protocol + src;

          if (src.indexOf('http') !== 0 && src.indexOf('//') !== 0) {
            src = src.indexOf('/') === 0 ? window.location.origin + src : window.location.origin + '/' + src;
          }

          return src;
        }

        function resizeImg(src, width, height) {
          src = normalizeShopifyImage(src);
          if (!src) return null;

          src = src.replace(/_(pico|icon|thumb|small|compact|medium|large|grande|original|\d+x\d*)(?=\.[a-zA-Z]{3,4}(\?[^.]*)?$)/, '');
          return src.replace(/(\.[a-zA-Z]{3,4})(\?[^.]*)?$/, '_' + width + 'x' + height + '$1$2');
        }

        function getProductImage(product) {
          if (!product) return null;

          if (typeof product.featured_image === 'string' && product.featured_image) return product.featured_image;

          if (product.featured_image && typeof product.featured_image === 'object') {
            if (product.featured_image.src) return product.featured_image.src;
            if (product.featured_image.url) return product.featured_image.url;
          }

          if (Array.isArray(product.images) && product.images.length) {
            var first = product.images[0];
            if (typeof first === 'string') return first;
            if (first && first.src) return first.src;
            if (first && first.url) return first.url;
          }

          if (product.image && product.image.src) return product.image.src;

          return null;
        }

        function fetchProducts(handle, limit) {
          if (!handle) return Promise.resolve([]);

          var cacheKey = handle + '::' + limit;

          if (Array.isArray(_cache[cacheKey])) {
            return Promise.resolve(_cache[cacheKey]);
          }

          if (_cache[cacheKey] && typeof _cache[cacheKey].then === 'function') {
            return _cache[cacheKey];
          }

          _cache[cacheKey] = fetch('/collections/' + encodeURIComponent(handle) + '/products.json?limit=' + encodeURIComponent(limit), {
            credentials: 'same-origin'
          })
            .then(function (res) {
              if (!res.ok) throw new Error('Fetch failed: ' + res.status);
              return res.json();
            })
            .then(function (data) {
              var products = Array.isArray(data.products) ? data.products : [];
              _cache[cacheKey] = products;
              return products;
            })
            .catch(function () {
              _cache[cacheKey] = [];
              return [];
            });

          return _cache[cacheKey];
        }

        function OcMega(panel) {
          this.panel = panel;
          this.productPanel = panel.querySelector('.oc-mega__product-panel');
          this.thumbCount = parseInt(this.productPanel.dataset.thumbCount || 4, 10);
          this.productLimit = parseInt(this.productPanel.dataset.productLimit || 8, 10);

          var styles = getComputedStyle(this.panel);
          this.thumbHeight = parseInt(styles.getPropertyValue('--oc-thumb-height') || 72, 10);
          this.thumbRenderWidth = Math.round(this.thumbHeight * 4 / 3);
          this.thumbImageWidth = parseInt(styles.getPropertyValue('--oc-thumb-image-width') || 500, 10);
          this.thumbImageHeight = Math.round(this.thumbImageWidth * 3 / 4);

          this.activeHandle = null;
          this.booted = false;
          this.bind();
          this.watchOpen();
        }

        OcMega.prototype.watchOpen = function () {
          var self = this;
          var submenu = this.panel.closest('.menu-list__submenu');
          var menuItem = submenu ? submenu.closest('.menu-list__list-item') : null;
          var trigger = menuItem ? menuItem.querySelector('[aria-haspopup]') : null;

          if (!trigger) {
            self.boot();
            return;
          }

          var mo = new MutationObserver(function (mutations) {
            mutations.forEach(function (m) {
              if (
                m.attributeName === 'aria-expanded' &&
                trigger.getAttribute('aria-expanded') === 'true' &&
                !self.booted
              ) {
                self.boot();
                mo.disconnect();
              }
            });
          });

          mo.observe(trigger, {
            attributes: true,
            attributeFilter: ['aria-expanded']
          });
        };

        OcMega.prototype.bind = function () {
          var self = this;

          this.panel.addEventListener('mouseenter', function (e) {
            var l0 = e.target.closest('.oc-mega__l0-item');
            var l1 = e.target.closest('.oc-mega__l1-item');

            if (l0) self.selectL0(Number(l0.dataset.grp), l0);
            if (l1 && l1.dataset.coll) self.prefetch(l1.dataset.coll);
          }, true);

          this.panel.addEventListener('click', function (e) {
            var l0 = e.target.closest('.oc-mega__l0-item');
            var l1 = e.target.closest('.oc-mega__l1-item');

            if (l0) {
              e.preventDefault();
              self.selectL0(Number(l0.dataset.grp), l0);
            }

            if (l1) {
              e.preventDefault();
              self.selectL1(l1);
            }
          });

          this.panel.addEventListener('focusin', function (e) {
            var l0 = e.target.closest('.oc-mega__l0-item');
            var l1 = e.target.closest('.oc-mega__l1-item');

            if (l0) self.selectL0(Number(l0.dataset.grp), l0);
            if (l1) self.selectL1(l1);
          });

          this.panel.addEventListener('keydown', function (e) {
            var l1 = e.target.closest('.oc-mega__l1-item');
            if (!l1) return;

            if (e.key === 'Enter' || e.key === ' ') {
              e.preventDefault();
              self.selectL1(l1);
            }

            if (e.key === 'ArrowDown' || e.key === 'ArrowUp') {
              e.preventDefault();
              var items = Array.from(l1.closest('.oc-mega__l1-list').querySelectorAll('.oc-mega__l1-item'));
              var index = items.indexOf(l1);
              var next = items[index + (e.key === 'ArrowDown' ? 1 : -1)];
              if (next) next.focus();
            }
          });
        };

        OcMega.prototype.boot = function () {
          if (this.booted) return;
          this.booted = true;

          var firstL0 = this.panel.querySelector('.oc-mega__l0-item');
          if (firstL0) {
            this.selectL0(Number(firstL0.dataset.grp || 0), firstL0);
            return;
          }

          this.render([], '', '');
        };

        OcMega.prototype.selectL0 = function (grp, activeEl) {
          var self = this;

          this.panel.querySelectorAll('.oc-mega__l0-item').forEach(function (el) {
            var on = el === activeEl;
            el.classList.toggle('on', on);
            el.setAttribute('aria-selected', on ? 'true' : 'false');
          });

          this.panel.querySelectorAll('.oc-mega__l1-group').forEach(function (group) {
            var show = Number(group.dataset.grp) === grp;
            group.classList.toggle('oc-hidden', !show);
          });

          var activeGroup = this.panel.querySelector('.oc-mega__l1-group[data-grp="' + grp + '"]');
          if (!activeGroup) {
            this.render([], '', activeEl ? activeEl.dataset.url : '');
            return;
          }

          var firstL1 = activeGroup.querySelector('.oc-mega__l1-item');
          this.panel.querySelectorAll('.oc-mega__l1-item').forEach(function (el) {
            var on = el === firstL1;
            el.classList.toggle('on', on);
            el.setAttribute('aria-selected', on ? 'true' : 'false');
          });

          if (firstL1) {
            self.loadProducts(firstL1.dataset.coll, firstL1.dataset.url);
          } else {
            self.render([], '', activeEl ? activeEl.dataset.url : '');
          }
        };

        OcMega.prototype.selectL1 = function (item) {
          this.panel.querySelectorAll('.oc-mega__l1-item').forEach(function (el) {
            var on = el === item;
            el.classList.toggle('on', on);
            el.setAttribute('aria-selected', on ? 'true' : 'false');
          });

          this.loadProducts(item.dataset.coll, item.dataset.url);
        };

        OcMega.prototype.prefetch = function (handle) {
          if (!handle) return;
          fetchProducts(handle, this.productLimit);
        };

        OcMega.prototype.loadProducts = function (handle, collUrl) {
          var self = this;

          if (!handle) {
            self.render([], handle, collUrl);
            return;
          }

          if (self.activeHandle === handle && self.productPanel.innerHTML.trim() !== '') {
            return;
          }

          self.activeHandle = handle;
          self.productPanel.setAttribute('aria-busy', 'true');
          self.productPanel.innerHTML = '<p class="oc-mega__loading">กำลังโหลด…</p>';

          fetchProducts(handle, self.productLimit).then(function (products) {
            if (self.activeHandle !== handle) return;
            self.render(products, handle, collUrl);
          });
        };

        OcMega.prototype.render = function (products, handle, collUrl) {
          var pp = this.productPanel;
          var tc = this.thumbCount;
          var thumbHeight = this.thumbHeight;
          var thumbRenderWidth = this.thumbRenderWidth;
          var thumbImageWidth = this.thumbImageWidth;
          var thumbImageHeight = this.thumbImageHeight;
          var url = collUrl || (handle ? '/collections/' + handle : '#');

          pp.setAttribute('aria-busy', 'false');

          if (!products || !products.length) {
            pp.innerHTML =
              '<p class="oc-mega__empty">ไม่พบสินค้าในหมวดนี้</p>' +
              (url !== '#'
                ? '<a href="' + esc(url) + '" class="btn-g oc-mega__viewall">ดูทั้งหมด →</a>'
                : '');
            return;
          }

          var thumbs = products.slice(0, tc);
          var rest = products.slice(tc);

          var html = '<div class="oc-mega__thumbs">';

          thumbs.forEach(function (p) {
            var rawImg = getProductImage(p);
            var src = rawImg ? resizeImg(rawImg, thumbImageWidth, thumbImageHeight) : null;
            var productUrl = '/products/' + esc(p.handle);

            html += '<a href="' + productUrl + '" class="oc-mega__thumb">';
            html += '<div class="oc-mega__thumb-media">';

            if (src) {
              html += '<img src="' + esc(src) + '" alt="' + esc(p.title) + '" loading="lazy" width="' + thumbRenderWidth + '" height="' + thumbHeight + '">';
            } else {
              html += '<div class="oc-mega__thumb-ph"></div>';
            }

            html += '</div>';
            html += '<span class="oc-mega__thumb-nm">' + esc(p.title) + '</span>';
            html += '</a>';
          });

          html += '</div>';

          if (rest.length) {
            html += '<p class="oc-mega__tags-hd">สินค้าอื่นๆ ในหมวดนี้</p>';
            html += '<div class="oc-mega__tags">';
            rest.forEach(function (p) {
              html += '<a href="/products/' + esc(p.handle) + '" class="oc-mega__tag">' + esc(p.title) + '</a>';
            });
            html += '</div>';
          }

          html += '<a href="' + esc(url) + '" class="btn-g oc-mega__viewall">ดูทั้งหมด →</a>';
          pp.innerHTML = html;
        };

        function tryInit() {
          document.querySelectorAll('.oc-mega-panel').forEach(function (panel) {
            if (!panel._ocMega) {
              panel._ocMega = new OcMega(panel);
            }
          });
        }

        tryInit();

        var obs = new MutationObserver(function (mutations) {
          var found = mutations.some(function (m) {
            return Array.from(m.addedNodes).some(function (n) {
              return n.nodeType === 1 && (
                n.matches('.oc-mega-panel') ||
                (n.querySelector && n.querySelector('.oc-mega-panel'))
              );
            });
          });

          if (found) tryInit();
        });

        obs.observe(document.body, { childList: true, subtree: true });

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', function () {
            tryInit();
            setTimeout(tryInit, 500);
            setTimeout(tryInit, 1200);
          });
        } else {
          setTimeout(tryInit, 100);
          setTimeout(tryInit, 500);
          setTimeout(tryInit, 1200);
        }
      })();
    </script>

    <script>
      (function () {
        'use strict';

        var CLOSE_DELAY = 900;

        function bindDelayedClose(root) {
          root.querySelectorAll('.menu-list__list-item').forEach(function (item) {
            if (item._ocHoverBound) return;
            item._ocHoverBound = true;

            var trigger = item.querySelector('.menu-list__link[aria-haspopup]');
            var submenu = item.querySelector('.menu-list__submenu');
            if (!trigger || !submenu) return;

            var closeTimer = null;

            function clearClose() {
              if (closeTimer) {
                clearTimeout(closeTimer);
                closeTimer = null;
              }
            }

            function openMenu() {
              clearClose();
              trigger.setAttribute('aria-expanded', 'true');
            }

            function closeMenuSoon() {
              clearClose();
              closeTimer = setTimeout(function () {
                var hoveredItem = item.matches(':hover');
                var hoveredSubmenu = submenu.matches(':hover');
                var focusedInside = item.contains(document.activeElement);

                if (!hoveredItem && !hoveredSubmenu && !focusedInside) {
                  trigger.setAttribute('aria-expanded', 'false');
                }
              }, CLOSE_DELAY);
            }

            item.addEventListener('mouseenter', openMenu);
            item.addEventListener('mouseleave', closeMenuSoon);

            submenu.addEventListener('mouseenter', openMenu);
            submenu.addEventListener('mouseleave', closeMenuSoon);

            trigger.addEventListener('focus', openMenu);
            item.addEventListener('focusout', function () {
              closeMenuSoon();
            });
          });
        }

        bindDelayedClose(document);

        var obs = new MutationObserver(function () {
          bindDelayedClose(document);
        });

        obs.observe(document.body, { childList: true, subtree: true });
      })();
    </script>

{% endcase %}

{% style %}
  .header__underlay {
    --color-submenu: rgb({{ block_settings.color_scheme.settings.background.rgba }});
  }
{% endstyle %}

{% stylesheet %}
.header__drawer {
  --header-drawer-min-height: 60px;
  display: flex;
  min-height: var(--header-drawer-min-height);
  align-items: center;
}

#header-component[data-menu-style='drawer'] .header__drawer {
  display: flex;
  min-height: var(--header-drawer-min-height);
}

@media screen and (min-width: 750px) {
  #header-component[data-menu-style='menu'] .header__drawer {
    display: none;
    min-height: 0;
  }
}

.header--compact .header__drawer {
  min-height: var(--minimum-touch-target);
}

.menu-list--mobile {
  &.menu-list { display: grid; }
  & .menu-list__list { width: max-content; margin-inline: auto; gap: var(--menu-horizontal-gap); }
  & li { width: max-content; padding-block: var(--padding-sm); }
  & li:first-of-type { padding-inline-start: var(--menu-horizontal-gap); }
  & li:last-of-type { padding-inline-end: var(--menu-horizontal-gap); }
  & a { color: var(--color-foreground); }
}

.menu-list__scroll-container {
  position: relative;
  overflow-x: auto;
  mask-image: linear-gradient(to right, transparent, #000 20px, #000 calc(100% - 20px), transparent);
  padding-block: var(--padding-2xs);
}

.menu-list {
  --menu-horizontal-gap: var(--gap-xl);
  --menu-vertical-gap: var(--gap-xl);
  display: flex;
  height: 100%;
}

.menu-list__list {
  display: flex;
  justify-content: var(--grid-area-alignment);
}

.menu-list__list-item {
  flex-shrink: 0;
  white-space: nowrap;
  display: flex;
  align-items: center;
  height: 100%;
}

.menu-list__list-item[aria-hidden='true'] {
  visibility: hidden;
}

.menu-list__link {
  font-family: var(--menu-top-level-font-family);
  font-style: var(--menu-top-level-font-style);
  font-weight: var(--menu-top-level-font-weight);
  font-size: var(--oc-top-menu-font-size, var(--menu-top-level-font-size));
  line-height: var(--menu-top-level-font-line-height);
  text-transform: var(--menu-top-level-font-case);
  color: var(--menu-top-level-font-color);
  text-decoration: none;
  display: flex;
  flex-direction: column;
  justify-content: center;
  cursor: pointer;
  height: 100%;
  margin-block: 0;

  &:hover,
  &:focus {
    color: var(--menu-top-level-font-color);
  }
}

@media screen and (min-width: 750px) {
  .menu-list__link {
    font-size: var(--oc-top-menu-font-size, var(--menu-top-level-font-size-desktop));
  }
}

.menu-list__link-title {
  padding-inline: calc(var(--gap-xl) / 2);
}

[slot='overflow'] .menu-list__link-title {
  padding-inline: 0;
}

.menu-list__list-item:not([slot='overflow']) {
  flex-direction: column;
}

.menu-list__list-item:not([slot='overflow'])::after {
  content: '';
  width: 100%;
  height: var(--header-padding);
  margin-bottom: calc(-1 * var(--header-padding));
}

[slot='overflow'] > .menu-list__link::after {
  content: none;
}

.menu-list:where(:has(.menu-list__list-item:hover)),
.menu-list:where(:has(.menu-list__list-item:focus-within)),
.menu-list:where(:has(.menu-list__list-item:not([aria-hidden='true']) .menu-list__link--active)) {
  .menu-list__link {
    color: rgb(var(--menu-top-level-font-color-rgb) / var(--opacity-subdued-text));
  }
}

.menu-list:not(:has(.menu-list__list-item:hover)) .menu-list__link--active,
.menu-list .menu-list__list-item:where(:hover, :focus-within) .menu-list__link,
.menu-list .menu-list__list-item[slot='overflow'] .menu-list__link[aria-expanded='true'] {
  color: var(--menu-top-level-font-color);
}

.overflow-menu::part(list) {
  --focus-outline-size: calc(var(--focus-outline-offset) + var(--focus-outline-width));
  gap: 0;
  margin-inline: calc(-1 * var(--menu-horizontal-gap) / 2);
}

.overflow-menu {
  background-color: transparent;
  padding: var(--focus-outline-size);
  margin: calc(-1 * var(--focus-outline-size));
}

.menu-list__submenu,
.overflow-menu::part(overflow) {
  --submenu-padding-block-start: var(--padding-3xl);
  --submenu-padding-block-end: var(--padding-3xl);
  background-color: transparent;
}

.header__row[style*='--border-bottom-width: 0px'] {
  .menu-list__submenu.color-scheme-matches-parent,
  .overflow-menu.color-scheme-matches-parent::part(overflow) {
    --submenu-padding-block-start: 0px;
  }
}

.menu-list__list-item:where(:not([slot='overflow'])) > .menu-list__submenu,
.overflow-menu::part(overflow) {
  --submenu-content-opacity: 0;
  --submenu-content-animation: opacity calc(var(--submenu-animation-speed) * 0.75) var(--animation-easing);
  visibility: hidden;
  position: absolute;
  width: 100%;
  left: 0;
  top: calc(100% - 1px + var(--border-bottom-width) - (var(--full-open-header-height) - var(--submenu-height)));
  z-index: var(--layer-header-menu);
  padding-inline: var(--padding-inline);
  clip-path: rect(var(--header-height) 100% var(--full-open-header-height) 0);
  transition: clip-path var(--submenu-animation-speed) var(--ease-out-cubic);
}

[data-submenu-overlap-bottom-row] {
  .menu-list__list-item:where(:not([slot='overflow'])) > .menu-list__submenu,
  .overflow-menu::part(overflow) {
    clip-path: rect(var(--top-row-height) 100% var(--full-open-header-height) 0);
  }
}

.menu-list__list-item:has([aria-expanded='true']) > .menu-list__submenu,
.overflow-menu:has([slot="overflow"] [aria-expanded='true'])::part(overflow-list),
.menu-list__submenu:is(:hover),
.overflow-menu::part(overflow):hover {
  --submenu-content-opacity: 1;
  visibility: visible;
}

.overflow-menu::part(overflow) {
  --menu-top-level-font-size: var(--font-size--xlarge);
  display: grid;
  grid-template-columns: var(--full-page-grid-with-margins);
}

.overflow-menu::part(overflow-list) {
  position: relative;
  display: grid;
  grid-template-columns: minmax(auto, 200px) 1fr;
  grid-template-areas: 'left right';
  grid-template-rows: max-content;
  grid-gap: 0;
  grid-column: 2;
}

.menu-list__list-item:is([slot='overflow']) {
  --menu-top-level-font-color: var(--color-foreground);
  --menu-top-level-font-color-rgb: var(--color-foreground-rgb);
  display: contents;
  white-space: normal;

  .menu-list__link {
    grid-area: left;
    grid-row: auto;
    height: min-content;
    font-size: var(--font-size--xl);
    transition: var(--submenu-content-animation);
  }

  .menu-list__submenu {
    visibility: hidden;
    grid-row: 1;
    grid-area: right;
    grid-row-end: span calc(var(--overflow-count) + 1);
    padding-inline-start: var(--menu-horizontal-gap);
  }

  .menu-list__submenu-inner {
    transform: none;
    grid-column: unset;
    padding-block: 0;
  }

  .menu-list__link[aria-expanded='true'] + .menu-list__submenu {
    visibility: visible;
  }
}

.header-menu {
  height: 100%;
}

.menu-list__submenu-inner,
.overflow-menu::part(overflow-list) {
  padding-block-start: var(--submenu-padding-block-start);
  padding-block-end: var(--submenu-padding-block-end);
  padding-inline: var(--section-padding-inline);
  opacity: var(--submenu-content-opacity);
  transition: var(--submenu-content-animation);
  transform: translateY(calc(var(--full-open-header-height) - var(--submenu-height)));
  max-height: calc(80vh - var(--header-height));
  overflow: hidden;
  overflow-x: hidden;
}

.oc-mega-inner {
  position: relative;
  display: flex;
  justify-content: space-between;
  padding: 0 !important;
  overflow: hidden !important;
  flex-wrap: nowrap !important;
  align-items: stretch;
}

.oc-mega-panel {
  display: flex;
  width: 100%;
  min-height: var(--oc-drawer-min-height, 260px);
  height: auto;
  max-height: calc(80vh - var(--header-height, 64px));
  align-items: stretch;
}

.oc-mega__col0,
.oc-mega__col1,
.oc-mega__col2 {
  overflow-y: auto;
  overflow-x: hidden;
  scrollbar-width: thin;
  scrollbar-color: var(--oc-ink-15) transparent;
}

.oc-mega__col0 {
  width: var(--oc-col0-width, 230px);
  flex-shrink: 0;
  border-right: 1px solid var(--oc-ink-15);
  padding: 0 6px 12px;
}

.oc-mega__col1 {
  width: var(--oc-col1-width, 230px);
  flex-shrink: 0;
  border-right: 1px solid var(--oc-ink-15);
  padding: 0 6px 12px;
  background: var(--oc-ink-05);
}

.oc-mega__col2 {
  flex: 1;
  padding: 12px 16px 16px;
  min-width: 0;
}

.oc-mega__col-hd {
  font-size: 10px;
  font-weight: 700;
  color: var(--oc-ink-40);
  text-transform: uppercase;
  letter-spacing: 0.07em;
  padding: 11px 8px 6px;
  position: sticky;
  top: 0;
  z-index: 1;
  border-bottom: 1px solid var(--oc-ink-15);
  margin: 0 -6px 3px;
  white-space: normal;
}

.oc-mega__col0 .oc-mega__col-hd {
  background: rgb(var(--color-background, 255 255 255));
}

.oc-mega__col1 .oc-mega__col-hd {
  background: var(--oc-ink-05);
}

.oc-mega__l0-list,
.oc-mega__l1-list {
  list-style: none;
  padding: 0;
  margin: 0;
}

.oc-mega__l0-item,
.oc-mega__l1-item {
  padding: 7px 8px;
  border-radius: var(--oc-radius-sm);
  line-height: 1.45;
  cursor: pointer;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 6px;
  margin-bottom: 1px;
  color: var(--oc-ink-70, #374151);
  white-space: normal;
  word-break: break-word;
  font-weight: 700;
  transition:
    background var(--oc-dur-fast) ease,
    color var(--oc-dur-fast) ease;
}

.oc-mega__l0-item {
  font-size: var(--oc-l0-font-size, 13px);
}

.oc-mega__l1-item {
  font-size: var(--oc-l1-font-size, 13px);
}

.oc-mega__l0-item::after {
  content: '›';
  font-size: 13px;
  line-height: 1.7;
  color: var(--oc-ink-15);
  flex-shrink: 0;
  transition: color var(--oc-dur-fast) ease;
}

.oc-mega__l0-item:hover,
.oc-mega__l0-item.on {
  background: var(--oc-cyan-l);
  color: var(--oc-cyan);
}

.oc-mega__l0-item.on::after {
  color: var(--oc-cyan);
}

.oc-mega__l1-item:hover,
.oc-mega__l1-item.on {
  background: var(--oc-purple-l);
  color: var(--oc-purple-d);
}

.oc-mega__l1-group {
  display: block;
}

.oc-mega__l1-group.oc-hidden {
  display: none;
}

.oc-mega__thumbs {
  display: flex;
  flex-wrap: nowrap;
  gap: 8px;
  margin-bottom: 12px;
}

.oc-mega__thumb {
  flex: 1 1 0;
  min-width: 0;
  display: flex;
  flex-direction: column;
  border: 1px solid var(--oc-ink-15);
  border-radius: 7px;
  overflow: hidden;
  text-decoration: none;
  transition:
    border-color var(--oc-dur-fast) ease,
    box-shadow var(--oc-dur-fast) ease;
}

.oc-mega__thumb:hover {
  border-color: var(--oc-cyan);
  box-shadow: 0 0 0 2px var(--oc-cyan-l);
}

.oc-mega__thumb-media {
  position: relative;
  width: 100%;
  aspect-ratio: 4 / 3;
  background: var(--oc-ink-05);
  overflow: hidden;
  flex-shrink: 0;
}

.oc-mega__thumb img,
.oc-mega__thumb-ph {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.oc-mega__thumb-nm {
  display: block;
  padding: 4px 6px 5px;
  font-size: var(--oc-thumb-title-font-size, 10px);
  color: var(--oc-ink-40);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  border-top: 1px solid var(--oc-ink-15);
  line-height: 1.35;
  font-weight: 600;
}

.oc-mega__tags-hd {
  font-size: 9px;
  font-weight: 700;
  color: var(--oc-ink-40);
  text-transform: uppercase;
  letter-spacing: 0.07em;
  margin: 0 0 5px;
}

.oc-mega__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
  margin-bottom: 10px;
}

.oc-mega__tag {
  display: inline-flex;
  align-items: center;
  padding: 3px 9px;
  border-radius: var(--oc-radius-pill);
  background: var(--oc-ink-05);
  border: 1px solid var(--oc-ink-15);
  font-size: 11px;
  color: var(--oc-ink-40);
  text-decoration: none;
  white-space: nowrap;
  transition:
    background var(--oc-dur-fast) ease,
    border-color var(--oc-dur-fast) ease,
    color var(--oc-dur-fast) ease;
}

.oc-mega__tag:hover {
  background: var(--oc-cyan-l);
  border-color: var(--oc-cyan);
  color: var(--oc-cyan);
}

.oc-mega__viewall {
  margin-top: 6px;
}

.oc-mega__loading,
.oc-mega__empty {
  font-size: 12px;
  color: var(--oc-ink-40);
  padding: 16px 0 8px;
  margin: 0;
}

@media screen and (max-width: 1199px) {
  .oc-mega__col0 { width: min(var(--oc-col0-width, 230px), 200px); }
  .oc-mega__col1 { width: min(var(--oc-col1-width, 230px), 200px); }
}

@media screen and (max-width: 989px) {
  .oc-mega-panel { flex-direction: column; max-height: none; }
  .oc-mega__col0,
  .oc-mega__col1 {
    width: 100%;
    border-right: none;
    border-bottom: 1px solid var(--oc-ink-15);
  }
  .oc-mega__col0 { max-height: 160px; }
  .oc-mega__col1 { max-height: 200px; }
}

@media (prefers-reduced-motion: reduce) {
  .oc-mega__l0-item,
  .oc-mega__l1-item,
  .oc-mega__thumb,
  .oc-mega__tag {
    transition: none !important;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.menu",
  "tag": null,
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    },
    {
      "type": "header",
      "content": "Mega menu content"
    },
    {
      "type": "range",
      "id": "mega_thumb_count",
      "label": "Thumbnail images shown",
      "min": 1,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "product_limit",
      "label": "Total products loaded",
      "min": 4,
      "max": 20,
      "step": 1,
      "default": 8
    },
    {
      "type": "header",
      "content": "Drawer height"
    },
    {
      "type": "range",
      "id": "drawer_min_height",
      "label": "Drawer minimum height (px)",
      "min": 220,
      "max": 600,
      "step": 10,
      "default": 260
    },
    {
      "type": "header",
      "content": "Thumbnail image"
    },
    {
      "type": "range",
      "id": "thumb_height",
      "label": "Thumbnail card height (px)",
      "min": 48,
      "max": 160,
      "step": 4,
      "default": 72
    },
    {
      "type": "range",
      "id": "thumb_image_width",
      "label": "Thumbnail image intrinsic width (px)",
      "min": 160,
      "max": 800,
      "step": 20,
      "default": 500
    },
    {
      "type": "range",
      "id": "thumb_title_font_size",
      "label": "Thumbnail title font size (px)",
      "min": 9,
      "max": 16,
      "step": 1,
      "default": 10
    },
    {
      "type": "header",
      "content": "Column width"
    },
    {
      "type": "range",
      "id": "col0_width",
      "label": "Left column width (px)",
      "min": 160,
      "max": 320,
      "step": 10,
      "default": 230
    },
    {
      "type": "range",
      "id": "col1_width",
      "label": "Middle column width (px)",
      "min": 160,
      "max": 320,
      "step": 10,
      "default": 230
    },
    {
      "type": "header",
      "content": "Font size"
    },
    {
      "type": "range",
      "id": "top_menu_font_size",
      "label": "Top menu font size (px)",
      "min": 12,
      "max": 24,
      "step": 1,
      "default": 16
    },
    {
      "type": "range",
      "id": "l0_font_size",
      "label": "Left column font size (px)",
      "min": 11,
      "max": 20,
      "step": 1,
      "default": 13
    },
    {
      "type": "range",
      "id": "l1_font_size",
      "label": "Middle column font size (px)",
      "min": 11,
      "max": 20,
      "step": 1,
      "default": 13
    },
    {
      "type": "header",
      "content": "Theme colour"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "primary"
    }
  ]
}
{% endschema %}