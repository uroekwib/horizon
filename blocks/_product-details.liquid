

{%- assign block_settings = block.settings -%}
<div
  id="ProductInformation-{{ section.id }}"
  class="
    product-details
    {% if block_settings.sticky_details_desktop %} sticky-content--desktop{% endif %}
    {% if block_settings.height == 'fill' -%} full-height--desktop{% endif -%}
  "
  style="--details-position: {{ block_settings.details_position }};"
  data-testid="product-information-details"
  {% if settings.transition_to_main_product %}
    data-view-transition-type="product-details"
  {% endif %}
>
  {% capture children %}
    <div class="view-product-title">
      <a
        href="{{ closest.product.selected_or_first_available_variant.url }}"
        class="link"
      >
        {{- closest.product.title }}
      </a>
    </div>
    {% content_for 'blocks' %}
  {% endcapture %}

  {% render 'group', children: children, settings: block_settings, shopify_attributes: block.shopify_attributes %}
</div>

{% stylesheet %}
  /* Clear padding on mobile, if not full-width */
  @media screen and (max-width: 749px) {
    .product-information.section--page-width .product-details > .group-block {
      padding-inline: 0;
    }
  }

  .view-product-title {
    display: none;
  }

  .product-details {
    display: flex;
    align-self: start;
    justify-content: center;
  }

  @media screen and (min-width: 750px) {
    /* reset wrapper height เฉพาะฝั่ง product info */
    .product-details,
    .product-details > .group-block,
    .product-details > .group-block > .group-block-content {
      height: auto !important;
      min-height: 0 !important;
    }

    /* กัน flex column ยืดสูงเกินจริง */
    .product-details .group-block-content.layout-panel-flex.layout-panel-flex--column {
      display: flex;
      flex-direction: column;
      flex-wrap: nowrap;
      justify-content: flex-start !important;
      align-items: stretch !important;
      gap: max(20px, calc(var(--gap-scale, 1) * 24px));
      height: auto !important;
      min-height: 0 !important;
    }

    /* ยกเลิกพฤติกรรมเดิมที่ใช้ min-content */
    .product-details > .group-block {
      height: auto !important;
    }

    /* sticky แบบนิ่ง ลดโอกาส shift */
    .product-details.sticky-content--desktop {
      position: sticky;
      top: calc(var(--sticky-header-offset, 0) + 72px);
      align-self: start;
    }

    /* กัน block ภายในโดน stretch แปลก ๆ */
    .product-details .group-block--height-fill,
    .product-details .group-block--height-custom,
    .product-details .group-block--height-fit {
      flex: 0 0 auto;
      height: auto;
      min-height: 0;
    }

    /* ปิด full-height logic เฉพาะฝั่งนี้ */
    .product-details.full-height--desktop {
      height: auto !important;
      max-height: none !important;
      min-height: 0 !important;
    }

    .product-details.full-height--desktop .group-block {
      align-self: start;
    }
  }
{% endstylesheet %}


<script>
  document.addEventListener('DOMContentLoaded', () => {
    const stickyElements = document.querySelectorAll('.sticky-content--desktop');
    
    if (stickyElements.length === 0) return;

    const adjustStickyTop = () => {
      stickyElements.forEach(el => {
        const viewportHeight = window.innerHeight;
        // ใช้ getBoundingClientRect().height เพื่อความแม่นยำที่สุด
        const elHeight = el.getBoundingClientRect().height; 
        
        // ดึงค่า offset ของ Header เดิมมาใช้ (ถ้ามี)
        const headerOffsetStr = getComputedStyle(el).getPropertyValue('--sticky-header-offset').trim();
        const headerOffset = parseInt(headerOffsetStr) || 20; // เผื่อระยะขอบไว้ 20px

        if (elHeight + headerOffset > viewportHeight) {
          // กรณีเนื้อหายาวกว่าหน้าจอ: เกาะที่ขอบล่าง
          // คำนวณดัน element ขึ้นไปให้ขอบล่างพอดีกับจอ (เผื่อขอบล่างไว้ 20px)
          const topValue = viewportHeight - elHeight - 20; 
          el.style.setProperty('--dynamic-sticky-top', `${topValue}px`);
        } else {
          // กรณีเนื้อหาสั้นกว่าจอ: เกาะที่ขอบบนตามปกติ
          el.style.setProperty('--dynamic-sticky-top', `var(--sticky-header-offset, 20px)`);
        }
      });
    };

    // คำนวณทันทีเมื่อโหลดเสร็จ
    adjustStickyTop();

    // คำนวณใหม่เมื่อมีการย่อ/ขยายหน้าจอ
    window.addEventListener('resize', adjustStickyTop);

    // ใช้ ResizeObserver เพื่อจับตาดูการเปลี่ยนแปลงความสูงของเนื้อหาข้างใน (เช่น กดเปิด/ปิด Accordion)
    // ทำให้ Layout ไม่พังและไม่ต้องกลัว Layout Shift
    const observer = new ResizeObserver(adjustStickyTop);
    stickyElements.forEach(el => observer.observe(el));
  });
</script>

