{% assign viewer_id = section.id | replace: '_', '' | downcase %}

{% style %}
  .pdfv-{{ viewer_id }} {
    --pdfv-bg: {{ section.settings.background_color }};
    --pdfv-header-bg: {{ section.settings.header_background }};
    --pdfv-text: {{ section.settings.text_color }};
    --pdfv-border: {{ section.settings.border_color }};
    --pdfv-primary: {{ section.settings.primary_color }};
    --pdfv-btn-bg: {{ section.settings.button_background }};
    --pdfv-btn-text: {{ section.settings.button_text }};
    --pdfv-btn-hover: {{ section.settings.button_hover }};
    --pdfv-btn-radius: {{ section.settings.button_radius }}px;
    --pdfv-radius: {{ section.settings.border_radius }}px;
    --pdfv-height: {{ section.settings.viewer_height }}px;
    --pdfv-gap: 24px;
    width: 100%;
  }

  .pdfv-{{ viewer_id }} * {
    box-sizing: border-box;
  }

  .pdfv-shell-{{ viewer_id }} {
    width: 100%;
    max-width: min(1800px, calc(100vw - 32px));
    margin: 0 auto;
    padding: 20px 16px;
  }

  .pdfv-card-{{ viewer_id }} {
    background: var(--pdfv-bg);
    border: 1px solid var(--pdfv-border);
    border-radius: var(--pdfv-radius);
    overflow: hidden;
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.08);
  }

  .pdfv-header-{{ viewer_id }} {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    flex-wrap: wrap;
    padding: 14px 18px;
    background: var(--pdfv-header-bg);
    border-bottom: 1px solid var(--pdfv-border);
  }

  .pdfv-title-{{ viewer_id }} {
    margin: 0;
    color: var(--pdfv-text);
    font-size: {{ section.settings.title_size }}px;
    line-height: 1.3;
    font-weight: 700;
  }

  .pdfv-meta-{{ viewer_id }} {
    color: var(--pdfv-text);
    opacity: .8;
    font-size: 13px;
    white-space: nowrap;
  }

  .pdfv-toolbar-{{ viewer_id }} {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px;
    padding: 12px 14px;
    background: var(--pdfv-header-bg);
    border-bottom: 1px solid var(--pdfv-border);
  }

  .pdfv-btn-{{ viewer_id }} {
    appearance: none;
    border: 1px solid var(--pdfv-border);
    background: var(--pdfv-btn-bg);
    color: var(--pdfv-btn-text);
    padding: 9px 14px;
    border-radius: var(--pdfv-btn-radius);
    cursor: pointer;
    font-size: 13px;
    line-height: 1;
    transition: background .2s ease, opacity .2s ease, transform .2s ease;
  }

  .pdfv-btn-{{ viewer_id }}:hover:not(:disabled) {
    background: var(--pdfv-btn-hover);
  }

  .pdfv-btn-{{ viewer_id }}:active:not(:disabled) {
    transform: translateY(1px);
  }

  .pdfv-btn-{{ viewer_id }}:disabled {
    opacity: .45;
    cursor: not-allowed;
  }

  .pdfv-btn-{{ viewer_id }}.is-active {
    outline: 2px solid var(--pdfv-primary);
    outline-offset: 1px;
  }

  .pdfv-zoom-label-{{ viewer_id }} {
    min-width: 60px;
    text-align: center;
    font-size: 13px;
    font-weight: 600;
    color: var(--pdfv-text);
    align-self: center;
  }

  .pdfv-stage-{{ viewer_id }} {
    position: relative;
    width: 100%;
    height: var(--pdfv-height);
    min-height: 420px;
    overflow: auto;
    background: linear-gradient(180deg, #f8f8f8 0%, #efefef 100%);
    -webkit-overflow-scrolling: touch;
  }

  .pdfv-stage-inner-{{ viewer_id }} {
    min-width: 100%;
    min-height: 100%;
    display: flex;
    justify-content: center;
    align-items: flex-start;
    padding: 24px;
  }

  .pdfv-spread-{{ viewer_id }} {
    display: flex;
    justify-content: center;
    align-items: flex-start;
    gap: var(--pdfv-gap);
    width: max-content;
    margin: 0 auto;
  }

  .pdfv-page-{{ viewer_id }} {
    position: relative;
    background: #fff;
    border-radius: 4px;
    overflow: hidden;
    box-shadow: 0 10px 24px rgba(0, 0, 0, .16);
    flex: 0 0 auto;
  }

  .pdfv-canvas-{{ viewer_id }} {
    display: block;
    width: auto;
    height: auto;
  }

  .pdfv-loading-{{ viewer_id }},
  .pdfv-empty-{{ viewer_id }},
  .pdfv-error-{{ viewer_id }} {
    min-height: var(--pdfv-height);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px 20px;
    text-align: center;
    color: var(--pdfv-text);
  }

  .pdfv-loading-box-{{ viewer_id }} {
    display: grid;
    gap: 12px;
    justify-items: center;
  }

  .pdfv-spinner-{{ viewer_id }} {
    width: 42px;
    height: 42px;
    border: 4px solid var(--pdfv-border);
    border-top-color: var(--pdfv-primary);
    border-radius: 50%;
    animation: pdfv-spin-{{ viewer_id }} 1s linear infinite;
  }

  @keyframes pdfv-spin-{{ viewer_id }} {
    to { transform: rotate(360deg); }
  }

  .pdfv-footer-{{ viewer_id }} {
    padding: 12px 14px;
    text-align: center;
    background: var(--pdfv-header-bg);
    border-top: 1px solid var(--pdfv-border);
    color: var(--pdfv-text);
    font-size: 12px;
    opacity: .7;
  }

  @media screen and (max-width: 989px) {
    .pdfv-shell-{{ viewer_id }} {
      max-width: 100%;
      padding: 16px 0;
    }

    .pdfv-stage-{{ viewer_id }} {
      height: min(78vh, {{ section.settings.viewer_height }}px);
    }

    .pdfv-stage-inner-{{ viewer_id }} {
      padding: 14px;
    }
  }

  @media screen and (max-width: 749px) {
    .pdfv-header-{{ viewer_id }} {
      padding: 12px 14px;
    }

    .pdfv-toolbar-{{ viewer_id }} {
      gap: 6px;
      padding: 10px 12px;
    }

    .pdfv-btn-{{ viewer_id }} {
      padding: 8px 11px;
      font-size: 12px;
    }

    .pdfv-stage-{{ viewer_id }} {
      min-height: 380px;
      height: min(76vh, 680px);
    }

    .pdfv-stage-inner-{{ viewer_id }} {
      padding: 10px;
    }

    .pdfv-{{ viewer_id }} .js-view-spread {
      display: none !important;
    }
  }
{% endstyle %}

<section
  class="pdfv-{{ viewer_id }}"
  data-pdf-url="{{ section.settings.pdf_file }}"
  data-default-view="{{ section.settings.default_view }}"
  data-default-fit="{{ section.settings.default_fit }}"
  {{ section.shopify_attributes }}
>
  <div class="pdfv-shell-{{ viewer_id }}">
    <div class="pdfv-card-{{ viewer_id }}">
      <div class="pdfv-header-{{ viewer_id }}">
        <h2 class="pdfv-title-{{ viewer_id }}">{{ section.settings.viewer_title }}</h2>
        <div class="pdfv-meta-{{ viewer_id }}">
          <span class="js-current-page">1</span> / <span class="js-total-pages">1</span>
        </div>
      </div>

      {% if section.settings.pdf_file == blank %}
        <div class="pdfv-empty-{{ viewer_id }}">
          <div>กรุณาใส่ URL ไฟล์ PDF ก่อน</div>
        </div>
      {% else %}
        <div class="pdfv-toolbar-{{ viewer_id }}">
          <button type="button" class="pdfv-btn-{{ viewer_id }} js-first">⏮</button>
          <button type="button" class="pdfv-btn-{{ viewer_id }} js-prev">◀</button>
          <button type="button" class="pdfv-btn-{{ viewer_id }} js-next">▶</button>
          <button type="button" class="pdfv-btn-{{ viewer_id }} js-last">⏭</button>

          <button type="button" class="pdfv-btn-{{ viewer_id }} js-view-single">Single</button>
          <button type="button" class="pdfv-btn-{{ viewer_id }} js-view-spread">Book</button>

          <button type="button" class="pdfv-btn-{{ viewer_id }} js-fit-page">Fit page</button>
          <button type="button" class="pdfv-btn-{{ viewer_id }} js-fit-width">Fit width</button>

          <button type="button" class="pdfv-btn-{{ viewer_id }} js-zoom-out">−</button>
          <span class="pdfv-zoom-label-{{ viewer_id }} js-zoom-label">100%</span>
          <button type="button" class="pdfv-btn-{{ viewer_id }} js-zoom-in">+</button>
        </div>

        <div class="pdfv-stage-{{ viewer_id }}">
          <div class="pdfv-loading-{{ viewer_id }} js-loading">
            <div class="pdfv-loading-box-{{ viewer_id }}">
              <div class="pdfv-spinner-{{ viewer_id }}"></div>
              <div>กำลังโหลด PDF...</div>
            </div>
          </div>

          <div class="pdfv-stage-inner-{{ viewer_id }} js-stage-inner" hidden>
            <div class="pdfv-spread-{{ viewer_id }}">
              <div class="pdfv-page-{{ viewer_id }} js-wrap-1">
                <canvas class="pdfv-canvas-{{ viewer_id }} js-canvas-1"></canvas>
              </div>
              <div class="pdfv-page-{{ viewer_id }} js-wrap-2" hidden>
                <canvas class="pdfv-canvas-{{ viewer_id }} js-canvas-2"></canvas>
              </div>
            </div>
          </div>
        </div>

        <div class="pdfv-footer-{{ viewer_id }}">
          Desktop: arrow key / Mobile: swipe
        </div>
      {% endif %}
    </div>
  </div>
</section>

<script>
  window.pdfjsLib = window.pdfjsLib || {};
  window.pdfjsLib.GlobalWorkerOptions = window.pdfjsLib.GlobalWorkerOptions || {};
  window.pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdn.jsdelivr.net/npm/pdfjs-dist@3.11.174/build/pdf.worker.min.js';
</script>
<script src="https://cdn.jsdelivr.net/npm/pdfjs-dist@3.11.174/build/pdf.min.js"></script>

<script>
(function() {
  class LeanPDFViewer{{ viewer_id }} {
    constructor(root) {
      this.root = root;
      this.pdfUrl = root.dataset.pdfUrl;
      this.defaultView = root.dataset.defaultView || 'spread';
      this.defaultFit = root.dataset.defaultFit || 'page';

      this.pdfDoc = null;
      this.totalPages = 0;
      this.currentPage = 1;
      this.viewMode = this.defaultView;
      this.fitMode = this.defaultFit;
      this.manualScale = 1;
      this.renderToken = 0;
      this.minScale = 0.45;
      this.maxScale = 3;

      this.touchStartX = 0;
      this.touchEndX = 0;
      this.resizeTimer = null;
      this.resizeObserver = null;

      this.cache();
      this.bind();
      this.load();
    }

    cache() {
      this.loadingEl = this.root.querySelector('.js-loading');
      this.stageEl = this.root.querySelector('.pdfv-stage-{{ viewer_id }}');
      this.stageInnerEl = this.root.querySelector('.js-stage-inner');

      this.currentPageEl = this.root.querySelector('.js-current-page');
      this.totalPagesEl = this.root.querySelector('.js-total-pages');
      this.zoomLabelEl = this.root.querySelector('.js-zoom-label');

      this.wrap1 = this.root.querySelector('.js-wrap-1');
      this.wrap2 = this.root.querySelector('.js-wrap-2');
      this.canvas1 = this.root.querySelector('.js-canvas-1');
      this.canvas2 = this.root.querySelector('.js-canvas-2');

      this.btnFirst = this.root.querySelector('.js-first');
      this.btnPrev = this.root.querySelector('.js-prev');
      this.btnNext = this.root.querySelector('.js-next');
      this.btnLast = this.root.querySelector('.js-last');
      this.btnViewSingle = this.root.querySelector('.js-view-single');
      this.btnViewSpread = this.root.querySelector('.js-view-spread');
      this.btnFitPage = this.root.querySelector('.js-fit-page');
      this.btnFitWidth = this.root.querySelector('.js-fit-width');
      this.btnZoomOut = this.root.querySelector('.js-zoom-out');
      this.btnZoomIn = this.root.querySelector('.js-zoom-in');
    }

    bind() {
      this.btnFirst?.addEventListener('click', () => this.goToPage(1));
      this.btnPrev?.addEventListener('click', () => this.previous());
      this.btnNext?.addEventListener('click', () => this.next());
      this.btnLast?.addEventListener('click', () => this.goToPage(this.getLastStartPage()));

      this.btnViewSingle?.addEventListener('click', () => {
        this.viewMode = 'single';
        if (this.fitMode !== 'manual') this.fitMode = 'page';
        this.render();
      });

      this.btnViewSpread?.addEventListener('click', () => {
        if (this.isMobile()) return;
        this.viewMode = 'spread';
        if (this.currentPage > 1 && this.currentPage % 2 !== 0) this.currentPage -= 1;
        if (this.fitMode !== 'manual') this.fitMode = 'page';
        this.render();
      });

      this.btnFitPage?.addEventListener('click', () => {
        this.fitMode = 'page';
        this.render();
      });

      this.btnFitWidth?.addEventListener('click', () => {
        this.fitMode = 'width';
        this.render();
      });

      this.btnZoomIn?.addEventListener('click', async () => this.zoomBy(1.2));
      this.btnZoomOut?.addEventListener('click', async () => this.zoomBy(1 / 1.2));

      document.addEventListener('keydown', (e) => this.onKeydown(e));

      this.stageEl?.addEventListener('touchstart', (e) => {
        this.touchStartX = e.changedTouches[0].screenX;
      }, { passive: true });

      this.stageEl?.addEventListener('touchend', (e) => {
        this.touchEndX = e.changedTouches[0].screenX;
        const diff = this.touchStartX - this.touchEndX;
        if (Math.abs(diff) > 50) {
          if (diff > 0) this.next();
          else this.previous();
        }
      }, { passive: true });

      if ('ResizeObserver' in window && this.stageEl) {
        this.resizeObserver = new ResizeObserver(() => this.onResize());
        this.resizeObserver.observe(this.stageEl);
      } else {
        window.addEventListener('resize', () => this.onResize());
      }
    }

    async load() {
      if (!this.pdfUrl || !window.pdfjsLib) return;

      try {
        const task = window.pdfjsLib.getDocument({
          url: this.pdfUrl,
          cMapUrl: 'https://cdn.jsdelivr.net/npm/pdfjs-dist@3.11.174/cmaps/',
          cMapPacked: true
        });

        this.pdfDoc = await task.promise;
        this.totalPages = this.pdfDoc.numPages;
        this.totalPagesEl.textContent = this.totalPages;

        if (this.isMobile()) this.viewMode = 'single';

        await this.render();

        this.loadingEl.hidden = true;
        this.stageInnerEl.hidden = false;
      } catch (error) {
        console.error(error);
        this.loadingEl.className = 'pdfv-error-{{ viewer_id }}';
        this.loadingEl.innerHTML = '<div>ไม่สามารถโหลด PDF ได้ กรุณาตรวจสอบ URL ไฟล์อีกครั้ง</div>';
      }
    }

    isMobile() {
      return window.matchMedia('(max-width: 749px)').matches;
    }

    getEffectiveViewMode() {
      return this.isMobile() ? 'single' : this.viewMode;
    }

    getVisiblePages() {
      const mode = this.getEffectiveViewMode();

      if (mode === 'spread') {
        if (this.currentPage <= 1) return [1, this.totalPages >= 2 ? 2 : null];
        const left = this.currentPage % 2 === 0 ? this.currentPage : this.currentPage - 1;
        return [left, left + 1 <= this.totalPages ? left + 1 : null];
      }

      return [this.currentPage, null];
    }

    getLastStartPage() {
      const mode = this.getEffectiveViewMode();
      if (mode === 'spread') {
        if (this.totalPages <= 2) return 1;
        return this.totalPages % 2 === 0 ? this.totalPages - 1 : this.totalPages;
      }
      return this.totalPages;
    }

    async getPageSize(pageNumber) {
      const page = await this.pdfDoc.getPage(pageNumber);
      const viewport = page.getViewport({ scale: 1 });
      return { width: viewport.width, height: viewport.height };
    }

    async getScaleForFit() {
      const mode = this.getEffectiveViewMode();
      const [page1, page2] = this.getVisiblePages();
      const size1 = await this.getPageSize(page1);
      const size2 = page2 ? await this.getPageSize(page2) : null;

      const styles = window.getComputedStyle(this.stageInnerEl);
      const innerPadX = parseFloat(styles.paddingLeft) + parseFloat(styles.paddingRight);
      const innerPadY = parseFloat(styles.paddingTop) + parseFloat(styles.paddingBottom);

      const availableWidth = Math.max(100, this.stageEl.clientWidth - innerPadX);
      const availableHeight = Math.max(100, this.stageEl.clientHeight - innerPadY);

      if (mode === 'single') {
        const scaleWidth = availableWidth / size1.width;
        const scalePage = Math.min(availableWidth / size1.width, availableHeight / size1.height);

        if (this.fitMode === 'width') return scaleWidth;
        if (this.fitMode === 'page') return scalePage;
        return this.manualScale;
      }

      const gap = size2 ? 24 : 0;
      const totalWidth = size1.width + (size2 ? size2.width : 0) + gap;
      const maxHeight = Math.max(size1.height, size2 ? size2.height : 0);
      const scaleByWidth = availableWidth / totalWidth;
      const scaleByHeight = availableHeight / maxHeight;

      if (this.fitMode === 'width') {
        return Math.min(scaleByWidth, 1.35);
      }

      if (this.fitMode === 'page') {
        return Math.min(scaleByWidth, scaleByHeight);
      }

      return this.manualScale;
    }

    async zoomBy(multiplier) {
      const currentScale = this.fitMode === 'manual'
        ? this.manualScale
        : await this.getScaleForFit();

      this.fitMode = 'manual';
      this.manualScale = Math.min(this.maxScale, Math.max(this.minScale, currentScale * multiplier));
      await this.render();
    }

    async render() {
      if (!this.pdfDoc) return;

      const token = ++this.renderToken;
      const mode = this.getEffectiveViewMode();
      const [page1, page2] = this.getVisiblePages();
      const scale = Math.min(this.maxScale, Math.max(this.minScale, await this.getScaleForFit()));

      if (token !== this.renderToken) return;

      this.wrap2.hidden = !(mode === 'spread' && page2);

      await this.renderPageToCanvas(page1, this.canvas1, scale, token);

      if (mode === 'spread' && page2) {
        await this.renderPageToCanvas(page2, this.canvas2, scale, token);
      } else {
        this.canvas2.width = 0;
        this.canvas2.height = 0;
        this.canvas2.style.width = '0px';
        this.canvas2.style.height = '0px';
      }

      this.currentPageEl.textContent = page1;
      this.updateUI(scale);
      this.updateButtons();

      if (this.fitMode === 'page' || this.fitMode === 'width') {
        this.stageEl.scrollTo({ left: 0, top: 0, behavior: 'auto' });
      }
    }

    async renderPageToCanvas(pageNumber, canvas, scale, token) {
      const page = await this.pdfDoc.getPage(pageNumber);
      if (token !== this.renderToken) return;

      const viewport = page.getViewport({ scale });
      const context = canvas.getContext('2d', { alpha: false });

      const dpr = window.devicePixelRatio || 1;
      const outputScale = this.isMobile() ? Math.min(dpr, 1.25) : Math.min(dpr, 1.5);

      canvas.width = Math.floor(viewport.width * outputScale);
      canvas.height = Math.floor(viewport.height * outputScale);
      canvas.style.width = Math.floor(viewport.width) + 'px';
      canvas.style.height = Math.floor(viewport.height) + 'px';

      context.setTransform(outputScale, 0, 0, outputScale, 0, 0);
      context.imageSmoothingEnabled = true;
      context.imageSmoothingQuality = 'medium';

      await page.render({
        canvasContext: context,
        viewport
      }).promise;
    }

    updateUI(scale) {
      const effective = this.getEffectiveViewMode();

      this.zoomLabelEl.textContent = Math.round(scale * 100) + '%';

      this.btnViewSingle?.classList.toggle('is-active', effective === 'single');
      this.btnViewSpread?.classList.toggle('is-active', effective === 'spread' && !this.isMobile());

      this.btnFitPage?.classList.toggle('is-active', this.fitMode === 'page');
      this.btnFitWidth?.classList.toggle('is-active', this.fitMode === 'width');

      if (this.isMobile()) {
        this.btnViewSpread?.classList.remove('is-active');
        this.btnViewSingle?.classList.add('is-active');
      }
    }

    updateButtons() {
      const lastStartPage = this.getLastStartPage();
      this.btnFirst.disabled = this.currentPage <= 1;
      this.btnPrev.disabled = this.currentPage <= 1;
      this.btnNext.disabled = this.currentPage >= lastStartPage;
      this.btnLast.disabled = this.currentPage >= lastStartPage;
    }

    goToPage(page) {
      const effective = this.getEffectiveViewMode();

      if (effective === 'spread' && page > 1 && page % 2 !== 0) {
        page -= 1;
      }

      this.currentPage = Math.max(1, Math.min(page, this.getLastStartPage()));
      this.render();
    }

    next() {
      const step = this.getEffectiveViewMode() === 'spread' ? 2 : 1;
      this.goToPage(this.currentPage + step);
    }

    previous() {
      const step = this.getEffectiveViewMode() === 'spread' ? 2 : 1;
      this.goToPage(this.currentPage - step);
    }

    onKeydown(e) {
      if (!this.pdfDoc) return;

      const tag = document.activeElement?.tagName;
      if (tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT') return;

      if (e.key === 'ArrowLeft') {
        e.preventDefault();
        this.previous();
      } else if (e.key === 'ArrowRight') {
        e.preventDefault();
        this.next();
      } else if (e.key === '+' || (e.key === '=' && (e.ctrlKey || e.metaKey))) {
        e.preventDefault();
        this.zoomBy(1.2);
      } else if (e.key === '-') {
        e.preventDefault();
        this.zoomBy(1 / 1.2);
      }
    }

    onResize() {
      if (!this.pdfDoc) return;

      if (this.isMobile()) this.viewMode = 'single';

      if (this.getEffectiveViewMode() === 'spread' && this.currentPage > 1 && this.currentPage % 2 !== 0) {
        this.currentPage -= 1;
      }

      clearTimeout(this.resizeTimer);
      this.resizeTimer = setTimeout(() => {
        if (this.fitMode === 'page' || this.fitMode === 'width') {
          this.render();
        }
      }, 220);
    }
  }

  document.addEventListener('DOMContentLoaded', function() {
    var root = document.querySelector('.pdfv-{{ viewer_id }}');
    if (root && !root.dataset.viewerMounted) {
      root.dataset.viewerMounted = 'true';
      new LeanPDFViewer{{ viewer_id }}(root);
    }
  });

  document.addEventListener('shopify:section:load', function(event) {
    var root = event.target.querySelector('.pdfv-{{ viewer_id }}');
    if (root && !root.dataset.viewerMounted) {
      root.dataset.viewerMounted = 'true';
      new LeanPDFViewer{{ viewer_id }}(root);
    }
  });
})();
</script>

{% schema %}
{
  "name": "PDF catalogue viewer",
  "settings": [
    {
      "type": "text",
      "id": "viewer_title",
      "label": "ชื่อแคตตาล็อก",
      "default": "Catalogue"
    },
    {
      "type": "url",
      "id": "pdf_file",
      "label": "URL ไฟล์ PDF"
    },
    {
      "type": "select",
      "id": "default_view",
      "label": "โหมดเริ่มต้นบน Desktop",
      "default": "spread",
      "options": [
        { "value": "single", "label": "Single page" },
        { "value": "spread", "label": "Book spread" }
      ]
    },
    {
      "type": "select",
      "id": "default_fit",
      "label": "ขนาดเริ่มต้น",
      "default": "page",
      "options": [
        { "value": "page", "label": "Fit page" },
        { "value": "width", "label": "Fit width" }
      ]
