{% doc %}
  @prompt
    Create a PDF catalogue viewer block for Shopify OS 2.0 using PDF.js library with the following features:
    
    1. Double-page spread toggle — button to switch between single-page and two-page spread (book/magazine open layout), with icon indicating current mode
    2. Zoom in/out buttons (+ and -) — correct zoom behavior: clicking + increases scale, clicking - decreases scale, with min/max limits (0.5x to 3x), zoom centered on current view
    3. Fit to screen button — auto-scales PDF to fill viewer container width, responsive on desktop and mobile
    4. Page navigation — prev/next buttons with current page / total pages display
    5. Responsive layout — single-page forced on small screens even if double-page mode selected
    
    Block settings: pdf_url, catalogue_title, viewer_height (default 700px), accent_color
    Toolbar layout: [Fit Screen] [−] [Zoom%] [+] [Single|Double toggle] [◀ Page X / Y ▶]
    Use PDF.js from CDN. Render pages to canvas elements. In double-page mode, render two consecutive pages side by side. Zoom state persists when toggling spread mode.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-pdf-viewer-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    border-radius: 8px;
    overflow: hidden;
  }

  .ai-pdf-viewer-header-{{ ai_gen_id }} {
    padding: 20px;
    background-color: {{ block.settings.header_background }};
    border-bottom: 1px solid {{ block.settings.border_color }};
  }

  .ai-pdf-viewer-title-{{ ai_gen_id }} {
    margin: 0;
    font-size: 20px;
    color: {{ block.settings.text_color }};
  }

  .ai-pdf-viewer-toolbar-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 16px;
    background-color: {{ block.settings.toolbar_background }};
    border-bottom: 1px solid {{ block.settings.border_color }};
    flex-wrap: wrap;
  }

  .ai-pdf-viewer-btn-{{ ai_gen_id }} {
    padding: 8px 16px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text }};
    border: 1px solid {{ block.settings.border_color }};
    border-radius: 4px;
    cursor: pointer;
    font-size: 14px;
    transition: all 0.2s ease;
    white-space: nowrap;
  }

  .ai-pdf-viewer-btn-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.accent_color }};
    color: #ffffff;
    border-color: {{ block.settings.accent_color }};
  }

  .ai-pdf-viewer-btn-{{ ai_gen_id }}:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .ai-pdf-viewer-btn-{{ ai_gen_id }}:disabled:hover {
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text }};
    border-color: {{ block.settings.border_color }};
  }

  .ai-pdf-viewer-btn-icon-{{ ai_gen_id }} {
    padding: 8px 12px;
    min-width: 40px;
  }

  .ai-pdf-viewer-zoom-display-{{ ai_gen_id }} {
    padding: 8px 12px;
    background-color: {{ block.settings.toolbar_background }};
    color: {{ block.settings.text_color }};
    border: 1px solid {{ block.settings.border_color }};
    border-radius: 4px;
    font-size: 14px;
    min-width: 70px;
    text-align: center;
  }

  .ai-pdf-viewer-page-info-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    color: {{ block.settings.text_color }};
    font-size: 14px;
  }

  .ai-pdf-viewer-spread-toggle-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .ai-pdf-viewer-spread-icon-{{ ai_gen_id }} {
    width: 20px;
    height: 16px;
    display: inline-block;
  }

  .ai-pdf-viewer-container-{{ ai_gen_id }} {
    height: {{ block.settings.viewer_height }}px;
    overflow: auto;
    background-color: #525659;
    display: flex;
    justify-content: center;
    align-items: flex-start;
    padding: 20px;
  }

  .ai-pdf-viewer-canvas-wrapper-{{ ai_gen_id }} {
    display: flex;
    gap: 10px;
    justify-content: center;
  }

  .ai-pdf-viewer-canvas-{{ ai_gen_id }} {
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
    background-color: #ffffff;
  }

  .ai-pdf-viewer-loading-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    height: {{ block.settings.viewer_height }}px;
    color: {{ block.settings.text_color }};
    font-size: 16px;
  }

  .ai-pdf-viewer-error-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    height: {{ block.settings.viewer_height }}px;
    color: #d82c0d;
    font-size: 16px;
    padding: 20px;
    text-align: center;
  }

  @media screen and (max-width: 749px) {
    .ai-pdf-viewer-toolbar-{{ ai_gen_id }} {
      gap: 8px;
      padding: 12px;
    }

    .ai-pdf-viewer-btn-{{ ai_gen_id }} {
      padding: 6px 12px;
      font-size: 13px;
    }

    .ai-pdf-viewer-btn-icon-{{ ai_gen_id }} {
      padding: 6px 10px;
      min-width: 36px;
    }

    .ai-pdf-viewer-zoom-display-{{ ai_gen_id }} {
      padding: 6px 10px;
      font-size: 13px;
      min-width: 60px;
    }

    .ai-pdf-viewer-page-info-{{ ai_gen_id }} {
      font-size: 13px;
    }

    .ai-pdf-viewer-container-{{ ai_gen_id }} {
      padding: 10px;
    }
  }
{% endstyle %}

<pdf-catalogue-viewer-{{ ai_gen_id }}
  class="ai-pdf-viewer-{{ ai_gen_id }}"
  data-pdf-url="{{ block.settings.pdf_url }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.catalogue_title != blank %}
    <div class="ai-pdf-viewer-header-{{ ai_gen_id }}">
      <h2 class="ai-pdf-viewer-title-{{ ai_gen_id }}">{{ block.settings.catalogue_title }}</h2>
    </div>
  {% endif %}

  <div class="ai-pdf-viewer-toolbar-{{ ai_gen_id }}">
    <button
      class="ai-pdf-viewer-btn-{{ ai_gen_id }} ai-pdf-fit-screen-{{ ai_gen_id }}"
      aria-label="Fit to screen"
    >
      Fit Screen
    </button>

    <button
      class="ai-pdf-viewer-btn-{{ ai_gen_id }} ai-pdf-viewer-btn-icon-{{ ai_gen_id }} ai-pdf-zoom-out-{{ ai_gen_id }}"
      aria-label="Zoom out"
    >
      −
    </button>

    <div class="ai-pdf-viewer-zoom-display-{{ ai_gen_id }} ai-pdf-zoom-level-{{ ai_gen_id }}">
      100%
    </div>

    <button
      class="ai-pdf-viewer-btn-{{ ai_gen_id }} ai-pdf-viewer-btn-icon-{{ ai_gen_id }} ai-pdf-zoom-in-{{ ai_gen_id }}"
      aria-label="Zoom in"
    >
      +
    </button>

    <button
      class="ai-pdf-viewer-btn-{{ ai_gen_id }} ai-pdf-spread-toggle-{{ ai_gen_id }}"
      aria-label="Toggle spread mode"
    >
      <span class="ai-pdf-viewer-spread-toggle-{{ ai_gen_id }}">
        <svg class="ai-pdf-viewer-spread-icon-{{ ai_gen_id }} ai-pdf-single-icon-{{ ai_gen_id }}" viewBox="0 0 20 16" fill="none" stroke="currentColor" stroke-width="1.5">
          <rect x="1" y="1" width="18" height="14" rx="1"/>
        </svg>
        <svg class="ai-pdf-viewer-spread-icon-{{ ai_gen_id }} ai-pdf-double-icon-{{ ai_gen_id }}" viewBox="0 0 20 16" fill="none" stroke="currentColor" stroke-width="1.5" style="display: none;">
          <rect x="1" y="1" width="8.5" height="14" rx="1"/>
          <rect x="10.5" y="1" width="8.5" height="14" rx="1"/>
        </svg>
        <span class="ai-pdf-spread-text-{{ ai_gen_id }}">Single</span>
      </span>
    </button>

    <div class="ai-pdf-viewer-page-info-{{ ai_gen_id }}">
      <button
        class="ai-pdf-viewer-btn-{{ ai_gen_id }} ai-pdf-viewer-btn-icon-{{ ai_gen_id }} ai-pdf-prev-page-{{ ai_gen_id }}"
        aria-label="Previous page"
      >
        ◀
      </button>
      <span class="ai-pdf-page-display-{{ ai_gen_id }}">
        Page <span class="ai-pdf-current-page-{{ ai_gen_id }}">1</span> / <span class="ai-pdf-total-pages-{{ ai_gen_id }}">1</span>
      </span>
      <button
        class="ai-pdf-viewer-btn-{{ ai_gen_id }} ai-pdf-viewer-btn-icon-{{ ai_gen_id }} ai-pdf-next-page-{{ ai_gen_id }}"
        aria-label="Next page"
      >
        ▶
      </button>
    </div>
  </div>

  <div class="ai-pdf-viewer-container-{{ ai_gen_id }} ai-pdf-canvas-container-{{ ai_gen_id }}">
    <div class="ai-pdf-viewer-loading-{{ ai_gen_id }}">Loading PDF...</div>
  </div>
</pdf-catalogue-viewer-{{ ai_gen_id }}>

<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>

<script>
  (function() {
    class PdfCatalogueViewer{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.pdfDoc = null;
        this.currentPage = 1;
        this.scale = 1.0;
        this.isDoubleSpread = false;
        this.minScale = 0.5;
        this.maxScale = 3.0;
        this.rendering = false;
      }

      connectedCallback() {
        const pdfUrl = this.dataset.pdfUrl;
        
        if (!pdfUrl) {
          this.showError('No PDF URL provided. Please add a PDF file in the block settings.');
          return;
        }

        this.initElements();
        this.loadPdf(pdfUrl);
      }

      initElements() {
        this.container = this.querySelector('.ai-pdf-canvas-container-{{ ai_gen_id }}');
        this.zoomInBtn = this.querySelector('.ai-pdf-zoom-in-{{ ai_gen_id }}');
        this.zoomOutBtn = this.querySelector('.ai-pdf-zoom-out-{{ ai_gen_id }}');
        this.fitScreenBtn = this.querySelector('.ai-pdf-fit-screen-{{ ai_gen_id }}');
        this.spreadToggleBtn = this.querySelector('.ai-pdf-spread-toggle-{{ ai_gen_id }}');
        this.prevPageBtn = this.querySelector('.ai-pdf-prev-page-{{ ai_gen_id }}');
        this.nextPageBtn = this.querySelector('.ai-pdf-next-page-{{ ai_gen_id }}');
        this.zoomDisplay = this.querySelector('.ai-pdf-zoom-level-{{ ai_gen_id }}');
        this.currentPageDisplay = this.querySelector('.ai-pdf-current-page-{{ ai_gen_id }}');
        this.totalPagesDisplay = this.querySelector('.ai-pdf-total-pages-{{ ai_gen_id }}');
        this.singleIcon = this.querySelector('.ai-pdf-single-icon-{{ ai_gen_id }}');
        this.doubleIcon = this.querySelector('.ai-pdf-double-icon-{{ ai_gen_id }}');
        this.spreadText = this.querySelector('.ai-pdf-spread-text-{{ ai_gen_id }}');

        this.zoomInBtn.addEventListener('click', () => this.zoomIn());
        this.zoomOutBtn.addEventListener('click', () => this.zoomOut());
        this.fitScreenBtn.addEventListener('click', () => this.fitToScreen());
        this.spreadToggleBtn.addEventListener('click', () => this.toggleSpread());
        this.prevPageBtn.addEventListener('click', () => this.prevPage());
        this.nextPageBtn.addEventListener('click', () => this.nextPage());
      }

      async loadPdf(url) {
        try {
          pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';
          
          const loadingTask = pdfjsLib.getDocument(url);
          this.pdfDoc = await loadingTask.promise;
          
          this.totalPagesDisplay.textContent = this.pdfDoc.numPages;
          this.renderPages();
          this.updateButtons();
        } catch (error) {
          this.showError('Failed to load PDF. Please check the URL and try again.');
          console.error('PDF loading error:', error);
        }
      }

      async renderPages() {
        if (this.rendering || !this.pdfDoc) return;
        
        this.rendering = true;
        this.container.innerHTML = '';

        const wrapper = document.createElement('div');
        wrapper.className = 'ai-pdf-viewer-canvas-wrapper-{{ ai_gen_id }}';

        const isMobile = window.innerWidth < 750;
        const effectiveDoubleSpread = this.isDoubleSpread && !isMobile;

        try {
          const canvas1 = document.createElement('canvas');
          canvas1.className = 'ai-pdf-viewer-canvas-{{ ai_gen_id }}';
          await this.renderPage(this.currentPage, canvas1);
          wrapper.appendChild(canvas1);

          if (effectiveDoubleSpread && this.currentPage < this.pdfDoc.numPages) {
            const canvas2 = document.createElement('canvas');
            canvas2.className = 'ai-pdf-viewer-canvas-{{ ai_gen_id }}';
            await this.renderPage(this.currentPage + 1, canvas2);
            wrapper.appendChild(canvas2);
          }

          this.container.appendChild(wrapper);
        } catch (error) {
          this.showError('Error rendering PDF pages.');
          console.error('Rendering error:', error);
        }

        this.rendering = false;
      }

      async renderPage(pageNum, canvas) {
        const page = await this.pdfDoc.getPage(pageNum);
        const viewport = page.getViewport({ scale: this.scale });
        
        const context = canvas.getContext('2d');
        canvas.height = viewport.height;
        canvas.width = viewport.width;

        const renderContext = {
          canvasContext: context,
          viewport: viewport
        };

        await page.render(renderContext).promise;
      }

      zoomIn() {
        if (this.scale < this.maxScale) {
          this.scale = Math.min(this.scale + 0.25, this.maxScale);
          this.updateZoom();
        }
      }

      zoomOut() {
        if (this.scale > this.minScale) {
          this.scale = Math.max(this.scale - 0.25, this.minScale);
          this.updateZoom();
        }
      }

      fitToScreen() {
        if (!this.pdfDoc) return;

        this.pdfDoc.getPage(1).then(page => {
          const viewport = page.getViewport({ scale: 1.0 });
          const containerWidth = this.container.clientWidth - 40;
          
          const isMobile = window.innerWidth < 750;
          const effectiveDoubleSpread = this.isDoubleSpread && !isMobile;
          
          const pageWidth = effectiveDoubleSpread ? viewport.width * 2 + 10 : viewport.width;
          this.scale = containerWidth / pageWidth;
          this.scale = Math.max(this.minScale, Math.min(this.scale, this.maxScale));
          
          this.updateZoom();
        });
      }

      toggleSpread() {
        this.isDoubleSpread = !this.isDoubleSpread;
        
        if (this.isDoubleSpread) {
          this.singleIcon.style.display = 'none';
          this.doubleIcon.style.display = 'inline-block';
          this.spreadText.textContent = 'Double';
        } else {
          this.singleIcon.style.display = 'inline-block';
          this.doubleIcon.style.display = 'none';
          this.spreadText.textContent = 'Single';
        }

        this.renderPages();
        this.updateButtons();
      }

      prevPage() {
        const isMobile = window.innerWidth < 750;
        const effectiveDoubleSpread = this.isDoubleSpread && !isMobile;
        const step = effectiveDoubleSpread ? 2 : 1;
        
        if (this.currentPage > 1) {
          this.currentPage = Math.max(1, this.currentPage - step);
          this.renderPages();
          this.updateButtons();
        }
      }

      nextPage() {
        const isMobile = window.innerWidth < 750;
        const effectiveDoubleSpread = this.isDoubleSpread && !isMobile;
        const step = effectiveDoubleSpread ? 2 : 1;
        
        if (this.currentPage < this.pdfDoc.numPages) {
          this.currentPage = Math.min(this.pdfDoc.numPages, this.currentPage + step);
          this.renderPages();
          this.updateButtons();
        }
      }

      updateZoom() {
        this.zoomDisplay.textContent = Math.round(this.scale * 100) + '%';
        this.renderPages();
        this.updateButtons();
      }

      updateButtons() {
        if (!this.pdfDoc) return;

        const isMobile = window.innerWidth < 750;
        const effectiveDoubleSpread = this.isDoubleSpread && !isMobile;

        this.currentPageDisplay.textContent = this.currentPage;
        
        this.prevPageBtn.disabled = this.currentPage <= 1;
        
        if (effectiveDoubleSpread) {
          this.nextPageBtn.disabled = this.currentPage >= this.pdfDoc.numPages;
        } else {
          this.nextPageBtn.disabled = this.currentPage >= this.pdfDoc.numPages;
        }

        this.zoomInBtn.disabled = this.scale >= this.maxScale;
        this.zoomOutBtn.disabled = this.scale <= this.minScale;
      }

      showError(message) {
        this.container.innerHTML = `<div class="ai-pdf-viewer-error-{{ ai_gen_id }}">${message}</div>`;
      }
    }

    customElements.define('pdf-catalogue-viewer-{{ ai_gen_id }}', PdfCatalogueViewer{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "PDF catalogue viewer",
  "settings": [
    {
      "type": "header",
      "content": "PDF settings"
    },
    {
      "type": "url",
      "id": "pdf_url",
      "label": "PDF file URL"
    },
    {
      "type": "text",
      "id": "catalogue_title",
      "label": "Catalogue title",
      "default": "Product Catalogue"
    },
    {
      "type": "range",
      "id": "viewer_height",
      "label": "Viewer height",
      "min": 400,
      "max": 1000,
      "step": 50,
      "unit": "px",
      "default": 700
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "header_background",
      "label": "Header background",
      "default": "#f3f7fa"
    },
    {
      "type": "color",
      "id": "toolbar_background",
      "label": "Toolbar background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Button background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_text",
      "label": "Button text",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border",
      "default": "#e6e6e6"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent",
      "default": "#14c3d8"
    }
  ],
  "presets": [
    {
      "name": "PDF catalogue viewer"
    }
  ]
}
{% endschema %}
