
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-title-divider-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-title-divider__heading-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.spacing_bottom }}px 0;
    padding-bottom: {{ block.settings.line_spacing }}px;
    position: relative;
    display: block;
    width: 100%;
    color: {{ block.settings.heading_color }}!important;
  }

  .ai-title-divider__heading-{{ ai_gen_id }}::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: {{ block.settings.line_width }}%;
    height: {{ block.settings.line_height }}px;
    border-radius: {{ block.settings.line_border_radius }}px;
    {% if block.settings.gradient_enabled %}
      background: linear-gradient({{ block.settings.gradient_angle }}deg, {{ block.settings.gradient_color_start }} 0%, {{ block.settings.gradient_color_end }} 100%);
    {% else %}
      background-color: {{ block.settings.line_color }};
    {% endif %}
  }
{% endstyle %}

<div class="ai-title-divider-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% case block.settings.heading_preset %}
    {% when 'h1' %}
      <h1 class="ai-title-divider__heading-{{ ai_gen_id }} h1 h1">
        {{ block.settings.heading_text | default: 'Your heading here' }}
      </h1>

    {% when 'h2' %}
      <h2 class="ai-title-divider__heading-{{ ai_gen_id }} h2 h2">
        {{ block.settings.heading_text | default: 'Your heading here' }}
      </h2>

    {% when 'h3' %}
      <h3 class="ai-title-divider__heading-{{ ai_gen_id }} h3 h3">
        {{ block.settings.heading_text | default: 'Your heading here' }}
      </h3>

    {% when 'h4' %}
      <h4 class="ai-title-divider__heading-{{ ai_gen_id }} h4 h4">
        {{ block.settings.heading_text | default: 'Your heading here' }}
      </h4>

    {% when 'h5' %}
      <h5 class="ai-title-divider__heading-{{ ai_gen_id }} h5 h5">
        {{ block.settings.heading_text | default: 'Your heading here' }}
      </h5>

    {% when 'h6' %}
      <h6 class="ai-title-divider__heading-{{ ai_gen_id }} h6 h6">
        {{ block.settings.heading_text | default: 'Your heading here' }}
      </h6>

    {% else %}
      <p class="ai-title-divider__heading-{{ ai_gen_id }} paragraph">
        {{ block.settings.heading_text | default: 'Your heading here' }}
      </p>
  {% endcase %}
</div>

{% schema %}
{
  "name": "Heading with divider",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading_text",
      "label": "Heading text",
      "default": "Your heading here"
    },
    {
      "type": "select",
      "id": "heading_preset",
      "label": "Typography preset",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "h6",
          "label": "H6"
        },
        {
          "value": "p",
          "label": "Paragraph"
        }
      ],
      "default": "h3"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Text color",
      "default": "#17a9bb"
    },
    {
      "type": "range",
      "id": "spacing_bottom",
      "label": "Bottom spacing",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "header",
      "content": "Divider line"
    },
    {
      "type": "checkbox",
      "id": "gradient_enabled",
      "label": "Enable gradient",
      "default": true
    },
    {
      "type": "color",
      "id": "gradient_color_start",
      "label": "Gradient start color",
      "default": "#c3f9ff"
    },
    {
      "type": "color",
      "id": "gradient_color_end",
      "label": "Gradient end color",
      "default": "#c78ff2"
    },
    {
      "type": "range",
      "id": "gradient_angle",
      "label": "Gradient angle",
      "min": 0,
      "max": 360,
      "step": 10,
      "unit": "deg",
      "default": 90
    },
    {
      "type": "color",
      "id": "line_color",
      "label": "Solid color",
      "default": "#c3f9ff"
    },
    {
      "type": "range",
      "id": "line_width",
      "label": "Line width",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "line_height",
      "label": "Line thickness",
      "min": 1,
      "max": 10,
      "step": 1,
      "unit": "px",
      "default": 3
    },
    {
      "type": "range",
      "id": "line_border_radius",
      "label": "Line border radius",
      "min": 0,
      "max": 10,
      "step": 1,
      "unit": "px",
      "default": 2
    },
    {
      "type": "range",
      "id": "line_spacing",
      "label": "Space between text and line",
      "min": 4,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Heading with divider"
    }
  ]
}
{% endschema %}
