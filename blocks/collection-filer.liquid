{% doc %}
  @prompt
    CLAUDE - Collection filter section with pill navigation (parent + subcollection rows)
    Icons defined per-collection via schema textarea settings
    Active state uses CI cyan gradient
    Subcollections sourced from custom.subcollections metafield (collection reference list)
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .oc-cf-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    font-family: 'Google Sans', 'Noto Sans Thai', sans-serif;
  }

  .oc-cf__wrap-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  /* ── Heading ── */
  .oc-cf__heading-{{ ai_gen_id }} {
    margin: 0 0 4px;
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 700;
    color: var(--color-foreground);
  }

  /* ── Pill rows ── */
  .oc-cf__row-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
  }

  .oc-cf__sub-row-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    align-items: center;
    padding-left: 4px;
  }

  /* ── Parent pill ── */
  .oc-cf__pill-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 18px;
    border-radius: 999px;
    background: rgba(0,0,0,0.06);
    color: var(--color-foreground);
    text-decoration: none;
    font-size: {{ block.settings.pill_font_size }}px;
    font-weight: 600;
    letter-spacing: 0.02em;
    white-space: nowrap;
    transition: background 0.2s ease, color 0.2s ease, box-shadow 0.2s ease;
    border: none;
    cursor: pointer;
  }

  .oc-cf__pill-{{ ai_gen_id }}:hover {
    background: rgba(23,169,187,0.12);
    color: #17a9bb;
  }

  .oc-cf__pill-{{ ai_gen_id }}.active {
    background: linear-gradient(135deg, #14c9df, #17a9bb);
    color: #fff;
    box-shadow: 0 2px 10px rgba(20,201,223,0.35);
  }

  /* ── Child pill (smaller) ── */
  .oc-cf__subpill-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 6px 14px;
    border-radius: 999px;
    background: rgba(0,0,0,0.05);
    color: var(--color-foreground);
    text-decoration: none;
    font-size: {{ block.settings.pill_font_size | minus: 1 }}px;
    font-weight: 500;
    white-space: nowrap;
    transition: background 0.2s ease, color 0.2s ease;
    border: none;
  }

  .oc-cf__subpill-{{ ai_gen_id }}:hover {
    background: rgba(23,169,187,0.12);
    color: #17a9bb;
  }

  .oc-cf__subpill-{{ ai_gen_id }}.active {
    background: linear-gradient(135deg, #14c9df, #17a9bb);
    color: #fff;
    box-shadow: 0 2px 8px rgba(20,201,223,0.3);
  }

  /* ── Icon inside pill ── */
  .oc-cf__icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .oc-cf__icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    fill: currentColor;
  }

  /* ── Sub-row visibility ── */
  .oc-cf__sub-wrap-{{ ai_gen_id }} {
    overflow: hidden;
    max-height: 0;
    opacity: 0;
    transition: max-height 0.3s ease, opacity 0.25s ease;
  }

  .oc-cf__sub-wrap-{{ ai_gen_id }}.visible {
    max-height: 200px;
    opacity: 1;
  }

  /* ── Divider between rows ── */
  .oc-cf__divider-{{ ai_gen_id }} {
    width: 1px;
    height: 20px;
    background: rgba(0,0,0,0.12);
    display: inline-block;
  }

  @media screen and (max-width: 749px) {
    .oc-cf__row-{{ ai_gen_id }},
    .oc-cf__sub-row-{{ ai_gen_id }} {
      flex-wrap: nowrap;
      overflow-x: auto;
      scrollbar-width: none;
      -ms-overflow-style: none;
      padding-bottom: 4px;
    }

    .oc-cf__row-{{ ai_gen_id }}::-webkit-scrollbar,
    .oc-cf__sub-row-{{ ai_gen_id }}::-webkit-scrollbar {
      display: none;
    }
  }
{% endstyle %}

<div
  class="oc-cf-{{ ai_gen_id }}"
  data-current-handle="{{ collection.handle }}"
  {{ block.shopify_attributes }}
>
  <div class="oc-cf__wrap-{{ ai_gen_id }}">

    {% if block.settings.heading != blank %}
      <h2 class="oc-cf__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    {%- comment -%} ── Row 1: Parent collection pills ── {%- endcomment -%}
    <div class="oc-cf__row-{{ ai_gen_id }}">
      {% for i in (1..10) %}
        {%- liquid
          assign col_key  = 'collection_' | append: i
          assign icon_key = 'icon_svg_'   | append: i
          assign col      = block.settings[col_key]
          assign icon_svg = block.settings[icon_key]
        -%}

        {% if col != blank %}
          {%- liquid
            assign is_active = false
            if collection.handle == col.handle
              assign is_active = true
            endif
            if col.metafields.custom.subcollections.value != blank
              for sub in col.metafields.custom.subcollections.value
                if collection.handle == sub.handle
                  assign is_active = true
                  break
                endif
              endfor
            endif
          -%}

          <a
            href="{{ col.url }}"
            class="oc-cf__pill-{{ ai_gen_id }}{% if is_active %} active{% endif %}"
            data-col-id="{{ col.id }}"
          >
            {% if icon_svg != blank %}
              <span class="oc-cf__icon-{{ ai_gen_id }}">{{ icon_svg }}</span>
            {% endif %}
            <span>{{ col.title }}</span>
          </a>
        {% endif %}
      {% endfor %}
    </div>

    {%- comment -%} ── Row 2: Subcollection pills (show only for active parent) ── {%- endcomment -%}
    {% for i in (1..10) %}
      {%- liquid
        assign col_key = 'collection_' | append: i
        assign col     = block.settings[col_key]
      -%}

      {% if col != blank and col.metafields.custom.subcollections.value != blank %}
        {%- liquid
          assign is_parent_active = false
          if collection.handle == col.handle
            assign is_parent_active = true
          endif
          for sub in col.metafields.custom.subcollections.value
            if collection.handle == sub.handle
              assign is_parent_active = true
              break
            endif
          endfor
        -%}

        <div class="oc-cf__sub-wrap-{{ ai_gen_id }}{% if is_parent_active %} visible{% endif %}" data-parent-id="{{ col.id }}">
          <div class="oc-cf__sub-row-{{ ai_gen_id }}">
            {% for sub in col.metafields.custom.subcollections.value %}
              <a
                href="{{ sub.url }}"
                class="oc-cf__subpill-{{ ai_gen_id }}{% if collection.handle == sub.handle %} active{% endif %}"
              >
                <span>{{ sub.title }}</span>
              </a>
            {% endfor %}
          </div>
        </div>
      {% endif %}
    {% endfor %}

  </div>
</div>

<script>
(function () {
  var wrap = document.querySelector('.oc-cf-{{ ai_gen_id }}');
  if (!wrap) return;

  var pills    = wrap.querySelectorAll('.oc-cf__pill-{{ ai_gen_id }}');
  var subWraps = wrap.querySelectorAll('.oc-cf__sub-wrap-{{ ai_gen_id }}');

  pills.forEach(function (pill) {
    pill.addEventListener('click', function (e) {
      var colId   = pill.getAttribute('data-col-id');
      var subWrap = wrap.querySelector('.oc-cf__sub-wrap-{{ ai_gen_id }}[data-parent-id="' + colId + '"]');

      /* ถ้ามี subcollections ให้เปิด row ก่อน แล้วค่อย navigate */
      if (subWrap) {
        var alreadyOpen = subWrap.classList.contains('visible');

        /* ปิด sub-wrap อื่นทั้งหมด */
        subWraps.forEach(function (sw) { sw.classList.remove('visible'); });

        if (!alreadyOpen) {
          e.preventDefault();
          subWrap.classList.add('visible');

          /* update active pill */
          pills.forEach(function (p) { p.classList.remove('active'); });
          pill.classList.add('active');
        }
        /* ถ้า open อยู่แล้ว ปล่อยให้ navigate ปกติ */
      }
    });
  });
})();
</script>

